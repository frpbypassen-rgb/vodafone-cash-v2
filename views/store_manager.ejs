<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>إدارة متجر الكروت | شركة الأهرام</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

<button class="mobile-nav-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<%- include('partials/sidebar', { activePage: 'store_manager' }) %>

<div class="main-content">
    <div class="container-fluid">
        <div class="admin-nav mb-4">
            <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-boxes-stacked text-success me-2"></i> إدارة مخزن الكروت ومظهر المتجر</h3>
        </div>

        <div class="data-card border-start border-warning border-4 mb-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h5 class="fw-bold text-success m-0"><i class="fa-solid fa-file-excel me-2"></i> تغذية المخزن (رفع كروت جديدة)</h5>
                    <p class="text-muted small m-0 mt-2">يتم توليد الأقسام والمنتجات تلقائياً من الإكسيل للتحكم بصورها في الأسفل.</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a href="/store-manager/product/excel-template" class="btn btn-outline-primary fw-bold rounded-3"><i class="fa-solid fa-download me-1"></i> تحميل النموذج</a>
                    <form action="/store-manager/product/import-excel" method="POST" enctype="multipart/form-data" class="d-flex gap-2">
                        <input type="file" name="excelFile" class="form-control" accept=".xlsx, .xls" required style="max-width: 230px;">
                        <button type="submit" class="btn btn-success fw-bold text-nowrap rounded-3"><i class="fa-solid fa-upload me-1"></i> رفع الكروت</button>
                    </form>
                </div>
            </div>
        </div>

        <h4 class="fw-bold text-dark mb-4 mt-5"><i class="fa-solid fa-images text-primary me-2"></i> تخصيص مظهر الأقسام والمنتجات</h4>
        
        <div class="row g-4 mb-5">
            <% if(categoriesMeta && categoriesMeta.length > 0) { %>
                <% categoriesMeta.forEach(cat => { %>
                    <div class="col-md-6">
                        <div class="data-card p-0 overflow-hidden h-100 border-0" style="border-top: 6px solid <%= cat.color %> !important;">
                            
                            <div class="p-4 border-bottom" style="background-color: var(--input-bg);">
                                <form action="/store-manager/category/<%= cat._id %>/update" method="POST" class="row g-3 align-items-center">
                                    
                                    <div class="col-12 text-center mb-2">
                                        <% if(cat.image) { %>
                                            <img src="<%= cat.image %>" class="shadow-sm mb-3 mx-auto d-block" style="width: 80px; height: 80px; object-fit: cover; border-radius: 20px; border: 2px solid <%= cat.color %>;">
                                        <% } else { %>
                                            <div class="shadow-sm mb-3 mx-auto d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; border-radius: 20px; border: 2px solid <%= cat.color %>; background-color: var(--card-bg);">
                                                <i class="fa-solid <%= cat.icon %> fa-2x" style="color: <%= cat.color %>;"></i>
                                            </div>
                                        <% } %>
                                        <h5 class="fw-bold m-0 text-dark"><%= cat.name %></h5>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="small fw-bold text-muted mb-1">الأيقونة</label>
                                        <input type="text" name="icon" class="form-control form-control-sm text-center" value="<%= cat.icon %>" dir="ltr">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="small fw-bold text-muted mb-1">اللون</label>
                                        <input type="color" name="color" class="form-control form-control-color form-control-sm w-100" value="<%= cat.color %>" style="padding:0; height: 35px; border-radius: 8px;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="small fw-bold text-muted mb-1">تغيير الصورة</label>
                                        <input type="file" class="form-control form-control-sm p-1" accept="image/*" onchange="encodeAndSubmit(this, 'cat_img_<%= cat._id %>')">
                                        <input type="hidden" name="imageBase64" id="cat_img_<%= cat._id %>">
                                    </div>
                                    <div class="col-12 mt-3">
                                        <button type="submit" class="btn btn-primary btn-sm w-100 fw-bold rounded-3 py-2"><i class="fa-solid fa-floppy-disk me-1"></i> حفظ إعدادات القسم</button>
                                    </div>
                                </form>
                            </div>

                            <div class="p-3">
                                <h6 class="fw-bold text-muted mb-3 text-center">المنتجات التابعة للقسم</h6>
                                <% const prods = productsMeta.filter(p => p.categoryName === cat.name); %>
                                <% if (prods.length > 0) { %>
                                    <div class="row g-2">
                                        <% prods.forEach(prod => { %>
                                            <div class="col-6">
                                                <div class="p-3 text-center h-100 rounded-4 border" style="background-color: var(--input-bg);">
                                                    <% if(prod.image) { %>
                                                        <img src="<%= prod.image %>" class="mx-auto mb-2 shadow-sm" style="width: 65px; height: 65px; object-fit: cover; border-radius: 14px; border: 1px solid var(--border-glass);">
                                                    <% } else { %>
                                                        <div class="mx-auto mb-2 d-flex align-items-center justify-content-center text-muted" style="width: 65px; height: 65px; border-radius: 14px; border: 1px dashed var(--border-glass); font-size: 0.8rem;">صورة</div>
                                                    <% } %>
                                                    <span class="fw-bold text-dark mb-3 text-truncate d-block" title="<%= prod.name %>" style="font-size: 0.8rem;"><%= prod.name %></span>
                                                    
                                                    <form action="/store-manager/product/<%= prod._id %>/update" method="POST" class="mt-auto">
                                                        <label class="btn btn-light btn-sm w-100 fw-bold m-0 rounded-3 border" style="cursor: pointer; font-size: 0.75rem;">
                                                            <i class="fa-solid fa-camera me-1"></i> تغيير 
                                                            <input type="file" class="d-none" accept="image/*" onchange="encodeAndSubmit(this, 'prod_img_<%= prod._id %>')">
                                                        </label>
                                                        <input type="hidden" name="imageBase64" id="prod_img_<%= prod._id %>">
                                                    </form>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                <% } else { %>
                                    <p class="text-center text-muted small p-2 m-0">لا توجد منتجات مسجلة في هذا القسم.</p>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5 data-card">
                    <i class="fa-solid fa-box-open fa-4x text-muted mb-3 opacity-25"></i>
                    <h5 class="text-muted fw-bold">لم يتم رفع أي كروت بعد. قم برفع ملف الإكسيل لتظهر لك الأقسام هنا!</h5>
                </div>
            <% } %>
        </div>

        <div class="data-card p-0 overflow-hidden mb-5 border-0">
            <div class="p-4 border-bottom" style="background-color: var(--input-bg);">
                <h5 class="fw-bold m-0 text-primary"><i class="fa-solid fa-layer-group me-2"></i> إحصائيات الكروت في المخزن</h5>
            </div>
            <div class="table-responsive m-0 border-0">
                <table class="table text-center align-middle mb-0 table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>القسم</th>
                            <th>المنتج</th>
                            <th>سعر البيع (شريحة 1)</th>
                            <th>المتاح للبيع (Unsold)</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(inventoryStats && inventoryStats.length === 0) { %>
                            <tr><td colspan="5" class="text-muted py-4 fw-bold">المخزن فارغ حالياً.</td></tr>
                        <% } else if(inventoryStats) { %>
                            <% inventoryStats.forEach(stat => { %>
                                <tr>
                                    <td class="fw-bold text-dark"><%= stat._id.category %></td>
                                    <td class="fw-bold text-success"><%= stat._id.name %></td>
                                    <td class="fw-bold" style="font-family: 'JetBrains Mono', monospace;"><%= stat.price_1 %> LYD</td>
                                    <td>
                                        <span class="badge <%= stat.unsold > 10 ? 'bg-success' : 'bg-danger' %> fs-6 px-3 rounded-pill mono-num"><%= stat.unsold %></span>
                                    </td>
                                    <td>
                                        <form action="/store-manager/delete-group" method="POST" class="m-0" onsubmit="return confirm('تأكيد مسح جميع الكروت غير المباعة في هذا القسم؟');">
                                            <input type="hidden" name="category" value="<%= stat._id.category %>">
                                            <input type="hidden" name="name" value="<%= stat._id.name %>">
                                            <button type="submit" class="btn btn-sm btn-danger rounded-3 fw-bold"><i class="fa-solid fa-trash me-1"></i> تفريغ غير المباع</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleSidebar() { document.querySelector('.sidebar').classList.toggle('active'); document.querySelector('.sidebar-overlay').classList.toggle('active'); }

    document.addEventListener("DOMContentLoaded", function() {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('success') === 'imported') {
            Swal.fire({title: 'تم الاستيراد بنجاح!', text: `تمت إضافة ${urlParams.get('count')} كارت.`, icon: 'success', customClass:{popup:'rounded-4'}});
            window.history.replaceState(null, null, window.location.pathname);
        }
    });

    function encodeAndSubmit(element, hiddenInputId) {
        const file = element.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onloadend = function() {
            document.getElementById(hiddenInputId).value = reader.result;
            element.closest('form').submit();
        }
        reader.readAsDataURL(file);
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>