                Swal.fire({
                    title: '<i class="fa-brands fa-telegram" style="color:#0ea5e9;font-size:2.5rem;"></i>',
                    html: `<h5 class="fw-bold mb-2">تفعيل التليجرام</h5>
                           <p class="small text-muted">تم نسخ رسالة التفعيل المشفرة تلقائياً.<br>سيتم تحويلك إلى بوت التليجرام لربط حسابك، قم بلصق الرسالة هناك.</p>
                           <div class="p-2 mb-3 rounded" style="background: rgba(0,0,0,0.05); border: 1px dashed #0ea5e9; font-family: monospace; font-size: 0.9rem; word-break: break-all;">
                               ${payload}
                           </div>`,
                    confirmButtonText: '<i class="fa-brands fa-telegram me-1"></i> افتح التليجرام والصق الرسالة',
                    confirmButtonColor: '#0ea5e9',
                    showCancelButton: true,
                    cancelButtonText: 'إلغاء',
                    allowOutsideClick: false
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = data.link;
                    }
                });
            } else {
                Swal.fire('خطأ', data.error || 'حدث خطأ أثناء توليد الرابط', 'error');
            }
        } catch (error) {
            Swal.fire('خطأ', 'تعذر الاتصال بالخادم', 'error');
        }
    }

    // 🟢 دالة زر عرض لوج الـ API
    function showApiLogBtn(btn) {
        const rawLog = btn.getAttribute('data-log');
        showApiLogFromText(rawLog);
    }

    // 🟢 دالة عرض نافذة السجل المنبثقة للـ API
    function showApiLogFromText(rawNotesEnc) {
        const rawNotes = decodeURIComponent(rawNotesEnc);
        let logContent = rawNotes;
        
        if (rawNotes.includes('--- سجل الـ API (Terminal Log) ---')) {
