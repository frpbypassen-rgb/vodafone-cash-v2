<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>إدارة الموظفين | الأهرام</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
        document.documentElement.setAttribute('data-bs-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        :root { 
            --bg-body: #f1f5f9; --glass-bg: rgba(255, 255, 255, 0.9); --glass-border: rgba(0, 0, 0, 0.08);
            --text-main: #0f172a; --text-muted: #64748b; --accent-gold: #d4af37; --accent-blue: #0ea5e9;
            --accent-green: #10b981; --accent-red: #ef4444; --shadow-glass: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
        }
        [data-theme="dark"] {
            --bg-body: #0f172a; --glass-bg: rgba(30, 41, 59, 0.85); --glass-border: rgba(255, 255, 255, 0.08);
            --text-main: #f8fafc; --text-muted: #94a3b8; --shadow-glass: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            --accent-gold: #fbbf24; --accent-blue: #3b82f6;
        }

        body { background-color: var(--bg-body); color: var(--text-main); font-family: 'Tajawal', sans-serif; transition: 0.3s; padding-bottom: 80px; overflow-x: hidden; }
        ::-webkit-scrollbar { width: 6px; } ::-webkit-scrollbar-track { background: transparent; } ::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 10px; }

        .navbar-glass {
            background: var(--glass-bg); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--glass-border); padding: 15px 20px; position: sticky; top: 0; z-index: 1000; box-shadow: var(--shadow-glass);
            display: flex; justify-content: space-between; align-items: center; gap: 15px; margin-bottom: 30px; transition: 0.3s;
        }
        .executor-info { display: flex; align-items: center; gap: 12px; }
        .executor-avatar { width: 45px; height: 45px; border-radius: 12px; background: rgba(212, 175, 55, 0.1); color: var(--accent-gold); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; border: 1px solid rgba(212, 175, 55, 0.3); }
        .executor-name { font-weight: 900; font-size: 1.1rem; margin: 0; color: var(--text-main); letter-spacing: -0.5px;}
        .executor-role { font-size: 0.75rem; color: var(--text-muted); font-weight: 700; }
        .nav-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
        .nav-btn { background: transparent; border: 1px solid var(--glass-border); color: var(--text-main); padding: 8px 16px; border-radius: 10px; font-weight: 700; text-decoration: none; transition: 0.3s; display: inline-flex; align-items: center; justify-content: center; gap: 6px; font-size: 0.9rem; }
        .nav-btn:hover { background: var(--glass-border); transform: translateY(-2px); }
        .btn-logout { background: rgba(239, 68, 68, 0.1); color: var(--accent-red); border-color: rgba(239, 68, 68, 0.3); }
        .btn-logout:hover { background: var(--accent-red); color: white; }
        .btn-theme { padding: 8px 12px; border-radius: 50%; color: var(--accent-gold); }

        .page-card { background: var(--glass-bg); backdrop-filter: blur(12px); border: 1px solid var(--glass-border); border-radius: 20px; padding: 25px; box-shadow: var(--shadow-glass); }
        .section-title { font-weight: 900; font-size: 1.3rem; color: var(--text-main); margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        .section-title i { color: var(--accent-gold); }

        .form-control, .form-select { background: rgba(0,0,0,0.05); border: 1px solid var(--glass-border); color: var(--text-main); border-radius: 12px; padding: 12px; font-weight: bold; }
        [data-theme="dark"] .form-control, [data-theme="dark"] .form-select { background: rgba(255,255,255,0.05); }
        .form-control:focus, .form-select:focus { background: transparent; border-color: var(--accent-blue); box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1); color: var(--text-main); }
        .form-label { font-weight: 700; font-size: 0.85rem; color: var(--text-muted); }
        .input-group-text { background: rgba(0,0,0,0.08); border: 1px solid var(--glass-border); color: var(--text-muted); border-radius: 12px; }
        [data-theme="dark"] .input-group-text { background: rgba(255,255,255,0.06); }

        .btn-create { background: linear-gradient(45deg, #10b981, #059669); color: white; border: none; padding: 12px 30px; border-radius: 12px; font-weight: 800; font-size: 1rem; transition: 0.3s; box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3); }
        .btn-create:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(16, 185, 129, 0.4); filter: brightness(1.1); color: white; }

        .emp-table { width: 100%; border-collapse: separate; border-spacing: 0 8px; }
        .emp-table th { font-size: 0.8rem; color: var(--text-muted); font-weight: 800; padding: 10px 15px; border: none; text-align: right; }
        .emp-table td { padding: 12px 15px; background: var(--glass-bg); border-top: 1px solid var(--glass-border); border-bottom: 1px solid var(--glass-border); font-weight: 700; font-size: 0.9rem; vertical-align: middle; }
        .emp-table tr td:first-child { border-radius: 0 12px 12px 0; border-right: 1px solid var(--glass-border); }
        .emp-table tr td:last-child { border-radius: 12px 0 0 12px; border-left: 1px solid var(--glass-border); }
        
        .role-badge { padding: 4px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 800; }
        .role-operator { background: rgba(14, 165, 233, 0.1); color: var(--accent-blue); border: 1px solid rgba(14, 165, 233, 0.2); }
        .role-accountant { background: rgba(212, 175, 55, 0.1); color: var(--accent-gold); border: 1px solid rgba(212, 175, 55, 0.2); }
        .role-manager { background: rgba(16, 185, 129, 0.1); color: var(--accent-green); border: 1px solid rgba(16, 185, 129, 0.2); }

        .status-active { color: var(--accent-green); }
        .status-suspended { color: var(--accent-red); }

        .btn-action { padding: 6px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 700; border: 1px solid var(--glass-border); background: transparent; color: var(--text-main); transition: 0.2s; cursor: pointer; }
        .btn-action:hover { transform: translateY(-1px); }
        .btn-toggle-active:hover { background: rgba(239, 68, 68, 0.1); color: var(--accent-red); border-color: rgba(239, 68, 68, 0.3); }
        .btn-toggle-suspended:hover { background: rgba(16, 185, 129, 0.1); color: var(--accent-green); border-color: rgba(16, 185, 129, 0.3); }
        .btn-delete:hover { background: rgba(239, 68, 68, 0.15); color: var(--accent-red); border-color: rgba(239, 68, 68, 0.4); }
        .btn-reset:hover { background: rgba(14, 165, 233, 0.1); color: var(--accent-blue); border-color: rgba(14, 165, 233, 0.3); }

        .empty-state { text-align: center; padding: 40px; color: var(--text-muted); }
        .empty-state i { font-size: 3rem; opacity: 0.3; margin-bottom: 15px; }

        .swal2-popup { background: var(--glass-bg) !important; backdrop-filter: blur(15px); color: var(--text-main) !important; border: 1px solid var(--glass-border); border-radius: 20px !important; }
        .swal2-title, .swal2-html-container { color: var(--text-main) !important; }

        @media (max-width: 768px) {
            .navbar-glass { flex-direction: column; gap: 15px; padding: 15px; border-radius: 0 0 20px 20px;}
            .executor-info { width: 100%; justify-content: center; }
            .nav-actions { width: 100%; justify-content: center; }
            .nav-btn { flex: 1 1 calc(25% - 8px); padding: 8px 5px; font-size: 0.8rem; }
            .page-card { padding: 15px; border-radius: 16px; }
            .emp-table { font-size: 0.8rem; }
            .emp-table th, .emp-table td { padding: 8px 10px; }
            .table-responsive { border-radius: 12px; }
        }
    </style>
</head>
<body>

<nav class="navbar-glass">
    <div class="executor-info">
        <div class="executor-avatar"><i class="fa-solid fa-user-astronaut"></i></div>
        <div>
            <h4 class="executor-name"><%= emp.name %></h4>
            <span class="executor-role"><i class="fa-solid fa-network-wired me-1"></i> غرفة العمليات: <%= emp.botId.name %></span>
        </div>
    </div>
    <div class="nav-actions">
        <button class="nav-btn btn-theme shadow-sm" onclick="toggleTheme()" title="المظهر"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
        <a href="/executor-portal/dashboard" class="nav-btn"><i class="fa-solid fa-satellite-dish me-1"></i> <span class="d-none d-sm-inline">الرادار</span></a>
        <a href="/executor-portal/reports" class="nav-btn"><i class="fa-solid fa-file-invoice me-1"></i> <span class="d-none d-sm-inline">السجل</span></a>
        <a href="/executor-portal/employees" class="nav-btn active" style="border-color: var(--accent-gold); color: var(--accent-gold);"><i class="fa-solid fa-users-gear me-1"></i> <span class="d-none d-sm-inline">الموظفين</span></a>
        <a href="/executor-portal/logout" class="nav-btn btn-logout"><i class="fa-solid fa-power-off"></i></a>
    </div>
</nav>

<div class="container-fluid px-3 px-md-4">
    <!-- قسم إنشاء حساب جديد -->
    <div class="page-card mb-4">
        <h5 class="section-title"><i class="fa-solid fa-user-plus"></i> إنشاء حساب موظف جديد</h5>
        
        <form id="createForm">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label"><i class="fa-solid fa-user me-1"></i> الاسم الكامل</label>
                    <input type="text" id="empName" class="form-control" placeholder="اسم الموظف" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label"><i class="fa-solid fa-phone me-1"></i> رقم الهاتف</label>
                    <input type="text" id="empPhone" class="form-control" placeholder="01xxxxxxxxx" dir="ltr">
                </div>
                <div class="col-md-4">
                    <label class="form-label"><i class="fa-solid fa-briefcase me-1"></i> الوظيفة</label>
                    <select id="empRole" class="form-select">
                        <option value="operator">موظف تنفيذ (Operator)</option>
                        <option value="accountant">محاسب (Accountant)</option>
                    </select>
                </div>
            </div>
            <hr style="border-color: var(--glass-border);">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label"><i class="fa-solid fa-at me-1"></i> اسم المستخدم</label>
                    <div class="input-group" dir="ltr">
                        <input type="text" id="empUsername" class="form-control text-end border-end-0" placeholder="username" required>
                        <span class="input-group-text border-start-0">@ahram.com</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label"><i class="fa-solid fa-lock me-1"></i> كلمة المرور</label>
                    <input type="password" id="empPassword" class="form-control" placeholder="••••••••" dir="ltr" required>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn-create w-100"><i class="fa-solid fa-plus me-2"></i> إنشاء الحساب</button>
                </div>
            </div>
        </form>
    </div>

    <!-- قسم قائمة الموظفين -->
    <div class="page-card">
        <h5 class="section-title"><i class="fa-solid fa-users"></i> فريق العمل (<span id="empCount">0</span>)</h5>
        
        <div class="table-responsive">
            <table class="emp-table">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>اسم المستخدم</th>
                        <th>الهاتف</th>
                        <th>الوظيفة</th>
                        <th>الحالة</th>
                        <th>تليجرام</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody id="empTableBody">
                </tbody>
            </table>
        </div>
        <div id="emptyState" class="empty-state d-none">
            <i class="fa-solid fa-users-slash d-block"></i>
            <p class="fw-bold">لا يوجد موظفين حالياً</p>
            <p class="small">قم بإنشاء حسابات لفريق عملك من النموذج أعلاه</p>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleTheme() {
        const html = document.documentElement;
        const currentTheme = html.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', newTheme);
        html.setAttribute('data-bs-theme', newTheme);
        localStorage.setItem('ahram_theme', newTheme);
        document.getElementById('themeIcon').className = newTheme === 'dark' ? 'fa-solid fa-sun text-warning' : 'fa-solid fa-moon text-dark';
    }
    document.addEventListener('DOMContentLoaded', () => {
        const theme = localStorage.getItem('ahram_theme') || 'dark';
        document.getElementById('themeIcon').className = theme === 'dark' ? 'fa-solid fa-sun text-warning' : 'fa-solid fa-moon text-dark';
        loadEmployees();
    });

    // إنشاء موظف جديد
    document.getElementById('createForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const name = document.getElementById('empName').value.trim();
        const phone = document.getElementById('empPhone').value.trim();
        const role = document.getElementById('empRole').value;
        const username = document.getElementById('empUsername').value.trim();
        const password = document.getElementById('empPassword').value.trim();

        if (!name || !username || !password) {
            return Swal.fire('تنبيه', 'يرجى ملء جميع الحقول المطلوبة', 'warning');
        }

        Swal.fire({ title: 'جاري الإنشاء...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

        try {
            const res = await fetch('/executor-portal/employees/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, phone, role, webUsername: username, webPassword: password })
            });
            const data = await res.json();
            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'تم إنشاء الحساب بنجاح!',
                    html: `<div class="text-start p-3 mt-2 rounded" style="background: rgba(0,0,0,0.1); border: 1px dashed var(--accent-green);">
                        <div class="mb-2"><span class="small d-block" style="color: var(--text-muted);">اسم المستخدم:</span><span class="fs-5 font-monospace fw-bold" dir="ltr">${data.username}</span></div>
                        <div><span class="small d-block" style="color: var(--text-muted);">كلمة المرور:</span><span class="fs-5 font-monospace fw-bold" dir="ltr">${password}</span></div>
                    </div>`,
                    confirmButtonColor: '#10b981'
                });
                document.getElementById('createForm').reset();
                loadEmployees();
            } else {
                Swal.fire('خطأ', data.error || 'حدث خطأ أثناء الإنشاء', 'error');
            }
        } catch (e) {
            Swal.fire('خطأ', 'تعذر الاتصال بالخادم', 'error');
        }
    });

    // تحميل قائمة الموظفين
    async function loadEmployees() {
        try {
            const res = await fetch('/executor-portal/employees/list');
            const data = await res.json();
            const tbody = document.getElementById('empTableBody');
            const emptyState = document.getElementById('emptyState');
            document.getElementById('empCount').textContent = data.employees.length;

            if (data.employees.length === 0) {
                tbody.innerHTML = '';
                emptyState.classList.remove('d-none');
                return;
            }
            emptyState.classList.add('d-none');

            tbody.innerHTML = data.employees.map(emp => {
                const roleLabel = emp.role === 'operator' ? 'موظف تنفيذ' : (emp.role === 'accountant' ? 'محاسب' : (emp.role === 'manager' ? 'مدير' : emp.role));
                const roleClass = emp.role === 'operator' ? 'role-operator' : (emp.role === 'accountant' ? 'role-accountant' : 'role-manager');
                const statusIcon = emp.status === 'active' ? '<i class="fa-solid fa-circle-check status-active"></i> فعّال' : '<i class="fa-solid fa-circle-xmark status-suspended"></i> معلق';
                const telegramIcon = emp.telegramId ? '<i class="fa-brands fa-telegram text-info fs-5"></i>' : '<span class="text-muted small">غير مفعّل</span>';
                const toggleClass = emp.status === 'active' ? 'btn-toggle-active' : 'btn-toggle-suspended';
                const toggleIcon = emp.status === 'active' ? 'fa-ban' : 'fa-check';
                const toggleTitle = emp.status === 'active' ? 'تعليق' : 'تفعيل';

                return `<tr>
                    <td class="fw-bold">${emp.name}</td>
                    <td dir="ltr" class="font-monospace small">${emp.webUsername || '---'}</td>
                    <td dir="ltr">${emp.phone || '---'}</td>
                    <td><span class="role-badge ${roleClass}">${roleLabel}</span></td>
                    <td>${statusIcon}</td>
                    <td class="text-center">${telegramIcon}</td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            ${emp.role !== 'manager' ? `
                                <button onclick="toggleEmployee('${emp._id}')" class="btn-action ${toggleClass}" title="${toggleTitle}"><i class="fa-solid ${toggleIcon}"></i></button>
                                <button onclick="resetPassword('${emp._id}', '${emp.name}')" class="btn-action btn-reset" title="إعادة تعيين كلمة المرور"><i class="fa-solid fa-key"></i></button>
                                <button onclick="deleteEmployee('${emp._id}', '${emp.name}')" class="btn-action btn-delete" title="حذف"><i class="fa-solid fa-trash"></i></button>
                            ` : '<span class="small text-muted">المدير</span>'}
                        </div>
                    </td>
                </tr>`;
            }).join('');
        } catch (e) {
            console.error(e);
        }
    }

    // تعليق / تفعيل موظف
    async function toggleEmployee(id) {
        const res = await fetch('/executor-portal/employees/toggle/' + id, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            Swal.fire({ icon: 'success', title: 'تم التحديث', timer: 1200, showConfirmButton: false });
            loadEmployees();
        }
    }

    // إعادة تعيين كلمة المرور
    async function resetPassword(id, name) {
        const { value: newPass } = await Swal.fire({
            title: 'إعادة تعيين كلمة المرور',
            html: `<p class="small text-muted">الموظف: <b>${name}</b></p>`,
            input: 'password',
            inputPlaceholder: 'كلمة المرور الجديدة',
            showCancelButton: true,
            confirmButtonText: 'تغيير',
            cancelButtonText: 'إلغاء',
            confirmButtonColor: '#0ea5e9',
            inputValidator: (val) => { if (!val || val.length < 4) return 'كلمة المرور يجب أن تكون 4 أحرف على الأقل'; }
        });
        if (newPass) {
            const res = await fetch('/executor-portal/employees/reset-password/' + id, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ newPassword: newPass })
            });
            const data = await res.json();
            if (data.success) Swal.fire({ icon: 'success', title: 'تم تغيير كلمة المرور', timer: 1500, showConfirmButton: false });
        }
    }

    // حذف موظف
    async function deleteEmployee(id, name) {
        const result = await Swal.fire({
            title: 'تأكيد الحذف',
            html: `<p>هل أنت متأكد من حذف الموظف <b>${name}</b>؟</p><p class="small text-danger">هذا الإجراء لا يمكن التراجع عنه!</p>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'نعم، احذف',
            cancelButtonText: 'إلغاء',
            confirmButtonColor: '#ef4444'
        });
        if (result.isConfirmed) {
            const res = await fetch('/executor-portal/employees/delete/' + id, { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                Swal.fire({ icon: 'success', title: 'تم الحذف', timer: 1200, showConfirmButton: false });
                loadEmployees();
            }
        }
    }
</script>
</body>
</html>
