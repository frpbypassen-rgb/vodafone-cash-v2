</head>

<body>
    <nav class="navbar-glass">
        <div class="executor-info">
            <div class="executor-avatar"><i class="fa-solid fa-user-astronaut"></i></div>
            <div>
                <h4 class="executor-name"><%= emp.name %></h4>
                <span class="executor-role"><i class="fa-solid fa-network-wired me-1"></i> غرفة العمليات: <%= emp.groupId ? emp.groupId.name : 'غير محدد' %></span>
            </div>
        </div>
        <div class="nav-actions">
            <span class="nav-btn text-success border border-success border-opacity-25" style="cursor: default; font-weight: 800;" title="المبلغ المتاح"><i class="fa-solid fa-wallet me-1"></i> <%= emp.groupId ? emp.groupId.balance.toFixed(2) : '0.00' %> EGP</span>
            <button class="nav-btn btn-theme shadow-sm" onclick="toggleTheme()" title="المظهر"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
            <a href="/executor-portal/logout" class="nav-btn btn-logout"><i class="fa-solid fa-power-off"></i></a>
        </div>
    </nav>

    <div class="container-fluid px-3 px-md-4 mt-2 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold m-0" style="color: var(--accent-gold);"><i class="fa-solid fa-chart-line me-2"></i> التقارير والعمليات</h4>
        </div>

        <!-- فلاتر التقرير -->
        <div class="card-glass <%= emp.role === 'operator' ? 'd-none' : '' %>">
            <div class="row g-3 align-items-end justify-content-center">
                <div class="col-md-3">
                    <label class="form-label text-muted fw-bold">الفترة الزمنية</label>
                    <select id="dateType" class="form-select" onchange="toggleDateInput()">
                        <option value="day">يوم محدد</option>
                        <% if (emp.role === 'manager' || emp.canViewAllReports) { %>
                        <option value="month">شهر محدد</option>
                        <% } %>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label text-muted fw-bold">&nbsp;</label>
                    <input type="date" id="dateValueDay" class="form-control">
                    <input type="month" id="dateValueMonth" class="form-control" style="display:none;">
                </div>

                <div class="col-md-3 text-end">
                    <button class="btn btn-warning w-100 fw-bold py-2" onclick="fetchReport()">
                        <i class="fa-solid fa-search"></i> عرض التقرير
                    </button>
                </div>
                <div class="col-md-3 text-end">
                    <button id="btnDownloadPdf" class="btn btn-danger w-100 fw-bold py-2 d-none" onclick="generatePDF()">
                        <i class="fa-solid fa-file-pdf"></i> تحميل التقرير
                    </button>
                </div>
            </div>
        </div>

        <!-- الإحصائيات -->
        <div class="row g-3 mb-4 d-none" id="statsSection">
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg, rgba(239,68,68,0.1), rgba(239,68,68,0.02)); border-color: rgba(239,68,68,0.2);">
                    <h5 class="fw-bold mb-2 text-danger" id="statTotalOps">0.00</h5>
                    <small class="text-danger fw-bold">إجمالي العمليات المنفذة (EGP)</small>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(16,185,129,0.02)); border-color: rgba(16,185,129,0.2);">
                    <h5 class="fw-bold mb-2 text-success" id="statCompletedCount">0</h5>
                    <small class="text-success fw-bold">العمليات الناجحة</small>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg, rgba(212,175,55,0.1), rgba(212,175,55,0.02)); border-color: rgba(212,175,55,0.2);">
                    <h5 class="fw-bold mb-2 text-warning" id="statRejectedCount">0</h5>
                    <small class="text-warning fw-bold">العمليات المرفوضة</small>
                </div>
            </div>
        </div>

        <!-- جدول العمليات -->
        <div class="card-glass d-none" id="tableSection">
            <h5 class="fw-bold mb-3"><i class="fa-solid fa-list text-muted me-1"></i> تفاصيل العمليات</h5>
            <div class="table-responsive d-none d-md-block">
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>رقم العملية</th>
                            <th>المبلغ بالمصري</th>
                            <th>وقت وصول العملية</th>
                            <th>وقت اكمال العملية</th>
                            <th>مدة اكمال العملية</th>
                            <th>حالة العملية</th>
                            <th>التاريخ والوقت</th>
                            <th>اسم المنفذ</th>
                        </tr>
                    </thead>
                    <tbody id="reportTableBody">
                    </tbody>
                </table>
            </div>
            <!-- قائمة العمليات للموبايل (تظهر كبطاقات تطبيق) -->
            <div class="mobile-ops-list d-flex flex-column gap-3 d-md-none" id="mobileReportList"></div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', newTheme);
            html.setAttribute('data-bs-theme', newTheme);
            localStorage.setItem('ahram_theme', newTheme);
            document.getElementById('themeIcon').className = newTheme === 'dark' ? 'fa-solid fa-sun text-warning' : 'fa-solid fa-moon text-dark';
        }
        document.addEventListener('DOMContentLoaded', () => {
            const theme = localStorage.getItem('ahram_theme') || 'dark';
            document.getElementById('themeIcon').className = theme === 'dark' ? 'fa-solid fa-sun text-warning' : 'fa-solid fa-moon text-dark';

            <% if (emp.role === 'operator') { %>
            fetchReport();
            <% } %>
        });

        // تهيئة التواريخ
        document.getElementById('dateValueDay').valueAsDate = new Date();
        const yyyyMM = new Date().toISOString().substring(0, 7);
        if(document.getElementById('dateValueMonth')) document.getElementById('dateValueMonth').value = yyyyMM;

        function toggleDateInput() {
            const type = document.getElementById('dateType').value;
            if (type === 'day') {
                document.getElementById('dateValueDay').style.display = 'block';
                if(document.getElementById('dateValueMonth')) document.getElementById('dateValueMonth').style.display = 'none';
            } else {
                document.getElementById('dateValueDay').style.display = 'none';
                if(document.getElementById('dateValueMonth')) document.getElementById('dateValueMonth').style.display = 'block';
            }
        }

        let lastReportData = null;

        async function fetchReport() {
            const dateType = document.getElementById('dateType').value;
            const dateValue = dateType === 'day' ? document.getElementById('dateValueDay').value : document.getElementById('dateValueMonth').value;

            if (!dateValue) {
                return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى اختيار التاريخ.' });
            }

            const btn = document.querySelector('button.btn-warning');
            const originalBtnHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> جاري التحميل...';
            btn.disabled = true;

            try {
                const res = await fetch('/executor-portal/reports/filter', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ dateType, dateValue })
                });
                const data = await res.json();

                if (!data.success) throw new Error(data.error);

                // Update Stats
                document.getElementById('statTotalOps').innerHTML = `${(data.data.totalEGP).toFixed(2)} <span class="fs-6">EGP</span>`;
                document.getElementById('statCompletedCount').innerHTML = data.data.completedCount;
                document.getElementById('statRejectedCount').innerHTML = data.data.rejectedCount;

                lastReportData = data.data;
                document.getElementById('statsSection').classList.remove('d-none');
                document.getElementById('tableSection').classList.remove('d-none');
                document.getElementById('btnDownloadPdf').classList.remove('d-none');

                // Render Operations Table
                const tbody = document.getElementById('reportTableBody');
                tbody.innerHTML = '';
                const mobileList = document.getElementById('mobileReportList');
                if (mobileList) mobileList.innerHTML = '';

                if (data.data.operations.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-4">لا توجد عمليات في هذه الفترة</td></tr>';
                    if (mobileList) mobileList.innerHTML = '<div class="text-center text-muted py-4">لا توجد عمليات في هذه الفترة</div>';
                } else {
                    data.data.operations.forEach((tx, i) => {
                        let stHtml = '';
                        if (tx.status === 'completed') stHtml = '<span class="badge-st st-done"><span class="indicator-dot dot-done"></span>مكتمل</span>';
                        else if (tx.status === 'rejected' || tx.status === 'cancelled_by_admin') stHtml = '<span class="badge-st st-fail"><span class="indicator-dot dot-fail"></span>مرفوض</span>';
                        else stHtml = '<span class="badge-st bg-secondary text-white"><span class="indicator-dot bg-light"></span>' + tx.status + '</span>';

                        let by = tx.operatorName || tx.executorName || tx.employeeName || '---';
                        
                        const dateObj = new Date(tx.createdAt);
                        const dateStr = dateObj.toLocaleDateString('en-GB');
                        const timeStr = dateObj.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });

                        // وقت وصول العملية
                        const arrivalTimeStr = dateObj.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });

                        // وقت إكمال العملية
                        let completionTimeStr = '---';
                        if (tx.status === 'completed' && tx.updatedAt) {
                            const completedDate = new Date(tx.updatedAt);
                            completionTimeStr = completedDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });
                        }

                        // مدة إكمال العملية
                        let durationText = '---';
                        if (tx.status === 'completed' && tx.updatedAt && tx.createdAt) {
                            const diffMs = new Date(tx.updatedAt) - new Date(tx.createdAt);
                            const diffSec = Math.floor(diffMs / 1000);
                            if (diffSec >= 0) {
                                const m = Math.floor(diffSec / 60);
                                const s = diffSec % 60;
                                durationText = m > 0 ? `${m} د و ${s} ث` : `${s} ث`;
                            }
                        }

                        // Desktop Row Render
                        tbody.innerHTML += `
                        <tr ${tx.status === 'completed' ? `onclick="showReceiptModal('${tx.proofImage || ''}', '${(tx.proofImages || []).join(',')}')" style="cursor: pointer;" title="عرض إيصال التحويل"` : ''}>
                            <td class="text-muted fw-bold">${i + 1}</td>
                            <td dir="ltr" class="fw-bold text-center">#${tx.customId || tx._id.toString().slice(-6)}</td>
                            <td class="fw-bold">${tx.amount} <small class="text-muted">EGP</small></td>
                            <td dir="ltr" class="text-center" style="font-size:0.85rem; font-family:monospace;">${arrivalTimeStr}</td>
                            <td dir="ltr" class="text-center" style="font-size:0.85rem; font-family:monospace;">${completionTimeStr}</td>
                            <td class="fw-bold text-success" style="font-size:0.85rem;">${durationText}</td>
                            <td>${stHtml}</td>
                            <td>
                                <div dir="ltr" style="font-size:0.85em;" class="text-center fw-bold">${dateStr}</div>
                                <div dir="ltr" style="font-size:0.75rem; color: #94a3b8;" class="text-center">${timeStr}</div>
                            </td>
                            <td>${by}</td>
                        </tr>
                        `;

                        // Mobile Card Render
                        if (mobileList) {
                            mobileList.innerHTML += `
                            <div class="mobile-tx-card" ${tx.status === 'completed' ? `onclick="showReceiptModal('${tx.proofImage || ''}', '${(tx.proofImages || []).join(',')}')" style="cursor: pointer;" title="عرض إيصال التحويل"` : ''}>
                                <div class="mobile-tx-header">
                                    <span class="tx-custom-id">#${tx.customId || tx._id.toString().slice(-6)}</span>
                                    <span>${stHtml}</span>
                                </div>
                                <div class="mobile-tx-body">
                                    <div class="tx-amount-wrapper">
                                        <span class="tx-amount">${tx.amount}</span>
                                        <span class="tx-currency">EGP</span>
                                    </div>
                                    <div class="tx-executor">
                                        <i class="fa-solid fa-user-astronaut me-1"></i>
                                        <span>${by}</span>
                                    </div>
                                </div>
                                <div class="mobile-tx-divider"></div>
                                <div class="mobile-tx-footer">
                                    <div class="tx-time-item">
                                        <span class="time-label"><i class="fa-solid fa-clock text-muted"></i> وصول</span>
                                        <span class="time-value">${arrivalTimeStr}</span>
                                    </div>
                                    <div class="tx-time-item">
                                        <span class="time-label"><i class="fa-solid fa-circle-check text-muted"></i> إكمال</span>
                                        <span class="time-value">${completionTimeStr}</span>
                                    </div>
                                    <div class="tx-time-item">
                                        <span class="time-label"><i class="fa-solid fa-hourglass-half text-success"></i> المدة</span>
                                        <span class="time-value fw-bold text-success">${durationText}</span>
                                    </div>
                                </div>
                                <div class="mobile-tx-date-row">
                                    <span><i class="fa-solid fa-calendar-alt text-muted"></i> ${dateStr} - ${timeStr}</span>
                                </div>
                            </div>
                            `;
                        }
                    });
                }

            } catch (e) {
                Swal.fire({ icon: 'error', title: 'خطأ', text: e.message || 'فشل جلب التقرير' });
            } finally {
                btn.innerHTML = originalBtnHtml;
                btn.disabled = false;
            }
        }

        function generatePDF() {
            if (!lastReportData) return;
            const data = lastReportData;
            const ei = data.entityInfo || {};

            let html = `
            <div style="font-family: 'Cairo', sans-serif; direction: rtl; padding: 15px; color: #000; background: #fff;">
                
                <!-- Header Section -->
                <div style="text-align: center; border-bottom: 3px solid #000; padding-bottom: 20px; margin-bottom: 30px;">
                    <h1 style="color: #000; margin: 0; font-size: 28px; font-weight: 900;">شركة الأهرام للخدمات المالية</h1>
                    <h2 style="color: #000; margin: 5px 0 0 0; font-size: 18px; font-weight: 800;">تقرير حساب العميل الشامل</h2>
                    <div style="margin-top: 10px; font-size: 12px; color: #000; font-weight: 600;">
                        تاريخ الإصدار: ${new Date().toLocaleDateString('en-GB')} | الوقت: ${new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true })}
                    </div>
                </div>
                
                <!-- Client Card 2030 Style -->
                <div style="background: #fff; border: 2px solid #000; border-right: 6px solid #000; border-radius: 12px; padding: 20px; margin-bottom: 30px;">
                    <h4 style="margin: 0 0 15px 0; color: #000; font-size: 16px; font-weight: 800; display: flex; align-items: center; border-bottom: 1px solid #ccc; padding-bottom: 10px;">
                        <span style="background: #000; color: #fff; padding: 4px 12px; border-radius: 6px; margin-left: 10px; font-size: 12px;">بيانات الحساب</span>
                    </h4>
                    <table style="width: 100%; font-size: 14px; color: #000; border-spacing: 0 10px; font-weight: 700;">
                        <tr>
                            <td style="width: 50%;">
                                <div style="color: #333; font-size: 12px; margin-bottom: 2px;">اسم العميل</div>
                                <strong style="color: #000; font-size: 16px;">${ei.name || '---'}</strong>
                            </td>
                            <td style="width: 50%;">
                                <div style="color: #333; font-size: 12px; margin-bottom: 2px;">رقم الهاتف</div>
                                <strong dir="ltr" style="color: #000; font-size: 16px;">${ei.phone || '---'}</strong>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div style="color: #333; font-size: 12px; margin-bottom: 2px;">اسم المستخدم</div>
                                <strong style="color: #000; font-size: 16px;">${ei.username || '---'}</strong>
                            </td>
                            <td>
                                <div style="color: #333; font-size: 12px; margin-bottom: 2px;">تاريخ الانضمام</div>
                                <strong style="color: #000; font-size: 16px;">${ei.joinDate ? new Date(ei.joinDate).toLocaleDateString('en-GB') : '---'}</strong>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="padding-top: 10px; border-top: 1px solid #000;">
                                <div style="color: #333; font-size: 12px; margin-bottom: 2px;">حالة العميل والتصنيف</div>
                                <strong style="color: #000; font-size: 16px;">${ei.status || '---'}</strong>
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- Financial Summary 2030 Style -->
                <div style="display: flex; justify-content: space-between; margin-bottom: 30px; gap: 10px;">
                    <div style="flex: 1; padding: 15px; background: #fff; border: 2px solid #000; border-radius: 8px; text-align: center;">
                        <div style="color: #000; font-size: 14px; font-weight: 700; margin-bottom: 8px; border-bottom: 1px dashed #000; padding-bottom: 5px;">إجمالي العمليات</div>
                        <div style="font-size: 18px; color: #000; font-weight: 900;">${data.totalEGP.toFixed(2)}</div>
                    </div>
                    <div style="flex: 1; padding: 15px; background: #fff; border: 2px solid #000; border-radius: 8px; text-align: center;">
                        <div style="color: #000; font-size: 14px; font-weight: 700; margin-bottom: 8px; border-bottom: 1px dashed #000; padding-bottom: 5px;">عمليات ناجحة</div>
                        <div style="font-size: 18px; color: #000; font-weight: 900;">${data.completedCount}</div>
                    </div>
                    <div style="flex: 1; padding: 15px; background: #fff; border: 2px solid #000; border-radius: 8px; text-align: center;">
                        <div style="color: #000; font-size: 14px; font-weight: 700; margin-bottom: 8px; border-bottom: 1px dashed #000; padding-bottom: 5px;">عمليات مرفوضة</div>
                        <div style="font-size: 18px; color: #000; font-weight: 900;">${data.rejectedCount}</div>
                    </div>
                </div>
            `;

            const generateOpsHeader = (isContinuation = false) => `
                <h4 style="color: #000; font-size: 18px; font-weight: 800; margin-bottom: 15px; padding-bottom: 8px; border-bottom: 2px solid #000;">
                    كشف العمليات ${isContinuation ? '<span style="font-size: 14px;">(تكملة)</span>' : ''}
                </h4>
                <table style="width: 100%; border-collapse: separate; border-spacing: 0; font-size: 11px; margin-bottom: 30px; text-align: right; border: 2px solid #000; border-radius: 8px; overflow: hidden;">
                    <thead>
                        <tr style="background: #000; color: #fff;">
                            <th style="padding: 10px 4px; border-bottom: 2px solid #000; font-weight: 800;">#</th>
                            <th style="padding: 10px 4px; border-bottom: 2px solid #000; font-weight: 800;">رقم العملية</th>
                            <th style="padding: 10px 4px; border-bottom: 2px solid #000; font-weight: 800;">المبلغ</th>
                            <th style="padding: 10px 4px; border-bottom: 2px solid #000; font-weight: 800;">وقت الوصول</th>
                            <th style="padding: 10px 4px; border-bottom: 2px solid #000; font-weight: 800;">وقت الإكمال</th>
                            <th style="padding: 10px 4px; border-bottom: 2px solid #000; font-weight: 800;">مدة الإكمال</th>
                            <th style="padding: 10px 4px; border-bottom: 2px solid #000; font-weight: 800;">الحالة</th>
                            <th style="padding: 10px 4px; border-bottom: 2px solid #000; font-weight: 800;">التاريخ والوقت</th>
                            <th style="padding: 10px 4px; border-bottom: 2px solid #000; font-weight: 800;">المنفذ</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            if (data.operations.length === 0) {
                html += generateOpsHeader() + '<tr><td colspan="9" style="border: 1px solid #000; padding: 15px; text-align: center; color: #000; font-weight: bold;">لا توجد عمليات</td></tr></tbody></table>';
            } else {
                let sortedOps = [...data.operations].sort((a, b) => {
                    const statusA = ['rejected', 'cancelled_by_admin'].includes(a.status) ? 1 : 0;
                    const statusB = ['rejected', 'cancelled_by_admin'].includes(b.status) ? 1 : 0;
                    if (statusA !== statusB) return statusA - statusB;
                    return new Date(b.createdAt) - new Date(a.createdAt);
                });

                let opsChunks = [];
                if (sortedOps.length > 10) {
                    opsChunks.push(sortedOps.slice(0, 10));
                    for (let i = 10; i < sortedOps.length; i += 20) {
                        opsChunks.push(sortedOps.slice(i, i + 20));
                    }
                } else {
                    opsChunks.push(sortedOps);
                }

                opsChunks.forEach((chunk, chunkIdx) => {
                    if (chunkIdx > 0) {
                        html += '<div style="page-break-before: always; margin-top: 20px;"></div>';
                    }
                    html += generateOpsHeader(chunkIdx > 0);

                    chunk.forEach((tx, idxInChunk) => {
                        const globalIdx = chunkIdx === 0 ? idxInChunk : 10 + ((chunkIdx - 1) * 20) + idxInChunk;

                        let stTxt = 'معلقة'; let stCol = '#000'; let stBg = '#fff';
                        if (tx.status === 'completed') { stTxt = 'ناجحة'; stCol = '#000'; stBg = '#fff'; }
                        else if (['rejected', 'cancelled_by_admin'].includes(tx.status)) { stTxt = 'ملغية'; stCol = '#fff'; stBg = '#000'; }

                        const dt = new Date(tx.createdAt);
                        const arrivalTimeStr = dt.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });

                        let completionTimeStr = '---';
                        if (tx.status === 'completed' && tx.updatedAt) {
                            const completedDate = new Date(tx.updatedAt);
                            completionTimeStr = completedDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });
                        }

                        let durationText = '---';
                        if (tx.status === 'completed' && tx.updatedAt && tx.createdAt) {
                            const diffMs = new Date(tx.updatedAt) - new Date(tx.createdAt);
                            const diffSec = Math.floor(diffMs / 1000);
                            if (diffSec >= 0) {
                                const m = Math.floor(diffSec / 60);
                                const s = diffSec % 60;
                                durationText = m > 0 ? `${m} د و ${s} ث` : `${s} ث`;
                            }
                        }

                        let by = tx.operatorName || tx.executorName || tx.employeeName || 'الإدارة';

                        html += `
                        <tr style="background: ${globalIdx % 2 === 0 ? '#fff' : '#f8f8f8'};">
                            <td style="padding: 8px 4px; border-bottom: 1px solid #000; color: #000; font-weight: 700;">${globalIdx + 1}</td>
                            <td style="padding: 8px 4px; border-bottom: 1px solid #000; font-weight: 800; color: #000;" dir="ltr">${tx.customId || tx._id.toString().slice(-6)}</td>
                            <td style="padding: 8px 4px; border-bottom: 1px solid #000; font-weight: 900; color: #000;" dir="ltr">${tx.amount} EGP</td>
                            <td style="padding: 8px 4px; border-bottom: 1px solid #000; font-family: monospace;" dir="ltr">${arrivalTimeStr}</td>
                            <td style="padding: 8px 4px; border-bottom: 1px solid #000; font-family: monospace;" dir="ltr">${completionTimeStr}</td>
                            <td style="padding: 8px 4px; border-bottom: 1px solid #000; color: #10b981; font-weight: 800;">${durationText}</td>
                            <td style="padding: 8px 4px; border-bottom: 1px solid #000;">
                                <span style="background: ${stBg}; color: ${stCol}; padding: 3px 6px; border-radius: 4px; font-size: 11px; font-weight: 800; border: 2px solid #000;">${stTxt}</span>
                            </td>
                            <td style="padding: 8px 4px; border-bottom: 1px solid #000;" dir="ltr">
                                <div style="color: #000; font-weight: 800;">${dt.toLocaleDateString('en-GB')}</div>
                                <div style="font-size: 10px; color: #000; font-weight: 700;">${dt.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true })}</div>
                            </td>
                            <td style="padding: 8px 4px; border-bottom: 1px solid #000; color: #000; font-weight: 800;">${by}</td>
                        </tr>
                        `;
                    });

                    html += `
                        </tbody>
                    </table>
                `;
                });
            }

            html += `</div>`;

            const opt = {
                margin: 10,
                filename: 'تقرير_الموظف.pdf',
                image: { type: 'jpeg', quality: 1.0 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            const container = document.createElement('div');
            container.innerHTML = html;
            html2pdf().set(opt).from(container).save();
        }

        // تشغيل التقرير تلقائياً عند تحميل الصفحة
        fetchReport();
        </script>
        
        <!-- شريط التنقل السفلي للهواتف (App-like Bottom Navigation) -->
        <div class="bottom-nav-mobile d-md-none">
            <!-- حسابي (الملف الشخصي والمنجزات) -->
            <a href="/executor-portal/dashboard#profile" class="bottom-nav-item" id="nav-profile">
                <i class="fa-solid fa-circle-user"></i>
                <span>حسابي</span>
            </a>
            <!-- الرادار -->
            <a href="/executor-portal/dashboard#radar" class="bottom-nav-item" id="nav-dash">
                <i class="fa-solid fa-satellite-dish"></i>
                <span>الرادار</span>
            </a>
            <!-- التقارير -->
            <a href="/executor-portal/reports" class="bottom-nav-item" id="nav-rep">
                <i class="fa-solid fa-chart-line"></i>
                <span>التقارير</span>
            </a>
            <% if (emp.role === 'manager') { %>
            <!-- الموظفين -->
            <a href="/executor-portal/employees" class="bottom-nav-item" id="nav-emp">
                <i class="fa-solid fa-users"></i>
                <span>الموظفين</span>
            </a>
            <% } %>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const path = window.location.pathname;
                if (path.includes('/dashboard')) {
                    document.getElementById('nav-dash')?.classList.add('active');
                } else if (path.includes('/reports')) {
                    document.getElementById('nav-rep')?.classList.add('active');
                } else if (path.includes('/employees')) {
                    document.getElementById('nav-emp')?.classList.add('active');
                }
            });
        </script>
</body>
</html>