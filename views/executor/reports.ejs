<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>تقارير المنفذ | الأهرام</title>

    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
        document.documentElement.setAttribute('data-bs-theme', savedTheme);
    
        window.showReceiptModal = function(proofImage, proofImagesStr) {
            let images = [];
            if (proofImagesStr) images = proofImagesStr.split(',').filter(i => i.trim() !== '');
            if (proofImage && proofImage !== 'undefined' && proofImage !== 'null' && !images.includes(proofImage)) images.push(proofImage);
            
            if (images.length === 0) return Swal.fire('تنبيه', 'لا توجد صورة إيصال متاحة لهذه العملية', 'info');
            
            let html = '<div class="receipt-container" style="text-align: center;">';
            images.forEach(img => {
                let src = img;
                if (!img.startsWith('http') && !img.startsWith('data:') && img.includes('.')) {
                    src = '/uploads/proofs/' + img;
                }
                html += `<img src="${src}" class="img-fluid rounded mb-3 shadow-sm border" style="max-height: 50vh; max-width: 100%; object-fit: contain;" />`;
            });
            html += '</div>';
            
            const mappedImages = images.map(img => {
                if (!img.startsWith('http') && !img.startsWith('data:') && img.includes('.')) return '/uploads/proofs/' + img;
                return img;
            });
            const imagesJoined = mappedImages.join(',');
            
            Swal.fire({
                title: '<i class="fa-solid fa-receipt me-2 text-success"></i> إيصال التحويل',
                html: html,
                showCloseButton: true,
                showConfirmButton: false,
                footer: `
                    <div class="d-flex justify-content-center gap-2 w-100 mt-2 px-3 pb-2">
                        <button class="btn btn-success fw-bold flex-fill py-2" onclick="downloadImages('${imagesJoined}')"><i class="fa-solid fa-download me-1"></i> تحميل</button>
                        <button class="btn btn-primary fw-bold flex-fill py-2" onclick="shareImages('${imagesJoined}')"><i class="fa-solid fa-share-nodes me-1"></i> مشاركة</button>
                    </div>
                `,
                customClass: { popup: 'swal2-popup' }
            });
        };

        window.downloadImages = async function(imagesStr) {
            const images = imagesStr.split(',');
            for (let i = 0; i < images.length; i++) {
                try {
                    const response = await fetch(images[i]);
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `receipt_${Date.now()}_${i}.jpg`;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    window.URL.revokeObjectURL(url);
                } catch(e) {
                    console.error('Download error:', e);
                }
            }
        };

        window.shareImages = async function(imagesStr) {
            const images = imagesStr.split(',');
            if (navigator.share) {
                try {
                    const filesArray = [];
                    for (let i = 0; i < images.length; i++) {
                        const response = await fetch(images[i]);
                        const blob = await response.blob();
                        filesArray.push(new File([blob], `receipt_${i}.jpg`, { type: blob.type || 'image/jpeg' }));
                    }
                    if (navigator.canShare && navigator.canShare({ files: filesArray })) {
                        await navigator.share({
                            files: filesArray,
                            title: 'إيصال التحويل',
                            text: 'مرفق إيصال العملية'
                        });
                    } else {
                        await navigator.share({
                            title: 'إيصال التحويل',
                            url: images[0]
                        });
                    }
                } catch (error) {
                    console.error('Error sharing:', error);
                }
            } else {
                Swal.fire('تنبيه', 'المشاركة المباشرة غير مدعومة في متصفحك، يرجى استخدام زر التحميل بدلاً من ذلك.', 'info');
            }
        };

    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <style>
        /* 🎨 المتغيرات (الوضع النهاري) */
        :root {
            --bg-body: #f0f4f8;
            --bg-gradient: linear-gradient(135deg, #f0f4f8 0%, #e2e8f0 50%, #f0f4f8 100%);
            --glass-bg: rgba(255, 255, 255, 0.92);
            --glass-border: rgba(0, 0, 0, 0.06);
            --text-main: #0f172a;
            --text-muted: #64748b;
            --accent-gold: #d4af37;
            --accent-blue: #0ea5e9;
            --accent-green: #10b981;
            --accent-red: #ef4444;
            --shadow-glass: 0 8px 32px 0 rgba(31, 38, 135, 0.06);
            --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.04);
            --nav-gradient: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(241, 245, 249, 0.95) 100%);
        }

        /* 🌙 المتغيرات (الوضع الليلي) */
        [data-theme="dark"] {
            --bg-body: #0c1222;
            --bg-gradient: linear-gradient(135deg, #0c1222 0%, #131d35 50%, #0c1222 100%);
            --glass-bg: rgba(22, 33, 55, 0.88);
            --glass-border: rgba(255, 255, 255, 0.07);
            --text-main: #f1f5f9;
            --text-muted: #8899b0;
            --shadow-glass: 0 8px 32px 0 rgba(0, 0, 0, 0.35);
            --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.2);
            --accent-gold: #fbbf24;
            --accent-blue: #38bdf8;
            --nav-gradient: linear-gradient(135deg, rgba(22, 33, 55, 0.95) 0%, rgba(15, 23, 42, 0.95) 100%);
        }

        * { box-sizing: border-box; }

        body { background: var(--bg-gradient); background-attachment: fixed; color: var(--text-main); font-family: 'Tajawal', sans-serif; transition: background 0.4s, color 0.3s; padding-bottom: 80px; overflow-x: hidden; min-height: 100vh; }

        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(100, 116, 139, 0.3); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(100, 116, 139, 0.5); }

        /* 🛸 Navbar Glassmorphism */
        .navbar-glass {
            background: var(--nav-gradient); backdrop-filter: blur(20px) saturate(1.2); -webkit-backdrop-filter: blur(20px) saturate(1.2);
            border-bottom: 1px solid var(--glass-border); padding: 14px 24px; position: sticky; top: 0; z-index: 1000;
            box-shadow: 0 1px 20px rgba(0, 0, 0, 0.06);
            display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px; transition: 0.3s;
        }

        [data-theme="dark"] .navbar-glass { box-shadow: 0 1px 20px rgba(0, 0, 0, 0.25); }

        .executor-info { display: flex; align-items: center; gap: 12px; }
        .executor-avatar {
            width: 44px; height: 44px; border-radius: 14px;
            background: linear-gradient(135deg, rgba(212, 175, 55, 0.15), rgba(212, 175, 55, 0.05));
            color: var(--accent-gold); display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
            border: 1px solid rgba(212, 175, 55, 0.25); transition: 0.3s;
        }

        .executor-name { font-weight: 900; font-size: 1.05rem; margin: 0; color: var(--text-main); letter-spacing: -0.3px; }
        .executor-role { font-size: 0.72rem; color: var(--text-muted); font-weight: 700; }

        .nav-actions { display: flex; gap: 6px; align-items: center; }
        .nav-btn {
            background: transparent; border: 1px solid var(--glass-border); color: var(--text-main);
            padding: 7px 14px; border-radius: 10px; font-weight: 700; text-decoration: none;
            transition: all 0.25s ease; display: inline-flex; align-items: center; justify-content: center; gap: 5px; font-size: 0.85rem;
            font-family: 'Tajawal', sans-serif;
        }

        .nav-btn:hover { background: rgba(14, 165, 233, 0.08); border-color: rgba(14, 165, 233, 0.25); transform: translateY(-1px); color: var(--accent-blue); }
        .nav-btn.active { background: rgba(14, 165, 233, 0.1); border-color: rgba(14, 165, 233, 0.3); color: var(--accent-blue); }
        .btn-logout { background: rgba(239, 68, 68, 0.06); color: var(--accent-red); border-color: rgba(239, 68, 68, 0.2); }
        .btn-logout:hover { background: var(--accent-red); color: white; border-color: var(--accent-red); }
        .btn-theme { padding: 7px 11px; border-radius: 50%; color: var(--accent-gold); font-size: 0.95rem; }
        .btn-theme:hover { background: rgba(251, 191, 36, 0.12); transform: rotate(20deg) translateY(-1px); }

        /* Report Styles */
        .card-glass {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            box-shadow: var(--shadow-soft);
            padding: 20px;
            margin-bottom: 20px;
        }

        .form-select,
        .form-control {
            background-color: rgba(0, 0, 0, 0.04);
            color: var(--text-main);
            border: 1px solid var(--glass-border);
            border-radius: 10px;
            padding: 10px;
            font-weight: bold;
        }

        [data-theme="dark"] .form-select,
        [data-theme="dark"] .form-control {
            background-color: rgba(255, 255, 255, 0.04);
        }

        .form-select:focus,
        .form-control:focus {
            background-color: transparent;
            color: var(--text-main);
            border-color: var(--accent-blue);
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
        }

        .stat-card {
            background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(212, 175, 55, 0.02));
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            color: var(--accent-gold);
        }

        .table-custom {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 12px;
            margin-top: 10px;
        }

        .table-custom th {
            color: var(--text-muted);
            font-weight: 700;
            padding: 14px 16px;
            font-size: 0.85rem;
            border: none;
            text-align: center;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .table-custom tr {
            transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .table-custom td {
            background: var(--glass-bg);
            border-top: 1px solid var(--glass-border);
            border-bottom: 1px solid var(--glass-border);
            padding: 16px 14px;
            vertical-align: middle;
            text-align: center;
            font-size: 0.9rem;
            color: var(--text-main);
            transition: background 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.03), 0 2px 4px -1px rgba(0, 0, 0, 0.02);
        }

        [data-theme="dark"] .table-custom td {
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
        }

        .table-custom tr td:first-child {
            border-right: 1px solid var(--glass-border);
            border-top-right-radius: 14px;
            border-bottom-right-radius: 14px;
        }

        .table-custom tr td:last-child {
            border-left: 1px solid var(--glass-border);
            border-top-left-radius: 14px;
            border-bottom-left-radius: 14px;
        }

        /* 🛸 Premium Hover Effects */
        .table-custom tbody tr:hover {
            transform: translateY(-3px) scale(1.005);
        }

        .table-custom tbody tr:hover td {
            background: rgba(255, 255, 255, 0.98);
            border-color: rgba(14, 165, 233, 0.3);
            box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.08), 0 8px 10px -6px rgba(0, 0, 0, 0.06);
        }

        [data-theme="dark"] .table-custom tbody tr:hover td {
            background: rgba(30, 41, 59, 0.98);
            border-color: rgba(251, 191, 36, 0.3);
            box-shadow: 0 12px 25px -5px rgba(0, 0, 0, 0.4), 0 8px 15px -6px rgba(0, 0, 0, 0.35);
        }

        .badge-st {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.78rem;
            font-weight: 700;
            line-height: 1;
        }

        .st-done {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .st-fail {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        /* Indicator dots for badges */
        .indicator-dot {
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            margin-left: 6px;
            vertical-align: middle;
        }
        .dot-done {
            background-color: #10b981;
            box-shadow: 0 0 6px #10b981;
        }
        .dot-fail {
            background-color: #ef4444;
            box-shadow: 0 0 6px #ef4444;
        }
        
        /* 📱 شاشات الهواتف الذكية (Native App Layout) */
        @media (max-width: 768px) {
            body {
                padding-top: 75px !important;
                padding-bottom: 90px !important;
            }
            
            .navbar-glass {
                position: fixed !important;
                top: 0;
                left: 0;
                right: 0;
                z-index: 1050;
                margin-bottom: 0 !important;
                flex-direction: row !important;
                justify-content: space-between !important;
                align-items: center !important;
                padding: 10px 16px !important;
                border-radius: 0 0 16px 16px !important;
                box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
            }
            .executor-info {
                width: auto !important;
                justify-content: flex-start !important;
                gap: 8px !important;
            }
            .executor-avatar {
                width: 36px !important;
                height: 36px !important;
                border-radius: 10px !important;
                font-size: 1.1rem !important;
            }
            .executor-name {
                font-size: 0.9rem !important;
            }
            .executor-role {
                display: none !important;
            }
            .nav-actions {
                width: auto !important;
                justify-content: flex-end !important;
                gap: 6px !important;
            }
            .nav-btn {
                padding: 6px 10px !important;
                font-size: 0.8rem !important;
                border-radius: 8px !important;
                flex: none !important;
            }
            .nav-btn span {
                display: none; /* إخفاء نص الأزرار لتوفير مساحة */
            }

            #statsSection {
                display: grid !important;
                grid-template-columns: repeat(3, 1fr) !important;
                gap: 8px !important;
            }
            .stat-card {
                padding: 10px 5px !important;
                border-radius: 12px !important;
            }
            .stat-card h5 {
                font-size: 0.95rem !important;
                margin-bottom: 2px !important;
            }
            .stat-card small {
                font-size: 0.62rem !important;
            }
        }

        /* 📱 شريط التنقل السفلي للهواتف */
        .bottom-nav-mobile {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 64px;
            background: var(--nav-gradient);
            backdrop-filter: blur(20px) saturate(1.2);
            -webkit-backdrop-filter: blur(20px) saturate(1.2);
            border-top: 1px solid var(--glass-border);
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 1000;
            box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.08);
            padding-bottom: env(safe-area-inset-bottom);
        }
        .bottom-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            color: var(--text-muted);
            text-decoration: none;
            flex: 1;
            height: 100%;
            transition: all 0.2s ease;
            font-size: 0.72rem;
            font-weight: 700;
        }
        .bottom-nav-item i {
            font-size: 1.25rem;
            transition: transform 0.2s ease;
        }
        .bottom-nav-item:hover {
            color: var(--text-main);
        }
        .bottom-nav-item.active {
            color: var(--accent-gold);
        }
        .bottom-nav-item.active i {
            transform: translateY(-2px);
        }

        /* بطاقات العمليات للهواتف */
        .mobile-tx-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
            transition: transform 0.15s ease, background 0.15s ease;
        }
        .mobile-tx-card:active {
            transform: scale(0.98);
            background: rgba(255, 255, 255, 0.95);
        }
        [data-theme="dark"] .mobile-tx-card:active {
            background: rgba(30, 41, 59, 0.95);
        }
        .mobile-tx-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .tx-custom-id {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 800;
            font-size: 0.95rem;
            color: var(--accent-gold);
        }
        .mobile-tx-body {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }
        .tx-amount-wrapper {
            display: flex;
            align-items: baseline;
            gap: 4px;
        }
        .tx-amount {
            font-size: 1.4rem;
            font-weight: 900;
            color: var(--text-main);
        }
        .tx-currency {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-muted);
        }
        .tx-executor {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--text-main);
            background: rgba(0, 0, 0, 0.04);
            padding: 4px 10px;
            border-radius: 20px;
        }
        [data-theme="dark"] .tx-executor {
            background: rgba(255, 255, 255, 0.04);
        }
        .mobile-tx-divider {
            height: 1px;
            background: var(--glass-border);
            margin: 4px 0;
        }
        .mobile-tx-footer {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            background: rgba(0, 0, 0, 0.02);
            padding: 8px;
            border-radius: 12px;
        }
        [data-theme="dark"] .mobile-tx-footer {
            background: rgba(255, 255, 255, 0.02);
        }
        .tx-time-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }
        .time-label {
            font-size: 0.7rem;
            color: var(--text-muted);
            font-weight: 700;
        }
        .time-value {
            font-size: 0.75rem;
            font-family: 'JetBrains Mono', monospace;
            font-weight: bold;
            color: var(--text-main);
        }
        .mobile-tx-date-row {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
        }

        /* SweetAlert */
        .swal2-popup { background: var(--glass-bg) !important; backdrop-filter: blur(15px); color: var(--text-main) !important; border: 1px solid var(--glass-border); border-radius: 20px !important; }
        .swal2-title, .swal2-html-container { color: var(--text-main) !important; }
        .swal2-input, .swal2-textarea { background: rgba(0,0,0,0.04) !important; color: var(--text-main) !important; border-color: var(--glass-border) !important; border-radius: 10px !important; }
        [data-theme="dark"] .swal2-input, [data-theme="dark"] .swal2-textarea { background: rgba(255,255,255,0.04) !important; }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#001a4d">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
