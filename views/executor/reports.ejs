<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>السجل المالي | غرفة العمليات</title>

    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
        document.documentElement.setAttribute('data-bs-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root { 
            --bg-grad: #f8fafc;
            --glass-bg: #ffffff;
            --glass-border: #e2e8f0;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --accent-gold: #d4af37;
            --accent-blue: #0ea5e9;
            --accent-green: #10b981;
            --accent-red: #ef4444;
            --accent-purple: #8b5cf6;
            --shadow-glass: 0 4px 15px rgba(0, 0, 0, 0.05);
        }

        [data-theme="dark"] {
            --bg-grad: radial-gradient(circle at top left, #1e293b, #020617);
            --glass-bg: rgba(15, 23, 42, 0.65);
            --glass-border: rgba(255, 255, 255, 0.08);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --accent-gold: #fbbf24;
            --accent-blue: #3b82f6;
            --accent-purple: #a855f7;
            --shadow-glass: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
        }

        body { font-family: 'Tajawal', sans-serif; background: var(--bg-grad); background-attachment: fixed; color: var(--text-main); transition: 0.3s; padding-top: 100px;}
        
        .glass-nav {
            background: var(--glass-bg); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--glass-border); position: fixed; top: 15px; left: 50%; transform: translateX(-50%); z-index: 1000;
            width: 96%; max-width: 1400px; box-shadow: var(--shadow-glass); padding: 15px 20px; border-radius: 20px; display: flex; justify-content: space-between; align-items: center; transition: 0.3s;
        }
        
        .nav-btn { background: transparent; border: 1px solid var(--glass-border); color: var(--text-main); padding: 8px 15px; border-radius: 12px; font-weight: 800; text-decoration: none; transition: 0.3s; display: inline-flex; align-items: center; gap: 8px; font-size: 0.9rem;}
        .nav-btn:hover { background: var(--accent-blue); color: white; border-color: var(--accent-blue); transform: translateY(-2px);}

        .data-card { background: var(--glass-bg); backdrop-filter: blur(12px); border-radius: 20px; box-shadow: var(--shadow-glass); border: 1px solid var(--glass-border); padding: 25px; margin-bottom: 25px; color: var(--text-main); transition: 0.3s;}
        
        .form-control, .form-select { background: rgba(0,0,0,0.02); color: var(--text-main); border: 1px solid var(--glass-border); border-radius: 12px; font-weight: 700;}
        [data-theme="dark"] .form-control { background: rgba(255,255,255,0.02); }
        .form-control:focus, .form-select:focus { background: transparent; color: var(--text-main); border-color: var(--accent-blue); box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1); }
        .input-group-text { background: transparent; border-color: var(--glass-border); color: var(--text-muted); border-radius: 0 12px 12px 0;}
        
        .btn-primary { background: linear-gradient(45deg, #0ea5e9, #2563eb); border: none; color: white; border-radius: 12px; font-weight: bold; padding: 10px; box-shadow: 0 4px 15px rgba(14, 165, 233, 0.3);}
        .btn-primary:hover { filter: brightness(1.1); transform: scale(1.02); }

        .table-responsive { border-radius: 16px; overflow-x: auto; -webkit-overflow-scrolling: touch; border: 1px solid var(--glass-border); background: rgba(0,0,0,0.02);}
        [data-theme="dark"] .table-responsive { background: rgba(0,0,0,0.2); }
        .table { color: var(--text-main); margin-bottom: 0; }
        .table thead th { background: transparent; color: var(--accent-blue); font-weight: 900; border-bottom: 2px solid var(--glass-border); padding: 15px; white-space: nowrap;}
        [data-theme="dark"] .table thead th { color: var(--accent-gold); }
        .table td { vertical-align: middle; border-color: var(--glass-border); background: transparent; padding: 15px; white-space: nowrap; font-weight: 600;}
        .table tbody tr:hover td { background: rgba(0,0,0,0.03); }
        [data-theme="dark"] .table tbody tr:hover td { background: rgba(255,255,255,0.03); }
        
        .mono-text { font-family: 'JetBrains Mono', monospace; font-weight: 800;}
        .mono-num { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 900; margin-top: 10px; }

        .clickable-id { color: var(--accent-blue); font-family: 'JetBrains Mono', monospace; cursor: pointer; text-decoration: none; font-weight: 800; transition: 0.2s;}
        [data-theme="dark"] .clickable-id { color: var(--accent-gold); }
        .clickable-id:hover { opacity: 0.7; }

        .summary-row { display: flex !important; flex-wrap: wrap; gap: 15px; margin-bottom: 25px !important; }
        .summary-col { flex: 1; min-width: 150px; }
        .stat-box { background: var(--glass-bg); backdrop-filter: blur(10px); border: 1px solid var(--glass-border); border-radius: 16px; padding: 20px; text-align: center; height: 100%; display: flex; flex-direction: column; justify-content: center; box-shadow: var(--shadow-glass); transition: 0.3s;}
        .stat-box:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }

        .neo-badge { padding: 6px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 800; background: rgba(0,0,0,0.05); border: 1px solid transparent;}
        [data-theme="dark"] .neo-badge { background: rgba(255,255,255,0.05); }
        
        /* 🟢 زر اللوج (API Log Button) */
        .btn-api-log { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; font-size: 0.9rem; transition: 0.2s; background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); cursor: pointer; }
        .btn-api-log:hover { background: #10b981; color: white; transform: translateY(-2px); }

        .seq-circle { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; font-family: 'JetBrains Mono', monospace; font-weight: 900; font-size: 0.9rem; background: rgba(14, 165, 233, 0.1); color: var(--accent-blue); margin: 0 auto; border: 1px solid rgba(14, 165, 233, 0.2); }
        [data-theme="dark"] .seq-circle { background: rgba(251, 191, 36, 0.1); color: var(--accent-gold); border-color: rgba(251, 191, 36, 0.3); }

        .accordion-button { background: var(--glass-bg) !important; color: var(--text-main) !important; border: 1px solid var(--glass-border) !important; border-radius: 16px !important; padding: 20px !important; box-shadow: var(--shadow-glass) !important; font-family: 'Tajawal', sans-serif;}
        .accordion-button:not(.collapsed) { background: rgba(14, 165, 233, 0.05) !important; border-color: var(--accent-blue) !important; color: var(--accent-blue) !important; border-bottom-left-radius: 0 !important; border-bottom-right-radius: 0 !important;}
        [data-theme="dark"] .accordion-button:not(.collapsed) { background: rgba(251, 191, 36, 0.05) !important; border-color: var(--accent-gold) !important; color: var(--accent-gold) !important;}
        .accordion-button::after { filter: var(--bs-body-color-rgb) === "255,255,255" ? invert(1) : none; }
        .accordion-item { background: transparent; border: none; margin-bottom: 20px;}
        .accordion-body { background: var(--glass-bg); border: 1px solid var(--glass-border); border-top: none; border-bottom-left-radius: 16px; border-bottom-right-radius: 16px; padding: 20px;}
        
        .day-summary-row { display: flex; width: 100%; justify-content: space-between; align-items: center; padding-right: 15px; flex-wrap: wrap; gap: 10px;}
        .day-stat { text-align: center; border-left: 1px dashed var(--glass-border); padding-left: 15px; flex: 1;}
        .day-stat:last-child { border-left: none; }
        .day-stat span { display: block; font-size: 0.75rem; color: var(--text-muted); font-weight: bold; margin-bottom: 5px;}
        .day-stat strong { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; }

        .modal-content { background: var(--glass-bg); backdrop-filter: blur(20px); border: 1px solid var(--glass-border); border-radius: 24px; color: var(--text-main); box-shadow: 0 25px 50px rgba(0,0,0,0.5);}
        .modal-header { border-bottom: 1px solid var(--glass-border); }

        @media (max-width: 768px) {
            body { padding-top: 150px; }
            .glass-nav { flex-direction: column; gap: 15px; border-radius: 16px; padding: 15px;}
            .nav-actions { justify-content: center; width: 100%; display: flex; flex-wrap: wrap; gap: 8px; }
            .nav-actions .nav-btn { flex: 1 1 calc(33% - 8px); justify-content: center; font-size: 0.8rem; padding: 8px;}
            .summary-col { min-width: 45%; }
            .table th, .table td { font-size: 0.85rem !important; padding: 10px 5px !important; }
            .day-summary-row { flex-direction: column; text-align: center; }
            .day-stat { border-left: none; border-bottom: 1px dashed var(--glass-border); width: 100%; padding-bottom: 10px; padding-left: 0;}
            .day-stat:last-child { border-bottom: none; }
            .accordion-button { padding: 15px !important; }
        }

        @media print {
            @page { size: A4 landscape; margin: 10mm; }
            body { background: white !important; color: black !important; background-image: none !important; padding-top: 0 !important;}
            .no-print, .glass-nav, .accordion-button::after { display: none !important; }
            .accordion-collapse { display: block !important; }
            .accordion-item, .data-card, .stat-box, .table-responsive, .accordion-body { box-shadow: none !important; border: 1px solid #ccc !important; background: white !important; color: black !important;}
            .accordion-button { border: 1px solid #ccc !important; background: #eee !important; color: black !important; }
            .table th { background: #eee !important; color: black !important; border: 1px solid #ccc !important;}
            .table td, .mono-num, .clickable-id { color: black !important; text-shadow: none !important; border: 1px solid #ccc !important;}
            .seq-circle { border: none !important; background: transparent !important; color: black !important; }
            .print-header { display: block !important; text-align: center; margin-bottom: 20px; border-bottom: 2px solid #000; padding-bottom: 10px; }
        }
        .print-header { display: none; }
    </style>
</head>
<body>

<nav class="glass-nav no-print">
    <div class="d-flex align-items-center gap-3">
        <div style="width: 45px; height: 45px; background: rgba(212,175,55,0.1); border-radius: 14px; display: flex; align-items: center; justify-content: center; color: var(--accent-gold); font-size: 1.5rem; border: 1px solid rgba(212,175,55,0.3);"><i class="fa-solid fa-file-invoice"></i></div>
        <div>
            <h5 class="m-0 fw-bold">السجل المالي</h5>
            <small style="font-weight: 700; color: var(--text-muted);"><%= emp.botId.name %></small>
        </div>
    </div>
  
    <div class="nav-actions">
        <button class="nav-btn" onclick="toggleTheme()" title="تغيير المظهر"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
        <a href="/executor-portal/dashboard" class="nav-btn"><i class="fa-solid fa-bolt me-1 text-warning"></i> الرادار</a>
        <a href="/executor-portal/reports" class="nav-btn"><i class="fa-solid fa-file-invoice me-1 text-info"></i> السجل</a>
        <a href="/executor-portal/support" class="nav-btn"><i class="fa-solid fa-headset me-1 text-success"></i> الإدارة</a>
        <button onclick="window.print()" class="nav-btn" style="color: var(--accent-gold); border-color: rgba(212, 175, 55, 0.4);"><i class="fa-solid fa-print me-1"></i> طباعة</button>
        <a href="/executor-portal/logout" class="nav-btn" style="color: var(--accent-red); border-color: rgba(239, 68, 68, 0.3);"><i class="fa-solid fa-power-off"></i></a>
    </div>
</nav>

<div class="container px-3 pb-5">
    
    <div class="print-header">
        <img src="/images/logo.jpeg" height="80" alt="Logo" style="margin-bottom: 10px;" onerror="this.style.display='none'">
        <h2 style="font-weight: 900; margin: 0;">شــــركــــــــة الاهـــــــــــرام للاتـــصــــالات والخدمات الرقمية</h2>
        <h4>كشف حساب عمليات بوت: <%= emp.botId.name %></h4>
        <p>تاريخ التقرير: <%= dateLabel %></p>
    </div>

    <div class="data-card no-print">
        <form method="GET" action="/executor-portal/reports" class="row align-items-end g-3">
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small">بحث برقم المحفظة أو الطلب</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
                    <input type="text" name="search" class="form-control mono-text" placeholder="بحث..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small">تحديد يوم</label>
                <input type="date" name="date" class="form-control fw-bold" value="<%= targetDate %>">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn-primary w-100 py-2"><i class="fa-solid fa-filter me-1"></i> فلترة</button>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <a href="/executor-portal/reports" class="nav-btn flex-fill justify-content-center">اليوم</a>
                <a href="/executor-portal/reports?month=true" class="nav-btn flex-fill justify-content-center" style="color: var(--accent-gold); border-color: rgba(212,175,55,0.3); background: rgba(212,175,55,0.05);"><i class="fa-solid fa-calendar-days me-1"></i> الشهر</a>
            </div>
        </form>
    </div>

    <div class="row g-2 mb-4 d-flex flex-wrap">
        <div class="summary-col">
            <div class="stat-box" style="border-bottom: 4px solid var(--text-muted);">
                <h6 class="text-muted small fw-bold mb-2">رصيد أول المدة</h6>
                <div class="mono-num" style="color: var(--text-muted);"><%= openingBalance.toFixed(2) %></div>
            </div>
        </div>

        <% if (totalSettle > 0) { %>
        <div class="summary-col">
            <div class="stat-box" style="border-bottom: 4px solid var(--accent-blue);">
                <h6 class="text-muted small fw-bold mb-2">إجمالي المسدد (إيداعات)</h6>
                <div class="mono-num" style="color: var(--accent-blue);"><%= totalSettle.toFixed(2) %></div>
            </div>
        </div>
        <% } %>

        <div class="summary-col">
            <div class="stat-box" style="border-bottom: 4px solid var(--accent-green);">
                <h6 class="text-muted small fw-bold mb-2">إجمالي التنفيذ (صادر)</h6>
                <div class="mono-num" style="color: var(--accent-green);"><%= totalCompleted.toFixed(2) %></div>
            </div>
        </div>

        <% if (totalDeduction > 0) { %>
        <div class="summary-col">
            <div class="stat-box" style="border-bottom: 4px solid var(--accent-red); background: rgba(239, 68, 68, 0.05);">
                <h6 class="small fw-bold mb-2" style="color: var(--accent-red);">مسحوب (خصومات)</h6>
                <div class="mono-num" style="color: var(--accent-red);"><%= totalDeduction.toFixed(2) %></div>
            </div>
        </div>
        <% } %>

        <div class="summary-col">
            <div class="stat-box" style="border-bottom: 4px solid var(--accent-gold); background: rgba(212, 175, 55, 0.05);">
                <h6 class="small fw-bold mb-2" style="color: var(--accent-gold);">الرصيد الختامي</h6>
                <div class="mono-num" style="color: var(--accent-gold);"><%= closingBalance.toFixed(2) %></div>
            </div>
        </div>
    </div>

    <% if (typeof showMonth !== 'undefined' && showMonth && !search && typeof groupedDaysArray !== 'undefined') { %>
        <h5 class="fw-bold mb-4 mt-5" style="color: var(--accent-blue);"><i class="fa-solid fa-layer-group me-2"></i> تقرير الشهر مفصل بالأيام</h5>
        
        <% if (groupedDaysArray.length === 0) { %>
            <div class="data-card text-center py-5 text-muted fw-bold border-0 fs-5"><i class="fa-solid fa-folder-open fs-1 d-block mb-3 opacity-25"></i> لا توجد عمليات في هذا الشهر.</div>
        <% } else { %>
            <div class="accordion" id="monthAccordion">
                <% groupedDaysArray.forEach((day, index) => { %>
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="heading-<%= index %>">
                            <button class="accordion-button <%= index !== 0 ? 'collapsed' : '' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-<%= index %>">
                                <div class="day-summary-row w-100">
                                    <div class="day-stat" style="text-align: right; flex: 1.5;">
                                        <span>التاريخ</span>
                                        <strong style="color: var(--accent-blue);"><i class="fa-regular fa-calendar me-1"></i> <%= day.displayDate %></strong>
                                    </div>
                                    <div class="day-stat">
                                        <span>عمليات</span>
                                        <strong style="color: var(--accent-purple);"><%= day.execCount %></strong>
                                    </div>
                                    <div class="day-stat">
                                        <span>قيمة سابقة</span>
                                        <strong style="color: var(--text-muted);"><%= day.openingBalance.toFixed(2) %></strong>
                                    </div>
                                    <div class="day-stat">
                                        <span>إيداعات (+)</span>
                                        <strong style="color: var(--accent-blue);"><%= day.totalSettle.toFixed(2) %></strong>
                                    </div>
                                    <div class="day-stat">
                                        <span>منفذ وصادر (-)</span>
                                        <strong style="color: var(--accent-green);"><%= day.totalCompleted.toFixed(2) %></strong>
                                    </div>
                                    <% if (day.totalDeduction > 0) { %>
                                    <div class="day-stat">
                                        <span class="text-danger">خصومات (-)</span>
                                        <strong style="color: var(--accent-red);"><%= day.totalDeduction.toFixed(2) %></strong>
                                    </div>
                                    <% } %>
                                    <div class="day-stat" style="border-left: none;">
                                        <span style="color: var(--accent-gold);">الرصيد الختامي</span>
                                        <strong style="color: var(--accent-gold); font-size: 1.25rem;"><%= day.closingBalance.toFixed(2) %></strong>
                                    </div>
                                </div>
                            </button>
                        </h2>
                        <div id="collapse-<%= index %>" class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>" data-bs-parent="#monthAccordion">
                            <div class="accordion-body p-0 mt-3 border-top" style="border-color: var(--glass-border) !important;">
                                <div class="table-responsive border-0 m-0 rounded-0">
                                    <table class="table text-center table-hover m-0">
                                        <thead style="background: rgba(0,0,0,0.02);">
                                            <tr>
                                                <th style="width: 50px;">ت</th>
                                                <th>الرقم</th>
                                                <th>النوع</th>
                                                <th>الرقم / الحساب</th>
                                                <th>المبلغ (EGP)</th>
                                                <th>الوقت</th>
                                                <th>الإثبات / السجل</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% day.transactions.forEach((tx, i) => { %>
                                                <tr style="<%= tx.status === 'deposit' ? 'background: rgba(59, 130, 246, 0.05);' : (tx.status === 'deduction' ? 'background: rgba(239, 68, 68, 0.05);' : '') %>">
                                                    <td><div class="seq-circle"><%= i + 1 %></div></td>
                                                    <td>
                                                        <% if (tx.status === 'completed' && (tx.proofImage || (tx.proofImages && tx.proofImages.length > 0))) { %>
                                                            <a href="javascript:void(0)" onclick="showProofImage('<%= tx._id %>')" class="clickable-id no-print">#<%= tx.customId || tx._id.toString().slice(-6) %> <i class="fa-solid fa-image ms-1 text-muted"></i></a>
                                                            <span class="mono-text opacity-75 print-only" style="display:none;">#<%= tx.customId || tx._id.toString().slice(-6) %></span>
                                                        <% } else { %>
                                                            <span class="mono-text opacity-75">#<%= tx.customId || tx._id.toString().slice(-6) %></span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <% if(tx.status === 'deposit') { %> <span class="fw-bold text-info"><i class="fa-solid fa-arrow-down me-1"></i> إيداع</span>
                                                        <% } else if(tx.status === 'deduction') { %> <span class="fw-bold text-danger"><i class="fa-solid fa-arrow-up me-1"></i> خصم</span>
                                                        <% } else { %> <span class="fw-bold text-success"><i class="fa-solid fa-check me-1"></i> تحويل</span> <% } %>
                                                    </td>
                                                    <td><span class="mono-text fw-bold fs-6" dir="ltr"><%= tx.vodafoneNumber || 'تسوية إدارية' %></span></td>
                                                    <td>
                                                        <span class="mono-text fw-bold fs-5" style="color: <%= tx.status==='deduction' ? 'var(--accent-red)' : (tx.status==='deposit' ? 'var(--accent-blue)' : 'var(--accent-green)') %>;">
                                                            <%= tx.amount.toFixed(2) %>
                                                        </span>
                                                    </td>
                                                    <td class="small mono-text opacity-75 text-muted"><%= new Date(tx.updatedAt).toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'}) %></td>
                                                    <td>
                                                        <div class="d-flex align-items-center justify-content-center gap-2">
                                                            <% if (tx.proofImage || (tx.proofImages && tx.proofImages.length > 0)) { %>
                                                                <a href="javascript:void(0)" onclick="showProofImage('<%= tx._id %>')" class="neo-badge text-decoration-none" style="color: var(--accent-green); border-color: rgba(16, 185, 129, 0.3); background: rgba(16, 185, 129, 0.1);">
                                                                    <i class="fa-solid fa-image"></i>
                                                                </a>
                                                            <% } else if (!(tx.notes && tx.notes.includes('--- سجل الـ API'))) { %>
                                                                <span class="opacity-25">-</span>
                                                            <% } %>
                                                            
                                                            <% if (tx.notes && tx.notes.includes('--- سجل الـ API')) { %>
                                                                <button onclick="showApiLog(this)" data-log="<%= encodeURIComponent(tx.notes) %>" class="btn-api-log no-print" title="سجل API"><i class="fa-solid fa-terminal"></i></button>
                                                            <% } %>
                                                        </div>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

    <% } else { %>
        <% 
            const execTxs = transactions.filter(t => t.status === 'completed');
            const depositTxs = transactions.filter(t => t.status === 'deposit');
            const deductionTxs = transactions.filter(t => t.status === 'deduction');
        %>

        <h5 class="fw-bold mb-3 mt-5" style="color: var(--accent-blue);"><i class="fa-solid fa-list-check me-2"></i> سجل التحويلات المنفذة</h5>
        <div class="data-card p-0">
            <div class="table-responsive border-0">
                <table class="table text-center table-hover">
                    <thead style="border-bottom: 2px solid var(--glass-border);">
                        <tr>
                            <th style="width: 50px;">ت</th>
                            <th>الرقم</th>
                            <th>الرقم / الحساب</th>
                            <th>المبلغ (EGP)</th>
                            <th>المنفذ</th>
                            <th>وقت الوصول</th>
                            <th>وقت التنفيذ</th>
                            <th>الاستغراق</th>
                            <th>الإثبات / السجل</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(execTxs.length === 0) { %>
                            <tr><td colspan="9" class="py-5 text-muted fw-bold border-0 fs-5">لا يوجد عمليات مطابقة.</td></tr>
                        <% } else { %>
                            <% execTxs.forEach((tx, index) => { 
                                const diffMs = new Date(tx.updatedAt) - new Date(tx.createdAt);
                                const diffMins = Math.floor(diffMs / 60000);
                                let timeTaken = ''; let timeClass = 'text-success';
                                if (diffMins < 1) { timeTaken = 'أقل من دقيقة'; } 
                                else if (diffMins < 60) { timeTaken = `${diffMins} دقيقة`; if(diffMins > 15) timeClass = 'text-warning'; if(diffMins > 30) timeClass = 'text-danger'; } 
                                else { const h = Math.floor(diffMins / 60); const m = diffMins % 60; timeTaken = `${h}س و ${m}د`; timeClass = 'text-danger'; }
                            %>
                                <tr>
                                    <td><div class="seq-circle"><%= index + 1 %></div></td>
                                    <td>
                                        <a href="javascript:void(0)" onclick="showProofImage('<%= tx._id %>')" class="clickable-id no-print">#<%= tx.customId || tx._id.toString().slice(-6) %> <i class="fa-solid fa-image ms-1 text-muted"></i></a>
                                        <span class="mono-text opacity-75 print-only" style="display:none;">#<%= tx.customId || tx._id.toString().slice(-6) %></span>
                                    </td>
                                    <td><span class="mono-text fw-bold fs-6" dir="ltr"><%= tx.vodafoneNumber || '---' %></span></td>
                                    <td><span class="mono-text fw-bold fs-5" style="color: var(--accent-green);"><%= tx.amount.toFixed(2) %></span></td>
                                    <td class="small fw-bold opacity-75"><%= tx.executorName || '---' %></td>
                                    <td class="small mono-text" style="line-height: 1.4;"><div class="text-muted"><%= new Date(tx.createdAt).toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'}) %></div><span style="font-size: 0.7rem; opacity: 0.5;"><%= new Date(tx.createdAt).toLocaleDateString('en-GB') %></span></td>
                                    <td class="small mono-text" style="line-height: 1.4;"><div style="color: var(--accent-blue);"><%= new Date(tx.updatedAt).toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'}) %></div><span style="font-size: 0.7rem; opacity: 0.5;"><%= new Date(tx.updatedAt).toLocaleDateString('en-GB') %></span></td>
                                    <td><span class="neo-badge <%= timeClass %> fw-bold" style="font-size: 0.75rem;"><i class="fa-solid fa-stopwatch me-1"></i> <%= timeTaken %></span></td>
                                    <td>
                                        <div class="d-flex align-items-center justify-content-center gap-2">
                                            <% if (tx.proofImage || (tx.proofImages && tx.proofImages.length > 0)) { %>
                                                <button onclick="showProofImage('<%= tx._id %>')" class="neo-badge text-decoration-none border-0" style="color: var(--accent-green); background: rgba(16, 185, 129, 0.1);"><i class="fa-solid fa-image"></i></button>
                                            <% } else if (!(tx.notes && tx.notes.includes('--- سجل الـ API'))) { %>
                                                <span class="opacity-25">-</span>
                                            <% } %>
                                            
                                            <% if (tx.notes && tx.notes.includes('--- سجل الـ API')) { %>
                                                <button onclick="showApiLog(this)" data-log="<%= encodeURIComponent(tx.notes) %>" class="btn-api-log no-print" title="سجل API"><i class="fa-solid fa-terminal"></i></button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <% if (depositTxs.length > 0 || deductionTxs.length > 0) { %>
        <h5 class="fw-bold mb-3 mt-5" style="color: var(--accent-blue);"><i class="fa-solid fa-money-bill-transfer me-2"></i> سجل التسويات (الإيداع والخصم)</h5>
        <div class="data-card p-0" style="border-left: 4px solid var(--accent-blue);">
            <div class="table-responsive border-0">
                <table class="table text-center table-hover">
                    <thead style="border-bottom: 2px solid var(--glass-border);">
                        <tr>
                            <th style="width: 50px;">ت</th>
                            <th>الرقم</th>
                            <th>النوع والبيان</th>
                            <th>المبلغ (EGP)</th>
                            <th>الملاحظة</th>
                            <th>وقت التسوية</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% let tsIndex = 1; %>
                        <% depositTxs.forEach((tx) => { %>
                            <tr style="background: rgba(14, 165, 233, 0.05);">
                                <td><div class="seq-circle"><%= tsIndex++ %></div></td>
                                <td><span class="mono-text opacity-75">#<%= tx.customId || tx._id.toString().slice(-6) %></span></td>
                                <td class="fw-bold" style="color: var(--accent-blue);"><i class="fa-solid fa-arrow-down me-1"></i> إيداع عهدة نقدي</td>
                                <td><span class="mono-text fw-bold fs-5" style="color: var(--accent-blue);"><%= tx.amount.toFixed(2) %></span></td>
                                <td class="small opacity-75 text-wrap" style="max-width: 200px;"><%= tx.notes || '---' %></td>
                                <td class="small mono-text text-muted" style="line-height: 1.4;">
                                    <%= new Date(tx.updatedAt).toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'}) %><br>
                                    <span style="font-size: 0.7rem; opacity: 0.5;"><%= new Date(tx.updatedAt).toLocaleDateString('en-GB') %></span>
                                </td>
                            </tr>
                        <% }) %>
                        <% deductionTxs.forEach((tx) => { %>
                            <tr style="background: rgba(239, 68, 68, 0.05);">
                                <td><div class="seq-circle"><%= tsIndex++ %></div></td>
                                <td><span class="mono-text opacity-75">#<%= tx.customId || tx._id.toString().slice(-6) %></span></td>
                                <td class="fw-bold" style="color: var(--accent-red);"><i class="fa-solid fa-arrow-up me-1"></i> خصم مديونية</td>
                                <td><span class="mono-text fw-bold fs-5" style="color: var(--accent-red);"><%= tx.amount.toFixed(2) %></span></td>
                                <td class="small opacity-75 text-wrap" style="max-width: 200px;"><%= tx.notes || '---' %></td>
                                <td class="small mono-text text-muted" style="line-height: 1.4;">
                                    <%= new Date(tx.updatedAt).toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'}) %><br>
                                    <span style="font-size: 0.7rem; opacity: 0.5;"><%= new Date(tx.updatedAt).toLocaleDateString('en-GB') %></span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

    <% } %>

</div>

<div class="modal fade" id="proofModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" style="filter: invert(var(--bs-body-color-rgb));"></button>
            </div>
            <div class="modal-body p-0" id="proofContainer" style="min-height: 300px; display: flex; align-items: center; justify-content: center;"></div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleTheme() {
        const html = document.documentElement;
        const currentTheme = html.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', newTheme);
        html.setAttribute('data-bs-theme', newTheme);
        localStorage.setItem('ahram_theme', newTheme);
        document.getElementById('themeIcon').className = newTheme === 'dark' ? 'fa-solid fa-sun text-warning' : 'fa-solid fa-moon text-dark';
    }

    document.addEventListener('DOMContentLoaded', () => {
        const theme = localStorage.getItem('ahram_theme') || 'dark';
        if (theme === 'dark') document.getElementById('themeIcon').className = 'fa-solid fa-sun text-warning';
    });
    
    // 🟢 دالة عرض نافذة السجل المنبثقة (Terminal View) تدعم كل الصيغ السابقة والجديدة
    function showApiLog(btn) {
        const rawNotes = decodeURIComponent(btn.getAttribute('data-log'));
        let logContent = rawNotes;
        
        if (rawNotes.includes('--- سجل الـ API (Terminal Log) ---')) {
            logContent = rawNotes.split('--- سجل الـ API (Terminal Log) ---')[1].trim();
        } else if (rawNotes.includes('--- سجل الـ API ---')) {
            logContent = rawNotes.split('--- سجل الـ API ---')[1].trim();
        } else if (rawNotes.includes('--- سجل الـ API')) {
            logContent = rawNotes.split('--- سجل الـ API')[1].trim();
        }
        
        Swal.fire({
            title: '<div style="color:#10b981; font-family:monospace; font-size:1.2rem; display:flex; align-items:center; gap:10px; justify-content:center;"><i class="fa-solid fa-terminal"></i> سجل التخاطب مع السيرفر</div>',
            html: `<div style="background:#0f172a; color:#a5b4fc; padding:15px; border-radius:8px; text-align:left; direction:ltr; font-family:'JetBrains Mono', monospace; font-size:0.85rem; white-space:pre-wrap; max-height:400px; overflow-y:auto; border:1px solid #334155; box-shadow:inset 0 2px 4px rgba(0,0,0,0.5);">${logContent}</div>`,
            background: '#1e293b',
            color: '#fff',
            confirmButtonColor: '#3b82f6',
            confirmButtonText: 'إغلاق الشاشة',
            width: '600px',
            customClass: { popup: 'border border-secondary rounded-4' }
        });
    }

    function showProofImage(txId) {
        const container = document.getElementById('proofContainer');
        container.innerHTML = '<div class="text-muted fw-bold text-center w-100 py-5"><i class="fa-solid fa-spinner fa-spin fa-2x mb-3 d-block mx-auto" style="color: var(--accent-blue);"></i> جاري جلب الإيصالات...</div>';
        new bootstrap.Modal(document.getElementById('proofModal')).show();
        
        container.innerHTML = `
            <div id="carouselExample" class="carousel slide w-100 p-2">
                <div class="carousel-inner" style="border-radius: 16px; overflow: hidden; background: rgba(0,0,0,0.1);">
                    <div class="carousel-item active"><img src="/executor-portal/proxy/image/${txId}/0" class="d-block w-100" style="max-height: 75vh; object-fit: contain;" onerror="this.src='/images/no-image.png'"></div>
                    <div class="carousel-item"><img src="/executor-portal/proxy/image/${txId}/1" class="d-block w-100" style="max-height: 75vh; object-fit: contain;" onerror="this.parentElement.remove()"></div>
                    <div class="carousel-item"><img src="/executor-portal/proxy/image/${txId}/2" class="d-block w-100" style="max-height: 75vh; object-fit: contain;" onerror="this.parentElement.remove()"></div>
                    <div class="carousel-item"><img src="/executor-portal/proxy/image/${txId}/3" class="d-block w-100" style="max-height: 75vh; object-fit: contain;" onerror="this.parentElement.remove()"></div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
            </div>`;
    }
</script>
</body>
</html>