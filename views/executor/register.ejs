<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إنشاء حساب منفذ | الأهرام</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
        :root { --brand-dark: #0f172a; --brand-neon: #10b981; }
        body { font-family: 'Tajawal', sans-serif; background: linear-gradient(135deg, #0f172a 0%, #1e1e2f 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; margin:0; padding: 20px;}
        .login-card { background: rgba(31, 41, 55, 0.95); border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.5); width: 100%; max-width: 500px; padding: 40px 30px; border-bottom: 5px solid var(--brand-neon); }
        .logo-container { text-align: center; margin-bottom: 30px; }
        .logo-icon { font-size: 3.5rem; color: var(--brand-neon); margin-bottom: 10px; filter: drop-shadow(0 0 10px rgba(16, 185, 129, 0.4)); }
        .form-control, .form-select { border-radius: 12px; padding: 12px 15px; border: 1px solid #374151; background: #111827; color: white; }
        .form-control:focus, .form-select:focus { border-color: var(--brand-neon); box-shadow: 0 0 0 0.25rem rgba(16, 185, 129, 0.25); color: white; background: #111827;}
        .form-control::placeholder { color: #6b7280; }
        .input-group-text { background: #374151; border-color: #374151; color: #9ca3af; }
        .btn-login { background: var(--brand-neon); border: none; border-radius: 12px; padding: 12px; font-weight: bold; font-size: 1.1rem; transition: 0.3s; color: #fff; }
        .btn-login:hover { background: #059669; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(16, 185, 129, 0.3); color: #fff;}
        .alert-danger { background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444; }
        .alert-success { background: rgba(16, 185, 129, 0.1); border: 1px solid #10b981; color: #10b981; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-container">
            <i class="fa-solid fa-user-plus logo-icon"></i>
            <h3 class="fw-bold text-white mb-0">انضم كمنفذ جديد</h3>
            <p class="text-muted small mt-1" style="color: #9ca3af !important;">أنشئ حساب وكالتك للبدء في تلقي وتنفيذ الطلبات</p>
        </div>
        
        <% if (error) { %>
            <div class="alert alert-danger text-center fw-bold small rounded-3 mb-4"><i class="fa-solid fa-circle-exclamation me-1"></i> <%= error %></div>
        <% } %>
        <% if (success) { %>
            <div class="alert alert-success text-center fw-bold small rounded-3 mb-4"><i class="fa-solid fa-check-circle me-1"></i> <%- success %></div>
        <% } %>

        <form action="/executor-portal/register" method="POST">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold small text-muted">اسم الشركة/المنفذ</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="fa-solid fa-building"></i></span>
                        <input type="text" name="companyName" class="form-control border-start-0" placeholder="مثال: شركة النور" required>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold small text-muted">اسم المدير الثلاثي</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="fa-solid fa-user-tie"></i></span>
                        <input type="text" name="managerName" class="form-control border-start-0" placeholder="اسمك بالكامل" required>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold small text-muted">رقم الهاتف</label>
                    <div class="input-group">
                        <span class="input-group-text border-end-0"><i class="fa-solid fa-phone"></i></span>
                        <input type="text" name="phone" class="form-control border-start-0" placeholder="01xxxxxxxxx" required dir="ltr">
                    </div>
            </div>

            <hr style="border-color: #374151;">
            
            <div class="mb-3">
                <label class="form-label fw-bold small text-muted">اسم المستخدم للدخول</label>
                <div class="input-group" dir="ltr">
                    <input type="text" name="webUsername" class="form-control text-end border-end-0" placeholder="Username" required>
                    <span class="input-group-text border-start-0 text-muted" style="background: #1f2937;">@ahram.com</span>
                </div>
                <small class="text-muted" style="font-size: 0.7rem;">يجب أن يكون باللغة الإنجليزية وبدون مسافات</small>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold small text-muted">كلمة المرور</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" id="webPassword" name="webPassword" class="form-control border-start-0" placeholder="••••••••" required dir="ltr">
                </div>
            </div>
            
            <div class="mb-4">
                <label class="form-label fw-bold small text-muted">تأكيد كلمة المرور</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" id="confirmPassword" name="confirmPassword" class="form-control border-start-0" placeholder="••••••••" required dir="ltr">
                </div>
                <small id="passwordError" class="text-danger d-none mt-1 fw-bold">كلمات المرور غير متطابقة</small>
            </div>

            <button type="submit" id="submitBtn" class="btn btn-login w-100 shadow mb-3">إنشاء الحساب <i class="fa-solid fa-arrow-left ms-1"></i></button>
            <div class="text-center">
                <a href="/executor-portal/login" class="text-decoration-none small text-muted">لديك حساب بالفعل؟ <span style="color: var(--brand-neon);">تسجيل الدخول</span></a>
            </div>
        </form>
    </div>
    
    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            const pwd = document.getElementById('webPassword').value;
            const confirmPwd = document.getElementById('confirmPassword').value;
            const errorText = document.getElementById('passwordError');
            
            if (pwd !== confirmPwd) {
                e.preventDefault();
                errorText.classList.remove('d-none');
            } else {
                errorText.classList.add('d-none');
            }
        });
    </script>
</body>
</html>
