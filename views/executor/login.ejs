<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل دخول المنفذين | الأهرام</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
        :root { --brand-dark: #0f172a; --brand-neon: #10b981; }
        body { font-family: 'Tajawal', sans-serif; background: linear-gradient(135deg, #0f172a 0%, #1e1e2f 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; margin:0;}
        .login-card { background: rgba(31, 41, 55, 0.95); border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.5); width: 100%; max-width: 400px; padding: 40px 30px; border-bottom: 5px solid var(--brand-neon); }
        .logo-container { text-align: center; margin-bottom: 30px; }
        .logo-icon { font-size: 3.5rem; color: var(--brand-neon); margin-bottom: 10px; filter: drop-shadow(0 0 10px rgba(16, 185, 129, 0.4)); }
        .form-control { border-radius: 12px; padding: 12px 15px; border: 1px solid #374151; background: #111827; color: white; }
        .form-control:focus { border-color: var(--brand-neon); box-shadow: 0 0 0 0.25rem rgba(16, 185, 129, 0.25); color: white; background: #111827;}
        .form-control::placeholder { color: #6b7280; }
        .input-group-text { background: #374151; border-color: #374151; color: #9ca3af; }
        .btn-login { background: var(--brand-neon); border: none; border-radius: 12px; padding: 12px; font-weight: bold; font-size: 1.1rem; transition: 0.3s; color: #fff; }
        .btn-login:hover { background: #059669; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(16, 185, 129, 0.3); color: #fff;}
        .alert-danger { background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-container">
            <i class="fa-solid fa-network-wired logo-icon"></i>
            <h3 class="fw-bold text-white mb-0">بوابة التنفيذ المركزية</h3>
            <p class="text-muted small mt-1" style="color: #9ca3af !important;">شاشة الموظفين والكاشير (غرفة العمليات)</p>
        </div>
        <% if (error) { %>
            <div class="alert alert-danger text-center fw-bold small rounded-3 mb-4"><i class="fa-solid fa-circle-exclamation me-1"></i> <%= error %></div>
        <% } %>
        <form action="/executor-portal/login" method="POST">
            <div class="mb-3">
                <label class="form-label fw-bold small text-muted">اسم المستخدم</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0"><i class="fa-solid fa-user"></i></span>
                    <input type="text" name="username" class="form-control border-start-0" placeholder="أدخل اسم المستخدم" required dir="ltr">
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold small text-muted">كلمة المرور</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="password" class="form-control border-start-0" placeholder="••••••••" required dir="ltr">
                </div>
            </div>
            <button type="submit" class="btn btn-login w-100 shadow">دخول إلى النظام <i class="fa-solid fa-arrow-left ms-1"></i></button>
            <div class="text-center mt-3">
                <a href="/executor-portal/register" class="text-decoration-none small" style="color: var(--brand-neon);">إنشاء حساب منفذ جديد</a>
            </div>
        </form>
    </div>
</body>
</html>