<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>لوحة التحكم | شركة الأهرام</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700;800&display=swap" rel="stylesheet">

    <style>
        .top-header { border-radius: 20px; padding: 20px !important; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; }
        .company-logo-box { background: rgba(212, 175, 55, 0.1); color: var(--brand-gold); width: 55px; height: 55px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; border: 1px solid rgba(212, 175, 55, 0.3); }
        
        .stat-card { border-radius: 24px; padding: 25px; height: 100%; display: flex; align-items: center; gap: 20px; position: relative; overflow: hidden; border-start: 4px solid transparent;}
        .stat-card:hover { transform: translateY(-5px); }
        .card-icon { width: 65px; height: 65px; display: flex; align-items: center; justify-content: center; border-radius: 18px; font-size: 2rem; background: rgba(0,0,0,0.03); border: 1px solid var(--border-glass); transition: 0.3s;}
        [data-theme="dark"] .card-icon { background: rgba(255,255,255,0.03); }
        
        .stat-users { border-right: 4px solid #3b82f6; } .stat-users .card-icon { color: #3b82f6; }
        .stat-companies { border-right: 4px solid #8b5cf6; } .stat-companies .card-icon { color: #8b5cf6; }
        .stat-execs { border-right: 4px solid #64748b; } .stat-execs .card-icon { color: #64748b; }
        .stat-pending { border-right: 4px solid #f59e0b; } .stat-pending .card-icon { color: #f59e0b; }
        .stat-processing { border-right: 4px solid #0ea5e9; } .stat-processing .card-icon { color: #0ea5e9; }
        .stat-completed { border-right: 4px solid #10b981; } .stat-completed .card-icon { color: #10b981; }

        .stat-val { font-family: 'JetBrains Mono', monospace; font-size: 2.2rem; font-weight: 900; line-height: 1; margin: 0; color: var(--text-main);}
        .stat-title { font-size: 0.9rem; font-weight: 700; margin-bottom: 5px; color: var(--text-muted); }

        .user-time-widget { position: fixed; bottom: 25px; left: 25px; border-radius: 20px; padding: 15px 25px; z-index: 1040; min-width: 260px; display: flex; flex-direction: column; align-items: center; gap: 10px; border-bottom: 4px solid var(--brand-gold);}
        .clock-display { font-family: 'JetBrains Mono', monospace; font-size: 1.5rem; font-weight: 900; letter-spacing: 1px; color: var(--brand-primary);}
        [data-theme="dark"] .clock-display { color: var(--brand-gold); }

        @media (max-width: 991px) {
            .top-header { flex-direction: column; gap: 15px; text-align: center; }
            .user-time-widget { position: static; margin-top: 30px; width: 100%; border-bottom: none; border-top: 4px solid var(--brand-gold);}
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#001a4d">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Al-Ahram">
    <!-- End PWA -->
</head>
<body>

<button class="mobile-nav-toggle no-print" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay no-print" onclick="toggleSidebar()"></div>

<%- include('partials/sidebar', { activePage: 'dashboard' }) %>

<div class="main-content">
    <div class="container-fluid">

        <div class="top-header data-card d-none d-lg-flex">
            <div class="d-flex align-items-center">
                <div class="company-logo-box me-3"><i class="fa-solid fa-shield-halved"></i></div>
                <div class="text-start">
                    <h4 class="fw-bold m-0" style="color: var(--text-main);">القيادة المركزية</h4>
                    <span class="small fw-bold" style="color: var(--text-muted);">نظام الأهرام للخدمات الرقمية</span>
                </div>
            </div>
            
            <div class="d-flex align-items-center gap-3 mt-3 mt-md-0">
                <div class="dropdown">
                    <button class="btn btn-light position-relative border-0 d-flex align-items-center justify-content-center" type="button" id="notifDropdown" data-bs-toggle="dropdown" style="width: 50px; height: 50px; border-radius: 14px; background: rgba(0,0,0,0.03);">
                        <i class="fa-solid fa-bell text-primary fs-5"></i>
                        <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none shadow-sm" style="font-size: 0.7rem; border: 2px solid white;">0</span>
                    </button>
                    <ul class="dropdown-menu shadow-lg p-0" aria-labelledby="notifDropdown" style="width: 350px; max-width: 90vw; right: auto; left: 0;">
                        <li class="p-3 fw-bold d-flex justify-content-between align-items-center border-bottom" style="background: var(--input-bg);">
                            <span style="color: var(--brand-primary);"><i class="fa-solid fa-bell me-2"></i> الإشعارات</span>
                            <button class="btn btn-sm btn-light py-1 px-3 fw-bold rounded-pill" onclick="markAllRead()" style="font-size: 0.75rem;">تحديد كمقروء</button>
                        </li>
                        <div id="notifList" style="max-height: 350px; overflow-y: auto; background: var(--card-bg);">
                            <li class="p-4 text-center text-muted fw-bold">لا توجد إشعارات</li>
                        </div>
                    </ul>
                </div>
                <div class="px-3 py-2 rounded-pill fw-bold small" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2);">
                    <i class="fa-solid fa-database me-2"></i> النظام متصل
                </div>
            </div>
        </div>

        <!-- إحصائيات اليوم (للهواتف فقط) -->
        <div class="d-block d-lg-none mb-5 mt-4">
            <h5 class="fw-bold mb-3" style="color: var(--text-main);"><i class="fa-solid fa-calendar-day me-2 text-primary"></i> إحصائيات اليوم</h5>
            <div class="row g-3">
                <div class="col-6">
                    <div class="d-flex flex-column align-items-center justify-content-center rounded-4 data-card m-0 p-3 text-center" style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); min-height: 120px;">
                        <i class="fa-solid fa-check-circle fs-3 mb-2" style="color: #10b981;"></i>
                        <div class="small fw-bold text-muted mb-1">مكتملة</div>
                        <h4 class="fw-bold m-0" style="color: #10b981;"><%= typeof todayCompleted !== 'undefined' ? todayCompleted : 0 %></h4>
                    </div>
                </div>
                <div class="col-6">
                    <div class="d-flex flex-column align-items-center justify-content-center rounded-4 data-card m-0 p-3 text-center" style="background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); min-height: 120px;">
                        <i class="fa-solid fa-hourglass-half fs-3 mb-2" style="color: #f59e0b;"></i>
                        <div class="small fw-bold text-muted mb-1">معلقة</div>
                        <h4 class="fw-bold m-0" style="color: #f59e0b;"><%= typeof todayPending !== 'undefined' ? todayPending : 0 %></h4>
                    </div>
                </div>
                <div class="col-6">
                    <div class="d-flex flex-column align-items-center justify-content-center rounded-4 data-card m-0 p-3 text-center" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); min-height: 120px;">
                        <i class="fa-solid fa-ban fs-3 mb-2" style="color: #ef4444;"></i>
                        <div class="small fw-bold text-muted mb-1">ملغية</div>
                        <h4 class="fw-bold m-0" style="color: #ef4444;"><%= typeof todayCancelled !== 'undefined' ? todayCancelled : 0 %></h4>
                    </div>
                </div>
                <div class="col-6">
                    <div class="d-flex flex-column align-items-center justify-content-center rounded-4 data-card m-0 p-3 text-center" style="background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.2); min-height: 120px;">
                        <i class="fa-solid fa-list-ol fs-3 mb-2" style="color: #3b82f6;"></i>
                        <div class="small fw-bold text-muted mb-1">إجمالي الحركات</div>
                        <h4 class="fw-bold m-0" style="color: #3b82f6;"><%= typeof todayTotal !== 'undefined' ? todayTotal : 0 %></h4>
                    </div>
                </div>
                <div class="col-12 mt-4">
                    <div class="d-flex flex-column justify-content-center rounded-4 data-card m-0 p-4 text-center" style="background: linear-gradient(135deg, var(--card-bg) 0%, rgba(212, 175, 55, 0.05) 100%); border: 1px solid rgba(212, 175, 55, 0.3);">
                        <h6 class="fw-bold text-muted mb-4"><i class="fa-solid fa-money-bill-wave me-2" style="color: var(--brand-gold);"></i> المبالغ المكتملة اليوم</h6>
                        <div class="d-flex justify-content-around w-100 align-items-center">
                            <div class="text-center" style="flex: 1;">
                                <div class="small fw-bold mb-2" style="color: var(--text-muted);">جنيه مصري</div>
                                <h3 class="fw-bold m-0" style="color: var(--text-main);"><%= typeof todayEGP !== 'undefined' ? todayEGP.toLocaleString() : 0 %> <span style="font-size: 0.8rem; color: var(--text-muted); font-family: 'JetBrains Mono', monospace;">EGP</span></h3>
                            </div>
                            <div style="height: 40px; border-left: 2px solid rgba(212, 175, 55, 0.2);"></div>
                            <div class="text-center" style="flex: 1;">
                                <div class="small fw-bold mb-2" style="color: var(--text-muted);">دينار ليبي</div>
                                <h3 class="fw-bold m-0" style="color: var(--text-main);"><%= typeof todayLYD !== 'undefined' ? todayLYD.toLocaleString() : 0 %> <span style="font-size: 0.8rem; color: var(--text-muted); font-family: 'JetBrains Mono', monospace;">LYD</span></h3>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- الرسم البياني للهاتف -->
                <div class="col-12 mt-4">
                    <div class="data-card p-3 rounded-4 border-0 text-center" style="box-shadow: var(--shadow-soft);">
                        <h6 class="fw-bold mb-3" style="color: var(--text-main);"><i class="fa-solid fa-chart-pie text-primary me-2"></i> توزيع حالات اليوم</h6>
                        <div style="height: 250px; width: 100%; position: relative;">
                            <canvas id="mobileTodayChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <h4 class="fw-bold mb-4 mt-5 d-none d-lg-block" style="color: var(--text-main);"><i class="fa-solid fa-chart-pie me-2 text-primary"></i> الإحصائيات الحية للمنصة</h4>

        <div class="row g-4 mb-5 d-none d-lg-flex">
            <div class="col-xl-4 col-md-6">
                <a href="/clients" class="text-decoration-none hover-card">
                    <div class="stat-card stat-users data-card m-0">
                        <div class="card-icon"><i class="fa-solid fa-user"></i></div>
                        <div>
                            <div class="stat-title text-muted">العملاء الأفراد</div>
                            <div class="stat-val text-dark"><%= typeof usersCount !== 'undefined' ? usersCount : 0 %></div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-xl-4 col-md-6">
                <a href="/clients" class="text-decoration-none hover-card">
                    <div class="stat-card stat-companies data-card m-0">
                        <div class="card-icon"><i class="fa-solid fa-building"></i></div>
                        <div>
                            <div class="stat-title text-muted">الشركات والوكلاء</div>
                            <div class="stat-val text-dark"><%= typeof companiesCount !== 'undefined' ? companiesCount : 0 %></div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-xl-4 col-md-6">
                <a href="/employees" class="text-decoration-none hover-card">
                    <div class="stat-card stat-execs data-card m-0">
                        <div class="card-icon"><i class="fa-solid fa-user-gear"></i></div>
                        <div>
                            <div class="stat-title text-muted">طاقم المنفذين</div>
                            <div class="stat-val text-dark"><%= typeof executorsCount !== 'undefined' ? executorsCount : 0 %></div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-xl-4 col-md-6">
                <a href="/transactions?status=pending" class="text-decoration-none hover-card">
                    <div class="stat-card stat-pending data-card m-0">
                        <div class="card-icon"><i class="fa-solid fa-hourglass-half"></i></div>
                        <div>
                            <div class="stat-title text-muted">عمليات معلقة</div>
                            <div class="stat-val text-dark"><%= typeof pendingTxs !== 'undefined' ? pendingTxs : 0 %></div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-xl-4 col-md-6">
                <a href="/transactions?status=processing" class="text-decoration-none hover-card">
                    <div class="stat-card stat-processing data-card m-0">
                        <div class="card-icon"><i class="fa-solid fa-spinner fa-spin-pulse"></i></div>
                        <div>
                            <div class="stat-title text-muted">توجيه للمنفذين</div>
                            <div class="stat-val text-dark"><%= typeof processingTxs !== 'undefined' ? processingTxs : 0 %></div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-xl-4 col-md-6">
                <a href="/transactions?status=completed" class="text-decoration-none hover-card">
                    <div class="stat-card stat-completed data-card m-0">
                        <div class="card-icon"><i class="fa-solid fa-check-double"></i></div>
                        <div>
                            <div class="stat-title text-muted">عمليات مكتملة</div>
                            <div class="stat-val text-dark"><%= typeof completedTxs !== 'undefined' ? completedTxs : 0 %></div>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <div class="row d-none d-lg-flex">
            <div class="col-12">
                <div class="data-card p-4 rounded-4 border-0">
                    <h5 class="fw-bold mb-4" style="color: var(--text-main);"><i class="fa-solid fa-chart-line text-primary me-2"></i> مسار عمليات اليوم</h5>
                    <div style="height: 350px; width: 100%;">
                        <canvas id="transactionsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="user-time-widget data-card d-none d-lg-flex">
            <div class="d-flex align-items-center gap-3 w-100 border-bottom pb-3 mb-2" style="border-color: var(--border-glass) !important;">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; color: var(--brand-primary); background: rgba(0,26,77,0.1);">
                    <i class="fa-solid fa-user-shield fs-5"></i>
                </div>
                <div>
                    <small class="text-muted d-block fw-bold" style="font-size: 0.75rem;">متصل كـ</small>
                    <strong class="text-dark"><%= locals.adminName || 'مدير' %></strong>
                </div>
            </div>
            <div class="text-center w-100">
                <div id="realtime-clock" class="clock-display">--:--:--</div>
                <div id="realtime-date" class="text-muted small fw-bold mt-1">--/--/----</div>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    function toggleSidebar() { document.querySelector('.sidebar').classList.toggle('active'); document.querySelector('.sidebar-overlay').classList.toggle('active'); }

    function updateRealTimeClock() {
        const now = new Date();
        const timeStr = now.toLocaleTimeString('en-US', { hour12: true, hour: '2-digit', minute: '2-digit', second: '2-digit' });
        const dateStr = now.toLocaleDateString('en-GB', { year: 'numeric', month: '2-digit', day: '2-digit' });
        if(document.getElementById('realtime-clock')) document.getElementById('realtime-clock').innerText = timeStr;
        if(document.getElementById('realtime-date')) document.getElementById('realtime-date').innerText = dateStr;
    }
    setInterval(updateRealTimeClock, 1000); updateRealTimeClock();

    // Notification logic moved to sidebar.ejs
    document.addEventListener("DOMContentLoaded", function() {
        const ctx = document.getElementById('transactionsChart').getContext('2d');
        const theme = localStorage.getItem('ahram_theme') || 'light';
        const chartColor = theme === 'dark' ? '#94a3b8' : '#64748b';
        Chart.defaults.color = chartColor;
        Chart.defaults.font.family = 'Tajawal';

        window.myChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['العمليات المعلقة', 'قيد التوجيه', 'العمليات المكتملة'],
                datasets: [{
                    label: 'العدد',
                    data: [Number('<%= typeof pendingTxs !== "undefined" ? pendingTxs : 0 %>'), Number('<%= typeof processingTxs !== "undefined" ? processingTxs : 0 %>'), Number('<%= typeof completedTxs !== "undefined" ? completedTxs : 0 %>')],
                    backgroundColor: ['#f59e0b', '#0ea5e9', '#10b981'],
                    borderWidth: 0, borderRadius: 12, barPercentage: 0.5
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1, font: { family: 'JetBrains Mono' } }, grid: { color: 'rgba(100,116,139,0.1)' } }, x: { grid: { display: false } } } }
        });

        // 📱 رسم بياني مخصص للهواتف (حالات اليوم)
        const mobileCtx = document.getElementById('mobileTodayChart').getContext('2d');
        window.mobileTodayChart = new Chart(mobileCtx, {
            type: 'doughnut',
            data: {
                labels: ['مكتملة', 'معلقة/قيد التنفيذ', 'ملغية'],
                datasets: [{
                    data: [
                        Number('<%= typeof todayCompleted !== "undefined" ? todayCompleted : 0 %>'),
                        Number('<%= typeof todayPending !== "undefined" ? todayPending : 0 %>') + Number('<%= typeof todayProcessing !== "undefined" ? todayProcessing : 0 %>'),
                        Number('<%= typeof todayCancelled !== "undefined" ? todayCancelled : 0 %>')
                    ],
                    backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: { position: 'bottom', labels: { font: { family: 'Tajawal', size: 12 }, color: chartColor, padding: 20 } }
                }
            }
        });
    });
</script>
</body>
</html>