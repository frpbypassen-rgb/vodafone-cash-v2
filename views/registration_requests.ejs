<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>طلبات التسجيل | الأهرام</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.9);
            --glass-border: rgba(0, 0, 0, 0.08);
            --shadow-3d: 0 10px 30px rgba(0, 0, 0, 0.04);
            --text-main: #1e293b;
            --text-muted: #64748b;
            --input-bg: #f8fafc;
        }
        [data-theme="dark"] {
            --glass-bg: rgba(30, 41, 59, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
            --shadow-3d: 0 10px 30px rgba(0, 0, 0, 0.3);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --input-bg: rgba(0, 0, 0, 0.2);
        }

        /* ===================== Stat Cards ===================== */
        .stat-row { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 30px; }
        .stat-card {
            flex: 1; min-width: 180px; padding: 20px 22px; border-radius: 20px;
            background: var(--glass-bg); border: 1px solid var(--glass-border);
            box-shadow: var(--shadow-3d); position: relative; overflow: hidden;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .stat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.12); }
        .stat-card .stat-icon {
            width: 48px; height: 48px; border-radius: 14px; display: flex;
            align-items: center; justify-content: center; font-size: 1.3rem; color: #fff;
            box-shadow: 0 6px 14px rgba(0,0,0,0.15);
        }
        .stat-card .stat-number { font-family: 'JetBrains Mono', monospace; font-weight: 800; font-size: 1.8rem; }

        /* ===================== Tabs ===================== */
        .nav-pills { background: var(--glass-bg); padding: 8px; border-radius: 20px; border: 1px solid var(--glass-border); box-shadow: var(--shadow-3d); display: inline-flex; flex-wrap: wrap; }
        .nav-pills .nav-link { color: var(--text-muted); border-radius: 14px; font-weight: 800; transition: 0.3s; padding: 10px 20px; white-space: nowrap; }
        .nav-pills .nav-link.active { background-color: #001a4d; color: white !important; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0, 26, 77, 0.2); }
        [data-theme="dark"] .nav-pills .nav-link.active { background-color: #fbbf24; color: black !important; box-shadow: 0 5px 15px rgba(212, 175, 55, 0.2); }

        /* ===================== Request Cards ===================== */
        .req-card {
            background: var(--glass-bg); border-radius: 20px; padding: 24px;
            border: 1px solid var(--glass-border); box-shadow: var(--shadow-3d);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative; overflow: hidden;
        }
        .req-card:hover { transform: translateY(-6px); box-shadow: 0 16px 35px rgba(0,0,0,0.12); }
        [data-theme="dark"] .req-card:hover { box-shadow: 0 16px 35px rgba(0,0,0,0.4); }

        .req-card::before {
            content: ''; position: absolute; top: 0; right: 0; width: 5px; height: 100%;
            border-radius: 0 20px 20px 0;
        }
        .req-card.type-direct::before { background: linear-gradient(180deg, #3b82f6, #1e40af); }
        .req-card.type-company::before { background: linear-gradient(180deg, #8b5cf6, #6d28d9); }
        .req-card.type-new::before { background: linear-gradient(180deg, #10b981, #047857); }
        .req-card.type-agent::before { background: linear-gradient(180deg, #f59e0b, #b45309); }
        .req-card.type-executor::before { background: linear-gradient(180deg, #ef4444, #991b1b); }

        .req-avatar {
            width: 52px; height: 52px; border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; color: #fff; box-shadow: 0 6px 14px rgba(0,0,0,0.15);
        }
        .av-direct { background: linear-gradient(135deg, #3b82f6, #1e40af); }
        .av-company { background: linear-gradient(135deg, #8b5cf6, #6d28d9); }
        .av-new { background: linear-gradient(135deg, #10b981, #047857); }
        .av-agent { background: linear-gradient(135deg, #f59e0b, #b45309); }
        .av-executor { background: linear-gradient(135deg, #ef4444, #991b1b); }

        .info-line {
            display: flex; align-items: center; justify-content: space-between;
            padding: 8px 14px; border-radius: 12px; margin-bottom: 6px;
            background: var(--input-bg); border: 1px solid var(--glass-border);
        }
        .info-line .label { font-size: 0.82rem; color: var(--text-muted); font-weight: 700; }
        .info-line .value { font-weight: 800; font-size: 0.88rem; color: var(--text-main); direction: ltr; }

        .mono { font-family: 'JetBrains Mono', monospace; }

        .badge-status { padding: 6px 14px; border-radius: 30px; font-weight: 800; font-size: 0.78rem; }

        .btn-action {
            border: none; border-radius: 14px; padding: 10px 18px;
            font-weight: 800; transition: all 0.3s; cursor: pointer;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .btn-action:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(0,0,0,0.15); }
        .btn-approve { background: linear-gradient(135deg, #10b981, #047857); color: white; }
        .btn-reject { background: linear-gradient(135deg, #ef4444, #b91c1c); color: white; }
        .btn-detail { background: var(--input-bg); color: var(--text-main); border: 1px solid var(--glass-border); }

        .empty-state { text-align: center; padding: 60px 20px; }
        .empty-state i { font-size: 4rem; opacity: 0.15; margin-bottom: 16px; }

        /* ===================== Modal ===================== */
        .modal-content { background: var(--glass-bg) !important; border: 1px solid var(--glass-border) !important; border-radius: 20px; }
        .modal-header { border-bottom-color: var(--glass-border) !important; }
        .modal-footer { border-top-color: var(--glass-border) !important; }

        /* ===================== Time Badge ===================== */
        .time-badge { background: rgba(100,116,139,0.08); padding: 4px 10px; border-radius: 8px; font-size: 0.75rem; color: var(--text-muted); font-weight: 700; }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#001a4d">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Al-Ahram">
    <!-- End PWA Setup -->
</head>
<body>

<%- include('partials/sidebar', { activePage: 'registration_requests' }) %>

<div class="main-content">
    <div class="container-fluid">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
            <h3 class="fw-bold m-0" style="color: var(--text-main);"><i class="fa-solid fa-user-plus text-primary me-2"></i> طلبات التسجيل الجديدة</h3>
            <div class="d-flex align-items-center gap-2">
                <a href="/registration-requests?status=pending" class="btn btn-sm <%= status === 'pending' ? 'btn-warning' : 'btn-outline-secondary' %> rounded-pill fw-bold px-3">
                    <i class="fa-solid fa-clock me-1"></i> قيد الانتظار <span class="badge bg-dark rounded-pill ms-1"><%= counts.pending %></span>
                </a>
                <a href="/registration-requests?status=approved" class="btn btn-sm <%= status === 'approved' ? 'btn-success' : 'btn-outline-secondary' %> rounded-pill fw-bold px-3">
                    <i class="fa-solid fa-check me-1"></i> مقبول <span class="badge bg-dark rounded-pill ms-1"><%= counts.approved %></span>
                </a>
                <a href="/registration-requests?status=rejected" class="btn btn-sm <%= status === 'rejected' ? 'btn-danger' : 'btn-outline-secondary' %> rounded-pill fw-bold px-3">
                    <i class="fa-solid fa-times me-1"></i> مرفوض <span class="badge bg-dark rounded-pill ms-1"><%= counts.rejected %></span>
                </a>
                <a href="/registration-requests" class="btn btn-sm btn-outline-secondary rounded-pill fw-bold px-3">
                    <i class="fa-solid fa-list me-1"></i> الكل
                </a>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="stat-row">
            <div class="stat-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);"><i class="fa-solid fa-clock"></i></div>
                    <div>
                        <div class="stat-number" style="color: #f59e0b;"><%= counts.pending %></div>
                        <div class="small text-muted fw-bold">قيد الانتظار</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #047857);"><i class="fa-solid fa-check-double"></i></div>
                    <div>
                        <div class="stat-number" style="color: #10b981;"><%= counts.approved %></div>
                        <div class="small text-muted fw-bold">تمت الموافقة</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #ef4444, #b91c1c);"><i class="fa-solid fa-ban"></i></div>
                    <div>
                        <div class="stat-number" style="color: #ef4444;"><%= counts.rejected %></div>
                        <div class="small text-muted fw-bold">مرفوض</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #3b82f6, #1e40af);"><i class="fa-solid fa-users"></i></div>
                    <div>
                        <div class="stat-number" style="color: #3b82f6;"><%= counts.total %></div>
                        <div class="small text-muted fw-bold">إجمالي الطلبات</div>
                    </div>
                </div>
            </div>
        </div>

        <% if (requests.length === 0) { %>
            <div class="empty-state">
                <i class="fa-solid fa-inbox text-muted d-block"></i>
                <h5 class="text-muted fw-bold">لا توجد طلبات تسجيل <%= status ? (status === 'pending' ? 'قيد الانتظار' : status === 'approved' ? 'مقبولة' : 'مرفوضة') : '' %></h5>
                <p class="text-muted">ستظهر الطلبات هنا فور تقديمها من صفحة التسجيل</p>
            </div>
        <% } else { %>
            <div class="row g-4">
                <% requests.forEach(req => { 
                    const typeLabels = { direct: 'عميل مباشر', company: 'شركة', new: 'عميل جديد', agent: 'وكيل منطقة', executor: 'منفذ' };
                    const typeIcons = { direct: 'fa-user', company: 'fa-building', new: 'fa-user-plus', agent: 'fa-handshake', executor: 'fa-gears' };
                    const typeLabel = typeLabels[req.accountType] || req.accountType;
                    const typeIcon = typeIcons[req.accountType] || 'fa-user';
                    const displayName = req.fullName || req.companyName || 'بدون اسم';
                    const displayPhone = req.phone || req.companyPhone || '---';
                    const createdDate = new Date(req.createdAt);
                    const dateStr = createdDate.toLocaleDateString('ar-LY', { year: 'numeric', month: 'short', day: 'numeric' });
                    const timeStr = createdDate.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
                %>
                    <div class="col-xl-4 col-lg-6 col-md-6">
                        <div class="req-card type-<%= req.accountType %>">
                            <!-- Header -->
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="req-avatar av-<%= req.accountType %>">
                                        <i class="fa-solid <%= typeIcon %>"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold m-0 text-truncate" style="max-width: 200px; color: var(--text-main);" title="<%= displayName %>"><%= displayName %></h6>
                                        <span class="badge rounded-pill px-2 py-1 mt-1" style="font-size: 0.72rem; background: rgba(100,116,139,0.1); color: var(--text-muted); border: 1px solid var(--glass-border);">
                                            <i class="fa-solid <%= typeIcon %> me-1"></i> <%= typeLabel %>
                                        </span>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <% if (req.status === 'pending') { %>
                                        <span class="badge-status" style="background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3);"><i class="fa-solid fa-clock me-1"></i>قيد الانتظار</span>
                                    <% } else if (req.status === 'approved') { %>
                                        <span class="badge-status" style="background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.3);"><i class="fa-solid fa-check me-1"></i>مقبول</span>
                                    <% } else { %>
                                        <span class="badge-status" style="background: rgba(239,68,68,0.12); color: #ef4444; border: 1px solid rgba(239,68,68,0.3);"><i class="fa-solid fa-times me-1"></i>مرفوض</span>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Info Lines -->
                            <div class="info-line">
                                <span class="label"><i class="fa-solid fa-hashtag me-1"></i> رقم الطلب</span>
                                <span class="value mono"><%= req.refCode %></span>
                            </div>
                            <div class="info-line">
                                <span class="label"><i class="fa-solid fa-phone me-1"></i> الهاتف</span>
                                <span class="value mono"><%= displayPhone %></span>
                            </div>
                            <% if (req.username) { %>
                            <div class="info-line">
                                <span class="label"><i class="fa-solid fa-at me-1"></i> المستخدم</span>
                                <span class="value mono" style="font-size: 0.8rem;"><%= req.username %></span>
                            </div>
                            <% } %>
                            <% if (req.companyEmail) { %>
                            <div class="info-line">
                                <span class="label"><i class="fa-solid fa-envelope me-1"></i> البريد</span>
                                <span class="value" style="font-size: 0.8rem;"><%= req.companyEmail %></span>
                            </div>
                            <% } %>
                            <% if (req.address || req.city) { %>
                            <div class="info-line">
                                <span class="label"><i class="fa-solid fa-location-dot me-1"></i> الموقع</span>
                                <span class="value"><%= req.address || req.city %></span>
                            </div>
                            <% } %>
                            <% if (req.storeName) { %>
                            <div class="info-line">
                                <span class="label"><i class="fa-solid fa-store me-1"></i> المتجر</span>
                                <span class="value"><%= req.storeName %></span>
                            </div>
                            <% } %>
                            <% if (req.agentCode) { %>
                            <div class="info-line">
                                <span class="label"><i class="fa-solid fa-key me-1"></i> رمز الوكيل</span>
                                <span class="value mono text-warning fw-bold"><%= req.agentCode %></span>
                            </div>
                            <% } %>

                            <div class="d-flex align-items-center justify-content-between mt-3">
                                <span class="time-badge"><i class="fa-regular fa-clock me-1"></i> <%= dateStr %> — <%= timeStr %></span>
                            </div>

                            <!-- Actions -->
                            <% if (req.status === 'pending') { %>
                            <div class="d-flex gap-2 mt-3">
                                <form action="/registration-requests/<%= req._id %>/approve" method="POST" class="flex-fill" onsubmit="return confirm('هل تريد الموافقة على هذا الطلب وإنشاء الحساب؟');">
                                    <button type="submit" class="btn-action btn-approve w-100"><i class="fa-solid fa-check-double"></i> قبول وتفعيل</button>
                                </form>
                                <form action="/registration-requests/<%= req._id %>/reject" method="POST" class="flex-fill" onsubmit="return confirm('هل تريد رفض هذا الطلب؟');">
                                    <button type="submit" class="btn-action btn-reject w-100"><i class="fa-solid fa-ban"></i> رفض</button>
                                </form>
                            </div>
                            <% } else if (req.reviewedBy) { %>
                            <div class="mt-3 text-muted small fw-bold">
                                <i class="fa-solid fa-user-check me-1"></i> تمت المراجعة بواسطة: <strong><%= req.reviewedBy %></strong>
                                <% if (req.reviewedAt) { %>
                                    — <%= new Date(req.reviewedAt).toLocaleDateString('ar-LY') %>
                                <% } %>
                            </div>
                            <% } %>

                            <% if (req.adminNotes) { %>
                            <div class="mt-2 p-2 rounded-3 small fw-bold" style="background: rgba(239,68,68,0.06); border: 1px dashed rgba(239,68,68,0.2); color: #ef4444;">
                                <i class="fa-solid fa-note-sticky me-1"></i> <%= req.adminNotes %>
                            </div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

    </div>
</div>

<script>
    function toggleSidebar() { 
        document.querySelector('.sidebar').classList.toggle('active');
        document.querySelector('.sidebar-overlay').classList.toggle('active'); 
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
