<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>إعدادات الردود | الأهرام</title>
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <style>
        .settings-nav { background: var(--input-bg); border-radius: 16px; padding: 10px; border: 1px solid var(--border-glass); margin-bottom: 25px; overflow-x: auto; white-space: nowrap;}
        .settings-nav .nav-link { color: var(--text-muted); font-weight: 700; border-radius: 12px; padding: 12px 20px; transition: 0.3s; margin: 0 4px; font-size: 0.9rem;}
        .settings-nav .nav-link:hover { background: var(--card-bg); color: var(--text-main); }
        .settings-nav .nav-link.active { background: var(--brand-primary); color: white !important; box-shadow: 0 4px 15px rgba(0, 26, 77, 0.2); }
        [data-theme="dark"] .settings-nav .nav-link.active { background: var(--brand-gold); color: black !important; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .min-w-fit { min-width: fit-content; }
    </style>
</head>
<body>

<button class="mobile-nav-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<%- include('partials/sidebar', { activePage: 'settings_content' }) %>

<div class="main-content">
    <div class="container-fluid">
        <div class="admin-nav mb-4">
            <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-gears text-primary me-2"></i> لوحة تحكم الإعدادات الشاملة</h3>
        </div>

        <ul class="nav nav-pills settings-nav d-flex flex-nowrap hide-scrollbar">
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings"><i class="fa-solid fa-sliders me-1"></i> العامة والأسعار</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link active text-nowrap" href="/settings/content"><i class="fa-solid fa-comment-dots me-1"></i> رسائل البوت</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/bots"><i class="fa-solid fa-robot me-1"></i> إدارة البوتات</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/excel"><i class="fa-solid fa-file-excel me-1"></i> محرر الإكسيل</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/clients-web"><i class="fa-solid fa-globe me-1"></i> ويب العملاء</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/executors-web"><i class="fa-solid fa-laptop-code me-1"></i> ويب المنفذين</a></li>
            <% if (typeof role !== 'undefined' && role === 'master') { %>
            <li class="nav-item text-center min-w-fit ms-auto"><a class="nav-link text-danger text-nowrap" href="/settings/users"><i class="fa-solid fa-user-shield me-1"></i> المديرين</a></li>
            <% } %>
        </ul>

        <div class="row justify-content-center">
            <div class="col-xl-9">
                <form action="/settings/content/update" method="POST">
                    
                    <div class="data-card border-start border-4 border-primary mb-4 p-4">
                        <h5 class="fw-bold text-primary mb-4"><i class="fa-solid fa-users me-2"></i> رسائل بوتات العملاء (البوت الرئيسي والوكلاء)</h5>
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">رسالة الترحيب (Welcome Message)</label>
                            <textarea name="welcomeMessage" class="form-control fw-bold p-3" rows="3" required><%= settings.welcomeMessage %></textarea>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">رسالة الشروط والتنبيهات (Terms)</label>
                            <textarea name="termsMessage" class="form-control fw-bold p-3" rows="3" required><%= settings.termsMessage %></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">رسالة الإغلاق (خارج أوقات العمل)</label>
                            <textarea name="closedMessage" class="form-control fw-bold p-3" rows="3" required><%= settings.closedMessage %></textarea>
                        </div>
                    </div>

                    <div class="data-card border-start border-4 border-info mb-4 p-4">
                        <h5 class="fw-bold text-info mb-4"><i class="fa-solid fa-robot me-2"></i> رسائل بوتات التنفيذ (طواقم الكاشير)</h5>
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">رسالة الترحيب للموظفين (Welcome)</label>
                            <textarea name="executorWelcomeMessage" class="form-control fw-bold p-3" rows="3" required><%= settings.executorWelcomeMessage %></textarea>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">رسالة انتظار المراجعة (للموظف الجديد)</label>
                            <textarea name="executorPendingMessage" class="form-control fw-bold p-3" rows="2" required><%= settings.executorPendingMessage %></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">رسالة الحظر (للموظف الموقوف)</label>
                            <textarea name="executorBannedMessage" class="form-control fw-bold p-3" rows="2" required><%= settings.executorBannedMessage %></textarea>
                        </div>
                    </div>

                    <div class="text-end mb-5">
                        <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold shadow-sm rounded-pill"><i class="fa-solid fa-save me-2"></i> حفظ التعديلات والردود</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>function toggleSidebar() { document.querySelector('.sidebar').classList.toggle('active'); document.querySelector('.sidebar-overlay').classList.toggle('active'); }</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>