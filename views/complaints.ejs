<!DOCTYPE html>
<html lang="ar" dir="rtl" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>الشكاوي والإنذارات - الأهرام باي</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        html, body { max-width: 100%; overflow-x: hidden; }
        body { font-family: 'Cairo', sans-serif; background-color: var(--bg-body); color: var(--text-main); transition: 0.3s; }
        .main-content { margin-right: 260px; padding: 20px; transition: 0.3s; overflow-x: hidden; }

        .complaints-page,
        .complaints-page * {
            box-sizing: border-box;
        }

        .complaints-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 16px;
        }

        .complaints-title {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .complaints-title-icon {
            width: 50px;
            height: 50px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            background: linear-gradient(135deg, #ef4444, #f59e0b);
            box-shadow: 0 14px 28px rgba(239, 68, 68, 0.24);
            flex: 0 0 50px;
        }

        .complaints-title h4 {
            line-height: 1.25;
        }

        .complaints-total-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 14px;
            border-radius: 999px;
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            color: var(--text-main);
            font-weight: 800;
            box-shadow: var(--shadow-soft);
            white-space: nowrap;
        }

        .complaints-metrics {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 10px;
            margin-bottom: 18px;
        }

        .complaints-metric {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            padding: 12px 14px;
            min-width: 0;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.04);
        }

        .complaints-metric span {
            color: var(--text-muted);
            font-size: 0.82rem;
            font-weight: 800;
        }

        .complaints-metric strong {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.1rem;
        }

        .metric-total { border-right: 4px solid #ef4444; }
        .metric-alerts { border-right: 4px solid #f59e0b; }
        .metric-open { border-right: 4px solid #3b82f6; }
        .metric-proof { border-right: 4px solid #10b981; }
        
        /* 💎 تصميم البطاقات الاحترافية المنسقة */
        .complaint-card {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 20px;
            padding: 24px;
            box-shadow: var(--shadow-soft);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 16px;
            height: 100%;
        }
        
        .complaint-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #ef4444, #fbbf24);
        }
        
        .complaint-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg), 0 10px 20px rgba(0, 0, 0, 0.05);
            border-color: rgba(239, 68, 68, 0.25);
        }

        .card-header-custom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px dashed var(--border-glass);
            padding-bottom: 12px;
            margin-bottom: 4px;
            gap: 10px;
        }

        .complaint-alert-box {
            background: rgba(239, 68, 68, 0.04);
            border-right: 4px solid #ef4444;
            border-radius: 12px;
            padding: 14px;
            color: var(--text-main);
            font-size: 0.95rem;
            line-height: 1.6;
        }
        [data-theme="dark"] .complaint-alert-box {
            background: rgba(239, 68, 68, 0.08);
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px dashed var(--border-glass);
            font-size: 0.9rem;
        }
        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            color: var(--text-muted);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            min-width: 0;
        }
        .detail-value {
            color: var(--text-main);
            font-weight: 700;
            min-width: 0;
            text-align: left;
            overflow-wrap: anywhere;
        }

        .proof-thumbnail-container {
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid var(--border-glass);
            position: relative;
            height: 130px;
            background: var(--input-bg);
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .proof-thumbnail-container:hover {
            transform: scale(1.02);
            filter: brightness(0.9);
        }

        .btn-card-action {
            width: 100%;
            background: linear-gradient(135deg, #ef4444, #c53030);
            color: white !important;
            font-weight: 700;
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-card-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(239, 68, 68, 0.35);
            filter: brightness(1.05);
        }
        .btn-card-action:active {
            transform: translateY(0);
        }

        .mono-num {
            font-family: 'JetBrains Mono', monospace;
        }

        .complaints-empty {
            max-width: 520px;
            margin: 54px auto 0;
            padding: 42px 22px;
            border-radius: 22px;
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            box-shadow: var(--shadow-soft);
        }

        .complaints-empty-icon {
            width: 58px;
            height: 58px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 14px;
            color: #10b981;
            background: rgba(16, 185, 129, 0.12);
            border: 1px solid rgba(16, 185, 129, 0.24);
            font-size: 1.45rem;
        }

        @media (max-width: 991px) {
            body .main-content {
                width: 100%;
                max-width: 100vw;
                min-width: 0;
                margin-right: 0 !important;
                padding: 85px 14px 100px 14px !important;
                overflow-x: hidden;
            }

            body .top-nav-admin-mobile {
                inset-inline: 0 !important;
                width: auto;
                max-width: 100vw;
                overflow: hidden;
                box-sizing: border-box;
            }

            body .top-nav-admin-mobile > .d-flex:first-child {
                min-width: 0;
                max-width: calc(100vw - 138px);
                flex: 1 1 auto;
                overflow: hidden;
            }

            .complaints-page {
                width: 100%;
                max-width: 100%;
                min-width: 0;
                padding-inline: 0 !important;
                overflow-x: hidden;
            }

            .complaints-header,
            .complaints-metrics,
            #complaintsContainer,
            .complaint-card {
                width: 100%;
                max-width: 100%;
                min-width: 0;
            }
        }

        @media (max-width: 768px) {
            .complaints-header {
                align-items: stretch;
                flex-direction: column;
                gap: 10px;
                margin-bottom: 12px;
            }

            .complaints-title {
                width: 100%;
                gap: 10px;
            }

            .complaints-title-icon {
                width: 42px;
                height: 42px;
                border-radius: 14px;
                flex-basis: 42px;
            }

            .complaints-title h4 {
                font-size: 1.08rem;
                margin: 0;
                overflow-wrap: anywhere;
            }

            .complaints-total-pill {
                width: 100%;
                justify-content: center;
                padding: 9px 12px;
                font-size: 0.92rem;
            }

            .complaints-metrics {
                grid-template-columns: repeat(2, minmax(0, 1fr));
                gap: 8px;
                margin-bottom: 12px;
            }

            .complaints-metric {
                padding: 10px 11px;
                border-radius: 14px;
            }

            .complaints-metric span {
                font-size: 0.76rem;
            }

            .complaints-metric strong {
                font-size: 1rem;
            }

            #complaintsContainer {
                --bs-gutter-x: 0;
                --bs-gutter-y: 12px;
                margin-top: 0 !important;
                padding-bottom: 84px;
            }

            .complaint-card {
                padding: 15px;
                border-radius: 18px;
                gap: 12px;
                box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
            }

            [data-theme="dark"] .complaint-card {
                box-shadow: 0 10px 24px rgba(0, 0, 0, 0.32);
            }

            .complaint-card:hover {
                transform: none;
            }

            .card-header-custom {
                padding-bottom: 10px;
                align-items: flex-start;
            }

            .card-header-custom .badge {
                white-space: normal;
                text-align: center;
                line-height: 1.25;
                padding: 6px 10px !important;
            }

            .card-header-custom h5 {
                font-size: 0.95rem;
                white-space: nowrap;
            }

            .complaint-alert-box {
                padding: 12px;
                border-radius: 14px;
                font-size: 0.86rem;
            }

            .complaint-alert-box .fw-bold:last-child {
                font-size: 0.88rem !important;
                line-height: 1.65;
            }

            .detail-row {
                align-items: flex-start;
                padding: 9px 0;
                font-size: 0.82rem;
            }

            .detail-label {
                flex: 1 1 48%;
                line-height: 1.45;
            }

            .detail-value {
                flex: 1 1 52%;
                text-align: left;
                line-height: 1.45;
            }

            .proof-thumbnail-container {
                height: auto;
                aspect-ratio: 2.2 / 1;
                border-radius: 14px;
            }

            .actions-zone {
                order: 3;
                margin-top: 0 !important;
                padding-top: 10px !important;
            }

            .card-details-box {
                order: 4;
            }

            .proof-section,
            .no-proof-placeholder {
                order: 5;
            }

            .btn-card-action {
                min-height: 46px;
                border-radius: 14px;
                font-size: 0.88rem;
                padding: 10px;
            }

            .complaints-empty {
                margin-top: 22px;
                padding: 34px 16px;
                border-radius: 18px;
            }

            .complaints-empty h5 {
                font-size: 1rem;
            }
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#001a4d">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Al-Ahram">
</head>
<body>
    <%- include('partials/sidebar', { activePage: 'complaints' }) %>
    <%
        const complaintItems = complaints || [];
        const totalComplaints = complaintItems.length;
        const emergencyComplaints = complaintItems.filter(tx => tx.emergencyAlert && String(tx.emergencyAlert).trim()).length;
        const textComplaints = complaintItems.filter(tx => tx.complaintText && String(tx.complaintText).trim()).length;
        const proofComplaints = complaintItems.filter(tx => tx.proofImage || (tx.proofImages && tx.proofImages.length > 0)).length;
    %>

    <div class="main-content">
        <div class="container-fluid complaints-page">
        <div class="complaints-header">
            <div class="complaints-title">
                <div class="complaints-title-icon"><i class="fa-solid fa-flag"></i></div>
                <h4 class="fw-bold m-0">قسم الشكاوي والإنذارات الطارئة</h4>
            </div>
            <div class="complaints-total-pill">
                <i class="fa-solid fa-bell text-danger"></i>
                <span>المفتوحة</span>
                <strong class="mono-num"><%= totalComplaints %></strong>
            </div>
        </div>

        <div class="complaints-metrics">
            <div class="complaints-metric metric-total"><span>الإجمالي</span><strong><%= totalComplaints %></strong></div>
            <div class="complaints-metric metric-alerts"><span>إنذارات</span><strong><%= emergencyComplaints %></strong></div>
            <div class="complaints-metric metric-open"><span>شكاوى</span><strong><%= textComplaints %></strong></div>
            <div class="complaints-metric metric-proof"><span>بإيصال</span><strong><%= proofComplaints %></strong></div>
        </div>

        <div class="row g-4 mt-2" id="complaintsContainer">
            <% if (complaintItems.length > 0) { %>
                <% complaintItems.forEach(tx => { %>
                    <div class="col-12 col-md-6 col-xl-4" id="row_<%= tx._id %>">
                        <!-- Professional Complaint Card -->
                        <div class="complaint-card">
                            
                            <!-- Card Header -->
                            <div class="card-header-custom">
                                <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-1 rounded-pill small fw-bold"><i class="fa-solid fa-triangle-exclamation fa-fade me-1"></i> شكوى معلقة</span>
                                <h5 class="fw-bold m-0 text-primary mono-num">#<%= tx.customId || tx._id.toString().slice(-6) %></h5>
                            </div>
                            
                            <!-- Complaint Content Box -->
                            <div class="complaint-alert-box">
                                <div class="small fw-bold mb-1 opacity-75"><i class="fa-solid fa-comment-dots me-1"></i> نص الشكوى المستلمة:</div>
                                <div class="fw-bold" style="white-space: pre-wrap; font-size: 0.95rem;"><%= tx.complaintText || tx.emergencyAlert || 'شكوى غير محددة' %></div>
                            </div>
                            
                            <!-- Detailed Transaction Info -->
                            <div class="card-details-box flex-fill">
                                <div class="detail-row">
                                    <span class="detail-label"><i class="fa-solid fa-wallet text-muted"></i> رقم المستلم / الحساب:</span>
                                    <span class="detail-value text-info mono-num" dir="ltr"><%= tx.vodafoneNumber || tx.accountNumber || '---' %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label"><i class="fa-solid fa-money-bill-wave text-muted"></i> المبلغ المطلوب:</span>
                                    <span class="detail-value text-success mono-num"><%= tx.amount.toFixed(2) %> EGP</span>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label"><i class="fa-solid fa-percent text-muted"></i> سعر الصرف:</span>
                                    <span class="detail-value text-warning mono-num"><%= tx.exchangeRate ? Number(tx.exchangeRate).toFixed(2) : (tx.costLYD ? (tx.amount / tx.costLYD).toFixed(2) : '0.00') %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label"><i class="fa-solid fa-coins text-muted"></i> القيمة بالدينار:</span>
                                    <span class="detail-value text-danger mono-num"><%= tx.costLYD ? tx.costLYD.toFixed(2) : '0.00' %> LYD</span>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label"><i class="fa-solid fa-user text-muted"></i> العميل (الطالب):</span>
                                    <span class="detail-value text-opacity-90"><%= tx.companyName || tx.employeeName || 'غير معروف' %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label"><i class="fa-solid fa-robot text-muted"></i> المنفذ الموكل:</span>
                                    <span class="detail-value text-opacity-90"><%= tx.executorName || '---' %></span>
                                </div>
                                <div class="detail-row">
                                    <span class="detail-label"><i class="fa-regular fa-clock text-muted"></i> وقت الشكوى:</span>
                                    <span class="detail-value opacity-75 small" dir="ltr"><%= new Date(tx.updatedAt || tx.createdAt).toLocaleString('en-GB') %></span>
                                </div>
                            </div>
                            
                            <!-- Proof Image Section -->
                            <% if (tx.proofImage || (tx.proofImages && tx.proofImages.length > 0)) { %>
                                <% let imgUrl = `/proxy/image/${tx._id}/0`; %>
                                <div class="proof-section mt-1">
                                    <span class="d-block text-muted small fw-bold mb-2"><i class="fa-regular fa-image me-1"></i> إيصال الإثبات الحالي:</span>
                                    <div class="proof-thumbnail-container" onclick="viewProofImage('<%= imgUrl %>')">
                                        <img src="<%= imgUrl %>" style="width: 100%; height: 100%; object-fit: cover;">
                                        <div class="position-absolute top-50 start-50 translate-middle text-white bg-dark bg-opacity-50 p-2 rounded-circle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem;">
                                            <i class="fa-solid fa-magnifying-glass-plus"></i>
                                        </div>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="no-proof-placeholder text-center text-muted small py-3 border rounded-3 border-dashed" style="background: rgba(255,255,255,0.01);">
                                    <i class="fa-regular fa-image-slash d-block mb-1 fs-5 opacity-40"></i> لا يوجد إيصال مرفق حالياً
                                </div>
                            <% } %>
                            
                            <!-- Actions Zone -->
                            <div class="actions-zone mt-2 pt-2 border-top border-light border-opacity-10">
                                <button class="btn-card-action" onclick="showComplaintActions('<%= tx._id %>', <%= tx.amount %>, <%= tx.exchangeRate || (tx.costLYD ? (tx.amount / tx.costLYD) : 0) %>)">
                                    <i class="fa-solid fa-gears"></i> اتخاذ إجراء والحل
                                </button>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12 text-center py-5 text-muted fw-bold">
                    <div class="complaints-empty">
                        <div class="complaints-empty-icon"><i class="fa-solid fa-circle-check"></i></div>
                        <h5>لا توجد شكاوي حالياً 🎉</h5>
                        <p class="m-0 text-muted small">كل شيء هادئ والعملاء سعداء!</p>
                    </div>
                </div>
            <% } %>
        </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('active');
            document.querySelector('.sidebar-overlay').classList.toggle('active');
        }

        function viewProofImage(url) {
            Swal.fire({
                imageUrl: url,
                imageAlt: 'إيصال الإثبات للعملية',
                confirmButtonText: 'إغلاق',
                confirmButtonColor: '#3b82f6',
                width: '600px',
                customClass: { popup: 'rounded-4 border border-secondary' }
            });
        }

        async function showComplaintActions(txId, currentAmount, currentRate) {
            await Swal.fire({
                title: '⚙️ إجراءات الشكوى والتحكم',
                html: `
                    <div class="d-flex flex-column gap-2 text-center mt-3">
                        <button onclick="triggerEditAmount('${txId}', ${currentAmount})" class="btn btn-warning fw-bold py-2"><i class="fa-solid fa-pen-to-square"></i> تعديل المبلغ المطلوب</button>
                        <button onclick="triggerEditRate('${txId}', ${currentRate})" class="btn btn-primary fw-bold py-2"><i class="fa-solid fa-percent"></i> تعديل سعر الصرف</button>
                        <button onclick="triggerUploadProof('${txId}')" class="btn btn-info text-white fw-bold py-2"><i class="fa-solid fa-cloud-arrow-up"></i> إرفاق صورة إثبات جديدة</button>
                        <button onclick="triggerResolveComplaint('${txId}')" class="btn btn-success fw-bold py-2"><i class="fa-solid fa-circle-check"></i> تم حل المشكلة (مع السبب)</button>
                        <button onclick="triggerCancelTransaction('${txId}')" class="btn btn-danger fw-bold py-2"><i class="fa-solid fa-circle-xmark"></i> إلغاء العملية (مع السبب)</button>
                    </div>
                `,
                showConfirmButton: false,
                showCancelButton: true,
                cancelButtonText: 'إغلاق',
                customClass: { popup: 'rounded-4' }
            });
        }

        async function triggerEditAmount(txId, currentAmount) {
            Swal.close();
            const { value: formValues } = await Swal.fire({
                title: 'تعديل المبلغ المطلوب',
                html: `
                    <div class="mb-3 text-start">
                        <label class="form-label fw-bold">المبلغ الجديد (EGP)</label>
                        <input id="new-amount-val" type="number" class="form-control text-center fw-bold fs-5" value="${currentAmount}">
                    </div>
                    <div class="text-start">
                        <label class="form-label fw-bold">السبب لتعديل القيمة</label>
                        <textarea id="edit-amount-reason" class="form-control" placeholder="اكتب سبب تعديل المبلغ..." rows="2"></textarea>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'تأكيد التعديل',
                cancelButtonText: 'تراجع',
                preConfirm: () => {
                    const amt = parseFloat(document.getElementById('new-amount-val').value);
                    const reason = document.getElementById('edit-amount-reason').value.trim();
                    if (!amt || amt <= 0) {
                        Swal.showValidationMessage('يرجى إدخال مبلغ صالح!');
                        return false;
                    }
                    return { newAmount: amt, reason };
                }
            });

            if (formValues) {
                Swal.fire({ title: 'جاري الحفظ وتحديث الحسابات...', didOpen: () => Swal.showLoading() });
                try {
                    const res = await fetch(`/api/complaints/${txId}/edit-amount`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formValues)
                    });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire('تم التعديل', 'تم تعديل مبلغ العملية بنجاح وتحديث أرصدة الحسابات.', 'success').then(() => location.reload());
                    } else {
                        Swal.fire('خطأ', data.error || 'فشل تعديل المبلغ', 'error');
                    }
                } catch(e) {
                    Swal.fire('خطأ', 'حدث خطأ في الاتصال بالسيرفر', 'error');
                }
            }
        }

        async function triggerEditRate(txId, currentRate) {
            Swal.close();
            const { value: formValues } = await Swal.fire({
                title: 'تعديل سعر الصرف',
                html: `
                    <div class="mb-3 text-start">
                        <label class="form-label fw-bold">سعر الصرف الجديد</label>
                        <input id="new-rate-val" type="number" step="0.001" class="form-control text-center fw-bold fs-5" value="${currentRate}">
                    </div>
                    <div class="text-start">
                        <label class="form-label fw-bold">السبب للتعديل</label>
                        <textarea id="edit-rate-reason" class="form-control" placeholder="اكتب سبب تعديل سعر الصرف..." rows="2"></textarea>
                    </div>
                `,
                showCancelButton: true,
                confirmButtonText: 'تأكيد التعديل',
                cancelButtonText: 'تراجع',
                preConfirm: () => {
                    const rate = parseFloat(document.getElementById('new-rate-val').value);
                    const reason = document.getElementById('edit-rate-reason').value.trim();
                    if (!rate || rate <= 0) {
                        Swal.showValidationMessage('يرجى إدخال سعر صرف صالح!');
                        return false;
                    }
                    return { newRate: rate, reason };
                }
            });

            if (formValues) {
                Swal.fire({ title: 'جاري الحفظ والتسوية...', didOpen: () => Swal.showLoading() });
                try {
                    const res = await fetch(`/api/complaints/${txId}/edit-rate`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formValues)
                    });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire('تم التعديل', 'تم تعديل سعر الصرف وتحديث أرصدة العملاء بنجاح.', 'success').then(() => location.reload());
                    } else {
                        Swal.fire('خطأ', data.error || 'فشل التعديل', 'error');
                    }
                } catch(e) {
                    Swal.fire('خطأ', 'حدث خطأ في الاتصال بالسيرفر', 'error');
                }
            }
        }

        async function triggerUploadProof(txId) {
            Swal.close();
            const { value: file } = await Swal.fire({
                title: 'إرفاق صورة إثبات جديدة',
                input: 'file',
                inputAttributes: {
                    'accept': 'image/*',
                    'aria-label': 'اختر صورة الإثبات الجديدة من جهازك'
                },
                showCancelButton: true,
                confirmButtonText: 'رفع وحفظ',
                cancelButtonText: 'تراجع'
            });

            if (file) {
                Swal.fire({ title: 'جاري ضغط ورفع الصورة...', didOpen: () => Swal.showLoading() });
                try {
                    const reader = new FileReader();
                    reader.onload = async function(e) {
                        const img = new Image();
                        img.onload = async function() {
                            const canvas = document.createElement('canvas'); 
                            const MAX_WIDTH = 1200; 
                            const MAX_HEIGHT = 1600;
                            let width = img.width; 
                            let height = img.height;
                            if (width > height) { 
                                if (width > MAX_WIDTH) { height *= MAX_WIDTH / width; width = MAX_WIDTH; } 
                            } else { 
                                if (height > MAX_HEIGHT) { width *= MAX_HEIGHT / height; height = MAX_HEIGHT; } 
                            }
                            canvas.width = width; 
                            canvas.height = height; 
                            const ctx = canvas.getContext('2d'); 
                            ctx.drawImage(img, 0, 0, width, height);
                            const base64 = canvas.toDataURL('image/jpeg', 0.6);

                            const res = await fetch(`/api/complaints/${txId}/upload-proof`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ imageBase64: base64 })
                            });
                            const data = await res.json();
                            if (data.success) {
                                Swal.fire('تم الرفع', 'تم إرفاق صورة الإثبات الجديدة بنجاح.', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('خطأ', data.error || 'فشل الرفع', 'error');
                            }
                        };
                        img.src = e.target.result;
                    };
                    reader.readAsDataURL(file);
                } catch (err) {
                    Swal.fire('خطأ', 'فشل معالجة الملف', 'error');
                }
            }
        }

        async function triggerResolveComplaint(txId) {
            Swal.close();
            const { value: reason } = await Swal.fire({
                title: 'تم حل المشكلة وتصفيتها',
                input: 'textarea',
                inputPlaceholder: 'اكتب تفاصيل أو سبب حل المشكلة بالتفصيل (سيتم تسجيله بملاحظات العملية)...',
                showCancelButton: true,
                confirmButtonText: 'تأكيد الحل والإغلاق',
                cancelButtonText: 'تراجع',
                inputValidator: (value) => {
                    if (!value) {
                        return 'يرجى إدخال تفاصيل أو سبب الحل!';
                    }
                }
            });

            if (reason) {
                Swal.fire({ title: 'جاري تسوية الشكوى...', didOpen: () => Swal.showLoading() });
                try {
                    const res = await fetch(`/api/complaints/${txId}/resolve`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ reason })
                    });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire('تم الحل بنجاح', 'تم إغلاق وحل الشكوى بنجاح وإزالتها من القائمة.', 'success').then(() => {
                            const row = document.getElementById('row_' + txId);
                            if (row) row.remove();
                            else location.reload();
                        });
                    } else {
                        Swal.fire('خطأ', data.error || 'فشل تسجيل الحل', 'error');
                    }
                } catch(e) {
                    Swal.fire('خطأ', 'حدث خطأ في الاتصال بالسيرفر', 'error');
                }
            }
        }

        async function triggerCancelTransaction(txId) {
            Swal.close();
            const { value: reason } = await Swal.fire({
                title: 'تأكيد إلغاء العملية وإرجاع الرصيد',
                text: 'سوف يتم إرجاع قيمة المعاملة بالكامل لحساب العميل وتعديل أرصدة الوكلاء!',
                input: 'textarea',
                inputPlaceholder: 'اكتب سبب الإلغاء (سيتم تسجيله في النظام)...',
                showCancelButton: true,
                confirmButtonText: 'تأكيد الإلغاء النهائي',
                confirmButtonColor: '#ef4444',
                cancelButtonText: 'تراجع',
                inputValidator: (value) => {
                    if (!value) {
                        return 'يرجى كتابة سبب الإلغاء!';
                    }
                }
            });

            if (reason) {
                Swal.fire({ title: 'جاري إلغاء العملية وإرجاع الأرصدة...', didOpen: () => Swal.showLoading() });
                try {
                    const res = await fetch(`/api/complaints/${txId}/cancel`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ reason })
                    });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire('تم إلغاء المعاملة', 'تمت تصفية المعاملة بنجاح وإرجاع الأرصدة إلى العميل.', 'success').then(() => {
                            const row = document.getElementById('row_' + txId);
                            if (row) row.remove();
                            else location.reload();
                        });
                    } else {
                        Swal.fire('خطأ', data.error || 'فشل إلغاء المعاملة', 'error');
                    }
                } catch(e) {
                    Swal.fire('خطأ', 'حدث خطأ في الاتصال بالسيرفر', 'error');
                }
            }
        }
    </script>
