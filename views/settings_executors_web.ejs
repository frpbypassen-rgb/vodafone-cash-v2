<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إدارة حسابات ويب المنفذين</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
    <style>
        .settings-nav { background: var(--input-bg); border-radius: 16px; padding: 10px; border: 1px solid var(--border-glass); margin-bottom: 25px; overflow-x: auto; white-space: nowrap;}
        .settings-nav .nav-link { color: var(--text-muted); font-weight: 700; border-radius: 12px; padding: 12px 20px; transition: 0.3s; margin: 0 4px; font-size: 0.9rem;}
        .settings-nav .nav-link:hover { background: var(--card-bg); color: var(--text-main); }
        .settings-nav .nav-link.active { background: var(--brand-primary); color: white !important; box-shadow: 0 4px 15px rgba(0, 26, 77, 0.2); }
        [data-theme="dark"] .settings-nav .nav-link.active { background: var(--brand-gold); color: black !important; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .min-w-fit { min-width: fit-content; }
        .mono-num { font-family: 'JetBrains Mono', monospace; font-size: 0.95rem;}
        .btn-action-sm { width: 35px; height: 35px; display: inline-flex; align-items: center; justify-content: center; border-radius: 10px; transition: 0.2s; border: none; }
    </style>
</head>
<body>

<button class="mobile-nav-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<%- include('partials/sidebar', { activePage: 'settings' }) %>

<div class="main-content">
    <div class="container-fluid">
        <div class="admin-nav mb-4">
            <h3 class="fw-bold text-dark m-0"><i class="fa-solid fa-gears text-primary me-2"></i> لوحة الإعدادات الشاملة</h3>
        </div>

        <ul class="nav nav-pills settings-nav d-flex flex-nowrap hide-scrollbar">
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings"><i class="fa-solid fa-sliders me-1"></i> العامة والأسعار</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/content"><i class="fa-solid fa-comment-dots me-1"></i> رسائل البوت</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/bots"><i class="fa-solid fa-robot me-1"></i> إدارة البوتات</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/excel"><i class="fa-solid fa-file-excel me-1"></i> تحرير الإكسيل</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link text-nowrap" href="/settings/clients-web"><i class="fa-solid fa-globe me-1"></i> ويب العملاء</a></li>
            <li class="nav-item text-center min-w-fit"><a class="nav-link active text-nowrap" href="/settings/executors-web"><i class="fa-solid fa-laptop-code me-1"></i> ويب المنفذين</a></li>
            <% if (typeof role !== 'undefined' && role === 'master') { %>
            <li class="nav-item text-center min-w-fit ms-auto"><a class="nav-link text-danger text-nowrap" href="/settings/users"><i class="fa-solid fa-user-shield me-1"></i> المديرين</a></li>
            <% } %>
        </ul>

        <% if (query.success) { %><div class="alert alert-success fw-bold border-0 shadow-sm rounded-4"><i class="fa-solid fa-check-circle me-2"></i> تم تنفيذ الإجراء بنجاح!</div><% } %>
        <% if (query.error) { %><div class="alert alert-danger fw-bold border-0 shadow-sm rounded-4"><i class="fa-solid fa-triangle-exclamation me-2"></i> حدث خطأ أثناء تنفيذ الإجراء.</div><% } %>

        <div class="row g-4">
            <div class="col-xl-4">
                <div class="data-card border-start border-danger border-4 p-4 h-100">
                    <h5 class="fw-bold text-danger mb-3"><i class="fa-solid fa-user-plus me-2"></i> تفعيل حساب ويب لمنفذ</h5>
                    <p class="text-muted small mb-4 opacity-75">امنح الموظف المنفذ اسم مستخدم وكلمة مرور ليدخل إلى لوحة التنفيذ (شاشة الكاشير).</p>
                    
                    <form action="/settings/executors-web/add" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">اختر الموظف (المنفذ)</label>
                            <select name="employeeId" class="form-select fw-bold" required>
                                <option value="" disabled selected>يرجى اختيار الموظف...</option>
                                <% employees.forEach(emp => { %>
                                    <option value="<%= emp._id %>"><%= emp.name %> (<%= emp.botId ? emp.botId.name : 'بدون بوت' %>)</option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">اسم المستخدم (للدخول)</label>
                            <input type="text" name="webUsername" class="form-control mono-num text-info" placeholder="cashier_1" dir="ltr" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">كلمة المرور (للدخول)</label>
                            <input type="text" name="webPassword" class="form-control mono-num text-danger" placeholder="أدخل كلمة مرور قوية" dir="ltr" required>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 fw-bold shadow-sm py-3 rounded-pill fs-5">
                            <i class="fa-solid fa-bolt me-1"></i> حفظ وتفعيل الحساب
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-xl-8">
                <div class="data-card border-start border-secondary border-4 p-0 overflow-hidden h-100">
                    <div class="p-4 border-bottom" style="background: var(--input-bg);">
                        <h5 class="fw-bold text-dark m-0"><i class="fa-solid fa-users-gear text-secondary me-2"></i> المنفذون الذين يمكنهم الدخول للويب</h5>
                    </div>
                    
                    <div class="table-responsive m-0 border-0">
                        <table class="table text-center align-middle mb-0 table-hover">
                            <thead class="table-light">
                                <tr><th>الموظف</th><th>البوت التابع له</th><th>بيانات الدخول</th><th>الإجراءات</th></tr>
                            </thead>
                            <tbody>
                                <% if(webExecutors.length === 0) { %>
                                    <tr><td colspan="4" class="py-5 text-muted fw-bold border-0 fs-5"><i class="fa-solid fa-laptop-code fs-1 d-block opacity-25 mb-3"></i> لا يوجد أي حسابات ويب مفعلة للمنفذين حالياً.</td></tr>
                                <% } %>

                                <% webExecutors.forEach(e => { %>
                                    <tr>
                                        <td><div class="fw-bold text-danger"><i class="fa-solid fa-user-astronaut me-1 opacity-50 small"></i> <%= e.name %></div></td>
                                        <td><span class="badge bg-secondary px-3 py-1 rounded-pill"><%= e.botId ? e.botId.name : '---' %></span></td>
                                        <td dir="ltr" style="font-size: 0.85rem;" class="mono-num text-start ps-4">
                                            <span class="text-muted small">U:</span> <b class="text-info"><%= e.webUsername %></b><br>
                                            <span class="text-muted small">P:</span> <code class="text-danger"><%= e.webPassword %></code>
                                        </td>
                                        <td>
                                            <div class="d-flex justify-content-center gap-2">
                                                <button class="btn btn-sm btn-warning shadow-sm btn-action-sm text-dark fw-bold" onclick="openEditModal('<%= e._id %>', '<%= e.webUsername %>', '<%= e.webPassword %>')" title="تعديل"><i class="fa-solid fa-pen"></i></button>

                                                <form action="/settings/executors-web/delete" method="POST" class="m-0" onsubmit="return confirm('هل أنت متأكد من سحب صلاحية الدخول من هذا المنفذ؟');">
                                                    <input type="hidden" name="employeeId" value="<%= e._id %>">
                                                    <button type="submit" class="btn btn-sm btn-danger shadow-sm btn-action-sm fw-bold"><i class="fa-solid fa-trash"></i></button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editWebAccountModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <form action="/settings/executors-web/edit" method="POST">
                <div class="modal-header border-0 pb-0 pt-4 px-4 position-relative">
                    <h5 class="modal-title fw-bold text-warning"><i class="fa-solid fa-pen-to-square me-2"></i> تعديل بيانات الدخول</h5>
                    <button type="button" class="btn-close position-absolute" data-bs-dismiss="modal" style="left: 20px; filter: invert(0.5);"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" name="employeeId" id="editAccountId">
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">اسم المستخدم (للدخول)</label>
                        <input type="text" name="webUsername" id="editWebUsername" class="form-control text-start fw-bold mono-num text-info" dir="ltr" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small">كلمة المرور (الجديدة)</label>
                        <input type="text" name="webPassword" id="editWebPassword" class="form-control text-start fw-bold mono-num text-danger" dir="ltr" required>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="submit" class="btn btn-warning w-100 fw-bold py-3 fs-5 rounded-3 text-dark">حفظ التحديثات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleSidebar() { 
        document.querySelector('.sidebar').classList.toggle('active'); 
        document.querySelector('.sidebar-overlay').classList.toggle('active');
    }

    function openEditModal(id, username, password) {
        document.getElementById('editAccountId').value = id;
        document.getElementById('editWebUsername').value = username;
        document.getElementById('editWebPassword').value = password;
        new bootstrap.Modal(document.getElementById('editWebAccountModal')).show();
    }
</script>
</body>
</html>