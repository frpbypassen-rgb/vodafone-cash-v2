<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل الدخول | الإدارة المركزية</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { background-color: #f4f6f9; font-family: 'Tajawal', sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin:0;}
        .login-card { border: none; border-radius: 12px; box-shadow: 0 8px 20px rgba(0,0,0,0.1); width: 100%; max-width: 400px; padding: 40px; border-top: 5px solid #002060; background: white; }
        .btn-custom { background-color: #002060; color: white; transition: 0.3s; border: none; }
        .btn-custom:hover { background-color: #dc3545; color: white; }
        .logo-text { color: #002060; font-weight: bold; }
    </style>
</head>
<body>
    <div class="login-card text-center">
        <h3 class="mb-3 logo-text"><i class="fa-solid fa-shield-halved"></i> الأهرام الرقمية</h3>
        <p class="text-muted mb-4">بوابة الإدارة المركزية الآمنة</p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger p-2 fw-bold small rounded-3 mb-4"><%= error %></div>
        <% } %>

        <form action="/login" method="POST">
            <div class="mb-3 text-start">
                <label class="form-label fw-bold">اسم المستخدم</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fa-solid fa-user"></i></span>
                    <input type="text" name="username" class="form-control" placeholder="أدخل اسم المستخدم" required dir="ltr">
                </div>
            </div>
            <div class="mb-4 text-start">
                <label class="form-label fw-bold">كلمة المرور</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="password" class="form-control" placeholder="أدخل كلمة المرور" required dir="ltr">
                </div>
            </div>
            <button type="submit" class="btn btn-custom w-100 fw-bold p-2 fs-5 rounded-3">دخول <i class="fa-solid fa-right-to-bracket ms-1"></i></button>
        </form>
    </div>
</body>
</html>