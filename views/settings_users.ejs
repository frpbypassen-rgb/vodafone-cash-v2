<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إدارة المستخدمين والصلاحيات | شركة الأهرام</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
</head>
<body>

<%- include('partials/sidebar', { activePage: 'settings_users' }) %>

<div class="main-content">
    <div class="container-fluid">
        <h3 class="fw-bold text-dark mb-4"><i class="fa-solid fa-user-shield text-primary me-2"></i> إدارة مستخدمي لوحة التحكم</h3>

        <div class="row">
            <!-- نموذج إضافة مدير جديد -->
            <div class="col-md-4">
                <div class="data-card shadow-sm border-0 border-top border-primary border-4">
                    <h5 class="fw-bold text-primary mb-3"><i class="fa-solid fa-user-plus me-2"></i> إضافة مدير جديد</h5>
                    <p class="text-muted small mb-4">قم بإنشاء حساب لمدير جديد لكي يتمكن من الدخول إلى لوحة التحكم وإدارة الطلبات.</p>
                    
                    <form action="/settings/users/add" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold small">اسم المدير (للعرض)</label>
                            <input type="text" name="name" class="form-control bg-light border-0" placeholder="مثال: المهندس أحمد" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">اسم المستخدم للموقع (Username)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-0"><i class="fa-solid fa-at text-muted"></i></span>
                                <input type="text" name="webUsername" class="form-control bg-light border-0" placeholder="ahmed_admin" required style="direction: ltr; text-align: left;">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold small">كلمة المرور (Password)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-0"><i class="fa-solid fa-lock text-muted"></i></span>
                                <input type="text" name="webPassword" class="form-control bg-light border-0" placeholder="12345678" required style="direction: ltr; text-align: left;">
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm py-2">
                            <i class="fa-solid fa-plus me-1"></i> إنشاء الحساب
                        </button>
                    </form>
                </div>
            </div>

            <!-- جدول عرض المديرين الحاليين -->
            <div class="col-md-8">
                <div class="data-card shadow-sm border-0">
                    <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-users-gear me-2 text-secondary"></i> المديرين المسجلين في الموقع</h5>
                    
                    <div class="table-responsive">
                        <table class="table text-center align-middle">
                            <thead class="table-light text-muted small">
                                <tr>
                                    <th>الاسم</th>
                                    <th>اسم المستخدم (Login)</th>
                                    <th>كلمة المرور</th>
                                    <th>تاريخ الإنشاء</th>
                                    <th>إجراء</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (webAdmins.length === 0) { %>
                                    <tr><td colspan="5" class="py-4 text-muted fw-bold">لا يوجد مديرين فرعيين مسجلين حتى الآن.</td></tr>
                                <% } %>
                                <% webAdmins.forEach(admin => { %>
                                <tr>
                                    <td class="fw-bold text-primary"><i class="fa-solid fa-user-tie me-1 text-muted"></i> <%= admin.name %></td>
                                    <td><code class="fs-6"><%= admin.webUsername %></code></td>
                                    <td><code class="fs-6 text-danger"><%= admin.webPassword %></code></td>
                                    <td class="small text-muted"><%= admin.createdAt.toLocaleDateString('en-GB') %></td>
                                    <td>
                                        <form action="/settings/users/delete/<%= admin._id %>" method="POST" class="mb-0" onsubmit="return confirm('هل أنت متأكد من حذف حساب هذا المدير؟ لن يتمكن من الدخول للموقع بعد الآن.')">
                                            <button type="submit" class="btn btn-sm btn-danger shadow-sm border-0 bg-opacity-10 text-danger" style="background-color: rgba(220,53,69,0.1);" title="حذف الحساب">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>