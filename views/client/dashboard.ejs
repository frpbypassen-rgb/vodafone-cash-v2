    <script id="transactionsData" type="application/json">
        <%- JSON.stringify(typeof transactions !== 'undefined' ? transactions : []) %>
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // 📡 Geolocation & Fetch Override for Security Audit
        const csrfToken = <%- JSON.stringify(typeof csrfToken !== 'undefined' ? csrfToken : '') %>;

        (function() {
            let lat = null, lng = null;
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(pos => {
                    lat = pos.coords.latitude;
                    lng = pos.coords.longitude;
                }, err => {
                    console.warn("GPS Error:", err.message);
                }, { enableHighAccuracy: true, timeout: 8000 });
            }
            const originalFetch = window.fetch;
            window.fetch = function(url, options) {
                options = options || {};
                options.headers = options.headers || {};
                const method = String(options.method || 'GET').toUpperCase();
                if (csrfToken && !['GET', 'HEAD', 'OPTIONS'].includes(method)) {
                    if (options.headers instanceof Headers) {
                        options.headers.set('x-csrf-token', csrfToken);
                    } else {
                        options.headers['x-csrf-token'] = csrfToken;
                    }
                }
                if (lat !== null && lng !== null) {
                    if (options.headers instanceof Headers) {
                        options.headers.set('X-Client-Latitude', lat);
                        options.headers.set('X-Client-Longitude', lng);
                    } else {
                        options.headers['X-Client-Latitude'] = lat;
                        options.headers['X-Client-Longitude'] = lng;
                    }
                }
                return originalFetch.call(this, url, options);
            };
        })();
        // 🪄 سحر الـ 3D لبطاقة الرصيد
        const walletCard = document.querySelector('.wallet-card');
        if (walletCard) {
            walletCard.addEventListener('mousemove', (e) => {
                const rect = walletCard.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                
                const rotateX = ((y - centerY) / centerY) * -10; 
                const rotateY = ((x - centerX) / centerX) * 10;
                
                walletCard.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
                walletCard.style.boxShadow = `${-rotateY}px ${rotateX}px 30px rgba(0,0,0,0.3)`;
            });

            walletCard.addEventListener('mouseleave', () => {
                walletCard.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
                walletCard.style.boxShadow = `0 20px 40px -10px rgba(0, 26, 77, 0.4)`;
                walletCard.style.transition = `transform 0.5s ease-out, box-shadow 0.5s ease-out`;
            });
            
            walletCard.addEventListener('mouseenter', () => {
                walletCard.style.transition = `none`; 
            });
        }

        let currentRate = parseFloat("<%= currentRate %>") || 1;
        let currentTransferType = '';
        const isSubAccount = <%= typeof isSubAccount !== 'undefined' ? isSubAccount : false %>;
        const isMaster = <%= typeof isMaster !== 'undefined' ? isMaster : false %>;

        function checkNetworkLogo() {
            const val = document.getElementById('tf_phone').value;
            const badgeDiv = document.getElementById('network_badge_div');
            const badge = document.getElementById('network_badge');
            if (currentTransferType !== 'كاش' || val.length < 3) {
                badgeDiv.style.display = 'none';
                badge.style.display = 'none !important';
                return;
            }
            let name = '', color = '', bg = '', icon = '';
            if (val.startsWith('010')) { name = 'فودافون'; color = '#fff'; bg = '#e60000'; icon = 'fa-solid fa-sim-card'; }
            else if (val.startsWith('011')) { name = 'اتصالات'; color = '#fff'; bg = '#2e7d32'; icon = 'fa-solid fa-signal'; }
            else if (val.startsWith('012')) { name = 'أورانج'; color = '#fff'; bg = '#ff6600'; icon = 'fa-solid fa-tower-cell'; }
            else if (val.startsWith('015')) { name = 'وي'; color = '#fff'; bg = '#6a1b9a'; icon = 'fa-solid fa-wifi'; }
            else { badgeDiv.style.display = 'none'; return; }

            badge.innerHTML = `<i class="${icon}"></i> ${name}`;
            badge.style.cssText = `background: ${bg}; color: ${color}; font-size: 1rem; display: inline-flex !important; padding: 8px 20px; border-radius: 50px; box-shadow: 0 4px 12px ${bg}55;`;
            badgeDiv.style.display = 'block';
        }

        function getServiceRate() {
            let rate = currentRate;
            if (currentTransferType === 'بريد حساب') rate = currentRate - 0.05;
            else if (currentTransferType === 'بريد بطاقة') rate = currentRate - 0.15;
            else if (currentTransferType === 'سيفا النيجر') rate = currentRate + 0.1;
            else if (currentTransferType === 'بنكك السودان') rate = currentRate + 0.2;
            return rate;
        }

        function updateServiceRateDisplay() {
            const rateEl = document.getElementById('tf_service_rate');
            if (rateEl) rateEl.innerText = getServiceRate().toFixed(2);
        }

        function calcFromEGP() {
            if (!currentTransferType) return;
            const rate = getServiceRate();
            const egp = parseFloat(document.getElementById('tf_amount').value) || 0;
            document.getElementById('tf_amount_lyd').value = egp > 0 ? (egp / rate).toFixed(2) : '';
        }

        function calcFromLYD() {
            if (!currentTransferType) return;
            const rate = getServiceRate();
            const lyd = parseFloat(document.getElementById('tf_amount_lyd').value) || 0;
            if (currentTransferType === 'سيفا النيجر') {
                const egpCalculated = Math.round(lyd * rate);
                document.getElementById('tf_amount').value = lyd > 0 ? egpCalculated.toFixed(3) : '';
            } else {
                document.getElementById('tf_amount').value = lyd > 0 ? (lyd * rate).toFixed(2) : '';
            }
        }

        // Keep old updateCost for compatibility
        function updateCost() { calcFromEGP(); updateServiceRateDisplay(); }

        let currentSefaSubtype = 'nita';
        function handleSefaSubtypeChange(subtype) {
            currentSefaSubtype = subtype;
            
            // Highlight active button
            document.querySelectorAll('.sefa-tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            const activeBtn = document.getElementById(`btn_sefa_${subtype}`);
            if (activeBtn) {
                activeBtn.classList.add('active');
            }
            
            // Show beneficiary name and phone (which is account number)
            document.getElementById('beneficiary_name_div').style.display = 'block';
            document.getElementById('phone_div').style.display = 'block';
            document.getElementById('tf_phone').required = true;
            document.getElementById('tf_phone').setAttribute('maxlength', '8');
            document.getElementById('tf_phone').setAttribute('minlength', '8');

            // Sefa Niger does not require quadruple name
            const benLabel = document.querySelector('#beneficiary_name_div label');
            if (benLabel) benLabel.innerText = 'الاسم';
            const benInput = document.getElementById('tf_beneficiary');
            if (benInput) benInput.placeholder = 'أدخل الاسم';

            if (subtype === 'nita') {
                document.getElementById('lbl_tf_phone').innerText = 'رقم حساب NITA (8 أرقام)';
                document.getElementById('tf_phone').placeholder = 'أدخل 8 أرقام';
                
                // Show city input for NITA
                document.getElementById('city_div').style.display = 'block';
                document.getElementById('tf_city').required = true;
            } else if (subtype === 'nita_account') {
                document.getElementById('lbl_tf_phone').innerText = 'رقم حساب NITA ACCOUNT (8 أرقام)';
                document.getElementById('tf_phone').placeholder = 'أدخل 8 أرقام';
                
                // Hide city input for NITA ACCOUNT
                document.getElementById('city_div').style.display = 'none';
                document.getElementById('tf_city').required = false;
                document.getElementById('tf_city').value = '';
            }
            
            // Clear subtype-specific input fields to avoid bleed-through
            document.getElementById('tf_phone').value = '';
            document.getElementById('tf_city').value = '';
            
            // Focus on account number
            document.getElementById('tf_phone').focus();
        }

        function handleTransferTypeChange(type) {
            currentTransferType = type;
            // Highlight active tab
            document.querySelectorAll('.transfer-tab-btn').forEach(btn => {
                btn.classList.remove('active', 'btn-primary');
                btn.classList.add('btn-outline-primary');
            });
            const activeBtn = document.querySelector(`.transfer-tab-btn[data-type="${type}"]`);
            if (activeBtn) { activeBtn.classList.remove('btn-outline-primary'); activeBtn.classList.add('btn-primary', 'active'); }

            document.getElementById('dynamicFormFields').style.display = 'block';
            document.getElementById('tf_phone').value = ''; document.getElementById('tf_beneficiary').value = ''; document.getElementById('tf_national_id').value = ''; document.getElementById('tf_id_image').value = '';
            document.getElementById('tf_governorate').value = ''; document.getElementById('tf_amount').value = ''; document.getElementById('tf_amount_lyd').value = ''; checkNetworkLogo();

            // Hide all optional fields first
            document.getElementById('beneficiary_name_div').style.display = 'none';
            document.getElementById('national_id_div').style.display = 'none';
            document.getElementById('id_image_div').style.display = 'none';
            document.getElementById('phone_div').style.display = 'none';
            document.getElementById('governorate_div').style.display = 'none';
            document.getElementById('client_phone_div').style.display = 'block'; // Always show for all types
            document.getElementById('network_badge_div').style.display = 'none';
            document.getElementById('tf_phone').required = false;
            document.getElementById('tf_governorate').required = false;
            if (document.getElementById('tf_client_phone')) document.getElementById('tf_client_phone').value = '';

            // Reset beneficiary name label and placeholder by default
            const benLabel = document.querySelector('#beneficiary_name_div label');
            if (benLabel) benLabel.innerText = 'اسم المستفيد (رباعي)';
            const benInput = document.getElementById('tf_beneficiary');
            if (benInput) benInput.placeholder = 'اكتب الاسم رباعي';

            // Hide city and sefa subtypes divs by default
            const cityDiv = document.getElementById('city_div');
            if (cityDiv) cityDiv.style.display = 'none';
            const cityInput = document.getElementById('tf_city');
            if (cityInput) cityInput.required = false;

            const sefaSubtypesDiv = document.getElementById('sefa_niger_subtypes_div');
            if (sefaSubtypesDiv) sefaSubtypesDiv.style.display = 'none';
            const postSubtypesDiv = document.getElementById('egypt_post_subtypes_div');
            if (postSubtypesDiv) postSubtypesDiv.style.display = 'none';

            updateServiceRateDisplay();

            if (type === 'كاش') {
                document.getElementById('phone_div').style.display = 'block';
                document.getElementById('lbl_tf_phone').innerText = 'رقم المحفظة (11 رقم)';
                document.getElementById('tf_phone').placeholder = 'مثال: 010XXXXXXXX';
                document.getElementById('tf_phone').required = true;
                document.getElementById('tf_phone').setAttribute('maxlength', '11');
                document.getElementById('tf_phone').setAttribute('minlength', '11');
                document.getElementById('tf_phone').focus();
            } 
            else if (type === 'بريد حساب') {
                if (postSubtypesDiv) postSubtypesDiv.style.display = 'block';
                document.getElementById('beneficiary_name_div').style.display = 'block';
                document.getElementById('phone_div').style.display = 'block';
                document.getElementById('lbl_tf_phone').innerText = 'رقم الحساب البريدي';
                document.getElementById('tf_phone').placeholder = 'أدخل 16 رقم';
                document.getElementById('tf_phone').required = true;
                document.getElementById('tf_phone').setAttribute('maxlength', '16');
                document.getElementById('tf_phone').setAttribute('minlength', '16');
                document.getElementById('tf_phone').focus();
            } 
            else if (type === 'بريد بطاقة') {
                if (postSubtypesDiv) postSubtypesDiv.style.display = 'block';
                document.getElementById('beneficiary_name_div').style.display = 'block';
                document.getElementById('national_id_div').style.display = 'block';
                document.getElementById('id_image_div').style.display = 'block';
                document.getElementById('governorate_div').style.display = 'block';
                document.getElementById('tf_governorate').required = true;
            }
            else if (type === 'حساب بنكي') {
                document.getElementById('beneficiary_name_div').style.display = 'block';
                document.getElementById('phone_div').style.display = 'block';
                document.getElementById('lbl_tf_phone').innerText = 'رقم الحساب البنكي (IBAN)';
                document.getElementById('tf_phone').placeholder = 'أدخل رقم IBAN';
                document.getElementById('tf_phone').required = true;
                document.getElementById('tf_phone').removeAttribute('maxlength');
                document.getElementById('tf_phone').removeAttribute('minlength');
                document.getElementById('tf_phone').focus();
            }
            else if (type === 'سيفا النيجر') {
