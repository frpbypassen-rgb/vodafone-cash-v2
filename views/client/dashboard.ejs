        let balanceTransferTarget = null;

        function resetBalanceTransferFlow() {
            balanceTransferTarget = null;
            const form = document.getElementById('balanceTransferForm');
            const resultBox = document.getElementById('bt_target_result');
            const detailsBox = document.getElementById('bt_transfer_details');
            const targetName = document.getElementById('bt_target_name');
            const targetMeta = document.getElementById('bt_target_meta');
            const lookupBtn = document.getElementById('btnLookupBalanceTarget');
            const submitBtn = document.getElementById('btnSubmitBalanceTransfer');

            if (form) form.reset();
            if (resultBox) resultBox.style.display = 'none';
            if (detailsBox) detailsBox.style.display = 'none';
            if (targetName) targetName.textContent = '-';
            if (targetMeta) targetMeta.textContent = '';
            if (lookupBtn) {
                lookupBtn.disabled = false;
                lookupBtn.innerHTML = '<i class="fa-solid fa-magnifying-glass me-1"></i> تحقق';
            }
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fa-solid fa-paper-plane me-2"></i> تحويل';
            }
        }

        function openBalanceTransferModal() {
            const transferModalEl = document.getElementById('transferModal');
            const transferModal = transferModalEl ? bootstrap.Modal.getInstance(transferModalEl) : null;
            if (transferModal) transferModal.hide();

            setTimeout(() => {
                const modalEl = document.getElementById('balanceTransferModal');
                if (!modalEl) return;
                resetBalanceTransferFlow();
                bootstrap.Modal.getOrCreateInstance(modalEl).show();
                setTimeout(() => document.getElementById('bt_target_code')?.focus(), 250);
            }, transferModal ? 250 : 0);
        }

        async function lookupBalanceTransferTarget() {
            const targetInput = document.getElementById('bt_target_code');
            const lookupBtn = document.getElementById('btnLookupBalanceTarget');
            const resultBox = document.getElementById('bt_target_result');
            const detailsBox = document.getElementById('bt_transfer_details');
            const targetAccountCode = targetInput.value.trim();

            if (!/^\d{4,6}$/.test(targetAccountCode)) {
                return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'ID المستلم يجب أن يكون من 4 إلى 6 أرقام.', customClass: { popup: 'swal2-popup' } });
            }

            balanceTransferTarget = null;
            if (resultBox) resultBox.style.display = 'none';
            if (detailsBox) detailsBox.style.display = 'none';
            lookupBtn.disabled = true;
            lookupBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i> بحث...';

            try {
                const response = await fetch('/client/balance-transfer/lookup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                    body: JSON.stringify({ targetAccountCode })
                });
                const result = await response.json();

                if (!response.ok || !result.success) {
                    throw new Error(result.error || 'لم يتم العثور على الحساب.');
                }

                balanceTransferTarget = result.target;
                document.getElementById('bt_target_name').textContent = result.target.name;
                document.getElementById('bt_target_meta').textContent = `${result.target.type} - ID ${result.target.accountCode}`;
                if (resultBox) resultBox.style.display = 'block';
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'عذراً', text: error.message || 'تعذر التحقق من الحساب.', customClass: { popup: 'swal2-popup' } });
            } finally {
                lookupBtn.disabled = false;
                lookupBtn.innerHTML = '<i class="fa-solid fa-magnifying-glass me-1"></i> تحقق';
            }
        }

        const balanceTargetInput = document.getElementById('bt_target_code');
        if (balanceTargetInput) {
            balanceTargetInput.addEventListener('input', () => {
                balanceTransferTarget = null;
                const resultBox = document.getElementById('bt_target_result');
                const detailsBox = document.getElementById('bt_transfer_details');
                if (resultBox) resultBox.style.display = 'none';
                if (detailsBox) detailsBox.style.display = 'none';
            });
            balanceTargetInput.addEventListener('keydown', (event) => {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    lookupBalanceTransferTarget();
                }
            });
        }

        const lookupBalanceBtn = document.getElementById('btnLookupBalanceTarget');
        if (lookupBalanceBtn) {
            lookupBalanceBtn.addEventListener('click', lookupBalanceTransferTarget);
        }

        const confirmBalanceTargetBtn = document.getElementById('bt_confirm_target');
        if (confirmBalanceTargetBtn) {
            confirmBalanceTargetBtn.addEventListener('click', () => {
                if (!balanceTransferTarget) return;
                const detailsBox = document.getElementById('bt_transfer_details');
                if (detailsBox) detailsBox.style.display = 'block';
                setTimeout(() => document.getElementById('bt_amount')?.focus(), 100);
            });
        }

        const balanceTransferForm = document.getElementById('balanceTransferForm');
        if (balanceTransferForm) {
            balanceTransferForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                const targetAccountCode = document.getElementById('bt_target_code').value.trim();
                const amount = document.getElementById('bt_amount').value;
                const notes = document.getElementById('bt_notes').value.trim();
                const numericAmount = Number(amount);

                if (!/^\d{4,6}$/.test(targetAccountCode)) {
                    return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'ID المستلم يجب أن يكون من 4 إلى 6 أرقام.', customClass: { popup: 'swal2-popup' } });
                }

                if (!balanceTransferTarget || balanceTransferTarget.accountCode !== targetAccountCode) {
                    return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى إدخال ID ثم الضغط على اسم الحساب للتأكيد.', customClass: { popup: 'swal2-popup' } });
                }

                if (!Number.isFinite(numericAmount) || numericAmount <= 0) {
                    return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى إدخال مبلغ صحيح.', customClass: { popup: 'swal2-popup' } });
                }

                const confirmation = await Swal.fire({
                    icon: 'warning',
                    title: 'تأكيد تحويل الرصيد',
                    text: `سيتم خصم ${numericAmount.toFixed(2)} LYD من رصيدك وإرسالها إلى ${balanceTransferTarget.name}.`,
                    showCancelButton: true,
                    confirmButtonText: 'موافق، نفذ التحويل',
                    cancelButtonText: 'إلغاء',
                    customClass: { popup: 'swal2-popup' }
                });

                if (!confirmation.isConfirmed) return;

                const btn = document.getElementById('btnSubmitBalanceTransfer');
                const originalText = btn.innerHTML;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i> جاري التنفيذ...';
                btn.disabled = true;

                try {
                    const response = await fetch('/client/balance-transfer', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                        body: JSON.stringify({ targetAccountCode, amount, notes })
                    });
                    const result = await response.json();

                    if (!response.ok || !result.success) {
                        throw new Error(result.error || 'تعذر تنفيذ تحويل الرصيد.');
                    }

                    Swal.fire({
                        icon: 'success',
                        title: 'تم تحويل الرصيد',
                        text: `${result.message} رقم العملية: ${result.transferId}`,
                        confirmButtonText: 'حسناً',
                        customClass: { popup: 'swal2-popup' }
                    }).then(() => window.location.reload());
                } catch (error) {
                    Swal.fire({ icon: 'error', title: 'عذراً', text: error.message || 'تعذر تنفيذ تحويل الرصيد.', customClass: { popup: 'swal2-popup' } });
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            });
        }

