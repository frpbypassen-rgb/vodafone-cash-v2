<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>بوابة العملاء | Al-Ahram Pay</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
        document.documentElement.setAttribute('data-bs-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        /* 🎨 المتغيرات (الوضع النهاري - Premium Light) */
        :root { 
            --brand-primary: #001a4d; --brand-gold: #d4af37; 
            --bg-body: #f4f7fa; --card-bg: #ffffff;
            --text-main: #1e293b; --text-muted: #64748b;
            --border-glass: #e2e8f0; --input-bg: #f8fafc;
            --shadow-soft: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            --accent-green: #10b981; --accent-red: #ef4444; --accent-blue: #0ea5e9;
        }

        /* 🌙 المتغيرات (الوضع الليلي - Premium Dark) */
        [data-theme="dark"] {
            --brand-primary: #3b82f6; --brand-gold: #fbbf24; 
            --bg-body: #0f172a; --card-bg: #1e293b; 
            --text-main: #f8fafc; --text-muted: #94a3b8;
            --border-glass: #334155; --input-bg: #0f172a;
            --shadow-soft: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
            --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
        }

        body { background-color: var(--bg-body); color: var(--text-main); font-family: 'Tajawal', sans-serif; transition: background-color 0.3s, color 0.3s; padding-bottom: 50px; overflow-x: hidden; }
        
        ::-webkit-scrollbar { width: 6px; height: 6px; } 
        ::-webkit-scrollbar-track { background: transparent; } 
        ::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 10px; }

        .mono-num { font-family: 'JetBrains Mono', Tahoma, sans-serif; font-weight: bold; letter-spacing: 0.5px;}

        /* 🛸 Navbar */
        .navbar-custom { background: var(--card-bg); border-bottom: 1px solid var(--border-glass); padding: 15px 0; position: sticky; top: 0; z-index: 1000; box-shadow: var(--shadow-soft); transition: 0.3s; margin-bottom: 40px;}
        .logo-img { height: 40px; transition: 0.3s; mix-blend-mode: multiply; filter: contrast(1.2); }
        [data-theme="dark"] .logo-img { mix-blend-mode: normal; background: white; padding: 2px; border-radius: 8px; }
        .navbar-brand { color: var(--brand-primary) !important; font-weight: 900; font-size: 1.5rem; margin: 0; letter-spacing: -0.5px;}
        [data-theme="dark"] .navbar-brand { color: var(--brand-gold) !important; }

        .nav-actions { display: flex; gap: 10px; align-items: center; }
        .nav-btn { background: var(--input-bg); border: 1px solid var(--border-glass); color: var(--text-main); padding: 10px 20px; border-radius: 12px; font-weight: 700; text-decoration: none; transition: 0.3s; display: inline-flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.9rem;}
        .nav-btn:hover { background: var(--card-bg); color: var(--brand-primary); border-color: var(--brand-primary); box-shadow: var(--shadow-soft); transform: translateY(-2px);}
        [data-theme="dark"] .nav-btn:hover { color: var(--brand-gold); border-color: var(--brand-gold); }
        
        .btn-theme { border-radius: 12px; width: 44px; padding: 0; justify-content: center; color: var(--brand-gold); border-color: var(--border-glass);}
        .btn-theme:hover { background: var(--brand-gold); color: #000; }
        .nav-logout { color: var(--accent-red); border-color: var(--border-glass); }
        .nav-logout:hover { background: var(--accent-red) !important; color: white !important; border-color: var(--accent-red) !important;}

        /* 🚀 💳 3D Interactive VIP Balance Card */
        .wallet-wrapper { 
            margin-top: 35px; margin-bottom: 25px; 
            perspective: 1000px; 
        }
        .wallet-card { 
            background: linear-gradient(135deg, #001a4d 0%, #000814 100%); 
            border-radius: 28px; padding: 40px; color: white; 
            position: relative; overflow: hidden; 
            box-shadow: 0 20px 40px -10px rgba(0, 26, 77, 0.4); margin-bottom: 30px; 
            display: flex; flex-direction: column; justify-content: space-between; min-height: 220px;
            transform-style: preserve-3d; 
            transition: transform 0.1s ease-out, box-shadow 0.3s ease-out; 
        }
        [data-theme="dark"] .wallet-card { 
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); 
            border: 1px solid rgba(255,255,255,0.05); 
        }
        
        .wallet-card::before { 
            content: ''; position: absolute; right: -20%; top: -50%; width: 300px; height: 300px; 
            background: radial-gradient(circle, rgba(212,175,55,0.15) 0%, transparent 70%); 
            border-radius: 50%; pointer-events: none; 
            transform: translateZ(-10px); 
        }
        .wallet-card::after {
            content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(to right, transparent, rgba(255,255,255,0.1), transparent);
            transform: skewX(-20deg); transition: 0.5s; pointer-events: none; z-index: 5;
        }
        .wallet-card:hover::after { left: 150%; }

        .wallet-card > div { transform: translateZ(40px); }

        .wallet-label { font-size: 0.9rem; font-weight: 700; color: rgba(255,255,255,0.6); margin-bottom: 5px; text-transform: uppercase; letter-spacing: 1px;}
        .wallet-balance { font-family: 'JetBrains Mono', monospace; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; margin: 0; color: #fff; line-height: 1; letter-spacing: 1px; position: relative; z-index: 2; text-shadow: 0 10px 20px rgba(0,0,0,0.5);}
        .wallet-balance span { color: var(--brand-gold); font-size: 1.5rem; vertical-align: super; margin-right: 5px;}
        .wallet-footer { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; position: relative; z-index: 2;}
        .wallet-name { font-size: 1.1rem; font-weight: 800; color: rgba(255,255,255,0.9); }
        .wallet-logo { font-size: 1.8rem; color: var(--brand-gold); opacity: 0.8; }

        /* 💱 شريط أسعار الصرف الحي */
        .live-rates-bar { background: var(--card-bg); border-radius: 20px; padding: 15px 25px; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; box-shadow: var(--shadow-soft); border: 1px solid var(--border-glass); margin-bottom: 40px; transition: 0.3s;}
        .rate-title { font-weight: 800; color: var(--text-muted); font-size: 0.9rem; display: flex; align-items: center; gap: 8px;}
        .rate-items { display: flex; gap: 15px; flex-wrap: wrap;}
        .rate-item { display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 1rem; color: var(--text-main);}
        .rate-item i { color: var(--brand-gold); }
        .rate-val { font-family: 'JetBrains Mono', monospace; color: var(--brand-primary); background: var(--input-bg); padding: 4px 10px; border-radius: 8px; border: 1px solid var(--border-glass); transition: 0.3s;}
        [data-theme="dark"] .rate-val { color: var(--brand-gold); }

        /* 🚀 Apps & Premium Button (3D Effect) */
        .app-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-bottom: 40px; perspective: 1000px;}
        .app-btn { 
            background: var(--card-bg); border: 1px solid var(--border-glass); border-radius: 24px; padding: 25px 15px; text-align: center; 
            cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; text-decoration: none;
            box-shadow: var(--shadow-soft); transform-style: preserve-3d;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease, border-color 0.3s ease;
        }
        .app-btn:hover { border-color: var(--brand-gold); transform: translateY(-8px) scale(1.02); box-shadow: 0 15px 35px rgba(0,0,0,0.1); }
        [data-theme="dark"] .app-btn:hover { box-shadow: 0 15px 35px rgba(0,0,0,0.4); }
        
        .app-icon { width: 65px; height: 65px; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; transition: 0.3s; transform: translateZ(20px);}
        .app-btn:hover .app-icon { transform: translateZ(40px) scale(1.1); color: #fff !important; }
        .app-title { font-weight: 800; font-size: 0.95rem; color: var(--text-main); margin: 0; transform: translateZ(10px);}
        
        .premium-transfer-btn { position: relative; overflow: hidden; border: 1px solid rgba(14, 165, 233, 0.3) !important; background: linear-gradient(180deg, var(--card-bg) 0%, rgba(14, 165, 233, 0.02) 100%) !important; }
        [data-theme="dark"] .premium-transfer-btn { background: linear-gradient(180deg, var(--card-bg) 0%, rgba(14, 165, 233, 0.05) 100%) !important; }
        .premium-transfer-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%; background: linear-gradient(to right, transparent, rgba(14, 165, 233, 0.1), transparent); transform: skewX(-20deg); transition: 0.7s; }
        .premium-transfer-btn:hover::after { left: 150%; }
        .premium-icon.icon-1 { background: linear-gradient(135deg, rgba(14, 165, 233, 0.2), rgba(37, 99, 235, 0.2)); color: #0ea5e9; box-shadow: 0 0 15px rgba(14, 165, 233, 0.15); transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .premium-transfer-btn:hover .premium-icon.icon-1 { background: linear-gradient(135deg, #0ea5e9, #2563eb); color: white !important; box-shadow: 0 10px 25px rgba(14, 165, 233, 0.4); transform: scale(1.15) translateY(-5px); }
        .premium-icon i { animation: moneyFly 1.5s infinite alternate ease-in-out; }
        @keyframes moneyFly { 0% { transform: translateX(0); } 100% { transform: translateX(-4px) translateY(-2px); } }
        .premium-badge { position: absolute; top: 12px; right: 12px; background: rgba(16, 185, 129, 0.15); color: #10b981; font-size: 0.65rem; font-weight: 800; padding: 3px 8px; border-radius: 20px; border: 1px solid rgba(16, 185, 129, 0.3); display: flex; align-items: center; gap: 3px; transform: translateZ(30px); }

        .icon-2 { background: rgba(16, 185, 129, 0.1); color: #10b981; } .app-btn:hover .icon-2 { background: #10b981; }
        .icon-4 { background: rgba(139, 92, 246, 0.1); color: #8b5cf6; } .app-btn:hover .icon-4 { background: #8b5cf6; }
        .sc-balance { background: linear-gradient(135deg, #0f766e, #115e59); }

        /* Stats (3D Hover) */
        .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; perspective: 1000px;}
        .stat-card { 
            background: var(--card-bg); border: 1px solid var(--border-glass); border-radius: 20px; padding: 25px; 
            display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; position: relative; overflow: hidden;
            box-shadow: var(--shadow-soft); transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
        [data-theme="dark"] .stat-card:hover { box-shadow: 0 15px 30px rgba(0,0,0,0.4); }
        .stat-card::before { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 4px; }
        .stat-card.c-blue::before { background: #0ea5e9; } .stat-card.c-green::before { background: #10b981; } .stat-card.c-gold::before { background: var(--brand-gold); }
        .stat-label { font-size: 0.85rem; font-weight: 700; color: var(--text-muted); margin-bottom: 8px;}
        .stat-val { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 900; color: var(--text-main); line-height: 1;}

        /* Table */
        .ledger-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; flex-wrap: wrap; gap: 15px;}
        .ledger-title { font-size: 1.3rem; font-weight: 900; color: var(--text-main); margin: 0;}
        .filter-box { display: flex; gap: 10px; align-items: center; background: var(--card-bg); padding: 8px; border-radius: 16px; border: 1px solid var(--border-glass); box-shadow: var(--shadow-soft);}
        .filter-input { border: none; background: var(--input-bg); border-radius: 10px; padding: 8px 15px; color: var(--text-main); font-weight: 700; outline: none;}
        .filter-btn { background: var(--brand-primary); color: white; border: none; border-radius: 10px; padding: 8px 20px; font-weight: 800; cursor: pointer; transition: 0.2s;}
        [data-theme="dark"] .filter-btn { background: var(--brand-gold); color: black;}

        .table-custom { width: 100%; border-collapse: separate; border-spacing: 0 10px; }
        .table-custom th { border: none; color: var(--text-muted); font-weight: 800; font-size: 0.85rem; padding: 10px 15px; white-space: nowrap; text-align: center;}
        .table-custom tbody tr { background: var(--card-bg); box-shadow: var(--shadow-soft); transition: 0.2s; }
        .table-custom tbody tr:hover { transform: scale(1.01); box-shadow: var(--shadow-hover); }
        .table-custom td { border: 1px solid var(--border-glass); border-style: solid none; padding: 18px 15px; vertical-align: middle; font-weight: 700; text-align: center; white-space: nowrap;}
        .table-custom td:first-child { border-left: 1px solid var(--border-glass); border-top-right-radius: 16px; border-bottom-right-radius: 16px; }
        .table-custom td:last-child { border-right: 1px solid var(--border-glass); border-top-left-radius: 16px; border-bottom-left-radius: 16px; }
        
        .tx-id { font-family: 'JetBrains Mono', monospace; font-weight: 900; color: var(--brand-primary); cursor: pointer; text-decoration: none; border-bottom: 2px dashed rgba(0,26,77,0.3); transition: 0.2s;}
        [data-theme="dark"] .tx-id { color: var(--brand-gold); border-bottom-color: rgba(212,175,55,0.3);}
        .tx-id:hover { opacity: 0.7; }
        .tx-amount { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; color: #10b981; }
        .tx-cost { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; color: #ef4444; }
        .tx-phone { font-family: 'JetBrains Mono', monospace; font-size: 1rem; color: var(--text-main); letter-spacing: 1px;}
        
        /* الحالات والأوسمة */
        .badge-st { padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 800; display: inline-flex; align-items: center; gap: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); white-space: nowrap; }
        .st-done { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
        .st-wait { background: rgba(245, 158, 11, 0.08); color: #d97706; border: 1px solid rgba(245, 158, 11, 0.2); } 
        [data-theme="dark"] .st-wait { color: #fbbf24; background: rgba(251, 191, 36, 0.06); }
        
        .st-accepted { background: rgba(14, 165, 233, 0.1); color: #0284c7; border: 1px solid rgba(14, 165, 233, 0.25); animation: livePulseBlue 2s infinite cubic-bezier(0.4, 0, 0.6, 1); }
        [data-theme="dark"] .st-accepted { color: #38bdf8; background: rgba(56, 189, 248, 0.08); }
        @keyframes livePulseBlue { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.85; transform: scale(0.98); } }
        
        .st-fail { background: rgba(239, 68, 68, 0.08); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }
        [data-theme="dark"] .st-fail { color: #f87171; background: rgba(248, 113, 113, 0.06); }
        .st-dep { background: rgba(14, 165, 233, 0.1); color: #0ea5e9; border: 1px solid rgba(14, 165, 233, 0.2); }

        /* Forms & Modals */
        .form-control, .form-select { background-color: var(--input-bg); color: var(--text-main); border: 1px solid var(--border-glass); border-radius: 14px; padding: 14px 18px; font-weight: 700; transition: 0.3s;}
        .form-control:focus, .form-select:focus { background-color: transparent; border-color: var(--brand-gold); box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15); color: var(--text-main);}
        .input-group-text { background-color: var(--input-bg); border-color: var(--border-glass); color: var(--text-muted); border-radius: 0 14px 14px 0; border-left: none;}
        
        .modal-content { background-color: var(--card-bg); color: var(--text-main); border: 1px solid var(--border-glass); border-radius: 28px; box-shadow: 0 25px 50px rgba(0,0,0,0.5); transform-style: preserve-3d;}
        .modal-header { border-bottom: 1px dashed var(--border-glass); padding: 25px;}
        .btn-submit-cyber { background: linear-gradient(45deg, #0ea5e9, #2563eb); border: none; color: white; border-radius: 14px; font-weight: 800; padding: 16px; width: 100%; font-size: 1.1rem; box-shadow: 0 5px 15px rgba(14, 165, 233, 0.3); transition: 0.3s;}
        .btn-submit-cyber:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(14, 165, 233, 0.5); color: white;}

        .swal2-popup { background: var(--card-bg) !important; color: var(--text-main) !important; border: 1px solid var(--border-glass); border-radius: 24px !important; }
        .swal2-title, .swal2-html-container { color: var(--text-main) !important; }

        .mobile-header { display: none; }
        .bottom-nav-mobile { display: none; }

        @media (max-width: 768px) {
            body {
                padding-bottom: 85px !important; /* Space for bottom navigation */
            }
            .navbar-custom {
                display: none !important; /* Hide desktop navbar */
            }
            .main-container {
                padding-left: 12px !important;
                padding-right: 12px !important;
                margin-top: 15px !important;
            }
            .table-responsive {
                display: none !important; /* Hide desktop table */
            }
            
            /* Compact stats for mobile */
            .stats-grid {
                display: grid !important;
                grid-template-columns: repeat(3, 1fr) !important;
                gap: 8px !important;
                margin-bottom: 20px !important;
            }
            .stat-card {
                padding: 12px 6px !important;
                border-radius: 12px !important;
            }
            .stat-label {
                font-size: 0.65rem !important;
                margin-bottom: 4px !important;
            }
            .stat-val {
                font-size: 1.15rem !important;
            }

            /* Compact apps for mobile */
            .app-grid {
                grid-template-columns: repeat(2, 1fr) !important;
                gap: 10px !important;
                margin-bottom: 25px !important;
            }
            .app-btn {
                padding: 15px 10px !important;
                border-radius: 18px !important;
            }
            .app-icon {
                width: 44px !important;
                height: 44px !important;
                border-radius: 12px !important;
                font-size: 1.3rem !important;
            }
            .app-title {
                font-size: 0.8rem !important;
            }
            
            /* Mobile Header */
            .mobile-header {
                display: flex !important;
                justify-content: space-between;
                align-items: center;
                background: var(--card-bg);
                border-bottom: 1px solid var(--border-glass);
                padding: 10px 16px;
                position: sticky;
                top: 0;
                z-index: 999;
                box-shadow: var(--shadow-soft);
            }
            .mobile-logo-wrapper {
                display: flex;
                align-items: center;
                gap: 8px;
            }
            .mobile-logo-wrapper img {
                height: 32px;
                border-radius: 6px;
            }
            .mobile-logo-wrapper h1 {
                font-size: 1.15rem;
                font-weight: 900;
                margin: 0;
                color: var(--brand-primary);
            }
            [data-theme="dark"] .mobile-logo-wrapper h1 {
                color: var(--brand-gold);
            }
            
            /* Bottom Navigation */
            .bottom-nav-mobile {
                display: flex !important;
                position: fixed;
                bottom: 0;
                left: 0;
                right: 0;
                height: 65px;
                background: var(--card-bg);
                border-top: 1px solid var(--border-glass);
                justify-content: space-around;
                align-items: center;
                z-index: 1000;
                box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.08);
                padding-bottom: env(safe-area-inset-bottom);
            }
            .bottom-nav-item {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 4px;
                color: var(--text-muted);
                text-decoration: none;
                flex: 1;
                height: 100%;
                font-size: 0.72rem;
                font-weight: bold;
                transition: 0.2s;
            }
            .bottom-nav-item i {
                font-size: 1.25rem;
                transition: transform 0.2s;
            }
            .bottom-nav-item:hover {
                color: var(--text-main);
            }
            .bottom-nav-item.active {
                color: var(--brand-primary);
            }
            [data-theme="dark"] .bottom-nav-item.active {
                color: var(--brand-gold);
            }
            .bottom-nav-item.active i {
                transform: translateY(-2px);
            }

            /* Mobile transaction cards */
            .mobile-tx-card {
                background: var(--card-bg);
                border: 1px solid var(--border-glass);
                border-radius: 18px;
                padding: 16px;
                display: flex;
                flex-direction: column;
                gap: 12px;
                box-shadow: var(--shadow-soft);
                transition: transform 0.15s ease, background-color 0.15s ease;
            }
            .mobile-tx-card:active {
                transform: scale(0.98);
                background-color: var(--input-bg);
            }
            .mobile-tx-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }
            .tx-custom-id {
                font-family: 'JetBrains Mono', monospace;
                font-weight: 800;
                font-size: 0.95rem;
                color: var(--brand-gold);
            }
            .mobile-tx-body {
                display: flex;
                justify-content: space-between;
                align-items: flex-end;
            }
            .tx-amount-section {
                display: flex;
                flex-direction: column;
                gap: 4px;
            }
            .tx-amount-wrapper {
                display: flex;
                align-items: baseline;
                gap: 4px;
            }
            .tx-amount {
                font-size: 1.35rem;
                font-weight: 900;
                color: var(--text-main);
            }
            .tx-currency {
                font-size: 0.75rem;
                font-weight: 700;
                color: var(--text-muted);
            }
            .tx-cost-wrapper {
                font-size: 0.9rem;
                display: flex;
                align-items: center;
                gap: 4px;
            }
            .mobile-tx-divider {
                height: 1px;
                background: var(--border-glass);
                margin: 4px 0;
            }
            .mobile-tx-date-row {
                font-size: 0.75rem;
                color: var(--text-muted);
                font-weight: 700;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }
            .mobile-tx-actions {
                display: flex;
                gap: 6px;
            }
            .mobile-tab-content {
                display: none;
            }
            .mobile-tab-content.active {
                display: block;
            }

            /* Services Grid inside transfers tab */
            .services-mobile-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
                margin-top: 15px;
            }
            .service-card-item {
                background: var(--card-bg);
                border: 1px solid var(--border-glass);
                border-radius: 20px;
                padding: 20px 10px;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 12px;
                cursor: pointer;
                box-shadow: var(--shadow-soft);
                transition: transform 0.2s, box-shadow 0.2s;
            }
            .service-card-item:active {
                transform: scale(0.95);
                background-color: var(--input-bg);
            }
            .service-card-icon {
                width: 50px;
                height: 50px;
                border-radius: 14px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
                color: #fff;
            }
            .sc-cash { background: linear-gradient(135deg, #10b981, #059669); }
            .sc-balance { background: linear-gradient(135deg, #0f766e, #115e59); }
            .sc-post-card { background: linear-gradient(135deg, #f59e0b, #d97706); }
            .sc-post-acc { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
            .sc-bank { background: linear-gradient(135deg, #6366f1, #4f46e5); }
            .sc-niger { background: linear-gradient(135deg, #14b8a6, #0d9488); }
            .sc-sudan { background: linear-gradient(135deg, #ef4444, #b91c1c); }

            .service-card-title {
                font-weight: 800;
                font-size: 0.82rem;
                text-align: center;
                color: var(--text-main);
            }

            /* Professional Profile Card for Mobile */
            .mobile-profile-card {
                background: linear-gradient(135deg, var(--card-bg) 0%, rgba(14, 165, 233, 0.02) 100%) !important;
                border: 1px solid var(--border-glass) !important;
                border-radius: 24px !important;
                padding: 24px 20px !important;
                box-shadow: 0 10px 35px rgba(0, 0, 0, 0.03) !important;
                position: relative;
                overflow: hidden;
            }
            [data-theme="dark"] .mobile-profile-card {
                background: linear-gradient(135deg, var(--card-bg) 0%, rgba(212, 175, 55, 0.01) 100%) !important;
            }
            .mobile-profile-card::before {
                content: '';
                position: absolute;
                top: 0;
                right: 0;
                width: 5px;
                height: 100%;
                background: linear-gradient(to bottom, var(--brand-primary), var(--brand-gold));
            }
            .mobile-profile-card-header {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 20px;
                border-bottom: 1px dashed var(--border-glass);
                padding-bottom: 12px;
            }
            .mobile-profile-card-icon {
                width: 42px;
                height: 42px;
                border-radius: 12px;
                background: rgba(212, 175, 55, 0.08);
                border: 1px solid rgba(212, 175, 55, 0.15);
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--brand-gold);
                font-size: 1.25rem;
            }
            .mobile-profile-card-title {
                font-size: 1.05rem;
                font-weight: 800;
                color: var(--text-main);
                margin: 0;
            }
            .mobile-profile-row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 10px 0;
                border-bottom: 1px solid rgba(0, 0, 0, 0.02);
            }
            [data-theme="dark"] .mobile-profile-row {
                border-bottom: 1px solid rgba(255, 255, 255, 0.02);
            }
            .mobile-profile-row:last-child {
                border-bottom: none;
            }
            .mobile-profile-label {
                color: var(--text-muted);
                font-size: 0.82rem;
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 8px;
            }
            .mobile-profile-label i {
                font-size: 0.95rem;
                width: 16px;
                text-align: center;
            }
            .mobile-profile-value {
                color: var(--text-main);
                font-size: 0.88rem;
                font-weight: 800;
            }
        }

        /* 🖨️ تصميم التقفيل المجزأ للطباعة فقط */
        @media print {
            body { visibility: hidden; background: white !important; padding: 0 !important; }
            .print-only-segmented {
                visibility: visible; position: absolute; top: 0; left: 0; width: 100%;
                background: white; padding: 20px; font-family: 'Tajawal', sans-serif;
            }
            .print-header { text-align: center; border-bottom: 2px solid #000; padding-bottom: 10px; margin-bottom: 30px; }
            .print-header h1 { margin: 0; font-size: 24px; font-weight: bold; color: #001a4d; }
            .print-header p { margin: 5px 0; font-size: 16px; font-weight: bold; }
            
            .print-table-title { font-weight: bold; font-size: 18px; margin-top: 25px; margin-bottom: 10px; padding: 5px; border-bottom: 2px dashed #ccc; }
            .print-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 13px; }
            .print-table th, .print-table td { border: 1px solid #333; padding: 8px; text-align: center; }
            .print-table th { background-color: #f1f1f1 !important; -webkit-print-color-adjust: exact; }
            
            .print-summary { width: 50%; margin-top: 30px; border: 2px solid #000; border-collapse: collapse; float: right;}
            .print-summary th, .print-summary td { border: 1px solid #000; padding: 10px; font-size: 15px; font-weight: bold; text-align: right; }
            .print-summary th { background-color: #eee !important; -webkit-print-color-adjust: exact; }
        }
        .print-only-segmented { display: none; }
        @media print { .print-only-segmented { display: block; } }

        @keyframes flashUpdate {
            0% { background-color: rgba(16, 185, 129, 0.5); transform: scale(1.1); }
            100% { background-color: var(--input-bg); transform: scale(1); }
        }
        .rate-updated { animation: flashUpdate 1s ease-out; }

        .transfer-tab-btn {
            font-size: 0.82rem;
            padding: 6px 12px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.2s;
            border-width: 2px;
        }
        .transfer-tab-btn:hover { transform: translateY(-1px); }
        .transfer-tab-btn.active, .transfer-tab-btn.btn-primary {
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.3);
        }

        .sefa-tab-btn {
            font-size: 0.9rem;
            padding: 10px 20px;
            border-radius: 12px;
            font-weight: 700;
            transition: all 0.25s ease;
            border-width: 2px;
        }
        .sefa-tab-btn:hover { transform: translateY(-1px); }
        .sefa-tab-btn.active {
            background: linear-gradient(135deg, #0ea5e9, #2563eb) !important;
            color: white !important;
            border-color: transparent !important;
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.4);
        }

        /* Desktop Services Grid */
        .services-desktop-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 15px;
        }
        .service-card-item-desktop {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 20px;
            padding: 25px 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            cursor: pointer;
            box-shadow: var(--shadow-soft);
            transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.25s ease, border-color 0.25s ease;
        }
        .service-card-item-desktop:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
            border-color: var(--brand-gold);
        }
        .service-card-item-desktop:active {
            transform: scale(0.98);
        }
        .service-card-item-desktop .service-card-icon {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: #fff;
            box-shadow: 0 8px 16px rgba(0,0,0,0.1);
        }
        .service-card-item-desktop .service-card-title {
            font-weight: 800;
            font-size: 0.95rem;
            text-align: center;
            color: var(--text-main);
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#001a4d">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
