                        <h5 class="fw-bold mb-3"><i class="fa-solid fa-address-card text-primary me-2"></i> بطاقة تعريف العميل</h5>
                        <div class="row align-items-center">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <div class="d-flex align-items-center mb-2">
                                <div style="width: 35px; height: 35px; border-radius: 8px; background: rgba(14, 165, 233, 0.1); display: flex; justify-content: center; align-items: center; margin-left: 10px;">
