                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-3 shadow-sm h-100 text-center" style="background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 12px;">
                    <div class="small text-muted fw-bold mb-1"><i class="fa-solid fa-list-ol text-info me-1"></i> عدد العمليات اليوم</div>
                    <div class="fw-bold fs-2 mono-num" style="color: #0ea5e9;" id="todayTxCount">0</div>
                </div>
            </div>
        </div>

        <div class="ledger-section">
            <div class="ledger-header">
                <h3 class="ledger-title"><i class="fa-solid fa-list-check me-2 text-primary"></i> سجل عمليات اليوم <span class="spinner-grow spinner-grow-sm text-success ms-2" style="vertical-align: middle;"></span></h3>
                
                <form method="GET" action="/client/dashboard" class="filter-box">
                    <input type="text" name="search" class="filter-input" placeholder="بحث برقم أو ملاحظة..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                    <input type="date" name="date" class="filter-input" value="<%= typeof targetDate !== 'undefined' ? targetDate : '' %>">
                    <button type="submit" class="filter-btn"><i class="fa-solid fa-filter"></i> عرض</button>
                    <button type="button" onclick="window.print()" class="filter-btn" style="background: var(--text-muted);"><i class="fa-solid fa-print"></i></button>
                </form>
            </div>
            
            <div class="table-responsive">
                <table class="table-custom" id="transactionsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>رقم العملية</th>
                            <th>المبلغ (EGP)</th>
                            <th>التكلفة / السعر</th>
                            <th>رقم الحساب</th>
                            <th>الوقت</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
