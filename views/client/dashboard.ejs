                        if (val % 1 !== 0) {
                            Swal.fire({
                                icon: 'error',
                                title: 'كسور غير مسموح بها',
                                text: 'يمنع كتابة أي كسور في القيمة لخدمة سيفا النيجر. الأصفار ثابتة لا تتغير (مثال: 1.000).',
