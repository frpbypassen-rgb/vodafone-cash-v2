        // 📡 نظام التحديث اللحظي للعميل (Smart Diffing & Live Notifications)
        let lastRenderedDataHash = '';
        async function fetchLiveClientPortalData() {
            try {
                const response = await fetch('/client/api/transactions' + window.location.search);
                if (!response.ok) return; 
                const data = await response.json();
                
                if (data.success) {
                    
                    // 🔔 1. نظام إشعار وتحديث سعر الصرف اللحظي
                    if (data.currentRate) {
                        let fetchedRate = parseFloat(data.currentRate);
                        if (Math.abs(fetchedRate - currentRate) > 0.001 && currentRate > 0) {
                            
                            currentRate = fetchedRate;
                            const rateCash = document.getElementById('liveRateCash');
                            const ratePostAcc = document.getElementById('liveRatePostAcc');
                            const ratePostCard = document.getElementById('liveRatePostCard');
                            const rateBank = document.getElementById('liveRateBank');
                            const rateNiger = document.getElementById('liveRateNiger');
                            const rateSudan = document.getElementById('liveRateSudan');
                            
                            if(rateCash) { rateCash.innerText = currentRate.toFixed(2); rateCash.classList.add('rate-updated'); setTimeout(()=>rateCash.classList.remove('rate-updated'), 1000); }
                            if(ratePostAcc) { ratePostAcc.innerText = (currentRate - 0.05).toFixed(2); ratePostAcc.classList.add('rate-updated'); setTimeout(()=>ratePostAcc.classList.remove('rate-updated'), 1000); }
                            if(ratePostCard) { ratePostCard.innerText = (currentRate - 0.15).toFixed(2); ratePostCard.classList.add('rate-updated'); setTimeout(()=>ratePostCard.classList.remove('rate-updated'), 1000); }
                            if(rateBank) { rateBank.innerText = currentRate.toFixed(2); rateBank.classList.add('rate-updated'); setTimeout(()=>rateBank.classList.remove('rate-updated'), 1000); }
                            if(rateNiger) { rateNiger.innerText = (currentRate + 0.1).toFixed(2); rateNiger.classList.add('rate-updated'); setTimeout(()=>rateNiger.classList.remove('rate-updated'), 1000); }
                            if(rateSudan) { rateSudan.innerText = (currentRate + 0.2).toFixed(2); rateSudan.classList.add('rate-updated'); setTimeout(()=>rateSudan.classList.remove('rate-updated'), 1000); }
                            
                            updateCost();
                            document.getElementById('alertSound').play().catch(()=>{});
                            
                            Swal.fire({
                                toast: true, position: 'top-end', icon: 'info', title: 'تحديث الأسعار 🔔',
                                html: `<b>تم تعديل سعر الصرف لمستواك ليصبح: ${currentRate.toFixed(2)}</b><br><small>تم التحديث تلقائياً في شاشتك.</small>`,
                                showConfirmButton: false, timer: 8000, timerProgressBar: true, customClass: { popup: 'swal2-popup' }
                            });
                        } else if (currentRate === 0) {
                            currentRate = fetchedRate;
                        }
                    }

                    if(data.availableBalance !== undefined) {
                        const balHolder = document.getElementById('liveBalanceHolder');
                        if (balHolder) balHolder.innerHTML = `<span class="currency-symbol">LYD</span>${data.availableBalance.toFixed(2)}`;
                    }
                    if(data.totalDeductions !== undefined && document.getElementById('liveDeductionsHolder')) {
                        document.getElementById('liveDeductionsHolder').innerText = data.totalDeductions.toFixed(2);
                    }

                    const currentHash = JSON.stringify(data.transactions);
                    if (currentHash !== lastRenderedDataHash) {
                        lastRenderedDataHash = currentHash;
                        renderClientTransactionsTable(data.transactions);
                    }
                }
            } catch (error) {}
        }

        function renderClientTransactionsTable(transactions) {
            window.allTransactions = transactions;
            const tbody = document.getElementById('tableBody');
            const mobileList = document.getElementById('mobileTransactionsList');
            const mobileListBrief = document.getElementById('mobileTransactionsListBrief');
            
            if (mobileList) mobileList.innerHTML = '';
            if (mobileListBrief) mobileListBrief.innerHTML = '';
            
            if (!transactions || transactions.length === 0) {
                 tbody.innerHTML = `<tr><td colspan="8" style="text-align: center; padding: 40px; color: var(--text-muted); font-weight: bold; border:none; background: transparent;"><i class="fa-solid fa-folder-open fs-1 opacity-25 d-block mb-3"></i> لا توجد عمليات لعرضها.</td></tr>`;
                 if (mobileList) {
                     mobileList.innerHTML = `<div class="text-center text-muted py-5 fw-bold"><i class="fa-solid fa-folder-open d-block fs-1 opacity-25 mb-2"></i> لا توجد عمليات لعرضها.</div>`;
                 }
                 if (mobileListBrief) {
                     mobileListBrief.innerHTML = `<div class="text-center text-muted py-4 fw-bold"><i class="fa-solid fa-folder-open d-block fs-2 opacity-25 mb-2"></i> لا توجد عمليات اليوم.</div>`;
                 }
                 updateTodaySummary([]);
                 return;
            }
            
            // Filter only transfer operations for summary (exclude deposits/deductions)
            const transferTxs = transactions.filter(t => t.status !== 'deposit' && t.status !== 'deduction');
            updateTodaySummary(transactions);
            
            let html = '';
            let seqNum = transferTxs.length;
            let briefCount = 0;
            
            transactions.forEach((tx, idx) => {
                // Skip deposit/deduction from sequential numbering
                const isFinancial = tx.status !== 'deposit' && tx.status !== 'deduction';
                const seq = isFinancial ? seqNum-- : '-';
                
                // Status pipeline
                let statusMarkup = '';
                if (tx.status === 'completed') {
                    // Check if rate was modified by executor
                    const rateModified = tx.adminNotes && tx.adminNotes.includes('تعديل');
                    if (rateModified) {
                        statusMarkup = `<span class="badge-st" style="background: rgba(245,158,11,0.1); color: #d97706; border: 1px solid rgba(245,158,11,0.3); cursor:pointer;" onclick="viewProof('${tx._id}')"><i class="fa-solid fa-check-double"></i> مكتمل (معدّل)</span>`;
                    } else {
                        statusMarkup = `<span class="badge-st st-done" onclick="viewProof('${tx._id}')" style="cursor:pointer;"><i class="fa-solid fa-check-circle"></i> مكتمل</span>`;
                    }
                } else if (tx.status === 'pending') {
                    statusMarkup = `<span class="badge-st st-wait"><i class="fa-solid fa-clock fa-spin"></i> قيد المعالجة</span>`;
                } else if (tx.status === 'processing') {
                    statusMarkup = `<span class="badge-st" style="background: rgba(139,92,246,0.1); color: #7c3aed; border: 1px solid rgba(139,92,246,0.3);"><i class="fa-solid fa-layer-group"></i> في طابور الانتظار</span>`;
                } else if (tx.status === 'accepted') {
                    statusMarkup = `<span class="badge-st st-accepted"><i class="fa-solid fa-gear fa-spin"></i> قيد العمل</span>`;
                } else if (tx.status === 'deposit') {
                    statusMarkup = `<span class="badge-st st-dep"><i class="fa-solid fa-arrow-down"></i> إيداع</span>`;
                } else if (tx.status === 'deduction') {
                    statusMarkup = `<span class="badge-st" style="background: rgba(100,116,139,0.1); color: #64748b; border: 1px solid rgba(100,116,139,0.2);"><i class="fa-solid fa-arrow-up"></i> خصم</span>`;
                } else if (tx.status === 'rejected' || tx.status === 'cancelled_by_admin') {
                    statusMarkup = `<span class="badge-st st-fail"><i class="fa-solid fa-ban"></i> ملغي</span>`;
                } else {
                    statusMarkup = `<span class="badge-st st-wait"><i class="fa-solid fa-spinner fa-spin"></i> ${tx.status}</span>`;
                }
 
                // Transaction ID
                let idContent = (tx.status === 'completed') 
                    ? `<a class="tx-id no-print" onclick="viewProof('${tx._id}')">#${tx.customId || tx._id.toString().slice(-6)}</a>` 
                    : `<span class="tx-id text-muted" style="border:none; cursor:default;">#${tx.customId || tx._id.toString().slice(-6)}</span>`;
                
                // Time in 12h format
                let dateObj = new Date(tx.createdAt);
                let timeStr = dateObj.toLocaleTimeString('en-US', { hour12: true, hour: '2-digit', minute: '2-digit' });
                
                // Cost and rate
                let costDisplay = isSubAccount ? (tx.subAccountCostLYD || tx.costLYD || 0).toFixed(2) : (tx.costLYD ? tx.costLYD.toFixed(2) : '0.00');
                let exRateDisplay = isSubAccount ? (tx.subClientRate || tx.exchangeRate || 0).toFixed(2) : (tx.exchangeRate ? tx.exchangeRate.toFixed(2) : '-');
                
                // Account number
                let numStr = tx.vodafoneNumber || tx.accountNumber || '---';
                
                // Actions
                let actionsHtml = '';
                if (isFinancial) {
                    let whatsappBtn = '';
                    // If proof images exist and completed, show WhatsApp button
                    if (tx.status === 'completed' && tx.proofImages && tx.proofImages.length > 0) {
                        whatsappBtn = `<button class="btn btn-sm btn-success d-flex align-items-center gap-1" onclick="sendToWhatsApp('${tx._id}')" title="إرسال للعميل عبر واتساب"><i class="fa-brands fa-whatsapp"></i></button>`;
                    }
                    let complaintBtn = `<button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1" onclick="submitComplaint('${tx._id}', '${tx.customId}')" title="تقديم شكوى"><i class="fa-solid fa-flag"></i></button>`;
                    actionsHtml = `<div class="d-flex gap-1 justify-content-center">${whatsappBtn} ${complaintBtn}</div>`;
                }
 
                html += `<tr>
                    <td class="fw-bold text-center" style="font-size: 0.85rem;">${seq}</td>
                    <td>${idContent}</td>
                    <td class="tx-amount">${tx.amount ? tx.amount.toFixed(2) : '0.00'}</td>
                    <td>
                        <span class="fw-bold mono-num" style="color: var(--brand-gold);">${costDisplay}</span>
                        <br><small class="text-muted">سعر: ${exRateDisplay}</small>
                    </td>
                    <td dir="ltr" class="tx-phone">${numStr}</td>
                    <td style="font-size: 0.8rem; color: var(--text-muted); font-family: monospace; font-weight: 700;">${timeStr}</td>
                    <td>${statusMarkup}</td>
                    <td>${actionsHtml}</td>
                </tr>`;

                // Mobile Render (Full ledger on mobile container if present)
                if (mobileList) {
                    let mobileActionsHtml = '';
                    if (isFinancial) {
                        let whatsappBtn = '';
                        if (tx.status === 'completed' && tx.proofImages && tx.proofImages.length > 0) {
                            whatsappBtn = `<button class="btn btn-sm btn-success d-flex align-items-center gap-1 py-1 px-2 fw-bold" onclick="sendToWhatsApp('${tx._id}')"><i class="fa-brands fa-whatsapp"></i></button>`;
                        }
                        let complaintBtn = `<button class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1 py-1 px-2 fw-bold" onclick="submitComplaint('${tx._id}', '${tx.customId}')"><i class="fa-solid fa-flag"></i></button>`;
                        mobileActionsHtml = `<div class="mobile-tx-actions">${whatsappBtn} ${complaintBtn}</div>`;
                    }

                    let mobileIdContent = (tx.status === 'completed') 
                        ? `<a class="tx-custom-id text-decoration-none" onclick="viewProof('${tx._id}')" style="cursor:pointer;">#${tx.customId || tx._id.toString().slice(-6)}</a>` 
                        : `<span class="tx-custom-id text-muted">#${tx.customId || tx._id.toString().slice(-6)}</span>`;

                    mobileList.innerHTML += `
                    <div class="mobile-tx-card">
                        <div class="mobile-tx-header">
                            ${mobileIdContent}
                            ${statusMarkup}
                        </div>
                        <div class="mobile-tx-body">
                            <div class="tx-amount-section">
                                <div class="tx-amount-wrapper">
                                    <span class="tx-amount">${tx.amount ? tx.amount.toFixed(2) : '0.00'}</span>
                                    <span class="tx-currency">EGP</span>
                                </div>
                                <div class="tx-cost-wrapper ${tx.status === 'deposit' ? 'text-success' : 'text-danger'}">
                                    <span class="fw-bold">${costDisplay}</span>
                                    <span class="tx-currency">LYD</span>
                                    <span class="badge bg-secondary-subtle text-secondary" style="font-size:0.65rem; padding: 2px 6px;">سعر: ${exRateDisplay}</span>
                                </div>
                            </div>
                            <div class="text-start">
                                <span class="tx-phone">${numStr}</span>
                            </div>
                        </div>
                        <div class="mobile-tx-divider"></div>
                        <div class="mobile-tx-date-row">
                            <span><i class="fa-solid fa-clock opacity-50 me-1"></i> ${timeStr}</span>
                            ${mobileActionsHtml}
                        </div>
                    </div>`;
                }

                // Mobile Brief Render (Account Tab - max 5 operations)
                if (mobileListBrief && briefCount < 5) {
                    briefCount++;
                    let mobileIdContent = (tx.status === 'completed') 
                        ? `<a class="tx-custom-id text-decoration-none" onclick="viewProof('${tx._id}')" style="cursor:pointer;">#${tx.customId || tx._id.toString().slice(-6)}</a>` 
                        : `<span class="tx-custom-id text-muted">#${tx.customId || tx._id.toString().slice(-6)}</span>`;

                    mobileListBrief.innerHTML += `
                    <div class="mobile-tx-card" style="padding: 12px 14px; border-radius: 14px; gap: 8px;">
                        <div class="mobile-tx-header">
                            ${mobileIdContent}
                            ${statusMarkup}
                        </div>
                        <div class="mobile-tx-body">
                            <div class="tx-amount-section">
                                <div class="tx-amount-wrapper">
                                    <span class="tx-amount" style="font-size: 1.15rem;">${tx.amount ? tx.amount.toFixed(2) : '0.00'}</span>
                                    <span class="tx-currency">EGP</span>
                                </div>
                                <div class="tx-cost-wrapper ${tx.status === 'deposit' ? 'text-success' : 'text-danger'}" style="font-size: 0.82rem;">
                                    <span class="fw-bold">${costDisplay}</span>
                                    <span class="tx-currency">LYD</span>
                                </div>
                            </div>
                            <div class="text-start" style="font-size: 0.85rem;">
                                <span class="tx-phone">${numStr}</span>
                            </div>
                        </div>
                    </div>`;
                }
            });
            tbody.innerHTML = html;
        }

        function updateTodaySummary(transactions) {
            let totalLYD = 0, totalEGP = 0, totalDeposits = 0, txCount = 0;
            transactions.forEach(tx => {
                if (tx.status === 'deposit') {
                    totalDeposits += (tx.amount || 0);
                } else if (tx.status !== 'deduction' && tx.status !== 'rejected' && tx.status !== 'cancelled_by_admin') {
                    totalLYD += (tx.costLYD || 0);
                    totalEGP += (tx.amount || 0);
                    txCount++;
                }
            });
            document.getElementById('todayTotalLYD').innerHTML = totalLYD.toFixed(2) + ' <small class="text-muted" style="font-size: 0.6em;">LYD</small>';
            document.getElementById('todayTotalEGP').innerHTML = totalEGP.toFixed(2) + ' <small class="text-muted" style="font-size: 0.7em;">EGP</small>';
            document.getElementById('todayTotalDeposits').innerHTML = totalDeposits.toFixed(2) + ' <small class="text-muted" style="font-size: 0.6em;">LYD</small>';
            document.getElementById('todayTxCount').innerText = txCount;
        }

        async function sendToWhatsApp(txId) {
            const tx = window.allTransactions.find(t => t._id === txId);
            if (!tx) return;
            const notes = tx.notes || '';
            let clientPhone = '';
            const phoneMatch = notes.match(/رقم العميل:\s*(\+?\d+)/);
            if (phoneMatch) clientPhone = phoneMatch[1];
            
            if (!clientPhone) {
                Swal.fire({
                    icon: 'info',
                    title: 'لا يوجد رقم عميل',
                    text: 'لم يتم إضافة رقم هاتف العميل في هذه العملية.',
                    confirmButtonText: 'حسناً'
                });
                return;
            }
            const proofUrl = window.location.origin + `/client/proxy/image/${txId}/0`;
            
            try {
                const response = await fetch(proofUrl);
                if (!response.ok) throw new Error('Image fetch failed');
                const blob = await response.blob();
                const file = new File([blob], `receipt_${tx.customId}.jpg`, { type: blob.type });

                if (navigator.canShare && navigator.canShare({ files: [file] })) {
                    try {
                        await navigator.share({
                            files: [file],
                            title: 'إيصال تحويل',
                            text: 'تم التحويل بنجاح ✅'
                        });
                        return; // Successfully shared
                    } catch (shareError) {
                        console.log('Share failed', shareError);
                    }
                }
                
                try {
                    const item = new ClipboardItem({ [blob.type]: blob });
                    await navigator.clipboard.write([item]);
                    
                    Swal.fire({
                        icon: 'success',
                        title: 'تم نسخ الصورة',
                        text: 'تم نسخ صورة الإثبات بنجاح. سيتم تحويلك للواتساب الآن، فقط قم بـ "لصق" (Paste) للصورة في المحادثة لترسلها للعميل.',
                        timer: 4000,
                        showConfirmButton: false
                    }).then(() => {
                        const message = `تم التحويل بنجاح ✅`;
                        const waUrl = `https://wa.me/${clientPhone}?text=${encodeURIComponent(message)}`;
                        window.open(waUrl, '_blank');
                    });
                } catch(clipboardErr) {
                    throw new Error('Clipboard write failed');
                }
            } catch(e) {
                const message = `تم التحويل بنجاح ✅\nإليك رابط إثبات التحويل:\n${proofUrl}`;
                const waUrl = `https://wa.me/${clientPhone}?text=${encodeURIComponent(message)}`;
                window.open(waUrl, '_blank');
            }
        }

        async function submitComplaint(txId, customId) {
            const { value: complaintNote } = await Swal.fire({
                title: `شكوى للعملية #${customId}`,
                input: 'textarea',
                inputLabel: 'اكتب ملاحظة الشكوى:',
                inputPlaceholder: 'اشرح المشكلة بالتفصيل...',
                inputAttributes: { 'aria-label': 'ملاحظة الشكوى' },
                showCancelButton: true,
                confirmButtonText: '<i class="fa-solid fa-paper-plane me-1"></i> إرسال الشكوى',
                cancelButtonText: 'إلغاء',
                inputValidator: (value) => { if (!value) return 'يرجى كتابة ملاحظة الشكوى!'; },
                customClass: { popup: 'swal2-popup' }
            });
            if (complaintNote) {
                try {
                    const res = await fetch('/client/complaint', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ transactionId: txId, complaintText: complaintNote })
                    });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire({ icon: 'success', title: 'تم إرسال الشكوى', text: 'سيتم فحص العملية من قبل الإدارة.', confirmButtonText: 'حسناً' });
                    } else {
                        Swal.fire({ icon: 'error', title: 'خطأ', text: data.error || 'حدث خطأ.', confirmButtonText: 'حسناً' });
                    }
                } catch(e) {
                    Swal.fire({ icon: 'error', title: 'خطأ', text: 'تعذر الاتصال بالخادم.' });
                }
            }
        }

        const txDataElement = document.getElementById('transactionsData');
        if (txDataElement && txDataElement.textContent) {
            try {
                const initialData = JSON.parse(txDataElement.textContent);
                renderClientTransactionsTable(initialData);
            } catch(e){}
        }

        fetchLiveClientPortalData();
        setInterval(fetchLiveClientPortalData, 3000);

        

        // Theme Toggle
        function toggleTheme() {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            document.documentElement.setAttribute('data-bs-theme', next);
            localStorage.setItem('ahram_theme', next);
            const icon = document.getElementById('themeIcon');
            if (icon) icon.className = next === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
            const mIcon = document.getElementById('mobileThemeIcon');
            if (mIcon) mIcon.className = next === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
        }
        // Set initial icon
        (function() {
            const theme = document.documentElement.getAttribute('data-theme');
            const icon = document.getElementById('themeIcon');
            if (icon) icon.className = theme === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
            const mIcon = document.getElementById('mobileThemeIcon');
            if (mIcon) mIcon.className = theme === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
        })();

        // 📱 Mobile View - DOM elements relocation & Tab Switcher
        let isMobileLayoutDone = false;
        function setupMobileLayout() {
            if (window.innerWidth <= 768 && !isMobileLayoutDone) {
                isMobileLayoutDone = true;
                
                // Move wallet card
                const walletCard = document.querySelector('.desktop-only-layout .wallet-card');
                const walletPlaceholder = document.getElementById('mobile-wallet-card-placeholder');
                if (walletCard && walletPlaceholder) {
                    walletPlaceholder.appendChild(walletCard);
                }

                // Move transfer form
                const transferForm = document.getElementById('transferForm');
                const transferPlaceholder = document.getElementById('mobile-transfer-form-placeholder');
                if (transferPlaceholder) {
                    if (transferForm) {
                        transferPlaceholder.appendChild(transferForm);
                    }
                }

                // Move rates card
                const ratesCard = document.getElementById('ratesCardContainer');
                const ratesPlaceholder = document.getElementById('mobile-rates-placeholder');
                if (ratesCard && ratesPlaceholder) {
                    ratesPlaceholder.appendChild(ratesCard);
                }
                
                // Ensure default transfer type is activated if not selected
                if (!currentTransferType) {
                    handleTransferTypeChange('كاش');
                }
            }
        }

        function switchMobileTab(tabName) {
            // Reset transfers wizard if switching to transfers tab
            if (tabName === 'transfers') {
                goBackToServices();
            }

            // Update active state on tab contents
            const contents = document.querySelectorAll('.mobile-tab-content');
            contents.forEach(el => {
                if (el.id === `mobile-tab-${tabName}`) {
                    el.classList.add('active');
                } else {
                    el.classList.remove('active');
                }
            });

            // Update active state on nav items
            const navItems = document.querySelectorAll('.bottom-nav-mobile .bottom-nav-item');
            navItems.forEach(el => {
                if (el.getAttribute('data-tab') === tabName) {
                    el.classList.add('active');
                } else {
                    el.classList.remove('active');
                }
            });

            // Update URL parameter without reload
            const url = new URL(window.location);
            url.searchParams.set('tab', tabName);
            window.history.pushState({}, '', url);
        }

        function selectTransferService(type) {
            // Set the service type in both desktop elements
            handleTransferTypeChange(type);

            // Update the title on the detail screen
            const serviceTitles = {
                'كاش': 'تحويل محافظ كاش',
                'بريد بطاقة': 'البريد المصري (بطاقة)',
                'بريد حساب': 'البريد المصري (حساب)',
                'حساب بنكي': 'حساب بنكي مصري',
                'سيفا النيجر': 'سيفا النيجر',
                'بنكك السودان': 'بنكك السودان'
            };
            const titleEl = document.getElementById('selectedServiceTitle');
            if (titleEl) {
                titleEl.innerText = serviceTitles[type] || 'تفاصيل التحويل';
            }

            // Hide grid and show form details screen
            document.getElementById('mobile-transfer-services-grid').style.display = 'none';
            document.getElementById('mobile-transfer-form-view').style.display = 'block';
        }

        function selectEgyptPostService() {
            selectTransferService('بريد حساب');
            const titleEl = document.getElementById('selectedServiceTitle');
            if (titleEl) titleEl.innerText = 'البريد المصري';
        }

        function goBackToServices() {
            // Show grid and hide form details screen
            const gridEl = document.getElementById('mobile-transfer-services-grid');
            const formViewEl = document.getElementById('mobile-transfer-form-view');
            if (gridEl) gridEl.style.display = 'block';
            if (formViewEl) formViewEl.style.display = 'none';
        }

        function selectTransferServiceDesktop(type) {
            // Set the service type
            handleTransferTypeChange(type);

            // Update the title on the detail screen
            const serviceTitles = {
                'كاش': 'تحويل محافظ كاش',
                'بريد بطاقة': 'البريد المصري (بطاقة)',
                'بريد حساب': 'البريد المصري (حساب)',
                'حساب بنكي': 'حساب بنكي مصري',
                'سيفا النيجر': 'سيفا النيجر',
                'بنكك السودان': 'بنكك السودان'
            };
            const titleEl = document.getElementById('selectedServiceTitleDesktop');
            if (titleEl) {
                titleEl.innerText = serviceTitles[type] || 'تفاصيل التحويل';
            }

            // Hide grid and show form details screen
            document.getElementById('desktop-transfer-services-grid').style.display = 'none';
            document.getElementById('desktop-transfer-form-view').style.display = 'block';
        }

        function selectEgyptPostServiceDesktop() {
            selectTransferServiceDesktop('بريد حساب');
            const titleEl = document.getElementById('selectedServiceTitleDesktop');
            if (titleEl) titleEl.innerText = 'البريد المصري';
        }

        function goBackToServicesDesktop() {
            // Show grid and hide form details screen
            const gridEl = document.getElementById('desktop-transfer-services-grid');
            const formViewEl = document.getElementById('desktop-transfer-form-view');
            if (gridEl) gridEl.style.display = 'block';
            if (formViewEl) formViewEl.style.display = 'none';
        }

        document.addEventListener('DOMContentLoaded', () => {
            setupMobileLayout();
            
            // Check URL search params for tab
            const urlParams = new URLSearchParams(window.location.search);
            const initialTab = urlParams.get('tab') || 'account';
            if (['account', 'transfers', 'rates'].includes(initialTab)) {
                switchMobileTab(initialTab);
            }

            // Reset desktop transfer modal when closed
            const modalEl = document.getElementById('transferModal');
            if (modalEl) {
                modalEl.addEventListener('hidden.bs.modal', () => {
                    goBackToServicesDesktop();
                });
            }
        });

        window.addEventListener('resize', setupMobileLayout);
    </script>

