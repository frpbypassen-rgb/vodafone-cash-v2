<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>بوابة العملاء | Al-Ahram Pay</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
        document.documentElement.setAttribute('data-bs-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        /* 🎨 المتغيرات (الوضع النهاري - Premium Light) */
        :root { 
            --brand-primary: #001a4d; --brand-gold: #d4af37; 
            --bg-body: #f4f7fa; --card-bg: #ffffff;
            --text-main: #1e293b; --text-muted: #64748b;
            --border-glass: #e2e8f0; --input-bg: #f8fafc;
            --shadow-soft: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            --accent-green: #10b981; --accent-red: #ef4444; --accent-blue: #0ea5e9;
        }

        /* 🌙 المتغيرات (الوضع الليلي - Premium Dark) */
        [data-theme="dark"] {
            --brand-primary: #3b82f6; --brand-gold: #fbbf24; 
            --bg-body: #0f172a; --card-bg: #1e293b; 
            --text-main: #f8fafc; --text-muted: #94a3b8;
            --border-glass: #334155; --input-bg: #0f172a;
            --shadow-soft: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
            --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
        }

        body { background-color: var(--bg-body); color: var(--text-main); font-family: 'Tajawal', sans-serif; transition: background-color 0.3s, color 0.3s; padding-bottom: 50px; overflow-x: hidden; }
        
        ::-webkit-scrollbar { width: 6px; height: 6px; } 
        ::-webkit-scrollbar-track { background: transparent; } 
        ::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 10px; }

        .mono-num { font-family: 'JetBrains Mono', Tahoma, sans-serif; font-weight: bold; letter-spacing: 0.5px;}

        /* 🛸 Navbar */
        .navbar-custom { background: var(--card-bg); border-bottom: 1px solid var(--border-glass); padding: 15px 0; position: sticky; top: 0; z-index: 1000; box-shadow: var(--shadow-soft); transition: 0.3s; margin-bottom: 40px;}
        .logo-img { height: 40px; transition: 0.3s; mix-blend-mode: multiply; filter: contrast(1.2); }
        [data-theme="dark"] .logo-img { mix-blend-mode: normal; background: white; padding: 2px; border-radius: 8px; }
        .navbar-brand { color: var(--brand-primary) !important; font-weight: 900; font-size: 1.5rem; margin: 0; letter-spacing: -0.5px;}
        [data-theme="dark"] .navbar-brand { color: var(--brand-gold) !important; }

        .nav-actions { display: flex; gap: 10px; align-items: center; }
        .nav-btn { background: var(--input-bg); border: 1px solid var(--border-glass); color: var(--text-main); padding: 10px 20px; border-radius: 12px; font-weight: 700; text-decoration: none; transition: 0.3s; display: inline-flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.9rem;}
        .nav-btn:hover { background: var(--card-bg); color: var(--brand-primary); border-color: var(--brand-primary); box-shadow: var(--shadow-soft); transform: translateY(-2px);}
        [data-theme="dark"] .nav-btn:hover { color: var(--brand-gold); border-color: var(--brand-gold); }
        
        .btn-theme { border-radius: 12px; width: 44px; padding: 0; justify-content: center; color: var(--brand-gold); border-color: var(--border-glass);}
        .btn-theme:hover { background: var(--brand-gold); color: #000; }
        .nav-logout { color: var(--accent-red); border-color: var(--border-glass); }
        .nav-logout:hover { background: var(--accent-red) !important; color: white !important; border-color: var(--accent-red) !important;}

        /* 🚀 💳 3D Interactive VIP Balance Card */
        .wallet-wrapper { 
            margin-top: 35px; margin-bottom: 25px; 
            perspective: 1000px; 
        }
        .wallet-card { 
            background: linear-gradient(135deg, #001a4d 0%, #000814 100%); 
            border-radius: 28px; padding: 40px; color: white; 
            position: relative; overflow: hidden; 
            box-shadow: 0 20px 40px -10px rgba(0, 26, 77, 0.4); margin-bottom: 30px; 
            display: flex; flex-direction: column; justify-content: space-between; min-height: 220px;
            transform-style: preserve-3d; 
            transition: transform 0.1s ease-out, box-shadow 0.3s ease-out; 
        }
        [data-theme="dark"] .wallet-card { 
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); 
            border: 1px solid rgba(255,255,255,0.05); 
        }
        
        .wallet-card::before { 
            content: ''; position: absolute; right: -20%; top: -50%; width: 300px; height: 300px; 
            background: radial-gradient(circle, rgba(212,175,55,0.15) 0%, transparent 70%); 
            border-radius: 50%; pointer-events: none; 
            transform: translateZ(-10px); 
        }
        .wallet-card::after {
            content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(to right, transparent, rgba(255,255,255,0.1), transparent);
            transform: skewX(-20deg); transition: 0.5s; pointer-events: none; z-index: 5;
        }
        .wallet-card:hover::after { left: 150%; }

        .wallet-card > div { transform: translateZ(40px); }

        .wallet-label { font-size: 0.9rem; font-weight: 700; color: rgba(255,255,255,0.6); margin-bottom: 5px; text-transform: uppercase; letter-spacing: 1px;}
        .wallet-balance { font-family: 'JetBrains Mono', monospace; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; margin: 0; color: #fff; line-height: 1; letter-spacing: 1px; position: relative; z-index: 2; text-shadow: 0 10px 20px rgba(0,0,0,0.5);}
        .wallet-balance span { color: var(--brand-gold); font-size: 1.5rem; vertical-align: super; margin-right: 5px;}
        .wallet-footer { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; position: relative; z-index: 2;}
        .wallet-name { font-size: 1.1rem; font-weight: 800; color: rgba(255,255,255,0.9); }
        .wallet-logo { font-size: 1.8rem; color: var(--brand-gold); opacity: 0.8; }

        /* 💱 شريط أسعار الصرف الحي */
        .live-rates-bar { background: var(--card-bg); border-radius: 20px; padding: 15px 25px; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; box-shadow: var(--shadow-soft); border: 1px solid var(--border-glass); margin-bottom: 40px; transition: 0.3s;}
        .rate-title { font-weight: 800; color: var(--text-muted); font-size: 0.9rem; display: flex; align-items: center; gap: 8px;}
        .rate-items { display: flex; gap: 15px; flex-wrap: wrap;}
        .rate-item { display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 1rem; color: var(--text-main);}
        .rate-item i { color: var(--brand-gold); }
        .rate-val { font-family: 'JetBrains Mono', monospace; color: var(--brand-primary); background: var(--input-bg); padding: 4px 10px; border-radius: 8px; border: 1px solid var(--border-glass); transition: 0.3s;}
        [data-theme="dark"] .rate-val { color: var(--brand-gold); }

        /* 🚀 Apps & Premium Button (3D Effect) */
        .app-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-bottom: 40px; perspective: 1000px;}
        .app-btn { 
            background: var(--card-bg); border: 1px solid var(--border-glass); border-radius: 24px; padding: 25px 15px; text-align: center; 
            cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; text-decoration: none;
            box-shadow: var(--shadow-soft); transform-style: preserve-3d;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease, border-color 0.3s ease;
        }
        .app-btn:hover { border-color: var(--brand-gold); transform: translateY(-8px) scale(1.02); box-shadow: 0 15px 35px rgba(0,0,0,0.1); }
        [data-theme="dark"] .app-btn:hover { box-shadow: 0 15px 35px rgba(0,0,0,0.4); }
        
        .app-icon { width: 65px; height: 65px; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; transition: 0.3s; transform: translateZ(20px);}
        .app-btn:hover .app-icon { transform: translateZ(40px) scale(1.1); color: #fff !important; }
        .app-title { font-weight: 800; font-size: 0.95rem; color: var(--text-main); margin: 0; transform: translateZ(10px);}
        
        .premium-transfer-btn { position: relative; overflow: hidden; border: 1px solid rgba(14, 165, 233, 0.3) !important; background: linear-gradient(180deg, var(--card-bg) 0%, rgba(14, 165, 233, 0.02) 100%) !important; }
        [data-theme="dark"] .premium-transfer-btn { background: linear-gradient(180deg, var(--card-bg) 0%, rgba(14, 165, 233, 0.05) 100%) !important; }
        .premium-transfer-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%; background: linear-gradient(to right, transparent, rgba(14, 165, 233, 0.1), transparent); transform: skewX(-20deg); transition: 0.7s; }
        .premium-transfer-btn:hover::after { left: 150%; }
        .premium-icon.icon-1 { background: linear-gradient(135deg, rgba(14, 165, 233, 0.2), rgba(37, 99, 235, 0.2)); color: #0ea5e9; box-shadow: 0 0 15px rgba(14, 165, 233, 0.15); transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .premium-transfer-btn:hover .premium-icon.icon-1 { background: linear-gradient(135deg, #0ea5e9, #2563eb); color: white !important; box-shadow: 0 10px 25px rgba(14, 165, 233, 0.4); transform: scale(1.15) translateY(-5px); }
        .premium-icon i { animation: moneyFly 1.5s infinite alternate ease-in-out; }
        @keyframes moneyFly { 0% { transform: translateX(0); } 100% { transform: translateX(-4px) translateY(-2px); } }
        .premium-badge { position: absolute; top: 12px; right: 12px; background: rgba(16, 185, 129, 0.15); color: #10b981; font-size: 0.65rem; font-weight: 800; padding: 3px 8px; border-radius: 20px; border: 1px solid rgba(16, 185, 129, 0.3); display: flex; align-items: center; gap: 3px; transform: translateZ(30px); }

        .icon-2 { background: rgba(16, 185, 129, 0.1); color: #10b981; } .app-btn:hover .icon-2 { background: #10b981; }
        .icon-4 { background: rgba(139, 92, 246, 0.1); color: #8b5cf6; } .app-btn:hover .icon-4 { background: #8b5cf6; }

        /* Stats (3D Hover) */
        .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; perspective: 1000px;}
        .stat-card { 
            background: var(--card-bg); border: 1px solid var(--border-glass); border-radius: 20px; padding: 25px; 
            display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; position: relative; overflow: hidden;
            box-shadow: var(--shadow-soft); transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
        [data-theme="dark"] .stat-card:hover { box-shadow: 0 15px 30px rgba(0,0,0,0.4); }
        .stat-card::before { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 4px; }
        .stat-card.c-blue::before { background: #0ea5e9; } .stat-card.c-green::before { background: #10b981; } .stat-card.c-gold::before { background: var(--brand-gold); }
        .stat-label { font-size: 0.85rem; font-weight: 700; color: var(--text-muted); margin-bottom: 8px;}
        .stat-val { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 900; color: var(--text-main); line-height: 1;}

        /* Table */
        .ledger-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; flex-wrap: wrap; gap: 15px;}
        .ledger-title { font-size: 1.3rem; font-weight: 900; color: var(--text-main); margin: 0;}
        .filter-box { display: flex; gap: 10px; align-items: center; background: var(--card-bg); padding: 8px; border-radius: 16px; border: 1px solid var(--border-glass); box-shadow: var(--shadow-soft);}
        .filter-input { border: none; background: var(--input-bg); border-radius: 10px; padding: 8px 15px; color: var(--text-main); font-weight: 700; outline: none;}
        .filter-btn { background: var(--brand-primary); color: white; border: none; border-radius: 10px; padding: 8px 20px; font-weight: 800; cursor: pointer; transition: 0.2s;}
        [data-theme="dark"] .filter-btn { background: var(--brand-gold); color: black;}

        .table-custom { width: 100%; border-collapse: separate; border-spacing: 0 10px; }
        .table-custom th { border: none; color: var(--text-muted); font-weight: 800; font-size: 0.85rem; padding: 10px 15px; white-space: nowrap; text-align: center;}
        .table-custom tbody tr { background: var(--card-bg); box-shadow: var(--shadow-soft); transition: 0.2s; }
        .table-custom tbody tr:hover { transform: scale(1.01); box-shadow: var(--shadow-hover); }
        .table-custom td { border: 1px solid var(--border-glass); border-style: solid none; padding: 18px 15px; vertical-align: middle; font-weight: 700; text-align: center; white-space: nowrap;}
        .table-custom td:first-child { border-left: 1px solid var(--border-glass); border-top-right-radius: 16px; border-bottom-right-radius: 16px; }
        .table-custom td:last-child { border-right: 1px solid var(--border-glass); border-top-left-radius: 16px; border-bottom-left-radius: 16px; }
        
        .tx-id { font-family: 'JetBrains Mono', monospace; font-weight: 900; color: var(--brand-primary); cursor: pointer; text-decoration: none; border-bottom: 2px dashed rgba(0,26,77,0.3); transition: 0.2s;}
        [data-theme="dark"] .tx-id { color: var(--brand-gold); border-bottom-color: rgba(212,175,55,0.3);}
        .tx-id:hover { opacity: 0.7; }
        .tx-amount { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; color: #10b981; }
        .tx-cost { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; color: #ef4444; }
        .tx-phone { font-family: 'JetBrains Mono', monospace; font-size: 1rem; color: var(--text-main); letter-spacing: 1px;}
        
        /* الحالات والأوسمة */
        .badge-st { padding: 6px 14px; border-radius: 50px; font-size: 0.8rem; font-weight: 800; display: inline-flex; align-items: center; gap: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); white-space: nowrap; }
        .st-done { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
        .st-wait { background: rgba(245, 158, 11, 0.08); color: #d97706; border: 1px solid rgba(245, 158, 11, 0.2); } 
        [data-theme="dark"] .st-wait { color: #fbbf24; background: rgba(251, 191, 36, 0.06); }
        
        .st-accepted { background: rgba(14, 165, 233, 0.1); color: #0284c7; border: 1px solid rgba(14, 165, 233, 0.25); animation: livePulseBlue 2s infinite cubic-bezier(0.4, 0, 0.6, 1); }
        [data-theme="dark"] .st-accepted { color: #38bdf8; background: rgba(56, 189, 248, 0.08); }
        @keyframes livePulseBlue { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.85; transform: scale(0.98); } }
        
        .st-fail { background: rgba(239, 68, 68, 0.08); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }
        [data-theme="dark"] .st-fail { color: #f87171; background: rgba(248, 113, 113, 0.06); }
        .st-dep { background: rgba(14, 165, 233, 0.1); color: #0ea5e9; border: 1px solid rgba(14, 165, 233, 0.2); }

        /* Forms & Modals */
        .form-control, .form-select { background-color: var(--input-bg); color: var(--text-main); border: 1px solid var(--border-glass); border-radius: 14px; padding: 14px 18px; font-weight: 700; transition: 0.3s;}
        .form-control:focus, .form-select:focus { background-color: transparent; border-color: var(--brand-gold); box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15); color: var(--text-main);}
        .input-group-text { background-color: var(--input-bg); border-color: var(--border-glass); color: var(--text-muted); border-radius: 0 14px 14px 0; border-left: none;}
        
        .modal-content { background-color: var(--card-bg); color: var(--text-main); border: 1px solid var(--border-glass); border-radius: 28px; box-shadow: 0 25px 50px rgba(0,0,0,0.5); transform-style: preserve-3d;}
        .modal-header { border-bottom: 1px dashed var(--border-glass); padding: 25px;}
        .btn-submit-cyber { background: linear-gradient(45deg, #0ea5e9, #2563eb); border: none; color: white; border-radius: 14px; font-weight: 800; padding: 16px; width: 100%; font-size: 1.1rem; box-shadow: 0 5px 15px rgba(14, 165, 233, 0.3); transition: 0.3s;}
        .btn-submit-cyber:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(14, 165, 233, 0.5); color: white;}

        .swal2-popup { background: var(--card-bg) !important; color: var(--text-main) !important; border: 1px solid var(--border-glass); border-radius: 24px !important; }
        .swal2-title, .swal2-html-container { color: var(--text-main) !important; }

        @media (max-width: 768px) {
            .navbar-custom { padding: 15px; } .navbar-brand { font-size: 1.2rem; }
            .app-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
            .stats-grid { grid-template-columns: 1fr; gap: 15px; }
            .wallet-card { padding: 30px 20px; } .wallet-balance { font-size: 2.2rem; }
            .filter-box { flex-direction: column; width: 100%; align-items: stretch;}
            .table-responsive { border: none; background: transparent; overflow-x: auto;}
            .table-custom td { padding: 12px 10px; font-size: 0.85rem;}
        }

        /* 🖨️ تصميم التقفيل المجزأ للطباعة فقط */
        @media print {
            body { visibility: hidden; background: white !important; padding: 0 !important; }
            .print-only-segmented {
                visibility: visible; position: absolute; top: 0; left: 0; width: 100%;
                background: white; padding: 20px; font-family: 'Tajawal', sans-serif;
            }
            .print-header { text-align: center; border-bottom: 2px solid #000; padding-bottom: 10px; margin-bottom: 30px; }
            .print-header h1 { margin: 0; font-size: 24px; font-weight: bold; color: #001a4d; }
            .print-header p { margin: 5px 0; font-size: 16px; font-weight: bold; }
            
            .print-table-title { font-weight: bold; font-size: 18px; margin-top: 25px; margin-bottom: 10px; padding: 5px; border-bottom: 2px dashed #ccc; }
            .print-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 13px; }
            .print-table th, .print-table td { border: 1px solid #333; padding: 8px; text-align: center; }
            .print-table th { background-color: #f1f1f1 !important; -webkit-print-color-adjust: exact; }
            
            .print-summary { width: 50%; margin-top: 30px; border: 2px solid #000; border-collapse: collapse; float: right;}
            .print-summary th, .print-summary td { border: 1px solid #000; padding: 10px; font-size: 15px; font-weight: bold; text-align: right; }
            .print-summary th { background-color: #eee !important; -webkit-print-color-adjust: exact; }
        }
        .print-only-segmented { display: none; }
        @media print { .print-only-segmented { display: block; } }

        @keyframes flashUpdate {
            0% { background-color: rgba(16, 185, 129, 0.5); transform: scale(1.1); }
            100% { background-color: var(--input-bg); transform: scale(1); }
        }
        .rate-updated { animation: flashUpdate 1s ease-out; }
    </style>
</head>
<body>

    <audio id="alertSound" src="https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3" preload="auto"></audio>

    <nav class="navbar-custom no-print">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <img src="/images/logo.jpeg" alt="Logo" class="logo-img" onerror="this.onerror=null; this.src='/images/logo.jpg';">
                <h1 class="navbar-brand d-none d-sm-block">Al-Ahram</h1>
            </div>
    
            <div class="d-flex align-items-center gap-2">
                <% if (!user.telegramId) { %>
                    <button class="nav-btn border-primary text-primary" onclick="activateTelegram('client')" title="تفعيل التليجرام"><i class="fa-brands fa-telegram"></i> <span class="d-none d-md-inline ms-1">تفعيل بوت التليجرام</span></button>
                <% } %>
                <span class="nav-btn d-none d-md-flex border-0 pe-none"><i class="fa-solid fa-user-tie text-muted"></i> <%= user.name %></span>
                <button class="nav-btn btn-theme" onclick="toggleTheme()" title="الوضع الليلي/النهاري"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
                <a href="/client/logout" class="nav-btn nav-logout"><i class="fa-solid fa-power-off"></i> <span class="d-none d-sm-inline ms-1">خروج</span></a>
            </div>
        </div>
    </nav>

    <div class="container main-container mb-5 no-print">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="wallet-wrapper">
                    <div class="wallet-card">
                        <div class="d-flex justify-content-between align-items-start position-relative z-1">
                            <div>
                                <div class="wallet-label"><%= isSubAccount ? 'الرصيد الافتراضي المتاح' : 'الرصيد المتاح للعمليات' %></div>
                                <div class="wallet-balance" dir="ltr" id="liveBalanceHolder">
                                    <span class="currency-symbol">LYD</span><%= user.balance.toFixed(2) %>
                                </div>
                            </div>
                            <div style="font-size: 2.5rem; color: rgba(255,255,255,0.8);"><i class="fa-brands fa-cc-mastercard"></i></div>
                        </div>
                        <div class="wallet-footer position-relative z-1">
                            <div class="wallet-name">
                                <i class="fa-solid fa-building me-2 opacity-50"></i><%= user.name %>
                                <% if (isSubAccount) { %><span class="badge bg-light text-dark ms-2 opacity-75" style="font-size: 0.65rem;">نقطة بيع فرعية</span><% } %>
                            </div>
                            <div class="wallet-logo">VIP CLIENT</div>
                        </div>
                    </div>
                </div>

                <div class="live-rates-bar rates-ticker" id="ratesContainer">
                    <div class="rate-title"><i class="fa-solid fa-bolt text-warning"></i> أسعار الصرف لمستواك:</div>
                    <div class="rate-item"><i class="fa-solid fa-mobile-screen-button text-info"></i> كاش <span class="rate-val" id="liveRateCash"><%= currentRate.toFixed(2) %></span></div>
                    <div class="rate-item"><i class="fa-solid fa-envelope text-success"></i> بريد حساب <span class="rate-val" id="liveRatePostAcc"><%= (currentRate - 0.05).toFixed(2) %></span></div>
                    <div class="rate-item"><i class="fa-solid fa-id-card text-warning"></i> بريد بطاقة <span class="rate-val" id="liveRatePostCard"><%= (currentRate - 0.15).toFixed(2) %></span></div>
                </div>
            </div>
        </div>

        <div class="app-grid mt-4">
            <% if (user.role !== 'accountant') { %>
            <a href="#" class="app-btn premium-transfer-btn" data-bs-toggle="modal" data-bs-target="#transferModal">
                <span class="premium-badge"><i class="fa-solid fa-bolt"></i> سريع</span>
                <div class="app-icon icon-1 premium-icon"><i class="fa-solid fa-money-bill-transfer"></i></div>
                <h5 class="app-title">تحويل مالي</h5>
            </a>
            <% } %>

            <% if (!isSubAccount && user.role !== 'accountant') { %>
            <a href="/client/sub-accounts" class="app-btn" style="border-color: rgba(139, 92, 246, 0.3);">
                <div class="app-icon icon-4"><i class="fa-solid fa-users-viewfinder"></i></div>
                <h5 class="app-title">إدارة نقاط البيع</h5>
            </a>
            <% } else if (user.role === 'accountant') { %>
                <div></div><div></div>
            <% } else { %>
                <div></div>
            <% } %>
            
            <a href="/client/support" class="app-btn">
                <div class="app-icon" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;"><i class="fa-solid fa-headset"></i></div>
                <h5 class="app-title">الدعم الفني</h5>
            </a>

            <a href="#" class="app-btn" onclick="activateTelegram()" style="border-color: rgba(14, 165, 233, 0.3);">
                <div class="app-icon" style="background: rgba(14, 165, 233, 0.1); color: #0ea5e9;"><i class="fa-brands fa-telegram"></i></div>
                <h5 class="app-title">تفعيل تليجرام</h5>
            </a>
        </div>

        <div class="stats-grid">
            <div class="stat-card c-blue">
                <span class="stat-label">إجمالي الإيداعات (EGP)</span>
                <span class="stat-val"><%= totals.depositsEGP.toFixed(2) %></span>
            </div>
            <div class="stat-card c-green">
                <span class="stat-label">التحويلات المنفذة (EGP)</span>
                <span class="stat-val"><%= totals.transfersEGP.toFixed(2) %></span>
            </div>
            <div class="stat-card c-gold">
                <span class="stat-label"><%= isMaster ? 'إجمالي التكلفة عليك (LYD)' : 'التكلفة المخصومة منك (LYD)' %></span>
                <span class="stat-val" style="color: var(--brand-gold);" id="liveDeductionsHolder"><%= totals.transfersLYD.toFixed(2) %></span>
            </div>
            <% if (isMaster && typeof masterTotalProfit !== 'undefined' && masterTotalProfit > 0) { %>
            <div class="stat-card" style="grid-column: 1 / -1; border-color: var(--accent-green);">
                <span class="stat-label text-success">إجمالي أرباحك من نقاط البيع (LYD)</span>
                <span class="stat-val text-success">+<%= masterTotalProfit.toFixed(2) %></span>
            </div>
            <% } %>
        </div>

        <div class="ledger-section">
            <div class="ledger-header">
                <h3 class="ledger-title"><i class="fa-solid fa-list-check me-2 text-primary"></i> سجل العمليات المباشر <span class="spinner-grow spinner-grow-sm text-success ms-2" style="vertical-align: middle;"></span></h3>
                
                <form method="GET" action="/client/dashboard" class="filter-box">
                    <input type="text" name="search" class="filter-input" placeholder="بحث برقم أو ملاحظة..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                    <input type="date" name="date" class="filter-input" value="<%= typeof targetDate !== 'undefined' ? targetDate : '' %>">
                    <button type="submit" class="filter-btn"><i class="fa-solid fa-filter"></i> عرض</button>
                    <a href="/client/dashboard?month=true" class="filter-btn" style="background: var(--brand-gold); color:#000; text-decoration:none;"><i class="fa-solid fa-calendar-days"></i> الشهر</a>
                    <button type="button" onclick="window.print()" class="filter-btn" style="background: var(--text-muted);"><i class="fa-solid fa-print"></i></button>
                    <a href="/client/export-excel?type=<%= typeof showMonth !== 'undefined' && showMonth ? 'monthly' : 'daily' %>" class="filter-btn" style="background: #10b981; color:white; text-decoration:none;"><i class="fa-solid fa-file-excel"></i> إكسيل</a>
                </form>
            </div>
            
            <div class="table-responsive">
                <table class="table-custom" id="transactionsTable">
                    <thead>
                        <tr>
                            <th>الرقم</th>
                            <% if (isMaster) { %><th>بواسطة (الجهة المنفذة)</th><% } %>
                            <th>المبلغ (EGP)</th>
                            <th>سعر الصرف</th> 
                            <th>التكلفة (LYD)</th>
                            <th>الرقم / الحساب</th>
                            <th>الوقت</th>
                            <th>الحالة</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        </tbody>
                </table>
            </div>
        </div>
    </div>

    <% 
        const masterTxs = typeof transactions !== 'undefined' ? transactions.filter(t => !t.isSubAccountTx && t.status === 'completed') : [];
        const subTxs = typeof transactions !== 'undefined' ? transactions.filter(t => t.isSubAccountTx && t.status === 'completed') : [];
        const depTxs = typeof transactions !== 'undefined' ? transactions.filter(t => t.status === 'deposit' || t.status === 'deduction') : [];
        
        let mLYD = 0, sLYD = 0, dLYD = 0;
        masterTxs.forEach(t => mLYD += (t.costLYD || 0));
        subTxs.forEach(t => sLYD += (t.costLYD || 0)); 
        depTxs.forEach(t => dLYD += (t.status === 'deposit' ? t.amount : -t.amount));
        const prevBal = user.balance + (mLYD + sLYD) - dLYD;
    %>
    <div class="print-only-segmented">
        <div class="print-header">
            <h1>شــــركــــــــة Al-Ahram Pay لـلـتـقـنـيـة</h1>
            <p>كشف حساب وتقفيل: <%= user.name %> | التاريخ: <%= dateLabel %></p>
        </div>

        <% if (isMaster) { %>
            <div class="print-table-title" style="color: #0ea5e9;">1. تحويلاتي المباشرة (الوكيل)</div>
            <table class="print-table">
                <tr><th>ت</th><th>رقم العملية</th><th>المحفظة / الحساب</th><th>المبلغ EGP</th><th>سعر الصرف</th><th>التكلفة LYD</th></tr>
                <% masterTxs.forEach((t, i) => { %>
                    <tr><td><%= i+1 %></td><td><%= t.customId %></td><td dir="ltr"><%= t.vodafoneNumber || t.accountNumber %></td><td><%= t.amount %></td><td><%= t.exchangeRate %></td><td><%= t.costLYD.toFixed(2) %></td></tr>
                <% }) %>
                <% if(masterTxs.length===0){ %><tr><td colspan="6">لا توجد عمليات مباشرة لك</td></tr><% } %>
                <tr style="background:#f9f9f9; font-weight:bold;"><td colspan="5" style="text-align:left;">إجمالي التكلفة المباشرة:</td><td style="color:#dc3545;"><%= mLYD.toFixed(2) %></td></tr>
            </table>

            <div class="print-table-title" style="color: #8b5cf6;">2. تحويلات العملاء ونقاط البيع</div>
            <table class="print-table">
                <tr><th>ت</th><th>اسم نقطة البيع</th><th>رقم العملية</th><th>المحفظة</th><th>المبلغ EGP</th><th>سعر الإدارة</th><th>التكلفة المخصومة منك</th></tr>
                <% subTxs.forEach((t, i) => { %>
                    <tr><td><%= i+1 %></td><td><%= t.subAccountName %></td><td><%= t.customId %></td><td dir="ltr"><%= t.vodafoneNumber || t.accountNumber %></td><td><%= t.amount %></td><td><%= t.exchangeRate %></td><td><%= t.costLYD.toFixed(2) %></td></tr>
                <% }) %>
                <% if(subTxs.length===0){ %><tr><td colspan="7">لا توجد عمليات من نقاط البيع</td></tr><% } %>
                <tr style="background:#f9f9f9; font-weight:bold;"><td colspan="6" style="text-align:left;">إجمالي المسحوب من نقاط البيع:</td><td style="color:#dc3545;"><%= sLYD.toFixed(2) %></td></tr>
            </table>
        <% } else { %>
            <div class="print-table-title" style="color: #0ea5e9;">سجل التحويلات المنفذة</div>
            <table class="print-table">
                <tr><th>ت</th><th>رقم العملية</th><th>المحفظة / الحساب</th><th>المبلغ EGP</th><th>السعر</th><th>التكلفة LYD</th></tr>
                <% subTxs.forEach((t, i) => { %>
                    <tr><td><%= i+1 %></td><td><%= t.customId %></td><td dir="ltr"><%= t.vodafoneNumber || t.accountNumber %></td><td><%= t.amount %></td><td><%= t.subClientRate %></td><td><%= t.subAccountCostLYD.toFixed(2) %></td></tr>
                <% }) %>
                <tr style="background:#f9f9f9; font-weight:bold;"><td colspan="5" style="text-align:left;">إجمالي التكلفة:</td><td style="color:#dc3545;"><%= sLYD.toFixed(2) %></td></tr>
            </table>
        <% } %>

        <div class="print-table-title" style="color: #10b981;">3. الإيداعات والتسويات</div>
        <table class="print-table">
            <tr><th>ت</th><th>البيان</th><th>المبلغ LYD</th><th>ملاحظات</th></tr>
            <% depTxs.forEach((t, i) => { %>
                <tr><td><%= i+1 %></td><td><%= t.status === 'deposit' ? 'إيداع' : 'خصم تسوية' %></td><td style="color:<%= t.status === 'deposit' ? '#198754' : '#dc3545' %>"><%= t.amount.toFixed(2) %></td><td><%= t.notes %></td></tr>
            <% }) %>
            <% if(depTxs.length===0){ %><tr><td colspan="4">لا توجد حركات تسوية</td></tr><% } %>
        </table>

        <table class="print-summary">
            <tr><th>الرصيد السابق (مرحل):</th><td><%= prevBal.toFixed(2) %> LYD</td></tr>
            <tr><th>إجمالي المسدد للإدارة (+):</th><td><%= dLYD.toFixed(2) %> LYD</td></tr>
            <tr><th>إجمالي المسحوب للتحويلات (-):</th><td><%= (mLYD + sLYD).toFixed(2) %> LYD</td></tr>
            <tr><th style="background:#001a4d !important; color:white;">الرصيد الختامي المتبقي:</th><td style="color:<%= user.balance < 0 ? '#dc3545' : '#198754' %>; font-size:18px;"><%= user.balance.toFixed(2) %> LYD</td></tr>
        </table>
    </div>

    <div class="modal fade" id="transferModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0 pt-4 px-4 position-relative">
                    <button type="button" class="btn-close position-absolute" data-bs-dismiss="modal" style="left: 20px; filter: invert(0.5);"></button>
                    <h5 class="modal-title fw-bold" style="color: var(--accent-blue);"><i class="fa-solid fa-paper-plane-top me-2"></i> طلب تحويل مالي</h5>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-4 pb-3 border-bottom" style="border-color: var(--border-glass) !important;">
                        <label class="form-label fw-bold small text-muted">نوع الخدمة المطلوب تنفيذها:</label>
                        <div class="input-group input-group-lg shadow-sm">
                            <span class="input-group-text"><i class="fa-solid fa-list-check" style="color: var(--brand-gold);"></i></span>
                            <select class="form-select fw-bold" id="transferTypeSelect" onchange="handleTransferTypeChange(this.value)">
                                <option value="" disabled selected>-- يرجى اختيار نوع التحويل --</option>
                                <option value="كاش">📱 محافظ إلكترونية (فودافون/أورانج/اتصالات/وي)</option>
                                <option value="بريد حساب">📮 بريد حساب</option>
                                <option value="بريد بطاقة">💳 بريد بطاقة</option>
                            </select>
                        </div>
                    </div>
                    
                    <form id="transferForm">
                        <div id="dynamicFormFields" style="display: none;">
                            <div class="mb-3" id="beneficiary_name_div" style="display: none;">
                                <label class="form-label small fw-bold text-muted">اسم المستفيد (رباعي)</label>
                                <input type="text" class="form-control text-center fw-bold" id="tf_beneficiary" placeholder="اكتب الاسم رباعي">
                            </div>
                            <div class="mb-3" id="national_id_div" style="display: none;">
                                <label class="form-label small fw-bold text-muted">الرقم القومي (14 رقم)</label>
                                <input type="text" class="form-control text-center mono-num" id="tf_national_id" placeholder="14 رقم" dir="ltr" maxlength="14">
                            </div>
                            <div class="mb-3" id="id_image_div" style="display: none;">
                                <label class="form-label small fw-bold text-muted">صورة البطاقة من الأمام</label>
                                <input type="file" class="form-control p-2" id="tf_id_image" accept="image/*">
                            </div>
                            <div class="mb-3" id="phone_div" style="display: none;">
                                <label class="form-label small fw-bold text-muted" id="lbl_tf_phone">رقم المستلم</label>
                                <div class="position-relative">
                                    <input type="text" class="form-control text-center mono-num fs-5" id="tf_phone" placeholder="010XXXXXXXX" dir="ltr" oninput="checkNetworkLogo()">
                                    <img id="network_logo" src="" alt="Logo" style="display: none; position: absolute; left: 12px; top: 50%; transform: translateY(-50%); height: 35px; width: 35px; border-radius: 8px; background: white; padding: 2px;">
                                </div>
                            </div>
                            <div class="mb-3" id="governorate_div" style="display: none;">
                                <label class="form-label small fw-bold text-muted">المحافظة</label>
                                <select class="form-select text-center fw-bold" id="tf_governorate">
                                    <option value="" disabled selected>اختر المحافظة</option>
                                    <option value="القاهرة">القاهرة</option><option value="الإسكندرية">الإسكندرية</option><option value="الجيزة">الجيزة</option>
                                </select>
                            </div>
                            <div class="mb-3 mt-4">
                                <label class="form-label small fw-bold text-muted">المبلغ بالمصري (EGP)</label>
                                <input type="number" class="form-control text-center fs-2 mono-num" style="color: var(--accent-green) !important; border-color: rgba(16, 185, 129, 0.4); background: rgba(16, 185, 129, 0.05);" id="tf_amount" placeholder="0.00">
                            </div>
                            <div class="p-3 rounded-4 mb-4 text-center border" style="background: rgba(212, 175, 55, 0.05); border-color: rgba(212, 175, 55, 0.2) !important;">
                                <span class="small d-block text-muted fw-bold mb-1">الخصم المتوقع من الرصيد (LYD)</span>
                                <h3 class="fw-bold m-0 mono-num" style="color: var(--brand-gold);" id="tf_cost">0.00</h3>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold small text-muted">ملاحظات إضافية (اختياري)</label>
                                <input type="text" class="form-control" id="tf_notes" placeholder="اكتب أي ملاحظة هنا...">
                            </div>
                            <button type="submit" class="btn-submit-cyber" id="btnSubmitTransfer"><i class="fa-solid fa-rocket me-2"></i> تأكيد وإرسال الطلب</button>
                        </div> 
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="proofModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 bg-transparent shadow-none" style="box-shadow: none;">
                <div class="modal-header border-0 p-3 position-absolute top-0 w-100 z-3" style="background: linear-gradient(180deg, rgba(0,0,0,0.8), transparent);">
                    <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0" id="proofContainer" style="min-height: 400px; display: flex; align-items: center; justify-content: center;"></div>
            </div>
        </div>
    </div>

    <script id="transactionsData" type="application/json">
        <%- JSON.stringify(typeof transactions !== 'undefined' ? transactions : []) %>
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // 🪄 سحر الـ 3D لبطاقة الرصيد
        const walletCard = document.querySelector('.wallet-card');
        if (walletCard) {
            walletCard.addEventListener('mousemove', (e) => {
                const rect = walletCard.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                
                const rotateX = ((y - centerY) / centerY) * -10; 
                const rotateY = ((x - centerX) / centerX) * 10;
                
                walletCard.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
                walletCard.style.boxShadow = `${-rotateY}px ${rotateX}px 30px rgba(0,0,0,0.3)`;
            });

            walletCard.addEventListener('mouseleave', () => {
                walletCard.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
                walletCard.style.boxShadow = `0 20px 40px -10px rgba(0, 26, 77, 0.4)`;
                walletCard.style.transition = `transform 0.5s ease-out, box-shadow 0.5s ease-out`;
            });
            
            walletCard.addEventListener('mouseenter', () => {
                walletCard.style.transition = `none`; 
            });
        }

        let currentRate = parseFloat("<%= currentRate %>") || 1;
        let currentTransferType = '';
        const isSubAccount = <%= typeof isSubAccount !== 'undefined' ? isSubAccount : false %>;
        const isMaster = <%= typeof isMaster !== 'undefined' ? isMaster : false %>;

        function checkNetworkLogo() {
            const val = document.getElementById('tf_phone').value;
            const logoEl = document.getElementById('network_logo'); const phoneInput = document.getElementById('tf_phone');
            if (currentTransferType !== 'كاش' || val.length < 3) { logoEl.style.opacity = '0';
                phoneInput.style.paddingLeft = "15px"; setTimeout(() => { if(val.length < 3) logoEl.style.display = 'none'; }, 300); return;
            }
            logoEl.style.display = 'block'; logoEl.style.opacity = 1;
            phoneInput.style.paddingLeft = "55px";
            if (val.startsWith('010')) logoEl.src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%23e60000'/%3E%3Ccircle cx='50' cy='50' r='35' fill='%23ffffff'/%3E%3Cpath d='M49 32c-11.7 0-16 9.8-16 18.4 0 7.4 4.9 13.1 11.6 13.1 7 0 11.8-5.3 11.8-12 0-6.9-3.8-10.4-9-10.4-2.6 0-5 1.1-6.6 3 0.8-7.2 4.4-9.8 8.1-9.8zm0 30c-3.2 0-5.3-2.6-5.3-6 0-3.6 2.3-6 5.3-6s5.3 2.4 5.3 6c0 3.5-2.1 6-5.3 6z' fill='%23e60000'/%3E%3C/svg%3E";
            else if (val.startsWith('011')) logoEl.src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%23699e10'/%3E%3Ctext x='50' y='63' font-family='Arial' font-weight='900' font-size='24' fill='%23ffffff' text-anchor='middle'%3Eetisalat%3C/text%3E%3C/svg%3E";
            else if (val.startsWith('012')) logoEl.src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%23ff6600'/%3E%3Crect x='25' y='25' width='50' height='50' fill='%23ffffff'/%3E%3Crect x='25' y='60' width='50' height='15' fill='%23000000'/%3E%3Crect x='25' y='25' width='50' height='35' fill='%23ff6600'/%3E%3C/svg%3E";
            else if (val.startsWith('015')) logoEl.src = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%234a186e'/%3E%3Ctext x='50' y='68' font-family='Arial' font-weight='900' font-size='42' fill='%23ffffff' text-anchor='middle'%3Ewe%3C/text%3E%3C/svg%3E";
            else { logoEl.style.opacity = '0'; phoneInput.style.paddingLeft = "15px"; setTimeout(() => { if(val.length < 3) logoEl.style.display = 'none'; }, 300); }
        }

        function updateCost() {
            if(!currentTransferType) return;
            let rate = currentRate;
            if (currentTransferType === 'بريد حساب') rate = currentRate - 0.05;
            else if (currentTransferType === 'بريد بطاقة') rate = currentRate - 0.15;
            const amountInput = document.getElementById('tf_amount');
            if (amountInput) { const amount = parseFloat(amountInput.value) || 0; document.getElementById('tf_cost').innerText = (amount / rate).toFixed(2); }
        }

        function handleTransferTypeChange(type) {
            currentTransferType = type;
            document.getElementById('dynamicFormFields').style.display = 'block';
            document.getElementById('tf_phone').value = ''; document.getElementById('tf_beneficiary').value = ''; document.getElementById('tf_national_id').value = ''; document.getElementById('tf_id_image').value = '';
            document.getElementById('tf_governorate').value = ''; document.getElementById('tf_amount').value = ''; document.getElementById('tf_cost').innerText = '0.00'; checkNetworkLogo();

            if (type === 'كاش') { document.getElementById('beneficiary_name_div').style.display = 'none';
                document.getElementById('national_id_div').style.display = 'none'; document.getElementById('id_image_div').style.display = 'none'; document.getElementById('phone_div').style.display = 'block'; document.getElementById('lbl_tf_phone').innerText = 'رقم المحفظة (فودافون/أورانج/اتصالات/وي)'; document.getElementById('tf_phone').placeholder = 'مثال: 010XXXXXXXX';
                document.getElementById('tf_phone').required = true; document.getElementById('tf_phone').setAttribute('maxlength', '11'); document.getElementById('tf_phone').setAttribute('minlength', '11'); document.getElementById('governorate_div').style.display = 'none'; document.getElementById('tf_governorate').required = false; document.getElementById('tf_phone').focus();
            } 
            else if (type === 'بريد حساب') { document.getElementById('beneficiary_name_div').style.display = 'block';
                document.getElementById('national_id_div').style.display = 'none'; document.getElementById('id_image_div').style.display = 'none'; document.getElementById('phone_div').style.display = 'block'; document.getElementById('lbl_tf_phone').innerText = 'رقم الحساب البريدي'; document.getElementById('tf_phone').placeholder = 'أدخل 16 رقم';
                document.getElementById('tf_phone').required = true; document.getElementById('tf_phone').setAttribute('maxlength', '16'); document.getElementById('tf_phone').setAttribute('minlength', '16'); document.getElementById('governorate_div').style.display = 'none'; document.getElementById('tf_governorate').required = false; document.getElementById('tf_phone').focus();
            } 
            else if (type === 'بريد بطاقة') { document.getElementById('beneficiary_name_div').style.display = 'block';
                document.getElementById('national_id_div').style.display = 'block'; document.getElementById('id_image_div').style.display = 'block'; document.getElementById('phone_div').style.display = 'none'; document.getElementById('tf_phone').required = false; document.getElementById('governorate_div').style.display = 'block'; document.getElementById('tf_governorate').required = true;
            }
            document.getElementById('tf_amount').required = true; updateCost();
        }

        const amountInput = document.getElementById('tf_amount'); if (amountInput) amountInput.addEventListener('input', updateCost);
        
        const transferForm = document.getElementById('transferForm');
        if (transferForm) {
            transferForm.addEventListener('submit', async function(e) {
                e.preventDefault(); if(!currentTransferType) return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى اختيار نوع التحويل.', customClass: { popup: 'swal2-popup' } });
                let phoneVal = '';
                if (currentTransferType === 'بريد بطاقة') { phoneVal = document.getElementById('tf_governorate').value; if (!phoneVal) return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى اختيار المحافظة.', customClass: { popup: 'swal2-popup' } }); } else { phoneVal = document.getElementById('tf_phone').value.trim(); if (currentTransferType === 'بريد حساب' && !/^\d{16}$/.test(phoneVal)) return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'حساب البريد يجب أن يكون 16 رقم.', customClass: { popup: 'swal2-popup' } }); if (currentTransferType === 'كاش' && !/^(010|011|012|015)\d{8}$/.test(phoneVal)) return Swal.fire({ icon: 'error', title: 'رقم خاطئ', text: 'رقم المحفظة غير صحيح.', customClass: { popup: 'swal2-popup' } }); }
                
                let finalNotes = document.getElementById('tf_notes').value.trim();
                let prefix = `[${currentTransferType}]`; let base64Image = null;
                if (currentTransferType === 'بريد حساب' || currentTransferType === 'بريد بطاقة') { const benName = document.getElementById('tf_beneficiary').value.trim();
                    if (benName.split(/\s+/).filter(n => n.length > 0).length < 4) return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'الاسم رباعي إجباري.', customClass: { popup: 'swal2-popup' } });
                    prefix += ` - ${benName}`; }
                if (currentTransferType === 'بريد بطاقة') { const natId = document.getElementById('tf_national_id').value.trim();
                    if (!/^\d{14}$/.test(natId)) return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'الرقم القومي يجب أن يكون 14 رقم.', customClass: { popup: 'swal2-popup' } });
                    prefix += ` - ${natId}`; const fileInput = document.getElementById('tf_id_image'); if (!fileInput.files || fileInput.files.length === 0) return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'أرفق صورة البطاقة.', customClass: { popup: 'swal2-popup' } });
                    const file = fileInput.files[0]; base64Image = await new Promise((resolve) => { const reader = new FileReader(); reader.onload = () => resolve(reader.result); reader.readAsDataURL(file); });
                }
                
                const btn = document.getElementById('btnSubmitTransfer');
                const originalText = btn.innerHTML; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> إرسال...'; btn.disabled = true;
                finalNotes = `${prefix} ` + (finalNotes ? `| ${finalNotes}` : '');
                
                try {
                    const response = await fetch('/client/transfer', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: JSON.stringify({ phone: phoneVal, amount: document.getElementById('tf_amount').value, notes: finalNotes, type: currentTransferType, imageBase64: base64Image }) });
                    const result = await response.json();
                    
                    if (response.ok) {
                        // 🎭 المشهد المسرحي (Gamification Alert 3D)
                        Swal.fire({
                            showConfirmButton: false, 
                            allowOutsideClick: false,
                            background: 'transparent',
                            backdrop: 'rgba(0,0,10,0.9)',
                            html: `
                            <div style="background: var(--card-bg); border-radius: 24px; padding: 40px; position: relative; overflow: hidden; box-shadow: 0 0 50px rgba(16, 185, 129, 0.2); text-align: right; direction: rtl;">
                                <h3 class="fw-bold text-success mb-2" id="success-title">تم إرسال الطلب بنجاح! 🚀</h3>
                                <p class="text-muted fw-bold mb-4">${result.message}</p>
                                
                                <div style="position: relative; height: 120px; width: 100%; display: flex; align-items: flex-end; direction: ltr;">
                                    <div id="magic-door" style="font-size: 60px; position: absolute; left: 10px; bottom: 0; z-index: 1; transition: 0.3s; transform-origin: left;">🚪</div>
                                    
                                    <div id="hammer-guy" style="font-size: 50px; position: absolute; left: 30px; bottom: -20px; opacity: 0; z-index: 2; transition: all 0.7s cubic-bezier(0.25, 1, 0.5, 1);">
                                        <span style="display:inline-block; transform: scaleX(-1);">🏃‍♂️</span>
                                        <span id="the-hammer" style="position:absolute; top: -10px; right: -20px; font-size: 40px; transition: transform 0.15s ease-in; transform-origin: bottom left;">🔨</span>
                                    </div>

                                    <div id="fake-ok-btn" style="position: absolute; right: 10px; bottom: 20px; background: #10b981; color: white; font-weight: 900; font-size: 1.2rem; padding: 10px 30px; border-radius: 12px; box-shadow: 0 10px 20px rgba(16, 185, 129, 0.4); transition: all 0.1s ease-out; font-family: 'Tajawal', sans-serif;">
                                        تم
                                    </div>
                                </div>
                            </div>
                            `,
                            didOpen: () => {
                                const door = document.getElementById('magic-door');
                                const guy = document.getElementById('hammer-guy');
                                const hammer = document.getElementById('the-hammer');
                                const btnFake = document.getElementById('fake-ok-btn');
                                const popup = document.querySelector('.swal2-popup');

                                // 🎬 تسلسل الحركة
                                setTimeout(() => {
                                    door.style.transform = 'scaleX(0.2) skewY(-15deg)'; 
                                    guy.style.opacity = '1';
                                    guy.style.bottom = '10px';
                                    
                                    setTimeout(() => {
                                        guy.style.left = 'calc(100% - 130px)';
                                        guy.style.bottom = '40px'; 
                                        
                                        setTimeout(() => {
                                            guy.style.bottom = '20px'; 
                                            
                                            setTimeout(() => {
                                                hammer.style.transform = 'rotate(85deg)';
                                                
                                                setTimeout(() => {
                                                    btnFake.style.transform = 'scaleY(0.2) scaleX(1.3) translateY(20px)';
                                                    btnFake.style.background = '#ef4444';
                                                    btnFake.style.color = 'transparent';
                                                    btnFake.style.boxShadow = 'none';
                                                    
                                                    popup.animate([
                                                        { transform: 'translate(1px, 1px) rotate(0deg)' },
                                                        { transform: 'translate(-3px, 0px) rotate(-1deg)' },
                                                        { transform: 'translate(3px, 2px) rotate(1deg)' },
                                                        { transform: 'translate(0px, -1px) rotate(0deg)' }
                                                    ], { duration: 300, iterations: 1 });

                                                    setTimeout(() => {
                                                        Swal.close();
                                                        window.location.reload();
                                                    }, 800); 

                                                }, 100); 
                                            }, 200); 
                                        }, 400); 
                                    }, 500); 
                                }, 600); 
                            }
                        });
                    } else { 
                        Swal.fire({ icon: 'error', title: 'عذراً!', text: result.error, customClass: { popup: 'swal2-popup' } }); 
                        btn.innerHTML = originalText; btn.disabled = false; 
                    }
                } catch (error) { 
                    Swal.fire({ icon: 'error', title: 'خطأ', text: 'تأكد من الاتصال.', customClass: { popup: 'swal2-popup' } });
                    btn.innerHTML = originalText; btn.disabled = false; 
                }
            });
        }

        // 🧾 Proof Viewer Logic
        function viewProof(txId) {
            const container = document.getElementById('proofContainer');
            container.innerHTML = '<div class="text-white fw-bold text-center w-100 py-5"><i class="fa-solid fa-spinner fa-spin fa-2x mb-3 d-block mx-auto text-primary"></i> جاري جلب الإيصالات...</div>';
            new bootstrap.Modal(document.getElementById('proofModal')).show();
            container.innerHTML = `
                <div id="carouselExample" class="carousel slide w-100 p-2">
                    <div class="carousel-inner" style="border-radius: 20px; overflow: hidden; background: rgba(0,0,0,0.5);">
                        <div class="carousel-item active"><img src="/client/proxy/image/${txId}/0" class="d-block w-100" style="max-height: 85vh; object-fit: contain;" onerror="this.src='/images/no-image.png'"></div>
                        <div class="carousel-item"><img src="/client/proxy/image/${txId}/1" class="d-block w-100" style="max-height: 85vh; object-fit: contain;" onerror="this.parentElement.remove()"></div>
                        <div class="carousel-item"><img src="/client/proxy/image/${txId}/2" class="d-block w-100" style="max-height: 85vh; object-fit: contain;" onerror="this.parentElement.remove()"></div>
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
                </div>`;
        }

        // 📡 نظام التحديث اللحظي للعميل (Smart Diffing & Live Notifications)
        let lastRenderedDataHash = '';
        async function fetchLiveClientPortalData() {
            try {
                const response = await fetch('/client/api/transactions' + window.location.search);
                if (!response.ok) return; 
                const data = await response.json();
                
                if (data.success) {
                    
                    // 🔔 1. نظام إشعار وتحديث سعر الصرف اللحظي
                    if (data.currentRate) {
                        let fetchedRate = parseFloat(data.currentRate);
                        if (Math.abs(fetchedRate - currentRate) > 0.001 && currentRate > 0) {
                            
                            currentRate = fetchedRate;
                            const rateCash = document.getElementById('liveRateCash');
                            const ratePostAcc = document.getElementById('liveRatePostAcc');
                            const ratePostCard = document.getElementById('liveRatePostCard');
                            
                            if(rateCash) { rateCash.innerText = currentRate.toFixed(2); rateCash.classList.add('rate-updated'); setTimeout(()=>rateCash.classList.remove('rate-updated'), 1000); }
                            if(ratePostAcc) { ratePostAcc.innerText = (currentRate - 0.05).toFixed(2); ratePostAcc.classList.add('rate-updated'); setTimeout(()=>ratePostAcc.classList.remove('rate-updated'), 1000); }
                            if(ratePostCard) { ratePostCard.innerText = (currentRate - 0.15).toFixed(2); ratePostCard.classList.add('rate-updated'); setTimeout(()=>ratePostCard.classList.remove('rate-updated'), 1000); }
                            
                            updateCost();
                            document.getElementById('alertSound').play().catch(()=>{});
                            
                            Swal.fire({
                                toast: true, position: 'top-end', icon: 'info', title: 'تحديث الأسعار 🔔',
                                html: `<b>تم تعديل سعر الصرف لمستواك ليصبح: ${currentRate.toFixed(2)}</b><br><small>تم التحديث تلقائياً في شاشتك.</small>`,
                                showConfirmButton: false, timer: 8000, timerProgressBar: true, customClass: { popup: 'swal2-popup' }
                            });
                        } else if (currentRate === 0) {
                            currentRate = fetchedRate;
                        }
                    }

                    if(data.availableBalance !== undefined) document.getElementById('liveBalanceHolder').innerHTML = `<span class="currency-symbol">LYD</span>${data.availableBalance.toFixed(2)}`;
                    if(data.totalDeductions !== undefined && document.getElementById('liveDeductionsHolder')) document.getElementById('liveDeductionsHolder').innerText = data.totalDeductions.toFixed(2);

                    const currentHash = JSON.stringify(data.transactions);
                    if (currentHash !== lastRenderedDataHash) {
                        lastRenderedDataHash = currentHash;
                        renderClientTransactionsTable(data.transactions);
                    }
                }
            } catch (error) {}
        }

        function renderClientTransactionsTable(transactions) {
            const tbody = document.getElementById('tableBody');
            
            if (!transactions || transactions.length === 0) {
                 tbody.innerHTML = `<tr><td colspan="${isMaster ? 8 : 7}" style="text-align: center; padding: 40px; color: var(--text-muted); font-weight: bold; border:none; background: transparent;"><i class="fa-solid fa-folder-open fs-1 opacity-25 d-block mb-3"></i> لا توجد عمليات لعرضها.</td></tr>`;
                 return;
            }
            
            let html = '';
            transactions.forEach(tx => {
                let statusMarkup = '';
                if (tx.status === 'completed') {
                    statusMarkup = tx.transferType !== 'card_sale' 
                        ? `<span class="badge-st st-done" onclick="viewProof('${tx._id}')" style="cursor:pointer;"><i class="fa-solid fa-check-circle"></i> مكتمل</span>`
                        : `<span class="badge-st st-done" style="text-decoration:none;"><i class="fa-solid fa-box-open"></i> مستلم</span>`;
                } else if (tx.status === 'deposit') { statusMarkup = `<span class="badge-st st-dep"><i class="fa-solid fa-arrow-down"></i> شحن رصيد</span>`; }
                else if (tx.status === 'accepted') { statusMarkup = `<span class="badge-st st-accepted"><i class="fa-solid fa-gear fa-spin"></i> قيد العمل</span>`; }
                else if (tx.status === 'pending' || tx.status === 'processing') { statusMarkup = `<span class="badge-st st-wait"><i class="fa-solid fa-spinner fa-spin"></i> معالجة</span>`; } 
                else if (tx.status === 'deduction') { statusMarkup = `<span class="badge-st st-fail" style="background: rgba(100,116,139,0.1); color: #64748b; border-color: rgba(100,116,139,0.2);"><i class="fa-solid fa-arrow-up"></i> سحب رصيد</span>`; }
                else { statusMarkup = `<span class="badge-st st-fail"><i class="fa-solid fa-ban"></i> ملغي</span>`; }

                let idContent = (tx.status === 'completed' && tx.transferType !== 'card_sale') ? `<a class="tx-id no-print" onclick="viewProof('${tx._id}')">#${tx.customId || tx._id.toString().slice(-6)}</a><span class="mono-num print-only" style="display:none; font-size:1rem;">#${tx.customId}</span>` : `<span class="tx-id text-muted" style="border:none; cursor:default;">#${tx.customId || tx._id.toString().slice(-6)}</span>`;
                let dateObj = new Date(tx.createdAt);
                
                let costDisplay = isSubAccount ? (tx.subAccountCostLYD || tx.costLYD).toFixed(2) : (tx.costLYD ? tx.costLYD.toFixed(2) : '0.00');
                let exRateDisplay = isSubAccount ? (tx.subClientRate || tx.exchangeRate).toFixed(2) : (tx.exchangeRate ? tx.exchangeRate.toFixed(2) : '-');
                if (tx.transferType === 'card_sale') exRateDisplay = 'مبيعات';
                
                let commissionBadge = (!isSubAccount && tx.masterProfit > 0) ? `<br><small class="text-success no-print">+ ${tx.masterProfit.toFixed(2)} ربح</small>` : '';

                let numStrP = tx.vodafoneNumber || tx.accountNumber || '';
                let netHtml = '';
                if(tx.transferType !== 'post_account' && tx.transferType !== 'post_card' && tx.status !== 'deposit' && tx.status !== 'deduction' && numStrP) {
                    if(numStrP.startsWith('010')) { netHtml = '<div class="fw-bold small mt-1 no-print"><span style="color: #dc3545;">فودافون</span></div>'; }
                    else if(numStrP.startsWith('011')) { netHtml = '<div class="fw-bold small mt-1 no-print"><span style="color: #198754;">اتصالات</span></div>'; }
                    else if(numStrP.startsWith('012')) { netHtml = '<div class="fw-bold small mt-1 no-print"><span style="color: #fd7e14;">اورانج</span></div>'; }
                    else if(numStrP.startsWith('015')) { netHtml = '<div class="fw-bold small mt-1 no-print"><span style="color: #0dcaf0;">وي</span></div>'; }
                }

                let executorCell = '';
                if (isMaster) {
                    if (tx.isSubAccountTx) {
                        executorCell = `<td><span class="badge bg-primary bg-opacity-10 text-primary border border-primary"><i class="fa-solid fa-store me-1"></i> نقطة بيع: ${tx.subAccountName}</span></td>`;
                    } else {
                        executorCell = `<td><span class="small text-muted"><i class="fa-solid fa-user opacity-50 me-1"></i> حسابك الشخصي</span></td>`;
                    }
                }

                html += `<tr>
                    <td>${idContent}</td>
                    ${executorCell}
                    <td class="tx-amount">${tx.amount ? tx.amount.toFixed(2) : '0.00'}</td>
                    <td style="font-family: monospace; font-weight: 800; color: var(--brand-gold);">${exRateDisplay}</td>
                    <td class="tx-cost">${costDisplay} ${commissionBadge}</td>
                    <td dir="ltr" class="tx-phone">${numStrP || '---'}${netHtml}</td>
                    <td style="font-size: 0.8rem; color: var(--text-muted); font-family: monospace; font-weight: 700;">${dateObj.toLocaleTimeString('en-US', { hour12: true, hour: '2-digit', minute: '2-digit' })} <br><span class="opacity-50">${dateObj.toLocaleDateString('en-GB')}</span></td>
                    <td>${statusMarkup}</td>
                </tr>`;
            });
            tbody.innerHTML = html;
        }

        const txDataElement = document.getElementById('transactionsData');
        if (txDataElement && txDataElement.textContent) {
            try {
                const initialData = JSON.parse(txDataElement.textContent);
                renderClientTransactionsTable(initialData);
            } catch(e){}
        }

        fetchLiveClientPortalData();
        setInterval(fetchLiveClientPortalData, 3000);

        async function activateTelegram(type) {
            try {
                if (!type) type = 'client';
                Swal.fire({ title: 'جاري توليد الرابط...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                const res = await fetch(`/${type}/generate-telegram-token`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
                const data = await res.json();
                if (data.success) {
                    Swal.close();
                    const prefix = type === 'client' ? 'LINK-CLIENT-' : 'LINK-EXEC-';
                    const link = `https://t.me/${data.botUsername}?start=${prefix}${data.token}`;
                    window.open(link, '_blank');
                    
                    Swal.fire({
                        icon: 'success',
                        title: 'تم التوجيه للتليجرام',
                        text: 'الرجاء الضغط على Start / بدء في البوت لتفعيل حسابك.',
                        confirmButtonText: 'حسناً'
                    }).then(() => location.reload());
                } else {
                    Swal.fire('خطأ', data.message || 'حدث خطأ أثناء توليد الرابط', 'error');
                }
            } catch (e) {
                Swal.fire('خطأ', 'تعذر الاتصال بالخادم', 'error');
            }
        }

        // Theme Toggle
        function toggleTheme() {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            document.documentElement.setAttribute('data-bs-theme', next);
            localStorage.setItem('ahram_theme', next);
            const icon = document.getElementById('themeIcon');
            if (icon) icon.className = next === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
        }
        // Set initial icon
        (function() {
            const theme = document.documentElement.getAttribute('data-theme');
            const icon = document.getElementById('themeIcon');
            if (icon) icon.className = theme === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
        })();
    </script>
</body>
</html>