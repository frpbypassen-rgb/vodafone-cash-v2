            <!-- قائمة العمليات للموبايل (تظهر كبطاقات تطبيق) -->
            <div class="mobile-ops-list d-flex flex-column gap-3 d-md-none mb-4" id="mobileTransactionsList"></div>
        </div>
        </div> <!-- End of desktop-only-layout -->

        <!-- Mobile Tab-based Layout -->
        <div class="mobile-only-layout d-md-none px-1" style="margin-top: 15px;">
            <!-- Tab 1: Account -->
            <div class="mobile-tab-content active" id="mobile-tab-account">
                <!-- Wallet Card (Client Balance Card) -->
                <div id="mobile-wallet-card-placeholder" class="mb-4"></div>

                <!-- Client Info Card for Mobile -->
                <div class="mobile-profile-card mb-4">
                    <div class="mobile-profile-card-header">
                        <div class="mobile-profile-card-icon">
                            <i class="fa-solid fa-address-card"></i>
                        </div>
                        <h6 class="mobile-profile-card-title">بطاقة تعريف العميل</h6>
                    </div>
                    
                    <div class="mobile-profile-row">
                        <span class="mobile-profile-label"><i class="fa-solid fa-tags"></i>نوع الحساب:</span>
                        <span class="badge bg-info-subtle text-info py-1.5 px-3 rounded-pill" style="font-size: 0.72rem; font-weight: 800;"><%= profile.accountTypeName %></span>
                    </div>
                    <% if (profile.accountTypeDetail) { %>
                        <div class="mobile-profile-row">
                            <span class="mobile-profile-label">
                                <% if (profile.accountTypeName === 'شركة') { %>
                                    <i class="fa-solid fa-building"></i>اسم الشركة:
                                <% } else if (profile.accountTypeName === 'وكيل') { %>
                                    <i class="fa-solid fa-user-tie"></i>اسم الوكيل:
                                <% } else if (profile.accountTypeName === 'عميل جديد') { %>
                                    <i class="fa-solid fa-user-group"></i>الوكيل التابع له:
                                <% } else { %>
                                    <i class="fa-solid fa-circle-info"></i>التفاصيل:
                                <% } %>
                            </span>
                            <span class="mobile-profile-value text-primary"><%= profile.accountTypeDetail %></span>
                        </div>
                    <% } %>
                    <div class="mobile-profile-row">
                        <span class="mobile-profile-label"><i class="fa-solid fa-user"></i>اسم العميل:</span>
                        <span class="mobile-profile-value"><%= profile.name %></span>
                    </div>
                    <div class="mobile-profile-row">
                        <span class="mobile-profile-label"><i class="fa-solid fa-shield-halved"></i>رتبة الحساب:</span>
                        <span class="badge bg-secondary-subtle text-secondary py-1.5 px-3 rounded-pill" style="font-size: 0.72rem; font-weight: 800;"><%= profile.userRoleLabel %></span>
                    </div>
                    <div class="mobile-profile-row">
                        <span class="mobile-profile-label"><i class="fa-solid fa-phone"></i>رقم الهاتف:</span>
                        <span class="mobile-profile-value" dir="ltr"><%= profile.phone %></span>
                    </div>
                    <div class="mobile-profile-row">
                        <span class="mobile-profile-label"><i class="fa-solid fa-id-badge"></i>ID الحساب:</span>
                        <span class="mobile-profile-value mono-num" dir="ltr"><%= profile.accountCode || 'غير محدد' %></span>
                    </div>
                    <div class="mobile-profile-row">
                        <span class="mobile-profile-label"><i class="fa-solid fa-user-gear"></i>اسم المستخدم:</span>
                        <span class="mobile-profile-value"><%= profile.username %></span>
                    </div>
                    <div class="mobile-profile-row">
                        <span class="mobile-profile-label"><i class="fa-solid fa-clock-rotate-left"></i>حالة النظام:</span>
                        <% if (profile.systemStatus === 'تعمل') { %>
                            <span class="badge bg-success-subtle text-success py-1.5 px-3 rounded-pill" style="font-size: 0.72rem; font-weight: 800;"><i class="fa-solid fa-lock-open me-1"></i><%= profile.systemStatus %></span>
                        <% } else { %>
                            <span class="badge bg-danger-subtle text-danger py-1.5 px-3 rounded-pill" style="font-size: 0.72rem; font-weight: 800;"><i class="fa-solid fa-lock me-1"></i><%= profile.systemStatus %></span>
                        <% } %>
                    </div>
                </div>

                <% if (user.role !== 'accountant') { %>
                    <div class="mb-4">
                        <button type="button" class="btn w-100 d-flex align-items-center justify-content-center gap-3 fw-bold shadow-sm" onclick="openBalanceTransferModal()" style="background: linear-gradient(135deg, #0f766e, #115e59); color: #fff; border: none; border-radius: 16px; padding: 16px 14px;">
                            <i class="fa-solid fa-wallet fs-4"></i>
                            <span>تحويل رصيد لحساب آخر</span>
                        </button>
                    </div>
                <% } %>

                <h5 class="fw-bold mb-3" style="color: var(--text-main); font-size: 1.1rem;">
                    <i class="fa-solid fa-clock-rotate-left text-primary me-2"></i> العمليات الأخيرة اليوم
                </h5>
                <div class="mobile-ops-list d-flex flex-column gap-3 mb-4" id="mobileTransactionsListBrief">
                    <!-- Brief compact list will go here -->
                </div>

                <div class="text-center mt-3 mb-4">
                    <a href="/client/reports" class="btn btn-outline-primary w-100 py-2 fw-bold" style="border-radius: 12px; font-size: 0.9rem;">
                        <i class="fa-solid fa-list-check me-2"></i> عرض جميع تقارير العمليات
                    </a>
                </div>
            </div>

            <!-- Tab 2: Transfers -->
            <div class="mobile-tab-content" id="mobile-tab-transfers">
                <!-- Screen 1: Services Grid -->
                <div id="mobile-transfer-services-grid" class="mb-4">
                    <h5 class="fw-bold mb-3 text-center" style="color: var(--text-main); font-size: 1.15rem;">
                        <i class="fa-solid fa-layer-group text-primary me-2"></i>اختر خدمة التحويل
                    </h5>
                    <div class="services-mobile-grid">
                        <div class="service-card-item" onclick="selectTransferService('كاش')">
                            <div class="service-card-icon sc-cash"><img src="/images/vodafone_cash_official.png" alt="محافظ كاش فودافون" style="width: 100%; height: 100%; object-fit: cover; border-radius: 14px;"></div>
                            <span class="service-card-title">تحويل محافظ كاش</span>
                        </div>
                        <div class="service-card-item" onclick="selectEgyptPostService()">
                            <div class="service-card-icon sc-post-acc"><img src="/images/egypt_post_official.png" alt="البريد المصري" style="width: 100%; height: 100%; object-fit: cover; border-radius: 14px;"></div>
                            <span class="service-card-title">البريد المصري</span>
                        </div>
                        <div class="service-card-item" onclick="selectTransferService('حساب بنكي')">
                            <div class="service-card-icon sc-bank"><img src="/images/instapay_official.png" alt="حساب بنكي انستا باي" style="width: 100%; height: 100%; object-fit: cover; border-radius: 14px;"></div>
                            <span class="service-card-title">حساب بنكي مصري</span>
                        </div>
                        <div class="service-card-item" onclick="selectTransferService('سيفا النيجر')">
                            <div class="service-card-icon sc-niger"><img src="/images/nita_official.png" alt="سيفا النيجر NITA" style="width: 100%; height: 100%; object-fit: cover; border-radius: 14px;"></div>
                            <span class="service-card-title">سيفا النيجر</span>
                        </div>
                        <div class="service-card-item" onclick="selectTransferService('بنكك السودان')">
                            <div class="service-card-icon sc-sudan"><img src="/images/bok_sudan_official.png" alt="بنكك السودان" style="width: 100%; height: 100%; object-fit: cover; border-radius: 14px;"></div>
                            <span class="service-card-title">بنكك السودان</span>
                        </div>
                    </div>
                </div>

                <!-- Screen 2: Form Details -->
                <div id="mobile-transfer-form-view" class="card p-4 shadow-sm mb-4" style="display: none; background: var(--card-bg); border: 1px solid var(--border-glass); border-radius: 20px;">
                    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="goBackToServices()">
                            <i class="fa-solid fa-arrow-right me-1"></i>رجوع للخدمات
                        </button>
                        <h6 class="fw-bold m-0 text-primary" id="selectedServiceTitle">تفاصيل التحويل</h6>
                    </div>
                    <div id="mobile-transfer-form-placeholder"></div>
                </div>
            </div>

            <!-- Tab 3: Rates -->
            <div class="mobile-tab-content" id="mobile-tab-rates">
                <div class="card p-4 shadow-sm mb-4" style="background: var(--card-bg); border: 1px solid var(--border-glass); border-radius: 20px;">
                    <h5 class="fw-bold mb-4" style="color: var(--text-main); font-size: 1.15rem;">
                        <i class="fa-solid fa-money-bill-trend-up text-success me-2"></i> أسعار الصرف الحالية لمستواك
                    </h5>
                    <div id="mobile-rates-placeholder"></div>
                </div>
            </div>
        </div>
    </div>

    <% 
        const masterTxs = typeof transactions !== 'undefined' ? transactions.filter(t => !t.isSubAccountTx && t.status === 'completed') : [];
        const subTxs = typeof transactions !== 'undefined' ? transactions.filter(t => t.isSubAccountTx && t.status === 'completed') : [];
        const depTxs = typeof transactions !== 'undefined' ? transactions.filter(t => t.status === 'deposit' || t.status === 'deduction') : [];
        
        let mLYD = 0, sLYD = 0, dLYD = 0;
        masterTxs.forEach(t => mLYD += (t.costLYD || 0));
        subTxs.forEach(t => sLYD += (t.costLYD || 0)); 
        depTxs.forEach(t => dLYD += (t.status === 'deposit' ? t.amount : -t.amount));
        const prevBal = (user.canViewBalance ? user.balance : 0) + (mLYD + sLYD) - dLYD;
    %>
    <div class="print-only-segmented">
        <div class="print-header">
            <h1>شــــركــــــــة Al-Ahram Pay لـلـتـقـنـيـة</h1>
            <p>كشف حساب وتقفيل: <%= user.name %> | التاريخ: <%= dateLabel %></p>
        </div>

        <% if (isMaster) { %>
            <div class="print-table-title" style="color: #0ea5e9;">1. تحويلاتي المباشرة (الوكيل)</div>
            <table class="print-table">
                <tr><th>ت</th><th>رقم العملية</th><th>المحفظة / الحساب</th><th>المبلغ EGP</th><th>سعر الصرف</th><th>التكلفة LYD</th></tr>
                <% masterTxs.forEach((t, i) => { %>
                    <tr><td><%= i+1 %></td><td><%= t.customId %></td><td dir="ltr"><%= t.vodafoneNumber || t.accountNumber %></td><td><%= t.amount %></td><td><%= t.exchangeRate %></td><td><%= t.costLYD.toFixed(2) %></td></tr>
                <% }) %>
                <% if(masterTxs.length===0){ %><tr><td colspan="6">لا توجد عمليات مباشرة لك</td></tr><% } %>
                <tr style="background:#f9f9f9; font-weight:bold;"><td colspan="5" style="text-align:left;">إجمالي التكلفة المباشرة:</td><td style="color:#dc3545;"><%= mLYD.toFixed(2) %></td></tr>
            </table>

            <div class="print-table-title" style="color: #8b5cf6;">2. تحويلات العملاء ونقاط البيع</div>
            <table class="print-table">
                <tr><th>ت</th><th>اسم نقطة البيع</th><th>رقم العملية</th><th>المحفظة</th><th>المبلغ EGP</th><th>سعر الإدارة</th><th>التكلفة المخصومة منك</th></tr>
                <% subTxs.forEach((t, i) => { %>
                    <tr><td><%= i+1 %></td><td><%= t.subAccountName %></td><td><%= t.customId %></td><td dir="ltr"><%= t.vodafoneNumber || t.accountNumber %></td><td><%= t.amount %></td><td><%= t.exchangeRate %></td><td><%= t.costLYD.toFixed(2) %></td></tr>
                <% }) %>
                <% if(subTxs.length===0){ %><tr><td colspan="7">لا توجد عمليات من نقاط البيع</td></tr><% } %>
                <tr style="background:#f9f9f9; font-weight:bold;"><td colspan="6" style="text-align:left;">إجمالي المسحوب من نقاط البيع:</td><td style="color:#dc3545;"><%= sLYD.toFixed(2) %></td></tr>
            </table>
        <% } else { %>
            <div class="print-table-title" style="color: #0ea5e9;">سجل التحويلات المنفذة</div>
            <table class="print-table">
                <tr><th>ت</th><th>رقم العملية</th><th>المحفظة / الحساب</th><th>المبلغ EGP</th><th>السعر</th><th>التكلفة LYD</th></tr>
                <% subTxs.forEach((t, i) => { %>
                    <tr><td><%= i+1 %></td><td><%= t.customId %></td><td dir="ltr"><%= t.vodafoneNumber || t.accountNumber %></td><td><%= t.amount %></td><td><%= t.subClientRate %></td><td><%= t.subAccountCostLYD.toFixed(2) %></td></tr>
                <% }) %>
                <tr style="background:#f9f9f9; font-weight:bold;"><td colspan="5" style="text-align:left;">إجمالي التكلفة:</td><td style="color:#dc3545;"><%= sLYD.toFixed(2) %></td></tr>
            </table>
        <% } %>

        <div class="print-table-title" style="color: #10b981;">3. الإيداعات والتسويات</div>
        <table class="print-table">
            <tr><th>ت</th><th>البيان</th><th>المبلغ LYD</th><th>ملاحظات</th></tr>
            <% depTxs.forEach((t, i) => { %>
                <tr><td><%= i+1 %></td><td><%= t.status === 'deposit' ? 'إيداع' : 'خصم تسوية' %></td><td style="color:<%= t.status === 'deposit' ? '#198754' : '#dc3545' %>"><%= t.amount.toFixed(2) %></td><td><%= t.notes %></td></tr>
            <% }) %>
            <% if(depTxs.length===0){ %><tr><td colspan="4">لا توجد حركات تسوية</td></tr><% } %>
        </table>

        <table class="print-summary">
            <tr><th>الرصيد السابق (مرحل):</th><td><%= prevBal.toFixed(2) %> LYD</td></tr>
            <tr><th>إجمالي المسدد للإدارة (+):</th><td><%= dLYD.toFixed(2) %> LYD</td></tr>
            <tr><th>إجمالي المسحوب للتحويلات (-):</th><td><%= (mLYD + sLYD).toFixed(2) %> LYD</td></tr>
            <tr><th style="background:#001a4d !important; color:white;">الرصيد الختامي المتبقي:</th><td style="color:<%= (user.canViewBalance ? user.balance : 0) < 0 ? '#dc3545' : '#198754' %>; font-size:18px;"><%= user.canViewBalance ? user.balance.toFixed(2) : '***' %> LYD</td></tr>
        </table>
    </div>

    <div class="modal fade" id="transferModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0 pt-4 px-4 position-relative">
                    <button type="button" class="btn-close position-absolute" data-bs-dismiss="modal" style="left: 20px; filter: invert(0.5);"></button>
                    <h5 class="modal-title fw-bold" style="color: var(--accent-blue);"><i class="fa-solid fa-paper-plane-top me-2"></i> طلب تحويل مالي</h5>
                </div>
                <div class="modal-body p-4">
                    <!-- Screen 1: Services Grid -->
                    <div id="desktop-transfer-services-grid" class="mb-4">
                        <h5 class="fw-bold mb-4 text-center" style="color: var(--text-main); font-size: 1.25rem;">
                            <i class="fa-solid fa-layer-group text-primary me-2"></i>اختر خدمة التحويل
                        </h5>
                        <div class="services-desktop-grid">
                            <div class="service-card-item-desktop" onclick="selectTransferServiceDesktop('كاش')">
                                <div class="service-card-icon sc-cash"><img src="/images/vodafone_cash_official.png" alt="محافظ كاش فودافون" style="width: 100%; height: 100%; object-fit: cover; border-radius: 18px;"></div>
                                <span class="service-card-title">تحويل محافظ كاش</span>
                            </div>
                            <div class="service-card-item-desktop" onclick="openBalanceTransferModal()">
                                <div class="service-card-icon sc-balance"><i class="fa-solid fa-wallet"></i></div>
                                <span class="service-card-title">تحويل رصيد</span>
                            </div>
                            <div class="service-card-item-desktop" onclick="selectEgyptPostServiceDesktop()">
                                <div class="service-card-icon sc-post-acc"><img src="/images/egypt_post_official.png" alt="البريد المصري" style="width: 100%; height: 100%; object-fit: cover; border-radius: 18px;"></div>
                                <span class="service-card-title">البريد المصري</span>
                            </div>
                            <div class="service-card-item-desktop" onclick="selectTransferServiceDesktop('حساب بنكي')">
                                <div class="service-card-icon sc-bank"><img src="/images/instapay_official.png" alt="حساب بنكي انستا باي" style="width: 100%; height: 100%; object-fit: cover; border-radius: 18px;"></div>
                                <span class="service-card-title">حساب بنكي مصري</span>
                            </div>
                            <div class="service-card-item-desktop" onclick="selectTransferServiceDesktop('سيفا النيجر')">
                                <div class="service-card-icon sc-niger"><img src="/images/nita_official.png" alt="سيفا النيجر NITA" style="width: 100%; height: 100%; object-fit: cover; border-radius: 18px;"></div>
                                <span class="service-card-title">سيفا النيجر</span>
                            </div>
                            <div class="service-card-item-desktop" onclick="selectTransferServiceDesktop('بنكك السودان')">
                                <div class="service-card-icon sc-sudan"><img src="/images/bok_sudan_official.png" alt="بنكك السودان" style="width: 100%; height: 100%; object-fit: cover; border-radius: 18px;"></div>
                                <span class="service-card-title">بنكك السودان</span>
                            </div>
                        </div>
                    </div>

