<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>التحقق الثنائي | بوابة العملاء</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-primary: #001a4d;
            --brand-gold: #d4af37;
            --bg-body: #f4f7f6;
            --card-bg: rgba(255, 255, 255, 0.95);
            --text-main: #1e293b;
        }
        [data-theme="dark"] {
            --brand-primary: #3b82f6;
            --brand-gold: #fbbf24;
            --bg-body: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.85);
            --text-main: #f8fafc;
        }

        body { 
            font-family: 'Tajawal', sans-serif; 
            background: var(--bg-body);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
            transition: 0.3s;
        }
        .bg-glow {
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 0;
            pointer-events: none;
        }
        .verify-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.1);
            overflow: hidden;
            width: 100%;
            max-width: 420px;
            padding: 40px;
            text-align: center;
            position: relative;
            z-index: 1;
            border-bottom: 6px solid var(--brand-gold);
        }
        .icon-box {
            width: 80px;
            height: 80px;
            background: rgba(212, 175, 55, 0.1);
            color: var(--brand-gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin: 0 auto 20px;
            border: 1px solid rgba(212, 175, 55, 0.3);
        }
        .otp-input {
            letter-spacing: 15px;
            font-size: 1.5rem;
            text-align: center;
            font-family: monospace;
            font-weight: bold;
            border-radius: 12px;
            padding: 15px;
            border: 2px solid rgba(212, 175, 55, 0.3);
            background: rgba(0,0,0,0.05);
            color: var(--text-main);
        }
        [data-theme="dark"] .otp-input { background: rgba(255,255,255,0.05); }
        .otp-input:focus {
            border-color: var(--brand-gold);
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
            background: transparent;
            color: var(--text-main);
        }
        .btn-verify {
            background: linear-gradient(90deg, var(--brand-gold) 0%, #b5952f 100%);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 800;
            font-size: 1.1rem;
            transition: 0.3s;
            color: white;
            box-shadow: 0 8px 20px rgba(212, 175, 55, 0.3);
        }
        .btn-verify:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(212, 175, 55, 0.4);
            color: white;
        }
    </style>
</head>
<body>
    <div class="bg-glow"></div>
    <div class="verify-card">
        <div class="icon-box">
            <i class="fa-solid fa-shield-halved"></i>
        </div>
        <h4 class="fw-bold mb-2" style="color: var(--text-main);">تأمين الدخول للمنصة</h4>
        <p class="small mb-4 fw-bold" style="color: var(--brand-gold);">أرسلنا كود من 6 أرقام إلى حسابك في تيليجرام لتأكيد هويتك.</p>

        <% if (error) { %>
            <div class="alert alert-danger fw-bold small rounded-3 mb-4 border-0" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">
                <i class="fa-solid fa-circle-exclamation me-1"></i> <%= error %>
            </div>
        <% } %>

        <form action="/client/verify" method="POST">
            <div class="mb-4">
                <input type="text" name="otp" class="form-control otp-input" placeholder="------" maxlength="6" autocomplete="off" required dir="ltr">
            </div>

            <button type="submit" class="btn-verify w-100 mb-3">تأكيد الرمز والدخول <i class="fa-solid fa-check ms-1"></i></button>
            
            <a href="/login" class="small text-decoration-none fw-bold" style="color: var(--text-muted); transition: 0.3s;"><i class="fa-solid fa-arrow-right me-1"></i> العودة لتسجيل الدخول</a>
        </form>
    </div>
</body>
</html>