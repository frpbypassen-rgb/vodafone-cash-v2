<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>تقارير العميل | Al-Ahram Pay</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
        document.documentElement.setAttribute('data-bs-theme', savedTheme);
    
        window.showReceiptModal = function(proofImage, proofImagesStr) {
            let images = [];
            if (proofImagesStr) images = proofImagesStr.split(',').filter(i => i.trim() !== '');
            if (proofImage && proofImage !== 'undefined' && proofImage !== 'null' && !images.includes(proofImage)) images.push(proofImage);
            
            if (images.length === 0) return Swal.fire('تنبيه', 'لا توجد صورة إيصال متاحة لهذه العملية', 'info');
            
            let html = '<div class="receipt-container" style="text-align: center;">';
            images.forEach(img => {
                let src = img;
                if (!img.startsWith('http') && !img.startsWith('data:') && img.includes('.')) {
                    src = '/uploads/proofs/' + img;
                }
                html += `<img src="${src}" class="img-fluid rounded mb-3 shadow-sm border" style="max-height: 50vh; max-width: 100%; object-fit: contain;" />`;
            });
            html += '</div>';
            
            const mappedImages = images.map(img => {
                if (!img.startsWith('http') && !img.startsWith('data:') && img.includes('.')) return '/uploads/proofs/' + img;
                return img;
            });
            const imagesJoined = mappedImages.join(',');
            
            Swal.fire({
                title: '<i class="fa-solid fa-receipt me-2 text-success"></i> إيصال التحويل',
                html: html,
                showCloseButton: true,
                showConfirmButton: false,
                footer: `
                    <div class="d-flex justify-content-center gap-2 w-100 mt-2 px-3 pb-2">
                        <button class="btn btn-success fw-bold flex-fill py-2" onclick="downloadImages('${imagesJoined}')"><i class="fa-solid fa-download me-1"></i> تحميل</button>
                        <button class="btn btn-primary fw-bold flex-fill py-2" onclick="shareImages('${imagesJoined}')"><i class="fa-solid fa-share-nodes me-1"></i> مشاركة</button>
                    </div>
                `,
                customClass: { popup: 'swal2-popup' }
            });
        };

        window.downloadImages = async function(imagesStr) {
            const images = imagesStr.split(',');
            for (let i = 0; i < images.length; i++) {
                try {
                    const response = await fetch(images[i]);
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `receipt_${Date.now()}_${i}.jpg`;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    window.URL.revokeObjectURL(url);
                } catch(e) {
                    console.error('Download error:', e);
                }
            }
        };

        window.shareImages = async function(imagesStr) {
            const images = imagesStr.split(',');
            if (navigator.share) {
                try {
                    const filesArray = [];
                    for (let i = 0; i < images.length; i++) {
                        const response = await fetch(images[i]);
                        const blob = await response.blob();
                        filesArray.push(new File([blob], `receipt_${i}.jpg`, { type: blob.type || 'image/jpeg' }));
                    }
                    if (navigator.canShare && navigator.canShare({ files: filesArray })) {
                        await navigator.share({
                            files: filesArray,
                            title: 'إيصال التحويل',
                            text: 'مرفق إيصال العملية'
                        });
                    } else {
                        await navigator.share({
                            title: 'إيصال التحويل',
                            url: images[0]
                        });
                    }
                } catch (error) {
                    console.error('Error sharing:', error);
                }
            } else {
                Swal.fire('تنبيه', 'المشاركة المباشرة غير مدعومة في متصفحك، يرجى استخدام زر التحميل بدلاً من ذلك.', 'info');
            }
        };

    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    
    <style>
        /* 🎨 المتغيرات (الوضع النهاري - Premium Light) */
        :root { 
            --brand-primary: #001a4d; --brand-gold: #d4af37; 
            --bg-body: #f4f7fa; --card-bg: #ffffff;
            --text-main: #1e293b; --text-muted: #64748b;
            --border-glass: #e2e8f0; --input-bg: #f8fafc;
            --shadow-soft: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            --accent-green: #10b981; --accent-red: #ef4444; --accent-blue: #0ea5e9;
        }

        /* 🌙 المتغيرات (الوضع الليلي - Premium Dark) */
        [data-theme="dark"] {
            --brand-primary: #3b82f6; --brand-gold: #fbbf24; 
            --bg-body: #0f172a; --card-bg: #1e293b; 
            --text-main: #f8fafc; --text-muted: #94a3b8;
            --border-glass: #334155; --input-bg: #0f172a;
            --shadow-soft: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
            --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
        }

        body { background-color: var(--bg-body); color: var(--text-main); font-family: 'Tajawal', sans-serif; transition: background-color 0.3s, color 0.3s; padding-bottom: 50px; overflow-x: hidden; }
        
        ::-webkit-scrollbar { width: 6px; height: 6px; } 
        ::-webkit-scrollbar-track { background: transparent; } 
        ::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 10px; }

        .mono-num { font-family: 'JetBrains Mono', Tahoma, sans-serif; font-weight: bold; letter-spacing: 0.5px;}

        /* 🛸 Navbar */
        .navbar-custom { background: var(--card-bg); border-bottom: 1px solid var(--border-glass); padding: 15px 0; position: sticky; top: 0; z-index: 1000; box-shadow: var(--shadow-soft); transition: 0.3s; margin-bottom: 40px;}
        .logo-img { height: 40px; transition: 0.3s; mix-blend-mode: multiply; filter: contrast(1.2); }
        [data-theme="dark"] .logo-img { mix-blend-mode: normal; background: white; padding: 2px; border-radius: 8px; }
        .navbar-brand { color: var(--brand-primary) !important; font-weight: 900; font-size: 1.5rem; margin: 0; letter-spacing: -0.5px;}
        [data-theme="dark"] .navbar-brand { color: var(--brand-gold) !important; }

        .nav-actions { display: flex; gap: 10px; align-items: center; }
        .nav-btn { background: var(--input-bg); border: 1px solid var(--border-glass); color: var(--text-main); padding: 10px 20px; border-radius: 12px; font-weight: 700; text-decoration: none; transition: 0.3s; display: inline-flex; align-items: center; gap: 8px; cursor: pointer; font-size: 0.9rem;}
        .nav-btn:hover, .nav-btn.active { background: var(--card-bg); color: var(--brand-primary); border-color: var(--brand-primary); box-shadow: var(--shadow-soft); transform: translateY(-2px);}
        [data-theme="dark"] .nav-btn:hover, [data-theme="dark"] .nav-btn.active { color: var(--brand-gold); border-color: var(--brand-gold); }
        
        .btn-theme { border-radius: 12px; width: 44px; padding: 0; justify-content: center; color: var(--brand-gold); border-color: var(--border-glass);}
        .btn-theme:hover { background: var(--brand-gold); color: #000; }
        .nav-logout { color: var(--accent-red); border-color: var(--border-glass); }
        .nav-logout:hover { background: var(--accent-red) !important; color: white !important; border-color: var(--accent-red) !important;}

        /* Report Styles */
        .card-glass {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            box-shadow: var(--shadow-soft);
            padding: 20px;
            margin-bottom: 20px;
        }

        .form-select,
        .form-control {
            background-color: var(--input-bg);
            color: var(--text-main);
            border: 1px solid var(--border-glass);
            border-radius: 10px;
            padding: 10px;
            font-weight: bold;
        }

        .form-select:focus,
        .form-control:focus {
            background-color: transparent;
            color: var(--text-main);
            border-color: var(--brand-primary);
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
        }
        [data-theme="dark"] .form-select:focus, [data-theme="dark"] .form-control:focus {
            border-color: var(--brand-gold);
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.15);
        }

        .stat-card {
            background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(212, 175, 55, 0.02));
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            color: var(--brand-gold);
        }

        .table-custom {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 12px;
        }

        .table-custom th {
            color: var(--text-muted);
            font-weight: 700;
            padding: 14px 16px;
            font-size: 0.85rem;
            border: none;
            text-align: center;
        }

        .table-custom tr {
            transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .table-custom td {
            background: var(--card-bg);
            border-top: 1px solid var(--border-glass);
            border-bottom: 1px solid var(--border-glass);
            padding: 16px 14px;
            vertical-align: middle;
            text-align: center;
            font-size: 0.9rem;
            color: var(--text-main);
            transition: background 0.25s, box-shadow 0.25s, border-color 0.25s;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.03), 0 2px 4px -1px rgba(0, 0, 0, 0.02);
        }

        [data-theme="dark"] .table-custom td {
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
        }

        .table-custom tr td:first-child {
            border-right: 1px solid var(--border-glass);
            border-top-right-radius: 14px;
            border-bottom-right-radius: 14px;
        }

        .table-custom tr td:last-child {
            border-left: 1px solid var(--border-glass);
            border-top-left-radius: 14px;
            border-bottom-left-radius: 14px;
        }

        /* Hover */
        .table-custom tbody tr:hover {
            transform: translateY(-3px) scale(1.005);
        }

        .table-custom tbody tr:hover td {
            background: rgba(255, 255, 255, 0.98);
            border-color: rgba(14, 165, 233, 0.3);
            box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.08), 0 8px 10px -6px rgba(0, 0, 0, 0.06);
        }

        [data-theme="dark"] .table-custom tbody tr:hover td {
            background: rgba(30, 41, 59, 0.98);
            border-color: rgba(251, 191, 36, 0.3);
            box-shadow: 0 12px 25px -5px rgba(0, 0, 0, 0.4), 0 8px 15px -6px rgba(0, 0, 0, 0.35);
        }

        .badge-st {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.78rem;
            font-weight: 700;
            line-height: 1;
        }

        .st-done {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .st-fail {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        /* Indicator dots for badges */
        .indicator-dot {
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            margin-left: 6px;
            vertical-align: middle;
        }
        .dot-done {
            background-color: #10b981;
            box-shadow: 0 0 6px #10b981;
        }
        .dot-fail {
            background-color: #ef4444;
            box-shadow: 0 0 6px #ef4444;
        }

        .mobile-header { display: none; }
        .bottom-nav-mobile { display: none; }

        /* 📱 شاشات الهواتف الذكية (Native App Layout) */
        @media (max-width: 768px) {
            body {
                padding-bottom: 90px; /* مساحة للشريط السفلي */
            }
            
            .navbar-custom {
                display: none !important; /* Hide desktop navbar */
            }
            
            .mobile-header {
                display: flex !important;
                justify-content: space-between;
                align-items: center;
                background: var(--card-bg);
                border-bottom: 1px solid var(--border-glass);
                padding: 10px 16px;
                position: sticky;
                top: 0;
                z-index: 999;
                box-shadow: var(--shadow-soft);
            }
            .mobile-logo-wrapper {
                display: flex;
                align-items: center;
                gap: 8px;
            }
            .mobile-logo-wrapper img {
                height: 32px;
                border-radius: 6px;
            }
            .mobile-logo-wrapper h1 {
                font-size: 1.15rem;
                font-weight: 900;
                margin: 0;
                color: var(--brand-primary);
            }
            [data-theme="dark"] .mobile-logo-wrapper h1 {
                color: var(--brand-gold);
            }

            #statsSection {
                display: grid !important;
                grid-template-columns: repeat(3, 1fr) !important;
                gap: 8px !important;
            }
            .stat-card {
                padding: 10px 5px !important;
                border-radius: 12px !important;
            }
            .stat-card h5 {
                font-size: 0.95rem !important;
                margin-bottom: 2px !important;
            }
            .stat-card small {
                font-size: 0.62rem !important;
            }
        }

        /* 📱 شريط التنقل السفلي للهواتف */
        .bottom-nav-mobile {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 65px;
            background: var(--card-bg);
            border-top: 1px solid var(--border-glass);
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 1000;
            box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.08);
            padding-bottom: env(safe-area-inset-bottom);
        }
        .bottom-nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            color: var(--text-muted);
            text-decoration: none;
            flex: 1;
            height: 100%;
            transition: all 0.2s ease;
            font-size: 0.72rem;
            font-weight: 700;
        }
        .bottom-nav-item i {
            font-size: 1.25rem;
            transition: transform 0.2s ease;
        }
        .bottom-nav-item:hover {
            color: var(--text-main);
        }
        .bottom-nav-item.active {
            color: var(--brand-primary);
        }
        [data-theme="dark"] .bottom-nav-item.active {
            color: var(--brand-gold);
        }
        .bottom-nav-item.active i {
            transform: translateY(-2px);
        }

        /* بطاقات العمليات للهواتف */
        .mobile-tx-card {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
            transition: transform 0.15s ease, background 0.15s ease;
        }
        .mobile-tx-card:active {
            transform: scale(0.98);
            background: var(--input-bg);
        }
        .mobile-tx-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .tx-custom-id {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 800;
            font-size: 0.95rem;
            color: var(--brand-gold);
        }
        .mobile-tx-body {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }
        .tx-amount-wrapper {
            display: flex;
            align-items: baseline;
            gap: 4px;
        }
        .tx-amount {
            font-size: 1.4rem;
            font-weight: 900;
            color: var(--text-main);
        }
        .tx-currency {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-muted);
        }
        .mobile-tx-divider {
            height: 1px;
            background: var(--border-glass);
            margin: 4px 0;
        }
        .mobile-tx-date-row {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
        }

        /* SweetAlert */
        .swal2-popup { background: var(--card-bg) !important; color: var(--text-main) !important; border: 1px solid var(--border-glass); border-radius: 20px !important; }
        .swal2-title, .swal2-html-container { color: var(--text-main) !important; }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#001a4d">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Al-Ahram">
    <!-- End PWA Setup -->
</head>
<body>

    <!-- Mobile Header -->
    <header class="mobile-header no-print">
        <div class="mobile-logo-wrapper">
            <img src="/images/logo.jpeg" alt="Logo" onerror="this.onerror=null; this.src='/images/logo.jpg';">
            <h1>Al-Ahram Pay</h1>
        </div>
        <div class="d-flex align-items-center gap-2">
            <!-- Balance badge -->
            <div class="pe-none" style="
                background: <%= (account.canViewBalance ? account.balance : 0) >= 0 ? 'linear-gradient(45deg, #10b981, #059669)' : 'linear-gradient(45deg, #ef4444, #dc2626)' %>;
                color: white;
                padding: 6px 12px;
                border-radius: 10px;
                font-weight: 800;
                box-shadow: 0 4px 10px <%= (account.canViewBalance ? account.balance : 0) >= 0 ? 'rgba(16, 185, 129, 0.2)' : 'rgba(239, 68, 68, 0.2)' %>;
                font-size: 0.82rem;
                display: flex;
                align-items: center;
                gap: 5px;
            ">
                <span dir="ltr" style="font-family: 'JetBrains Mono', monospace;"><%= account.canViewBalance ? account.balance.toFixed(2) : '***' %> LYD</span>
                <i class="fa-solid fa-wallet"></i>
            </div>
            
            <button class="nav-btn btn-theme" onclick="toggleTheme()" style="padding: 6px; width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-moon" id="mobileThemeIcon"></i></button>
            <a href="/client/logout" class="nav-btn nav-logout" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border-color: rgba(239, 68, 68, 0.3); padding: 6px; width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-power-off"></i></a>
        </div>
    </header>

    <nav class="navbar-custom">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-3">
                    <img src="/images/logo.jpeg" alt="Logo" class="logo-img" onerror="this.onerror=null; this.src='/images/logo.jpg';">
                    <h4 class="navbar-brand d-none d-sm-block">Al-Ahram Pay</h4>
                </div>
                
                <div class="nav-actions">
                    <button class="nav-btn btn-theme" onclick="toggleTheme()" title="تغيير المظهر">
                        <i class="fa-solid fa-moon" id="themeIcon"></i>
                    </button>
                    <a href="/client/dashboard" class="nav-btn"><i class="fa-solid fa-arrow-right"></i> رجوع</a>
                    <a href="/client/logout" class="nav-btn nav-logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> خروج</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4 mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold m-0" style="color: var(--brand-primary);" id="pageTitle"><i class="fa-solid fa-chart-line me-2"></i> التقارير والعمليات</h4>
        </div>

        <!-- فلاتر التقرير -->
        <div class="card-glass">
            <div class="row g-3 align-items-end justify-content-center">
                <div class="col-md-3">
                    <label class="form-label text-muted fw-bold">الفترة الزمنية</label>
                    <select id="dateType" class="form-select" onchange="toggleDateInput()">
                        <option value="day">يوم محدد</option>
                        <% if (accountType !== 'company' || account.role === 'manager' || account.canViewAllReports) { %>
                        <option value="month">شهر محدد</option>
                        <% } %>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label text-muted fw-bold">&nbsp;</label>
                    <input type="date" id="dateValueDay" class="form-control">
                    <input type="month" id="dateValueMonth" class="form-control" style="display:none;">
                </div>

                <div class="col-md-3 text-end">
                    <button class="btn btn-primary w-100 fw-bold py-2" onclick="fetchReport()" id="btnFetch">
                        <i class="fa-solid fa-search"></i> عرض التقرير
                    </button>
                </div>
                <div class="col-md-3 text-end">
                    <button id="btnDownloadPdf" class="btn btn-danger w-100 fw-bold py-2 d-none" onclick="generatePDF()">
                        <i class="fa-solid fa-file-pdf"></i> تحميل التقرير
                    </button>
                </div>
            </div>
        </div>

        <!-- الإحصائيات -->
        <div class="row g-3 mb-4 d-none" id="statsSection">
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg, rgba(239,68,68,0.1), rgba(239,68,68,0.02)); border-color: rgba(239,68,68,0.2);">
                    <h5 class="fw-bold mb-2 text-danger" id="statTotalOps">0.00</h5>
                    <small class="text-danger fw-bold">إجمالي العمليات المنفذة (LYD)</small>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(16,185,129,0.02)); border-color: rgba(16,185,129,0.2);">
                    <h5 class="fw-bold mb-2 text-success" id="statCompletedCount">0</h5>
                    <small class="text-success fw-bold">العمليات الناجحة</small>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card" style="background: linear-gradient(135deg, rgba(212,175,55,0.1), rgba(212,175,55,0.02)); border-color: rgba(212,175,55,0.2);">
                    <h5 class="fw-bold mb-2 text-warning" id="statRejectedCount">0</h5>
                    <small class="text-warning fw-bold">العمليات المرفوضة</small>
                </div>
            </div>
        </div>

        <!-- جدول العمليات -->
        <div class="card-glass d-none" id="tableSection">
            <h5 class="fw-bold mb-3"><i class="fa-solid fa-list text-muted me-1"></i> تفاصيل العمليات</h5>
            <div class="table-responsive d-none d-md-block">
