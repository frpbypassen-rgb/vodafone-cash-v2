                            <td style="padding: 10px 8px; border-bottom: 1px solid #000; font-weight: 900; color: #000;">${tx.costLYD || 0} LYD</td>
                            <td style="padding: 10px 8px; border-bottom: 1px solid #000;" dir="ltr">
                                <div style="color: #000; font-weight: 800;">${dt.toLocaleDateString('en-GB')}</div>
                                <div style="font-size: 11px; color: #000; font-weight: 700;">${dt.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true })}</div>
                            </td>
                            <td style="padding: 10px 8px; border-bottom: 1px solid #000;">
                                <span style="background: ${stBg}; color: ${stCol}; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 800; border: 2px solid #000;">${stTxt}</span>
                            </td>
                        </tr>
                    `;
                    });

                    html += `
                        </tbody>
                    </table>
                `;
                });
            }

            html += `</div>`;

            const opt = {
                margin: 10,
                filename: 'تقرير_العميل.pdf',
                image: { type: 'jpeg', quality: 1.0 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            const container = document.createElement('div');
            container.innerHTML = html;
            html2pdf().set(opt).from(container).save();
        }
    </script>
    
