<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>سجل التدقيق – منظومة الأهرام</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --brand-gold: #d4af37;
            --brand-gold-dark: #b5952f;
            /* fallbacks إذا لم يتم تحميل sidebar.ejs بعد */
            --bg-body: #f4f7fa;
            --card-bg: #ffffff;
            --border-glass: #e2e8f0;
            --text-main: #1e293b;
            --text-muted: #64748b;
        }
        [data-theme="dark"] {
            --bg-body: #0f172a;
            --card-bg: #1e293b;
            --border-glass: #334155;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
        }

        .stat-card {
            border-radius: 16px;
            padding: 22px 20px;
            border: 1px solid var(--border-glass);
            background: var(--card-bg);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,0,0,0.12); }
        .stat-icon {
            width: 52px; height: 52px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; flex-shrink: 0;
        }
        .stat-value { font-size: 2rem; font-weight: 800; line-height: 1; }
        .stat-label { font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; }

        .filter-bar {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            padding: 18px 20px;
        }

        .audit-table-wrapper {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            overflow: hidden;
        }
        .audit-table-wrapper .table { margin-bottom: 0; }
        .audit-table-wrapper .table thead th {
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 14px 16px;
            border-bottom: 2px solid var(--border-glass);
            white-space: nowrap;
            background: var(--card-bg);
            color: var(--text-muted);
        }
        .audit-table-wrapper .table tbody td {
            padding: 12px 16px;
            font-size: 0.875rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-glass);
            background: var(--card-bg);
            color: var(--text-main);
        }
        .audit-table-wrapper .table tbody tr:last-child td { border-bottom: none; }
        .audit-table-wrapper .table tbody tr:hover td { background: rgba(212, 175, 55, 0.04) !important; }

        .action-badge {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 4px 10px; border-radius: 20px;
            font-size: 0.75rem; font-weight: 700;
            white-space: nowrap;
        }
        .ab-login-success  { background: rgba(34,197,94,0.12);   color: #22c55e; border: 1px solid rgba(34,197,94,0.25); }
        .ab-login-failed   { background: rgba(239,68,68,0.12);   color: #ef4444; border: 1px solid rgba(239,68,68,0.25); }
        .ab-transfer       { background: rgba(59,130,246,0.12);  color: #3b82f6; border: 1px solid rgba(59,130,246,0.25); }
        .ab-cancel         { background: rgba(245,158,11,0.12);  color: #f59e0b; border: 1px solid rgba(245,158,11,0.25); }
        .ab-complete       { background: rgba(16,185,129,0.12);  color: #10b981; border: 1px solid rgba(16,185,129,0.25); }
        .ab-token          { background: rgba(139,92,246,0.12);  color: #8b5cf6; border: 1px solid rgba(139,92,246,0.25); }
        .ab-admin          { background: rgba(212,175,55,0.12);  color: #d4af37; border: 1px solid rgba(212,175,55,0.25); }
        .ab-default        { background: rgba(100,116,139,0.12); color: #64748b; border: 1px solid rgba(100,116,139,0.25); }

        .status-dot {
            width: 8px; height: 8px; border-radius: 50%;
            display: inline-block; margin-left: 6px; flex-shrink: 0;
        }
        .dot-success { background: #22c55e; box-shadow: 0 0 6px rgba(34,197,94,0.6); }
        .dot-fail    { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,0.6); }

        .detail-section {
            background: var(--bg-body);
            border-radius: 10px; padding: 14px; margin-bottom: 12px;
            border: 1px solid var(--border-glass);
        }
        .detail-label {
            font-size: 0.72rem; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;
        }
        .detail-value { font-size: 0.88rem; font-weight: 600; word-break: break-all; color: var(--text-main); }
        .json-view {
            font-family: 'Courier New', monospace; font-size: 0.78rem;
            background: var(--bg-body); border-radius: 8px; padding: 10px;
            max-height: 200px; overflow-y: auto; white-space: pre-wrap;
            border: 1px solid var(--border-glass); color: var(--text-main);
            direction: ltr; text-align: left;
        }

        .pagination .page-link {
            background: var(--card-bg); border-color: var(--border-glass);
            color: var(--text-main); border-radius: 8px; margin: 0 2px; padding: 8px 14px;
        }
        .pagination .page-item.active .page-link {
            background: var(--brand-gold); border-color: var(--brand-gold); color: white;
        }
        .pagination .page-link:hover { background: rgba(212,175,55,0.1); color: var(--brand-gold); }

        .page-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 28px; flex-wrap: wrap; gap: 12px;
        }
        .page-header h2 { font-size: 1.6rem; font-weight: 800; margin: 0; color: var(--text-main); }
        .page-header h2 small {
            font-size: 0.85rem; font-weight: 400; color: var(--text-muted);
            display: block; margin-top: 2px;
        }

        @keyframes fadeSlideIn {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-in { animation: fadeSlideIn 0.35s ease forwards; }

        /* تصحيح Modal في الوضع الليلي */
        .modal-content {
            background: var(--card-bg) !important;
            color: var(--text-main) !important;
            border-color: var(--border-glass) !important;
        }
        .modal-header { border-color: var(--border-glass) !important; }
        .btn-close { filter: var(--bs-btn-close-filter, none); }
        [data-theme="dark"] .btn-close { filter: invert(1) grayscale(100%) brightness(200%); }
    </style>
</head>
<body>

<%- include('partials/sidebar') %>

<div class="main-content">

    <!-- ── ترويسة الصفحة ── -->
    <div class="page-header fade-in">
        <div>
            <h2>
                <i class="fa-solid fa-shield-halved me-2" style="color: var(--brand-gold);"></i>
                سجل التدقيق الشامل
                <small>متابعة جميع الحركات والعمليات داخل المنظومة</small>
            </h2>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-sm btn-outline-secondary" onclick="exportLogs()">
                <i class="fa-solid fa-file-export me-1"></i> تصدير JSON
            </button>
            <button class="btn btn-sm fw-bold" style="background: var(--brand-gold); color: #000;" onclick="location.reload()">
                <i class="fa-solid fa-rotate me-1"></i> تحديث
            </button>
        </div>
    </div>

    <!-- ── كروت الإحصاء السريع ── -->
    <div class="row g-3 mb-4 fade-in">
        <div class="col-6 col-md-3">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(59,130,246,0.12); color: #3b82f6;">
                    <i class="fa-solid fa-calendar-day"></i>
                </div>
                <div>
                    <div class="stat-value" style="color: #3b82f6;"><%= stats.todayTotal.toLocaleString() %></div>
                    <div class="stat-label">إجمالي اليوم</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(34,197,94,0.12); color: #22c55e;">
                    <i class="fa-solid fa-arrow-right-arrow-left"></i>
                </div>
                <div>
                    <div class="stat-value" style="color: #22c55e;"><%= stats.transfersToday.toLocaleString() %></div>
                    <div class="stat-label">تحويلات اليوم</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(239,68,68,0.12); color: #ef4444;">
                    <i class="fa-solid fa-user-slash"></i>
                </div>
                <div>
                    <div class="stat-value" style="color: #ef4444;"><%= stats.loginsFailed.toLocaleString() %></div>
                    <div class="stat-label">دخول فاشل اليوم</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(245,158,11,0.12); color: #f59e0b;">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div>
                    <div class="stat-value" style="color: #f59e0b;"><%= stats.todayFailed.toLocaleString() %></div>
                    <div class="stat-label">عمليات فاشلة اليوم</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── شريط الفلاتر ── -->
    <div class="filter-bar mb-4 fade-in">
        <form method="GET" action="/audit-log" id="filterForm">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-2">
                    <label class="form-label fw-semibold small">نوع العملية</label>
                    <select name="action" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">— جميع العمليات —</option>
                        <optgroup label="🔐 المصادقة">
                            <option value="LOGIN_SUCCESS"  <%= filters.action === 'LOGIN_SUCCESS'   ? 'selected' : '' %>>✅ دخول ناجح</option>
                            <option value="LOGIN_FAILED"   <%= filters.action === 'LOGIN_FAILED'    ? 'selected' : '' %>>❌ دخول فاشل</option>
                            <option value="LOGOUT"         <%= filters.action === 'LOGOUT'          ? 'selected' : '' %>>🚪 تسجيل خروج</option>
                            <option value="TOKEN_REFRESH"  <%= filters.action === 'TOKEN_REFRESH'   ? 'selected' : '' %>>🔄 تجديد توكن</option>
                        </optgroup>
                        <optgroup label="💸 التحويلات">
                            <option value="TRANSFER_CREATED"   <%= filters.action === 'TRANSFER_CREATED'   ? 'selected' : '' %>>➕ تحويل جديد</option>
                            <option value="TRANSFER_COMPLETED" <%= filters.action === 'TRANSFER_COMPLETED' ? 'selected' : '' %>>✔️ تحويل مكتمل</option>
                            <option value="TRANSFER_CANCELLED" <%= filters.action === 'TRANSFER_CANCELLED' ? 'selected' : '' %>>🚫 تحويل ملغى</option>
                        </optgroup>
                        <optgroup label="⚙️ إدارية">
                            <option value="ADMIN_ACTION"     <%= filters.action === 'ADMIN_ACTION'     ? 'selected' : '' %>>🛡️ إجراء إداري</option>
                            <option value="SETTINGS_CHANGED" <%= filters.action === 'SETTINGS_CHANGED' ? 'selected' : '' %>>⚙️ تغيير إعدادات</option>
                            <option value="USER_BANNED"      <%= filters.action === 'USER_BANNED'      ? 'selected' : '' %>>🚫 حظر مستخدم</option>
                        </optgroup>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label fw-semibold small">بواسطة</label>
                    <input type="text" name="performedBy" class="form-control form-control-sm"
                           placeholder="اسم المنفذ..." value="<%= filters.performedBy %>">
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small">من تاريخ</label>
                    <input type="date" name="dateFrom" class="form-control form-control-sm" value="<%= filters.dateFrom %>">
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small">إلى تاريخ</label>
                    <input type="date" name="dateTo" class="form-control form-control-sm" value="<%= filters.dateTo %>">
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small">النتيجة</label>
                    <select name="success" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">— الكل —</option>
                        <option value="true"  <%= filters.success === 'true'  ? 'selected' : '' %>>✅ ناجحة فقط</option>
                        <option value="false" <%= filters.success === 'false' ? 'selected' : '' %>>❌ فاشلة فقط</option>
                    </select>
                </div>
                <div class="col-6 col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-sm flex-fill fw-bold"
                            style="background: var(--brand-gold); color: #000;">
                        <i class="fa-solid fa-magnifying-glass me-1"></i> بحث
                    </button>
                    <a href="/audit-log" class="btn btn-sm btn-outline-secondary" title="مسح الفلاتر">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- ── جدول السجلات ── -->
    <div class="audit-table-wrapper fade-in">
        <div class="d-flex align-items-center justify-content-between px-4 py-3"
             style="border-bottom: 1px solid var(--border-glass);">
            <div>
                <span class="fw-bold">
                    <i class="fa-solid fa-list-ul me-2" style="color: var(--brand-gold);"></i>نتائج البحث
                </span>
                <span class="badge ms-2"
                      style="background: rgba(212,175,55,0.15); color: var(--brand-gold); border: 1px solid rgba(212,175,55,0.3);">
                    <%= total.toLocaleString() %> سجل
                </span>
            </div>
            <small class="text-muted">صفحة <%= page %> من <%= totalPages || 1 %></small>
        </div>

        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>النتيجة</th>
                        <th>نوع العملية</th>
                        <th>المنفذ</th>
                        <th>نوع الحساب</th>
                        <th>العنوان (IP)</th>
                        <th>المسار</th>
                        <th>الوقت</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% if (!logs || logs.length === 0) { %>
                    <tr>
                        <td colspan="9" class="text-center py-5">
                            <i class="fa-solid fa-inbox fa-3x mb-3 d-block"
                               style="color: var(--text-muted); opacity: 0.35;"></i>
                            <p class="text-muted mb-0">لا توجد سجلات مطابقة للبحث</p>
                        </td>
                    </tr>
                    <% } else { %>
                    <%
                        // خريطة العمليات — تُعرَّف مرة واحدة خارج حلقة forEach
                        const ACTION_MAP = {
                            LOGIN_SUCCESS:      ['ab-login-success', 'fa-right-to-bracket',   'دخول ناجح'],
                            LOGIN_FAILED:       ['ab-login-failed',  'fa-user-slash',          'دخول فاشل'],
                            LOGOUT:             ['ab-default',       'fa-right-from-bracket',  'خروج'],
                            TOKEN_REFRESH:      ['ab-token',         'fa-rotate',              'تجديد توكن'],
                            TRANSFER_CREATED:   ['ab-transfer',      'fa-paper-plane',         'تحويل جديد'],
                            TRANSFER_COMPLETED: ['ab-complete',      'fa-circle-check',        'تحويل مكتمل'],
                            TRANSFER_CANCELLED: ['ab-cancel',        'fa-ban',                 'تحويل ملغى'],
                            ADMIN_ACTION:       ['ab-admin',         'fa-user-shield',         'إجراء إداري'],
                            SETTINGS_CHANGED:   ['ab-admin',         'fa-gear',                'تغيير إعدادات'],
                            USER_BANNED:        ['ab-login-failed',  'fa-lock',                'حظر مستخدم'],
                        };
                        const MODEL_MAP = {
                            Employee:       '👷 منفذ',
                            ClientEmployee: '🏢 موظف شركة',
                            User:           '👤 عميل',
                            Admin:          '🛡️ مدير',
                            System:         '⚙️ نظام',
                        };
                    %>
                    <% logs.forEach(function(log, idx) { %>
                    <%
                        const actionInfo = ACTION_MAP[log.action] || ['ab-default', 'fa-circle', log.action || '—'];
                        const badgeCls  = actionInfo[0];
                        const badgeIcon = actionInfo[1];
                        const badgeText = actionInfo[2];
                        const modelLabel = MODEL_MAP[log.performedByModel] || (log.performedByModel || '—');
                        const logDate  = log.createdAt ? new Date(log.createdAt) : null;
                        const dateStr  = logDate ? logDate.toLocaleDateString('ar-EG', { day:'2-digit', month:'short', year:'numeric' }) : '—';
                        const timeStr  = logDate ? logDate.toLocaleTimeString('ar-EG', { hour:'2-digit', minute:'2-digit', second:'2-digit' }) : '';
                    %>
                    <tr>
                        <td class="text-muted fw-bold small"><%= (page - 1) * limit + idx + 1 %></td>
                        <td>
                            <% if (log.success !== false) { %>
                                <span class="status-dot dot-success"></span>
                                <small class="text-success fw-bold">ناجح</small>
                            <% } else { %>
                                <span class="status-dot dot-fail"></span>
                                <small class="text-danger fw-bold">فاشل</small>
                            <% } %>
                        </td>
                        <td>
                            <span class="action-badge <%= badgeCls %>">
                                <i class="fa-solid <%= badgeIcon %>"></i> <%= badgeText %>
                            </span>
                        </td>
                        <td>
                            <span class="fw-semibold"><%= log.performedByName || '—' %></span>
                        </td>
                        <td>
                            <small class="text-muted"><%= modelLabel %></small>
                        </td>
                        <td>
                            <code class="small" style="font-size:0.75rem; color:var(--text-muted);">
                                <%= log.ipAddress || '—' %>
                            </code>
                        </td>
                        <td>
                            <small class="text-muted text-truncate d-inline-block"
                                   style="max-width:160px;"
                                   title="<%= log.endpoint || '' %>">
                                <%= log.endpoint || '—' %>
                            </small>
                        </td>
                        <td>
                            <small style="white-space:nowrap;">
                                <span class="d-block"><%= dateStr %></span>
                                <span class="text-muted"><%= timeStr %></span>
                            </small>
                        </td>
                        <td>
                            <%
                                // تحويل log إلى JSON آمن لتمريره عبر onclick
                                const safeLog = JSON.stringify(log)
                                    .replace(/\\/g, '\\\\')
                                    .replace(/'/g, "\\'");
                            %>
                            <button class="btn btn-sm btn-outline-secondary"
                                    onclick="showDetails('<%= safeLog %>')"
                                    title="عرض التفاصيل">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </td>
                    </tr>
                    <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- ── ترقيم الصفحات ── -->
        <% if (totalPages > 1) { %>
        <div class="d-flex justify-content-center align-items-center py-4">
            <nav aria-label="ترقيم الصفحات">
                <ul class="pagination pagination-sm mb-0">
                    <% if (page > 1) { %>
                    <li class="page-item">
                        <a class="page-link"
                           href="?page=<%= page - 1 %>&action=<%= encodeURIComponent(filters.action) %>&dateFrom=<%= filters.dateFrom %>&dateTo=<%= filters.dateTo %>&performedBy=<%= encodeURIComponent(filters.performedBy) %>&success=<%= filters.success %>">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </li>
                    <% } %>
                    <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
                    <li class="page-item <%= p === page ? 'active' : '' %>">
                        <a class="page-link"
                           href="?page=<%= p %>&action=<%= encodeURIComponent(filters.action) %>&dateFrom=<%= filters.dateFrom %>&dateTo=<%= filters.dateTo %>&performedBy=<%= encodeURIComponent(filters.performedBy) %>&success=<%= filters.success %>">
                            <%= p %>
                        </a>
                    </li>
                    <% } %>
                    <% if (page < totalPages) { %>
                    <li class="page-item">
                        <a class="page-link"
                           href="?page=<%= page + 1 %>&action=<%= encodeURIComponent(filters.action) %>&dateFrom=<%= filters.dateFrom %>&dateTo=<%= filters.dateTo %>&performedBy=<%= encodeURIComponent(filters.performedBy) %>&success=<%= filters.success %>">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                    </li>
                    <% } %>
                </ul>
            </nav>
        </div>
        <% } %>
    </div><!-- /audit-table-wrapper -->
</div><!-- /main-content -->

<!-- ── Modal التفاصيل ── -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="detailModalLabel">
                    <i class="fa-solid fa-file-magnifying-glass me-2" style="color: var(--brand-gold);"></i>
                    تفاصيل العملية
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body" id="detailBody">
                <!-- تُملأ بـ JavaScript -->
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script>
    // ── خريطة التسميات ──────────────────────────────────────────
    const ACTION_LABELS = {
        LOGIN_SUCCESS:      '✅ دخول ناجح',
        LOGIN_FAILED:       '❌ دخول فاشل',
        LOGOUT:             '🚪 تسجيل خروج',
        TOKEN_REFRESH:      '🔄 تجديد توكن',
        TRANSFER_CREATED:   '➕ تحويل جديد',
        TRANSFER_COMPLETED: '✔️ تحويل مكتمل',
        TRANSFER_CANCELLED: '🚫 تحويل ملغى',
        ADMIN_ACTION:       '🛡️ إجراء إداري',
        SETTINGS_CHANGED:   '⚙️ تغيير إعدادات',
        USER_BANNED:        '🚫 حظر مستخدم',
    };

    const MODEL_LABELS = {
        Employee:       '👷 منفذ (Employee)',
        ClientEmployee: '🏢 موظف شركة',
        User:           '👤 عميل فردي',
        Admin:          '🛡️ مدير النظام',
        System:         '⚙️ النظام',
    };

    // ── عرض التفاصيل في Modal ───────────────────────────────────
    function showDetails(jsonStr) {
        let log;
        try {
            log = JSON.parse(jsonStr);
        } catch (e) {
            console.error('خطأ في تحليل بيانات السجل:', e);
            return;
        }

        const d = log.createdAt ? new Date(log.createdAt) : null;
        const formattedDate = d
            ? d.toLocaleString('ar-EG', {
                year: 'numeric', month: 'long', day: 'numeric',
                hour: '2-digit', minute: '2-digit', second: '2-digit'
              })
            : '—';

        const successClass = log.success !== false ? 'text-success' : 'text-danger';
        const successText  = log.success !== false ? '✅ ناجحة' : '❌ فاشلة';
        const errorPart    = log.errorCode
            ? ` &mdash; كود الخطأ: <code>${escHtml(log.errorCode)}</code>`
            : '';

        let html = `<div class="row g-3">
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-label">نوع العملية</div>
                    <div class="detail-value">${escHtml(ACTION_LABELS[log.action] || log.action || '—')}</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-label">النتيجة</div>
                    <div class="detail-value ${successClass}">${successText}${errorPart}</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-label">المنفذ</div>
                    <div class="detail-value">${escHtml(log.performedByName || '—')}</div>
                    <small class="text-muted">${escHtml(MODEL_LABELS[log.performedByModel] || log.performedByModel || '')}</small>
                </div>
            </div>
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-label">الوقت</div>
                    <div class="detail-value">${formattedDate}</div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-label">عنوان IP</div>
                    <div class="detail-value"><code>${escHtml(log.ipAddress || '—')}</code></div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-label">المسار (Endpoint)</div>
                    <div class="detail-value"><code style="font-size:0.78rem;">${escHtml(log.endpoint || '—')}</code></div>
                </div>
            </div>`;

        if (log.userAgent) {
            html += `<div class="col-12">
                <div class="detail-section">
                    <div class="detail-label">المتصفح / التطبيق (User Agent)</div>
                    <div class="detail-value" style="font-size:0.78rem;">${escHtml(log.userAgent)}</div>
                </div>
            </div>`;
        }

        if (log.metadata && Object.keys(log.metadata).length > 0) {
            html += `<div class="col-12">
                <div class="detail-section">
                    <div class="detail-label">بيانات إضافية (Metadata)</div>
                    <div class="json-view">${escHtml(JSON.stringify(log.metadata, null, 2))}</div>
                </div>
            </div>`;
        }

        if (log.oldData && Object.keys(log.oldData).length > 0) {
            html += `<div class="col-12 col-md-6">
                <div class="detail-section">
                    <div class="detail-label">📋 البيانات قبل التغيير</div>
                    <div class="json-view">${escHtml(JSON.stringify(log.oldData, null, 2))}</div>
                </div>
            </div>`;
        }

        if (log.newData && Object.keys(log.newData).length > 0) {
            html += `<div class="col-12 col-md-6">
                <div class="detail-section">
                    <div class="detail-label">✏️ البيانات بعد التغيير</div>
                    <div class="json-view">${escHtml(JSON.stringify(log.newData, null, 2))}</div>
                </div>
            </div>`;
        }

        html += '</div>';

        document.getElementById('detailBody').innerHTML = html;
        const modal = new bootstrap.Modal(document.getElementById('detailModal'));
        modal.show();
    }

    // ── تشفير HTML لمنع XSS ─────────────────────────────────────
    function escHtml(str) {
        if (str === null || str === undefined) return '';
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    // ── تصدير السجلات بصيغة JSON ────────────────────────────────
    function exportLogs() {
        const params = new URLSearchParams(window.location.search);
        params.delete('page'); // تصدير بدون ترقيم
        const url = '/audit-log/export?' + params.toString();

        const link = document.createElement('a');
        link.href = url;
        link.download = 'audit_log_' + new Date().toISOString().slice(0, 10) + '.json';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }

    // ── تحديث تلقائي كل 30 ثانية (بدون فلاتر فقط) ─────────────
    const currentParams = new URLSearchParams(window.location.search);
    currentParams.delete('page');
    if (currentParams.toString() === '') {
        let autoRefreshTimer = setInterval(function () {
            location.reload();
        }, 30000);

        // إيقاف التحديث عند فتح المودال
        document.getElementById('detailModal').addEventListener('show.bs.modal', function () {
            clearInterval(autoRefreshTimer);
        });
    }
</script>
</body>
</html>
