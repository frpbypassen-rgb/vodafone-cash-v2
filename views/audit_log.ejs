<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>سجل التدقيق الأمني – منظومة الأهرام</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-gold: #fbbf24;
            --brand-gold-dark: #d97706;
            --cyber-green: #10b981;
            --cyber-cyan: #06b6d4;
            --cyber-red: #ef4444;
            --cyber-orange: #f59e0b;
            --bg-body: #f4f7fa;
            --card-bg: #ffffff;
            --border-glass: #e2e8f0;
            --text-main: #1e293b;
            --text-muted: #64748b;
        }
        [data-theme="dark"] {
            --bg-body: #0b0f19;
            --card-bg: #111827;
            --border-glass: #1f2937;
            --text-main: #f9fafb;
            --text-muted: #9ca3af;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
        }

        .stat-card {
            border-radius: 16px;
            padding: 20px;
            border: 1px solid var(--border-glass);
            background: var(--card-bg);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 4px; height: 100%;
            background: transparent;
            transition: background 0.3s;
        }
        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .stat-card:hover::before {
            background: var(--brand-gold);
        }
        .stat-icon {
            width: 48px; height: 48px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; flex-shrink: 0;
            transition: transform 0.3s;
        }
        .stat-card:hover .stat-icon {
            transform: scale(1.1) rotate(5deg);
        }
        .stat-value { font-size: 1.8rem; font-weight: 800; line-height: 1.1; }
        .stat-label { font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; font-weight: 600; }

        .filter-bar {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            padding: 18px 20px;
        }

        .audit-table-wrapper {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }
        .audit-table-wrapper .table { margin-bottom: 0; }
        .audit-table-wrapper .table thead th {
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 14px 16px;
            border-bottom: 2px solid var(--border-glass);
            white-space: nowrap;
            background: var(--card-bg);
            color: var(--text-muted);
        }
        .audit-table-wrapper .table tbody td {
            padding: 12px 16px;
            font-size: 0.875rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-glass);
            background: var(--card-bg);
            color: var(--text-main);
        }
        .audit-table-wrapper .table tbody tr:last-child td { border-bottom: none; }
        .audit-table-wrapper .table tbody tr:hover td { background: rgba(251, 191, 36, 0.03) !important; }

        /* Cyberpunk Terminal Modal Styles */
        .terminal-modal .modal-content {
            background-color: #030712 !important;
            border: 2px solid var(--cyber-green) !important;
            box-shadow: 0 0 25px rgba(16, 185, 129, 0.3);
            font-family: 'Fira Code', 'Courier New', monospace;
            color: var(--cyber-green);
        }
        .terminal-modal .modal-header {
            border-bottom: 1px solid var(--cyber-green) !important;
            background-color: #0b0f19;
            color: var(--cyber-green);
        }
        .terminal-modal .modal-title {
            color: var(--cyber-green);
            text-shadow: 0 0 10px rgba(16, 185, 129, 0.8);
            font-weight: bold;
        }
        .terminal-modal .btn-close {
            filter: invert(1) sepia(1) saturate(5) hue-rotate(90deg);
        }
        .terminal-body {
            background-color: #020617;
            padding: 22px;
            border-radius: 8px;
            border: 1px solid rgba(16, 185, 129, 0.2);
            max-height: 550px;
            overflow-y: auto;
            text-align: left;
            direction: ltr;
        }
        .terminal-line {
            margin-bottom: 6px;
            line-height: 1.4;
            white-space: pre-wrap;
            opacity: 0;
            animation: typeIn 0.2s forwards;
            font-size: 0.82rem;
        }
        .terminal-success { color: #10b981; text-shadow: 0 0 5px rgba(16, 185, 129, 0.4); }
        .terminal-info { color: #06b6d4; text-shadow: 0 0 5px rgba(6, 182, 212, 0.4); }
        .terminal-warning { color: #f59e0b; text-shadow: 0 0 5px rgba(245, 158, 11, 0.4); }
        .terminal-danger { color: #ef4444; text-shadow: 0 0 5px rgba(239, 68, 68, 0.4); }
        .terminal-default { color: #9ca3af; }
        
        @keyframes typeIn {
            to { opacity: 1; }
        }
        
        /* Cyberpunk Log Button */
        .btn-cyber {
            background: #020617;
            border: 1px solid var(--cyber-green);
            color: var(--cyber-green);
            font-family: 'Fira Code', monospace;
            font-size: 0.72rem;
            font-weight: bold;
            box-shadow: 0 0 5px rgba(16, 185, 129, 0.1);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 6px;
            padding: 4px 10px;
        }
        .btn-cyber:hover {
            background: var(--cyber-green);
            color: #020617;
            box-shadow: 0 0 15px rgba(16, 185, 129, 0.6);
            transform: scale(1.05);
        }

        .pagination .page-link {
            background: var(--card-bg); border-color: var(--border-glass);
            color: var(--text-main); border-radius: 8px; margin: 0 2px; padding: 8px 14px;
        }
        .pagination .page-item.active .page-link {
            background: var(--brand-gold); border-color: var(--brand-gold); color: #000; font-weight: bold;
        }
        .pagination .page-link:hover { background: rgba(251, 191, 36, 0.1); color: var(--brand-gold-dark); }

        .page-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 28px; flex-wrap: wrap; gap: 12px;
        }
        .page-header h2 { font-size: 1.6rem; font-weight: 800; margin: 0; color: var(--text-main); }
        .page-header h2 small {
            font-size: 0.85rem; font-weight: 400; color: var(--text-muted);
            display: block; margin-top: 2px;
        }

        @keyframes fadeSlideIn {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-in { animation: fadeSlideIn 0.35s ease forwards; }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#001a4d">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Al-Ahram">
</head>
<body>

<%- include('partials/sidebar') %>

<div class="main-content">

    <!-- ── ترويسة الصفحة ── -->
    <div class="page-header fade-in">
        <div>
            <h2>
                <i class="fa-solid fa-user-shield me-2" style="color: var(--brand-gold);"></i>
                سجل التدفق والتدقيق الأمني
                <small>مراقبة وحماية العمليات والتحويلات اليومية في الزمن الفعلي</small>
            </h2>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-sm btn-outline-secondary" onclick="exportLogs()">
                <i class="fa-solid fa-file-export me-1"></i> تصدير JSON
            </button>
            <button class="btn btn-sm fw-bold" style="background: var(--brand-gold); color: #000;" onclick="location.reload()">
                <i class="fa-solid fa-rotate me-1"></i> تحديث السجل
            </button>
        </div>
    </div>

    <!-- ── كروت الإحصاء الخمسة ── -->
    <div class="row g-3 mb-4 fade-in">
        <!-- 1- العمليات اليوم -->
        <div class="col-6 col-md-4 col-lg">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(59,130,246,0.1); color: #3b82f6;">
                    <i class="fa-solid fa-server"></i>
                </div>
                <div>
                    <div class="stat-value text-primary"><%= stats.todayTotal.toLocaleString() %></div>
                    <div class="stat-label">عمليات السيرفر اليوم</div>
                </div>
            </div>
        </div>
        <!-- 2- مستخدمي التطبيق -->
        <div class="col-6 col-md-4 col-lg">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(16,185,129,0.1); color: #10b981;">
                    <i class="fa-solid fa-mobile-screen-button"></i>
                </div>
                <div>
                    <div class="stat-value text-success"><%= stats.appUsers.toLocaleString() %></div>
                    <div class="stat-label">مستخدمي التطبيق</div>
                </div>
            </div>
        </div>
        <!-- 3- مستخدمي الموقع -->
        <div class="col-6 col-md-4 col-lg">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(139,92,246,0.1); color: #8b5cf6;">
                    <i class="fa-solid fa-globe"></i>
                </div>
                <div>
                    <div class="stat-value" style="color:#8b5cf6;"><%= stats.webUsers.toLocaleString() %></div>
                    <div class="stat-label">مستخدمي الموقع</div>
                </div>
            </div>
        </div>
        <!-- 4- المتواجدين الان -->
        <div class="col-6 col-md-6 col-lg">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(6,182,212,0.1); color: #06b6d4;">
                    <i class="fa-solid fa-circle-nodes"></i>
                </div>
                <div>
                    <div class="stat-value text-info"><%= stats.onlineUsers.toLocaleString() %></div>
                    <div class="stat-label">المتواجدين الآن (Socket)</div>
                </div>
            </div>
        </div>
        <!-- 5- الدخول ناجح وفاشل اليوم -->
        <div class="col-6 col-md-6 col-lg">
            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(245,158,11,0.1); color: #f59e0b;">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size: 1rem; color: #f59e0b; font-weight: 800; line-height: 1.3;">
                        <span class="text-success"><i class="fa-solid fa-circle-check small"></i> ناجح: <%= stats.loginsSuccessToday %></span><br>
                        <span class="text-danger"><i class="fa-solid fa-circle-xmark small"></i> فاشل: <%= stats.loginsFailedToday %></span>
                    </div>
                    <div class="stat-label">محاولات الدخول اليوم</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── شريط الفلاتر ── -->
    <div class="filter-bar mb-4 fade-in">
        <form method="GET" action="/audit-log" id="filterForm">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-2">
                    <label class="form-label fw-semibold small">نوع العملية</label>
                    <select name="action" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">— جميع العمليات —</option>
                        <optgroup label="🔐 المصادقة والحسابات">
                            <option value="LOGIN_SUCCESS"  <%= filters.action === 'LOGIN_SUCCESS'   ? 'selected' : '' %>>✅ دخول ناجح</option>
                            <option value="LOGIN_FAILED"   <%= filters.action === 'LOGIN_FAILED'    ? 'selected' : '' %>>❌ دخول فاشل</option>
                            <option value="LOGOUT"         <%= filters.action === 'LOGOUT'          ? 'selected' : '' %>>🚪 تسجيل خروج</option>
                            <option value="USER_CREATED"   <%= filters.action === 'USER_CREATED'    ? 'selected' : '' %>>👤 إنشاء حساب جديد</option>
                        </optgroup>
                        <optgroup label="💸 التحويلات المالية">
                            <option value="TRANSFER_CREATED"   <%= filters.action === 'TRANSFER_CREATED'   ? 'selected' : '' %>>➕ طلب تحويل</option>
                            <option value="TRANSFER_COMPLETED" <%= filters.action === 'TRANSFER_COMPLETED' ? 'selected' : '' %>>✔️ تحويل مكتمل</option>
                            <option value="TRANSFER_CANCELLED" <%= filters.action === 'TRANSFER_CANCELLED' ? 'selected' : '' %>>🚫 تحويل ملغى</option>
                        </optgroup>
                        <optgroup label="⚙️ إدارية وأنظمة">
                            <option value="ADMIN_ACTION"     <%= filters.action === 'ADMIN_ACTION'     ? 'selected' : '' %>>🛡️ إجراء إداري</option>
                            <option value="SETTINGS_CHANGED" <%= filters.action === 'SETTINGS_CHANGED' ? 'selected' : '' %>>⚙️ تعديل إعدادات</option>
                            <option value="USER_BANNED"      <%= filters.action === 'USER_BANNED'      ? 'selected' : '' %>>🚫 حظر مستخدم</option>
                        </optgroup>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label fw-semibold small">اسم المنفذ</label>
                    <input type="text" name="performedBy" class="form-control form-control-sm"
                           placeholder="اسم المنفذ..." value="<%= filters.performedBy %>">
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small">من تاريخ</label>
                    <input type="date" name="dateFrom" class="form-control form-control-sm" value="<%= filters.dateFrom %>">
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small">إلى تاريخ</label>
                    <input type="date" name="dateTo" class="form-control form-control-sm" value="<%= filters.dateTo %>">
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label fw-semibold small">النتيجة</label>
                    <select name="success" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">— الكل —</option>
                        <option value="true"  <%= filters.success === 'true'  ? 'selected' : '' %>>✅ ناجحة فقط</option>
                        <option value="false" <%= filters.success === 'false' ? 'selected' : '' %>>❌ فاشلة فقط</option>
                    </select>
                </div>
                <div class="col-6 col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-sm flex-fill fw-bold"
                            style="background: var(--brand-gold); color: #000;">
                        <i class="fa-solid fa-magnifying-glass me-1"></i> بحث
                    </button>
                    <a href="/audit-log" class="btn btn-sm btn-outline-secondary" title="مسح الفلاتر">
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- ── جدول السجلات ── -->
    <div class="audit-table-wrapper fade-in">
        <div class="d-flex align-items-center justify-content-between px-4 py-3"
             style="border-bottom: 1px solid var(--border-glass);">
            <div>
                <span class="fw-bold">
                    <i class="fa-solid fa-list-ul me-2" style="color: var(--brand-gold);"></i>نتائج الاستعلام
                </span>
                <span class="badge ms-2"
                      style="background: rgba(251, 191, 36, 0.15); color: var(--brand-gold); border: 1px solid rgba(251, 191, 36, 0.3);">
                    <%= total.toLocaleString() %> سجل
                </span>
            </div>
            <small class="text-muted">صفحة <%= page %> من <%= totalPages || 1 %></small>
        </div>

        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>النتيجة</th>
                        <th>نوع العملية</th>
                        <th>المنفذ</th>
                        <th>نوع الحركة</th>
                        <th>الاسم</th>
                        <th>العنوان (IP)</th>
                        <th>الموقع (GPS)</th>
                        <th>الوقت والتاريخ</th>
                        <th>سجل الأمان</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (!logs || logs.length === 0) { %>
                    <tr>
                        <td colspan="10" class="text-center py-5">
                            <i class="fa-solid fa-inbox fa-3x mb-3 d-block"
                               style="color: var(--text-muted); opacity: 0.35;"></i>
                            <p class="text-muted mb-0">لا توجد سجلات مطابقة للبحث</p>
                        </td>
                    </tr>
                    <% } else { %>
                    <% logs.forEach(function(log, idx) { %>
                    <%
                        // Result badge
                        let resultBadge = '';
                        if (log.result === 'ناجح') {
                            resultBadge = '<span class="badge bg-success px-2 py-1">ناجح</span>';
                        } else if (log.result === 'فاشل') {
                            resultBadge = '<span class="badge bg-danger px-2 py-1">فاشل</span>';
                        } else if (log.result === 'معلق') {
                            resultBadge = '<span class="badge bg-warning text-dark px-2 py-1">معلق</span>';
                        } else if (log.result === 'محظور') {
                            resultBadge = '<span class="badge bg-dark text-danger border border-danger px-2 py-1">محظور</span>';
                        } else {
                            resultBadge = `<span class="badge bg-secondary px-2 py-1">${log.result || '—'}</span>`;
                        }

                        // Process Type Label translation
                        let processLabel = '—';
                        if (log.action === 'LOGIN_SUCCESS' || log.action === 'LOGIN_FAILED') {
                            processLabel = 'تسجيل دخول';
                        } else if (log.action === 'LOGOUT') {
                            processLabel = 'تسجيل خروج';
                        } else if (log.action === 'USER_CREATED') {
                            if (log.metadata && log.metadata.actionLabel) {
                                processLabel = log.metadata.actionLabel;
                            } else {
                                const role = log.metadata?.role || log.newData?.role || '';
                                if (role === 'accountant') processLabel = 'انشاء حساب محاسب';
                                else if (role === 'operator' || role === 'employee') processLabel = 'انشاء حساب موظف';
                                else processLabel = 'انشاء حساب';
                            }
                        } else if (log.action && log.action.startsWith('TRANSFER_')) {
                            const tType = log.metadata?.transferType || log.newData?.transferType || '';
                            if (tType === 'balance_transfer' || tType === 'internal') {
                                processLabel = 'تحويل رصيد داخلي';
                            } else if (tType.includes('post') || tType.includes('بريد')) {
                                processLabel = 'تحويل بريد';
                            } else if (tType.includes('سيفا') || tType.includes('niger') || tType.includes('cfa')) {
                                processLabel = 'تحويل سيفا النيجر';
                            } else if (tType.includes('بنكك') || tType.includes('sudan') || tType.includes('bankak')) {
                                processLabel = 'تحويل بنكك السودان';
                            } else {
                                processLabel = 'تحويل كاش';
                            }
                        } else {
                            processLabel = log.action || '—';
                        }

                        // Date digits only & time 12-hour
                        const logDate = log.createdAt ? new Date(log.createdAt) : null;
                        let dateStr = '—';
                        let timeStr = '';
                        if (logDate) {
                            const year = logDate.getFullYear();
                            const month = String(logDate.getMonth() + 1).padStart(2, '0');
                            const day = String(logDate.getDate()).padStart(2, '0');
                            dateStr = `${year}-${month}-${day}`;
                            
                            let hours = logDate.getHours();
                            const minutes = String(logDate.getMinutes()).padStart(2, '0');
                            const seconds = String(logDate.getSeconds()).padStart(2, '0');
                            const ampm = hours >= 12 ? 'م' : 'ص';
                            hours = hours % 12;
                            hours = hours ? hours : 12;
                            timeStr = `${String(hours).padStart(2, '0')}:${minutes}:${seconds} ${ampm}`;
                        }

                        // GPS Coordinates link
                        let gpsHtml = '—';
                        if (log.location && log.location.latitude && log.location.longitude) {
                            gpsHtml = `<a href="https://www.google.com/maps?q=${log.location.latitude},${log.location.longitude}" target="_blank" class="btn btn-sm btn-outline-info py-0 px-2 fw-semibold" style="font-size:0.75rem;"><i class="fa-solid fa-map-location-dot"></i> خرائط</a>`;
                        }

                        // safeLog encoding
                        const safeLog = JSON.stringify(log)
                            .replace(/\\/g, '\\\\')
                            .replace(/'/g, "\\'");
                    %>
                    <tr>
                        <td class="text-muted fw-bold small"><%= (page - 1) * limit + idx + 1 %></td>
                        <td><%- resultBadge %></td>
                        <td><span class="fw-semibold"><%= processLabel %></span></td>
                        <td><span class="badge bg-secondary opacity-75"><%= log.initiator || 'موقع' %></span></td>
                        <td><span class="badge bg-dark"><%= log.deviceType || 'كمبيوتر' %></span></td>
                        <td><span class="fw-semibold"><%= log.performedByName || '—' %></span></td>
                        <td><code class="small" style="font-size:0.75rem; color:var(--text-muted);"><%= log.ipAddress || '—' %></code></td>
                        <td><%- gpsHtml %></td>
                        <td>
                            <small style="white-space:nowrap;">
                                <span class="d-block text-dark fw-bold" style="font-size:0.8rem;"><%= dateStr %></span>
                                <span class="text-muted"><%= timeStr %></span>
                            </small>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-cyber" onclick="showCyberLog('<%= safeLog %>')">
                                <i class="fa-solid fa-terminal"></i> LOG
                            </button>
                        </td>
                    </tr>
                    <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- ── ترقيم الصفحات ── -->
        <% if (totalPages > 1) { %>
        <div class="d-flex justify-content-center align-items-center py-4">
            <nav aria-label="ترقيم الصفحات">
                <ul class="pagination pagination-sm mb-0">
                    <% if (page > 1) { %>
                    <li class="page-item">
                        <a class="page-link"
                           href="?page=<%= page - 1 %>&action=<%= encodeURIComponent(filters.action) %>&dateFrom=<%= filters.dateFrom %>&dateTo=<%= filters.dateTo %>&performedBy=<%= encodeURIComponent(filters.performedBy) %>&success=<%= filters.success %>">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </li>
                    <% } %>
                    <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
                    <li class="page-item <%= p === page ? 'active' : '' %>">
                        <a class="page-link"
                           href="?page=<%= p %>&action=<%= encodeURIComponent(filters.action) %>&dateFrom=<%= filters.dateFrom %>&dateTo=<%= filters.dateTo %>&performedBy=<%= encodeURIComponent(filters.performedBy) %>&success=<%= filters.success %>">
                            <%= p %>
                        </a>
                    </li>
                    <% } %>
                    <% if (page < totalPages) { %>
                    <li class="page-item">
                        <a class="page-link"
                           href="?page=<%= page + 1 %>&action=<%= encodeURIComponent(filters.action) %>&dateFrom=<%= filters.dateFrom %>&dateTo=<%= filters.dateTo %>&performedBy=<%= encodeURIComponent(filters.performedBy) %>&success=<%= filters.success %>">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                    </li>
                    <% } %>
                </ul>
            </nav>
        </div>
        <% } %>
    </div>
</div>

<!-- ── Modal التفاصيل (سايبر بنك كونسول) ── -->
<div class="modal fade terminal-modal" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="detailModalLabel">
                    <i class="fa-solid fa-terminal me-2"></i> SECURITY VERIFICATION CONSOLE
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="إغلاق"></button>
            </div>
            <div class="modal-body">
                <div class="terminal-body" id="detailBody">
                    <!-- تُملأ عبر Javascript -->
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script>
    // ── عرض تفاصيل العملية في الكونسول الأمني ──
    function showCyberLog(jsonStr) {
        let log;
        try {
            log = JSON.parse(jsonStr);
        } catch (e) {
            console.error('خطأ في تحليل بيانات السجل:', e);
            return;
        }

        const detailBody = document.getElementById('detailBody');
        detailBody.innerHTML = ''; // تهيئة الكونسول

        function addLine(text, type = 'info', delay = 0) {
            const line = document.createElement('div');
            line.className = `terminal-line terminal-${type}`;
            line.style.animationDelay = `${delay}ms`;
            line.innerHTML = text;
            detailBody.appendChild(line);
        }

        let delay = 0;
        const step = 45; // سرعة الكتابة

        addLine(`[SYSTEM] Initializing audit trail cryptographic verification...`, 'info', delay);
        delay += step;

        addLine(`[SECURITY] Retrieving client network address: ${escHtml(log.ipAddress || 'unknown')}`, 'info', delay);
        delay += step;

        const ipOk = log.ipAddress && log.ipAddress !== 'unknown';
        addLine(`[SECURITY] Enforcing client IP existence validation... ${ipOk ? 'PASSED' : 'FAILED'}`, ipOk ? 'success' : 'danger', delay);
        delay += step;

        const initiator = log.initiator || 'موقع';
        const deviceType = log.deviceType || 'كمبيوتر';
        addLine(`[DEVICE] Inspecting HTTP client headers... PLATFORM: ${escHtml(initiator)} | DEVICE: ${escHtml(deviceType)}`, 'info', delay);
        delay += step;
        
        if (log.userAgent) {
            addLine(`[DEVICE] Raw user agent: ${escHtml(log.userAgent)}`, 'default', delay);
            delay += step;
        }

        if (log.location && log.location.latitude && log.location.longitude) {
            addLine(`[LOCATION] GPS coordinate verification: LAT: ${log.location.latitude}, LON: ${log.location.longitude} (VERIFIED)`, 'success', delay);
        } else {
            addLine(`[LOCATION] GPS coordinate verification: No geolocational metadata provided`, 'warning', delay);
        }
        delay += step;

        addLine(`[INTEGRITY] Reading ledger cryptographic block hash keys...`, 'info', delay);
        delay += step;
        addLine(`   | Previous block hash:  ${escHtml(log.previousHash || 'GENESIS')}`, 'default', delay);
        delay += step;
        addLine(`   | Current block hash:   ${escHtml(log.hash || 'N/A')}`, 'default', delay);
        delay += step;
        addLine(`[INTEGRITY] Blockchain hash matching verification status: SECURE`, 'success', delay);
        delay += step;

        const d = log.createdAt ? new Date(log.createdAt) : null;
        const formattedDate = d ? d.toLocaleString('ar-EG') : '—';
        addLine(`[PROCESS] Launching process payload data execution...`, 'info', delay);
        delay += step;
        addLine(`   | Action Name:      ${escHtml(log.action)}`, 'default', delay);
        delay += step;
        addLine(`   | Performed By:     ${escHtml(log.performedByName || 'System')} (${escHtml(log.performedByModel || 'System')})`, 'default', delay);
        delay += step;
        addLine(`   | Timestamp:        ${formattedDate}`, 'default', delay);
        delay += step;

        if (log.metadata && Object.keys(log.metadata).length > 0) {
            addLine(`[PAYLOAD] Metadata: \n${escHtml(JSON.stringify(log.metadata, null, 2))}`, 'info', delay);
            delay += step;
        }

        if (log.oldData && Object.keys(log.oldData).length > 0) {
            addLine(`[PAYLOAD] Previous Ledger Data (Old Data): \n${escHtml(JSON.stringify(log.oldData, null, 2))}`, 'default', delay);
            delay += step;
        }

        if (log.newData && Object.keys(log.newData).length > 0) {
            addLine(`[PAYLOAD] Executed Ledger Data (New Data): \n${escHtml(JSON.stringify(log.newData, null, 2))}`, 'default', delay);
            delay += step;
        }

        const isSuccess = log.success !== false;
        const resultLabel = log.result || (isSuccess ? 'ناجح' : 'فاشل');
        let statusType = 'success';
        if (resultLabel === 'فاشل') statusType = 'danger';
        else if (resultLabel === 'معلق') statusType = 'warning';
        else if (resultLabel === 'محظور') statusType = 'danger';

        addLine(`[RESULT] Transaction block execution completed. Status: [${resultLabel.toUpperCase()}]`, statusType, delay);

        // فتح المودال
        const modal = new bootstrap.Modal(document.getElementById('detailModal'));
        modal.show();
    }

    function escHtml(str) {
        if (str === null || str === undefined) return '';
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function exportLogs() {
        const params = new URLSearchParams(window.location.search);
        params.delete('page');
        const url = '/audit-log/export?' + params.toString();

        const link = document.createElement('a');
        link.href = url;
        link.download = 'audit_log_' + new Date().toISOString().slice(0, 10) + '.json';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }

    // تحديث تلقائي كل 30 ثانية
    const currentParams = new URLSearchParams(window.location.search);
    currentParams.delete('page');
    if (currentParams.toString() === '') {
        let autoRefreshTimer = setInterval(function () {
            location.reload();
        }, 30000);

        document.getElementById('detailModal').addEventListener('show.bs.modal', function () {
            clearInterval(autoRefreshTimer);
        });
    }
</script>
</body>
</html>
