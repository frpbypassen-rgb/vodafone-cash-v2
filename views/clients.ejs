<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>إدارة العملاء | الأهرام</title>
    
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    
    <style>
        /* =========================================
           ✨ 3D Modern Cards - التصميم ثلاثي الأبعاد
           ========================================= */
        .card-3d-wrapper {
            perspective: 1000px;
            height: 100%;
        }

        .client-card-3d {
            background: var(--card-bg);
            border-radius: 24px;
            padding: 25px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            height: 100%;
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border-glass);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            z-index: 1;
        }

        .client-card-3d::before {
            content: ''; position: absolute; top: -50%; right: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 60%);
            transform: rotate(45deg); pointer-events: none; z-index: -1;
        }

        [data-theme="dark"] .client-card-3d {
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
        }

        .client-card-3d:hover {
            transform: translateY(-10px) rotateX(2deg) rotateY(-2deg);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
        }

        [data-theme="dark"] .client-card-3d:hover {
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6), inset 0 0 0 1px rgba(255, 255, 255, 0.1);
        }

        .profile-icon {
            width: 65px; height: 65px; border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            font-size: 28px; color: white;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            position: relative;
        }

        .profile-icon::after {
            content: ''; position: absolute; width: 100%; height: 100%;
            border-radius: inherit; background: inherit;
            filter: blur(12px); z-index: -1; opacity: 0.6; transition: 0.3s;
        }

        .client-card-3d:hover .profile-icon::after { filter: blur(18px); opacity: 0.9; }

        .user-icon { background: linear-gradient(135deg, #3b82f6, #2563eb); }
        .company-icon { background: linear-gradient(135deg, #8b5cf6, #6d28d9); }

        .balance-box {
            background: var(--input-bg); border-radius: 20px; padding: 20px;
            margin: 20px 0; border: 1px solid var(--border-glass);
            position: relative; overflow: hidden; text-align: center;
            box-shadow: inset 0 4px 10px rgba(0,0,0,0.02);
        }

        [data-theme="dark"] .balance-box { box-shadow: inset 0 4px 10px rgba(0,0,0,0.2); }

        .mono-num { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 900; line-height: 1; }

        .btn-3d {
            background: var(--input-bg); border: 1px solid var(--border-glass);
            color: var(--text-main); border-radius: 16px; padding: 12px;
            font-weight: 800; transition: all 0.3s;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            display: flex; align-items: center; justify-content: center; text-decoration: none;
        }

        .btn-3d.user-btn:hover { background: #3b82f6; color: white; border-color: #3b82f6; transform: translateY(-3px); box-shadow: 0 10px 25px rgba(59, 130, 246, 0.4); }
        .btn-3d.company-btn:hover { background: #8b5cf6; color: white; border-color: #8b5cf6; transform: translateY(-3px); box-shadow: 0 10px 25px rgba(139, 92, 246, 0.4); }

        /* Tabs Styling */
        .nav-pills .nav-link {
            color: var(--text-muted); border: 1px solid var(--border-glass);
            border-radius: 16px; margin-left: 10px; font-weight: 800;
            background: var(--card-bg); transition: 0.3s; padding: 14px 30px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        }
        .nav-pills .nav-link.active { background-color: var(--brand-primary); color: white !important; border-color: var(--brand-primary); transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0, 0, 77, 0.2); }
        [data-theme="dark"] .nav-pills .nav-link.active { background-color: var(--brand-gold); color: black !important; border-color: var(--brand-gold); box-shadow: 0 8px 20px rgba(212, 175, 55, 0.3); }
        
        /* 📱 تحسين المظهر على الجوال */
        @media (max-width: 768px) {
            .nav-pills { flex-wrap: nowrap; overflow-x: auto; padding-bottom: 10px; border: none !important; background: transparent !important; }
            .nav-pills .nav-link { white-space: nowrap; padding: 10px 20px; font-size: 0.9rem; }
        }
    </style>
</head>
<body>

<button class="mobile-nav-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<%- include('partials/sidebar', { activePage: 'clients' }) %>

<div class="main-content">
    <div class="container-fluid">
        <div class="admin-nav mb-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <h3 class="fw-bold m-0 text-dark"><i class="fa-solid fa-users text-primary me-2"></i> إدارة العملاء والوكلاء</h3>
            
            <ul class="nav nav-pills d-inline-flex m-0 p-1 rounded-4 border data-card" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#users-tab" type="button"><i class="fa-solid fa-user me-1"></i> العملاء الأفراد</button>
                </li>
                <li class="nav-item m-0" role="presentation">
                    <button class="nav-link" data-bs-toggle="pill" data-bs-target="#companies-tab" type="button"><i class="fa-solid fa-building me-1"></i> الشركات والوكلاء</button>
                </li>
            </ul>
        </div>

        <div class="tab-content mt-4">
            <div class="tab-pane fade show active" id="users-tab">
                <div class="row g-4 pb-5">
                    <% if(users.length === 0) { %>
                        <div class="col-12 text-center py-5">
                            <i class="fa-solid fa-user-slash fa-4x text-muted opacity-25 mb-3"></i>
                            <h5 class="text-muted fw-bold">لا يوجد عملاء أفراد مسجلين في المنظومة.</h5>
                        </div>
                    <% } %>

                    <% users.forEach(u => { %>
                        <div class="col-xl-3 col-lg-4 col-md-6">
                            <div class="card-3d-wrapper">
                                <div class="client-card-3d" style="border-top: 5px solid #3b82f6;">
                                    <div>
                                        <div class="d-flex justify-content-between align-items-start mb-4">
                                            <div class="d-flex align-items-center gap-3 w-100">
                                                <div class="profile-icon user-icon">
                                                    <i class="fa-solid fa-user"></i>
                                                </div>
                                                <div style="width: calc(100% - 80px);">
                                                    <h5 class="fw-bold m-0 text-dark mb-1 text-truncate" title="<%= u.name %>"><%= u.name %></h5>
                                                    <span class="badge <%= u.status === 'active' ? 'bg-success' : 'bg-danger' %> bg-opacity-10 text-<%= u.status === 'active' ? 'success' : 'danger' %> border rounded-pill px-2 py-1 mt-1" style="font-size:0.75rem;">
                                                        <i class="fa-solid <%= u.status === 'active' ? 'fa-check-circle' : 'fa-ban' %> me-1"></i><%= u.status === 'active' ? 'نشط ومفعل' : 'محظور' %>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="d-flex justify-content-between align-items-center text-muted small fw-bold mb-2 px-1">
                                            <span dir="ltr"><i class="fa-solid fa-phone me-1 opacity-50 text-primary"></i> <%= u.phone %></span>
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary rounded-pill px-2">مستوى <%= u.tier || 1 %></span>
                                        </div>
                                        
                                        <div class="text-muted small fw-bold mb-3 px-1 text-truncate">
                                            <i class="fa-brands fa-telegram me-1 opacity-50 text-info"></i> <code class="text-muted"><%= u.telegramId || 'لم يربط التيليجرام' %></code>
                                        </div>

                                        <div class="balance-box">
                                            <div class="text-muted small fw-bold mb-2"><i class="fa-solid fa-wallet me-1 opacity-50"></i> الرصيد الحالي (LYD)</div>
                                            <div class="mono-num <%= u.balance < 0 ? 'text-danger' : 'text-success' %>" dir="ltr">
                                                <%= u.balance.toFixed(2) %>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <a href="/user/<%= u._id %>" class="btn-3d user-btn">
                                        <i class="fa-solid fa-folder-open me-2"></i> إدارة ملف العميل
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="tab-pane fade" id="companies-tab">
                <div class="row g-4 pb-5">
                    <% if(companies.length === 0) { %>
                        <div class="col-12 text-center py-5">
                            <i class="fa-solid fa-building-circle-xmark fa-4x text-muted opacity-25 mb-3"></i>
                            <h5 class="text-muted fw-bold">لا يوجد شركات أو وكلاء مسجلين في المنظومة.</h5>
                        </div>
                    <% } %>

                    <% companies.forEach(c => { %>
                        <div class="col-xl-3 col-lg-4 col-md-6">
                            <div class="card-3d-wrapper">
                                <div class="client-card-3d" style="border-top: 5px solid #8b5cf6;">
                                    <div>
                                        <div class="d-flex justify-content-between align-items-start mb-4">
                                            <div class="d-flex align-items-center gap-3 w-100">
                                                <div class="profile-icon company-icon">
                                                    <i class="fa-solid fa-building"></i>
                                                </div>
                                                <div style="width: calc(100% - 80px);">
                                                    <h5 class="fw-bold m-0 text-dark mb-1 text-truncate" title="<%= c.name %>"><%= c.name %></h5>
                                                    <span class="badge <%= c.status === 'active' ? 'bg-success' : 'bg-danger' %> bg-opacity-10 text-<%= c.status === 'active' ? 'success' : 'danger' %> border rounded-pill px-2 py-1 mt-1" style="font-size:0.75rem;">
                                                        <i class="fa-solid <%= c.status === 'active' ? 'fa-check-circle' : 'fa-ban' %> me-1"></i><%= c.status === 'active' ? 'يعمل' : 'مغلق' %>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="d-flex justify-content-between align-items-center text-muted small fw-bold mb-2 px-1">
                                            <span dir="ltr"><i class="fa-solid fa-phone me-1 opacity-50" style="color: #8b5cf6;"></i> <%= c.phone %></span>
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary rounded-pill px-2">مستوى <%= c.tier || 1 %></span>
                                        </div>

                                        <div class="text-muted small fw-bold mb-3 px-1 text-truncate" title="<%= c.token %>">
                                            <i class="fa-solid fa-key me-1 opacity-50" style="color: #8b5cf6;"></i> <code class="text-muted" style="filter: blur(2px); transition: 0.3s; cursor: pointer;" onmouseover="this.style.filter='none'" onmouseout="this.style.filter='blur(2px)'"><%= c.token %></code>
                                        </div>

                                        <div class="balance-box">
                                            <div class="text-muted small fw-bold mb-2"><i class="fa-solid fa-wallet me-1 opacity-50"></i> ميزانية الشركة (LYD)</div>
                                            <div class="mono-num <%= c.balance < 0 ? 'text-danger' : 'text-success' %>" dir="ltr">
                                                <%= c.balance.toFixed(2) %>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <a href="/company/<%= c._id %>" class="btn-3d company-btn">
                                        <i class="fa-solid fa-folder-open me-2"></i> إدارة ملف الشركة
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleSidebar() { 
        document.querySelector('.sidebar').classList.toggle('active');
        document.querySelector('.sidebar-overlay').classList.toggle('active'); 
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>