<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>التقفيل المركزي | الأهرام</title>
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <style>
        .close-box { background: linear-gradient(135deg, var(--brand-primary), #000); color: white; border-radius: 24px; padding: 40px; position: relative; overflow: hidden; box-shadow: var(--shadow-hover); border: 1px solid var(--border-glass);}
        [data-theme="dark"] .close-box { background: linear-gradient(135deg, #1e293b, #0f172a); border-color: var(--brand-gold);}
        .close-box i.bg-icon { position: absolute; left: -20px; bottom: -40px; font-size: 250px; opacity: 0.05; transform: rotate(-15deg); pointer-events: none;}
        .mono-num { font-family: 'JetBrains Mono', monospace; }
    </style>
</head>
<body>

<button class="mobile-nav-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<%- include('partials/sidebar', { activePage: 'closing' }) %>

<div class="main-content">
    <div class="container-fluid">
        <div class="admin-nav mb-4">
            <h3 class="fw-bold m-0 text-dark"><i class="fa-solid fa-box-archive text-primary me-2"></i> مركز التقفيل والأرشيف المحاسبي (Vault)</h3>
        </div>

        <div class="data-card close-box mb-5 border-0">
            <i class="fa-solid fa-vault bg-icon"></i>
            <div class="row align-items-center position-relative z-1">
                <div class="col-md-7 mb-4 mb-md-0">
                    <h2 class="fw-bold mb-3 text-white" style="color: var(--brand-gold) !important;">تقفيل اليوميات (Snapshot)</h2>
                    <p class="mb-0 fs-5 text-white opacity-75" style="line-height: 1.8;">قم باختيار تاريخ محدد لإغلاقه وتجميد الأرصدة. سيتم إنشاء ملف Excel شامل لجميع حركات البوتات والمنفذين وحفظه في الأرشيف بشكل دائم لتجنب أي تعديلات مستقبلية.</p>
                </div>
                <div class="col-md-5">
                    <div class="p-4 rounded-4 shadow-sm" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.2);">
                        <form action="/closing/generate" method="POST" onsubmit="return confirm('هل أنت متأكد من إنشاء تقفيل لهذا اليوم؟ سيتم حفظه في الأرشيف بالأسفل.')">
                            <label class="form-label fw-bold small text-white opacity-75 mb-2">تحديد تاريخ التقفيل المُراد حفظه:</label>
                            <input type="date" name="date" class="form-control form-control-lg fw-bold text-center mb-3 mono-num" required style="background: rgba(255,255,255,0.9) !important; color: #000 !important;">
                            <button type="submit" class="btn btn-light btn-lg w-100 fw-bold shadow-sm text-primary rounded-pill"><i class="fa-solid fa-lock me-2"></i> إغلاق وتوليد التقرير</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <h4 class="fw-bold text-dark mb-4"><i class="fa-solid fa-folder-open text-warning me-2"></i> الأرشيف (التقارير المحفوظة)</h4>
        
        <div class="data-card p-0 overflow-hidden border-start border-4" style="border-left-color: var(--brand-gold) !important;">
            <div class="table-responsive m-0 border-0">
                <table class="table text-center align-middle mb-0 table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>التاريخ المُقفل</th>
                            <th>نوع التقرير</th>
                            <th>بواسطة</th>
                            <th>وقت التقفيل (Snapshot)</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (reports.length === 0) { %>
                            <tr><td colspan="5" class="py-5 text-muted fw-bold fs-5 border-0"><i class="fa-solid fa-box-open fs-1 opacity-25 d-block mb-3"></i> لا يوجد أي ملفات تقفيل في الأرشيف حالياً.</td></tr>
                        <% } else { %>
                            <% reports.forEach(rep => { %>
                                <tr>
                                    <td><span class="badge bg-primary fs-6 px-3 py-2 rounded-pill mono-num"><i class="fa-regular fa-calendar-days me-1"></i> <%= rep.dateString %></span></td>
                                    <td class="fw-bold text-dark"><%= rep.reportType %></td>
                                    <td class="fw-bold text-muted"><i class="fa-solid fa-user-shield me-1 opacity-50"></i> <%= rep.generatedBy %></td>
                                    <td class="small text-muted mono-num" dir="ltr">
                                        <%= rep.createdAt.toLocaleTimeString('en-US') %> <br> <span class="opacity-50"><%= rep.createdAt.toLocaleDateString('en-GB') %></span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="/closing/download/<%= rep._id %>" class="btn btn-sm btn-success fw-bold px-3 shadow-sm rounded-3">
                                                <i class="fa-solid fa-download me-1"></i> تحميل
                                            </a>
                                            <form action="/closing/delete/<%= rep._id %>" method="POST" class="m-0" onsubmit="return confirm('تحذير: هل أنت متأكد من حذف هذا الأرشيف نهائياً؟')">
                                                <button type="submit" class="btn btn-sm btn-danger fw-bold shadow-sm rounded-3"><i class="fa-solid fa-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<script>function toggleSidebar() { document.querySelector('.sidebar').classList.toggle('active'); document.querySelector('.sidebar-overlay').classList.toggle('active'); }</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>