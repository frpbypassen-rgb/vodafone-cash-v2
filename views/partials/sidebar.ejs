        <button class="mobile-menu-trigger" type="button" data-sidebar-toggle onclick="toggleSidebar()" aria-label="فتح القائمة" aria-controls="sidebarMenu" aria-expanded="false">
            <i class="fa-solid fa-bars-staggered"></i>
            <span id="mobileMenuBadge" class="position-absolute bg-danger rounded-circle" style="display: none; top: 12px; right: 14px; width: 9px; height: 9px; border: 2px solid var(--card-bg);"></span>
        </button>
        <div class="avatar-sm me-2"><i class="fa-solid fa-user-shield"></i></div>
        <div class="d-flex flex-column">
            <span class="fw-bold" style="font-size: 0.85rem; color: var(--text-main);"><%= typeof adminName !== 'undefined' ? adminName : 'مدير النظام' %></span>
            <span style="font-size: 0.65rem; color: var(--brand-gold);">القيادة المركزية</span>
        </div>
    </div>
    <div class="d-flex align-items-center gap-2">
        <div class="dropdown">
            <button class="btn-theme-mobile position-relative" type="button" id="notifDropdownMobile" data-bs-toggle="dropdown" style="background: transparent; border: none; padding: 0;">
                <i class="fa-solid fa-bell" style="color: var(--text-main); font-size: 1.2rem;"></i>
                <span id="notifBadgeMobile" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none shadow-sm" style="font-size: 0.6rem; border: 2px solid var(--card-bg);">0</span>
            </button>
            <ul class="dropdown-menu shadow-lg p-0" aria-labelledby="notifDropdownMobile" style="width: 320px; max-width: 90vw; right: auto; left: 0;">
                <li class="p-3 fw-bold d-flex justify-content-between align-items-center border-bottom" style="background: var(--input-bg);">
                    <span style="color: var(--brand-primary);"><i class="fa-solid fa-bell me-2"></i> الإشعارات</span>
                    <button class="btn btn-sm btn-light py-1 px-3 fw-bold rounded-pill" onclick="markAllRead()" style="font-size: 0.75rem;">تحديد كمقروء</button>
                </li>
                <div id="notifListMobile" style="max-height: 350px; overflow-y: auto; background: var(--card-bg);">
                    <li class="p-4 text-center text-muted fw-bold">لا توجد إشعارات</li>
                </div>
            </ul>
        </div>
        <button class="btn-theme-mobile" onclick="toggleGlobalTheme()" title="تغيير المظهر">
            <i id="mobileTopThemeIcon" class="fa-solid fa-moon"></i>
        </button>
        <a href="/logout" class="btn-logout-mobile" title="تسجيل الخروج">
            <i class="fa-solid fa-power-off"></i>
        </a>
    </div>
</div>

