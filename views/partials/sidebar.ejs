<script>
    function setAdminSidebarState(forceOpen) {
        const primarySidebar = document.getElementById('sidebarMenu') || document.querySelector('.sidebar');
        if (!primarySidebar) return false;

        const shouldOpen = typeof forceOpen === 'boolean' ? forceOpen : !primarySidebar.classList.contains('active');
        document.querySelectorAll('.sidebar').forEach(sidebar => sidebar.classList.toggle('active', shouldOpen));
        document.querySelectorAll('.sidebar-overlay').forEach(overlay => overlay.classList.toggle('active', shouldOpen));
        document.body.classList.toggle('sidebar-open-mobile', shouldOpen);
        document.querySelectorAll('[data-sidebar-toggle], .mobile-nav-toggle, .mobile-menu-trigger').forEach(button => {
            button.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
        });

        return shouldOpen;
    }

    function toggleSidebar(forceOpen) {
        return setAdminSidebarState(forceOpen);
    }

    window.__toggleAdminSidebar = toggleSidebar;
    window.closeAdminSidebar = () => setAdminSidebarState(false);

    function toggleGlobalTheme() {
        const html = document.documentElement;
        const currentTheme = html.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', newTheme);
        localStorage.setItem('ahram_theme', newTheme);
        updateSidebarThemeIcon(newTheme);

        if (typeof Chart !== 'undefined' && window.myChart) {
            const color = newTheme === 'dark' ? '#94a3b8' : '#6c757d';
            Chart.defaults.color = color;
            if(window.myChart.options.scales.x) window.myChart.options.scales.x.ticks.color = color;
            if(window.myChart.options.scales.y) window.myChart.options.scales.y.ticks.color = color;
            window.myChart.update();
        }
    }

    function updateSidebarThemeIcon(theme) {
        const icon = document.getElementById('sidebarThemeIcon');
        const text = document.getElementById('sidebarThemeText');
        if (icon && text) {
            icon.className = theme === 'dark' ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
            text.innerText = theme === 'dark' ? ' التبديل للوضع النهاري' : ' التبديل للوضع الليلي';
        }
        
        const topIcon = document.getElementById('mobileTopThemeIcon');
        if (topIcon) {
            topIcon.className = theme === 'dark' ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
        }
    }

    async function updateSidebarStats() {
        try {
            const res = await fetch('/api/sidebar-stats');
            const data = await res.json();
            if (data.success) {
                // 1. الدعم الفني
                const supportBadge = document.getElementById('sidebarSupportBadge');
                if (supportBadge) {
                    if (data.supportCount > 0) {
                        supportBadge.innerText = data.supportCount;
                        supportBadge.style.display = 'inline-block';
                    } else {
                        supportBadge.style.display = 'none';
                    }
                }

                // 2. الشكاوى (القائمة الجانبية والشريط السفلي للهاتف)
                const complaintsBadge = document.getElementById('sidebarComplaintsBadge');
                if (complaintsBadge) {
                    if (data.complaintsCount > 0) {
                        complaintsBadge.innerText = data.complaintsCount;
                        complaintsBadge.style.display = 'inline-block';
                    } else {
                        complaintsBadge.style.display = 'none';
                    }
                }
                
                const mobileTransactionsBadge = document.getElementById('mobileTransactionsBadge');
                if (mobileTransactionsBadge) {
                    if (data.pendingCount > 0) {
                        mobileTransactionsBadge.innerText = data.pendingCount;
                        mobileTransactionsBadge.style.display = 'inline-block';
                    } else {
                        mobileTransactionsBadge.style.display = 'none';
                    }
                }

                const mobileComplaintsBadge = document.getElementById('mobileComplaintsBadge');
                if (mobileComplaintsBadge) {
                    if (data.complaintsCount > 0) {
                        mobileComplaintsBadge.innerText = data.complaintsCount;
                        mobileComplaintsBadge.style.display = 'inline-block';
                    } else {
                        mobileComplaintsBadge.style.display = 'none';
                    }
                }

                // 3. طلبات التسجيل
                const regBadge = document.getElementById('sidebarRegBadge');
                if (regBadge) {
                    if (data.regRequestsCount > 0) {
                        regBadge.innerText = data.regRequestsCount;
                        regBadge.style.display = 'inline-block';
                    } else {
                        regBadge.style.display = 'none';
                    }
                }

                // 4. نقطة إشعار القائمة للموبايل (إذا كان هناك دعم أو طلبات تسجيل جديدة)
                const mobileMenuBadge = document.getElementById('mobileMenuBadge');
                if (mobileMenuBadge) {
                    if (data.supportCount > 0 || data.regRequestsCount > 0) {
                        mobileMenuBadge.style.display = 'block';
                    } else {
                        mobileMenuBadge.style.display = 'none';
                    }
                }
            }
        } catch (e) {
            console.error('Error fetching sidebar stats:', e);
        }
    }

    async function fetchNotifications() {
        try {
            const res = await fetch('/api/notifications/unread'); const data = await res.json();
            
            // Desktop IDs
            const badge = document.getElementById('notifBadge'); const list = document.getElementById('notifList');
            // Mobile IDs
            const badgeMobile = document.getElementById('notifBadgeMobile'); const listMobile = document.getElementById('notifListMobile');
            
            if (data.count > 0) {
                let html = ''; data.notifications.forEach(n => { html += `<li class="dropdown-item border-bottom p-3" style="cursor:pointer; border-color: var(--border-glass) !important;" onclick="markRead('${n._id}')"><div class="fw-bold small mb-1" style="color: var(--text-main);"><i class="fa-solid fa-circle-info text-primary me-1"></i> ${n.title}</div><div class="text-muted" style="font-size: 0.85rem;">${n.message}</div><div class="text-end text-muted mt-2 mono-num opacity-50" style="font-size: 0.75rem;">${new Date(n.createdAt).toLocaleTimeString('en-US')}</div></li>`; });
                
                if(badge && list) { badge.innerText = data.count; badge.classList.remove('d-none'); list.innerHTML = html; }
                if(badgeMobile && listMobile) { badgeMobile.innerText = data.count; badgeMobile.classList.remove('d-none'); listMobile.innerHTML = html; }
            } else {
                const emptyHtml = '<li class="p-4 text-center text-muted fw-bold"><i class="fa-solid fa-check-circle fs-1 opacity-25 d-block mb-2"></i> لا توجد إشعارات جديدة</li>';
                if(badge && list) { badge.classList.add('d-none'); list.innerHTML = emptyHtml; }
                if(badgeMobile && listMobile) { badgeMobile.classList.add('d-none'); listMobile.innerHTML = emptyHtml; }
            }
        } catch (e) {}
    }
    async function markRead(id) { await fetch(`/api/notifications/${id}/read`, { method: 'POST' }); fetchNotifications(); }
    async function markAllRead() { await fetch(`/api/notifications/read-all`, { method: 'POST' }); fetchNotifications(); }

    document.addEventListener('DOMContentLoaded', () => {
        window.toggleSidebar = window.__toggleAdminSidebar || toggleSidebar;

        document.querySelectorAll('.sidebar-menu a[href]:not([href^="javascript"])').forEach(link => {
            link.addEventListener('click', () => {
                if (window.innerWidth <= 991) setAdminSidebarState(false);
            });
        });

        document.addEventListener('keydown', event => {
            if (event.key === 'Escape') setAdminSidebarState(false);
        });

        window.addEventListener('resize', () => {
            if (window.innerWidth > 991) setAdminSidebarState(false);
        });

        const savedTheme = localStorage.getItem('ahram_theme') || 'light';
        updateSidebarThemeIcon(savedTheme);
        updateSidebarStats();
        setInterval(updateSidebarStats, 10000);
        
        fetchNotifications();
        setInterval(fetchNotifications, 5000);
        
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW registration failed:', err));
        }
    });
</script>
