<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleSidebar() { document.querySelector('.sidebar').classList.toggle('active'); document.querySelector('.sidebar-overlay').classList.toggle('active'); }

    function initExcelBuilder(prefix, dataSettings) {
        const p = prefix === 'client' ? '' : 'e_';
        const savedKeys = dataSettings.colKeys.split(','), savedNames = dataSettings.colNames.split(',');
        const savedSumKeys = dataSettings.sumKeys.split(','), savedSumNames = dataSettings.sumNames.split(',');
        document.getElementById(p+'alignInput').value = dataSettings.alignment;

        function buildDragLists() {
            const colList = document.getElementById(p+'columnsList'); colList.innerHTML = '';
            savedKeys.forEach((key, index) => {
                const li = document.createElement('li'); li.className = 'draggable-item border-start border-4 border-secondary'; li.draggable = true; li.dataset.key = key;
                li.innerHTML = `<i class="fa-solid fa-grip-vertical text-muted fs-5"></i><input type="text" class="col-name-input mx-3" value="${savedNames[index]}">`;
                colList.appendChild(li);
            });
            const sumList = document.getElementById(p+'summaryList'); sumList.innerHTML = '';
            savedSumKeys.forEach((key, index) => {
                const li = document.createElement('li'); li.className = 'draggable-item border-start border-4 border-warning'; li.draggable = true; li.dataset.key = key;
                li.innerHTML = `<i class="fa-solid fa-grip-vertical text-warning fs-5"></i><input type="text" class="col-name-input mx-3" value="${savedSumNames[index]}">`;
                sumList.appendChild(li);
            });
            attachDragEvents();
        }

        function attachDragEvents() {
            let draggedItem = null;
            const items = document.querySelectorAll(`#${p}columnsList .draggable-item, #${p}summaryList .draggable-item`);
            items.forEach(item => {
                item.addEventListener('dragstart', function(e) { draggedItem = this; setTimeout(() => this.style.opacity = '0.5', 0); });
                item.addEventListener('dragend', function() { this.style.opacity = '1'; draggedItem = null; updateHiddenInputsAndPreview(); });
                item.addEventListener('dragover', function(e) {
                    e.preventDefault();
                    if (this !== draggedItem && this.parentNode === draggedItem.parentNode) {
                        let offset = this.getBoundingClientRect().y + (this.getBoundingClientRect().height / 2);
                        if (e.clientY - offset > 0) this.after(draggedItem); else this.before(draggedItem);
                    }
                });
                item.querySelector('input').addEventListener('input', updateHiddenInputsAndPreview);
            });
        }

        function updateHiddenInputsAndPreview() {
            const colItems = document.querySelectorAll(`#${p}columnsList .draggable-item`);
            const newKeys = [], newNames = [];
            colItems.forEach(item => { newKeys.push(item.dataset.key); newNames.push(item.querySelector('input').value); });
            document.getElementById(p === '' ? 'excelColKeys' : 'e_excelColKeys').value = newKeys.join(',');
            document.getElementById(p === '' ? 'excelColNames' : 'e_excelColNames').value = newNames.join(',');

            const sumItems = document.querySelectorAll(`#${p}summaryList .draggable-item`);
            const newSumKeys = [], newSumNames = [];
            sumItems.forEach(item => { newSumKeys.push(item.dataset.key); newSumNames.push(item.querySelector('input').value); });
            document.getElementById(p === '' ? 'excelSummaryKeys' : 'e_excelSummaryKeys').value = newSumKeys.join(',');
            document.getElementById(p === '' ? 'excelSummaryNames' : 'e_excelSummaryNames').value = newSumNames.join(',');
            
            updatePreviewTable(newKeys, newNames, newSumKeys, newSumNames);
        }

        function updatePreviewTable(keys, names, sumKeys, sumNames) {
            const colCount = keys.length;
            document.getElementById(p+'prevTitleBg').colSpan = colCount;
            document.querySelector(`#${p}previewTable .ex-sub`).colSpan = colCount;
            document.querySelector(`#${p}previewTable tr td[style*="border:none"]`).colSpan = colCount;

            const headerRow = document.getElementById(p+'prevHeaderRow');
            headerRow.innerHTML = ''; headerRow.style.backgroundColor = document.getElementById(p+'headerBg').value;
            names.forEach(name => { headerRow.innerHTML += `<td style="padding:10px; border:1px solid rgba(255,255,255,0.2);">${name}</td>`; });

            const tbody = document.getElementById(p+'prevBody');
            tbody.innerHTML = '';
            dataSettings.dummyData.forEach(row => {
                let tr = '<tr>'; keys.forEach(k => { tr += `<td style="padding:10px;">${row[k] || '-'}</td>`; }); tr += '</tr>'; tbody.innerHTML += tr;
            });

            const tfoot = document.getElementById(p+'prevFooter');
            tfoot.innerHTML = `<tr><td colspan="${colCount}" style="border:none; height: 10px; background:transparent;"></td></tr>`;
            
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const borderCol = isDark ? '#334155' : '#d4d4d4';
            const textCol = isDark ? '#f8fafc' : '#333';

            sumKeys.forEach((key, index) => {
                const item = dataSettings.summaryValues[key]; if (!item) return;
                let tr = '<tr>'; if (colCount > 2) tr += `<td colspan="${colCount - 2}" style="border:none; background:transparent;"></td>`;
                
                let bgName = isDark ? 'transparent' : item.bg;
                let textColor = isDark ? '#fbbf24' : '#000';
                if(item.isTotal) { bgName = document.getElementById(p+'totalBg').value; textColor = '#fff'; }
                
                tr += `<td style="background:${isDark? 'rgba(255,255,255,0.05)' : item.bg}; color:${textCol}; font-weight:bold; text-align:left; padding:8px; border: 1px solid ${borderCol};">${sumNames[index]}</td>`;
                tr += `<td style="background:${isDark? 'rgba(0,0,0,0.2)' : 'transparent'}; color:${textCol}; font-weight:bold; padding:8px; border: 1px solid ${borderCol}; ${item.isTotal ? 'font-size:1.1em; color:#d4af37;' : ''}">${item.val}</td>`;
                tr += '</tr>'; tfoot.innerHTML += tr;
            });
            applyStyles();
        }

        function applyStyles() {
            const table = document.getElementById(p+'previewTable');
            document.getElementById(p+'prevTitleBg').style.backgroundColor = document.getElementById(p+'titleBg').value;
            document.getElementById(p+'prevTitleText').innerText = document.getElementById(p+'mainTitleInput').value;
            table.style.fontSize = document.getElementById(p+'fontSize').value + 'px';
            const rowH = document.getElementById(p+'rowHeightInput').value + 'px';
            const colW = (document.getElementById(p+'colWidthInput').value * 4) + 'px'; 
            const align = document.getElementById(p+'alignInput').value;
            table.querySelectorAll('td').forEach(c => {
                if(c.colSpan === 1 && !c.style.border.includes('none')) { c.style.paddingTop = (parseInt(rowH)/4) + 'px'; c.style.paddingBottom = (parseInt(rowH)/4) + 'px'; c.style.minWidth = colW; c.style.textAlign = align; }
            });
            document.getElementById(p+'prevTitleBg').style.textAlign = 'center';
            document.querySelector(`#${p}previewTable .ex-sub`).style.textAlign = 'center';
        }

        const styleInputs = ['titleBg', 'headerBg', 'totalBg', 'fontSize', 'mainTitleInput', 'colWidthInput', 'rowHeightInput', 'alignInput'];
        styleInputs.forEach(id => { document.getElementById(p+id).addEventListener('input', () => { if(id === 'headerBg' || id === 'totalBg') updateHiddenInputsAndPreview(); else applyStyles(); }); });

        buildDragLists(); updateHiddenInputsAndPreview();
        
        const observer = new MutationObserver(() => { updateHiddenInputsAndPreview(); });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    }

    document.addEventListener("DOMContentLoaded", () => {
        initExcelBuilder('client', {
            colKeys: "<%= settings.excelColKeys %>", colNames: "<%= settings.excelColNames %>",
            sumKeys: "<%= settings.excelSummaryKeys %>", sumNames: "<%= settings.excelSummaryNames %>",
            alignment: "<%= settings.excelAlignment %>",
            dummyData: [{ id: 'ATT-001', employee: 'أحمد علي', phone: '01012345678', amount: '1000', rate: '6.45', cost: '155.04', date: '30/04/2026' }],
            summaryValues: { 'totalEGP': { val: '1500.00', bg: '#fff2cc' }, 'prevLYD': { val: '1000.00', bg: '#f2f2f2' }, 'totalLYD': { val: '232.56', bg: '#eaeaea' }, 'deposits': { val: '0.00', bg: '#d9ead3' }, 'netBalance': { val: '767.44', bg: document.getElementById('totalBg').value, isTotal: true } }
        });
        initExcelBuilder('executor', {
            colKeys: "<%= settings.execExcelColKeys %>", colNames: "<%= settings.execExcelColNames %>",
            sumKeys: "<%= settings.execExcelSummaryKeys %>", sumNames: "<%= settings.execExcelSummaryNames %>",
            alignment: "<%= settings.execExcelAlignment %>",
            dummyData: [{ id: 'ATT-001', employee: 'محمد أحمد', phone: '01099999999', amount: '2500', status: 'مكتمل', date: '30/04/2026' }],
            summaryValues: { 'totalEGP': { val: '2500.00', bg: '#fff2cc' }, 'prevValue': { val: '0.00', bg: '#f2f2f2' }, 'paid': { val: '0.00', bg: '#d9ead3' }, 'grandTotal': { val: '2500.00', bg: document.getElementById('e_totalBg').value, isTotal: true } }
        });
    });
</script>
</body>
</html>