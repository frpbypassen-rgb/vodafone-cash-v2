<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>محرر الإكسيل | الأهرام</title>
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <style>
        .settings-nav { background: var(--input-bg); border-radius: 16px; padding: 10px; border: 1px solid var(--border-glass); margin-bottom: 25px; overflow-x: auto; white-space: nowrap;}
        .settings-nav .nav-link { color: var(--text-muted); font-weight: 700; border-radius: 12px; padding: 12px 20px; transition: 0.3s; margin: 0 4px; font-size: 0.9rem;}
        .settings-nav .nav-link:hover { background: var(--card-bg); color: var(--text-main); }
        .settings-nav .nav-link.active { background: var(--brand-primary); color: white !important; box-shadow: 0 4px 15px rgba(0, 26, 77, 0.2); }
        [data-theme="dark"] .settings-nav .nav-link.active { background: var(--brand-gold); color: black !important; }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .min-w-fit { min-width: fit-content; }

        .sub-tabs .nav-link { border: 1px solid var(--border-glass); color: var(--text-muted); background: var(--input-bg); margin-left: 5px; font-weight: 700; border-radius: 12px;}
        .sub-tabs .nav-link.active { background: var(--text-main); color: var(--card-bg) !important; border-color: var(--text-main);}

        .excel-preview { border: 1px solid var(--border-glass); background: #ffffff; padding: 20px; border-radius: 16px; font-family: 'Arial', sans-serif; overflow-x: auto; box-shadow: inset 0 0 20px rgba(0,0,0,0.05); color: #000 !important; }
        [data-theme="dark"] .excel-preview { background: #f8fafc; }
        
        .ex-table { width: 100%; border-collapse: collapse; transition: 0.3s; color: #000;}
        .ex-table td, .ex-table th { border: 1px solid #cbd5e1; transition: 0.3s; white-space: nowrap; color: #000; }
        .ex-title { font-weight: bold; color: #fff; text-align: center;}
        .ex-sub { background: #f1f5f9; font-weight: bold; font-size: 0.9em; text-align: center;}
        
        .draggable-list { list-style: none; padding: 0; margin: 0; }
        .draggable-item { background: var(--card-bg); border: 1px solid var(--border-glass); margin-bottom: 8px; padding: 10px 15px; border-radius: 12px; display: flex; align-items: center; cursor: grab; transition: 0.2s; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        .draggable-item:active { cursor: grabbing; opacity: 0.6; transform: scale(0.98); border-color: var(--brand-gold) !important;}
        .draggable-item i { color: var(--text-muted); margin-left: 10px; cursor: grab; }
        .col-name-input { border: 1px dashed var(--border-glass); background: transparent; color: var(--text-main); padding: 6px 12px; border-radius: 8px; flex-grow: 1; font-weight: bold; outline: none; transition: 0.3s;}
        .col-name-input:focus { border-color: var(--brand-primary); background: var(--input-bg); }
        [data-theme="dark"] .col-name-input:focus { border-color: var(--brand-gold); box-shadow: 0 0 0 2px rgba(212,175,55,0.1); }
        
        input[type="color"] { width: 100%; height: 45px; border: 1px solid var(--border-glass); border-radius: 12px; cursor: pointer; padding: 2px; background: var(--input-bg); }
    </style>
</head>
