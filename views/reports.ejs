<!DOCTYPE html>
<html lang="ar" dir="rtl" data-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>التقارير الشاملة - الأهرام باي</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
        }

        .main-content {
            margin-right: 260px;
            padding: 20px;
            transition: 0.3s;
        }

        @media (max-width: 991px) {
            .main-content {
                margin-right: 0;
                padding: 15px;
            }
        }

        .card-glass {
            background: var(--card-bg);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            box-shadow: var(--shadow-soft);
            padding: 20px;
            margin-bottom: 20px;
        }

        .form-select,
        .form-control {
            background-color: var(--input-bg);
            color: var(--text-main);
            border: 1px solid var(--border-glass);
            border-radius: 10px;
            padding: 10px;
        }

        .form-select:focus,
        .form-control:focus {
            background-color: var(--input-bg);
            color: var(--text-main);
            border-color: var(--brand-gold);
            box-shadow: 0 0 0 0.25rem rgba(212, 175, 55, 0.25);
        }

        .stat-card {
            background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(212, 175, 55, 0.02));
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            color: var(--brand-gold);
        }

        .table-custom {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 12px;
        }

        .table-custom th {
            color: var(--text-muted);
            font-weight: 700;
            padding: 14px 16px;
            font-size: 0.85rem;
            border: none;
            text-align: center;
        }

        .table-custom tr {
            transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .table-custom td {
            background: var(--card-bg);
            border-top: 1px solid var(--border-glass);
            border-bottom: 1px solid var(--border-glass);
            padding: 16px 14px;
            vertical-align: middle;
            text-align: center;
            font-size: 0.9rem;
            color: var(--text-main);
            transition: background 0.25s, box-shadow 0.25s, border-color 0.25s;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.03), 0 2px 4px -1px rgba(0, 0, 0, 0.02);
        }

        [data-theme="dark"] .table-custom td {
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
        }

        .table-custom tr td:first-child {
            border-right: 1px solid var(--border-glass);
            border-top-right-radius: 14px;
            border-bottom-right-radius: 14px;
        }

        .table-custom tr td:last-child {
            border-left: 1px solid var(--border-glass);
            border-top-left-radius: 14px;
            border-bottom-left-radius: 14px;
        }

        /* Hover */
        .table-custom tbody tr:hover {
            transform: translateY(-3px) scale(1.005);
        }

        .table-custom tbody tr:hover td {
            background: rgba(255, 255, 255, 0.98);
            border-color: rgba(14, 165, 233, 0.3);
            box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.08), 0 8px 10px -6px rgba(0, 0, 0, 0.06);
        }

        [data-theme="dark"] .table-custom tbody tr:hover td {
            background: rgba(30, 41, 59, 0.98);
            border-color: rgba(251, 191, 36, 0.3);
            box-shadow: 0 12px 25px -5px rgba(0, 0, 0, 0.4), 0 8px 15px -6px rgba(0, 0, 0, 0.35);
        }

        .badge-st {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.78rem;
            font-weight: 700;
            line-height: 1;
        }

        .st-done {
            background: rgba(16, 185, 129, 0.1);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .st-fail {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        /* Indicator dots for badges */
        .indicator-dot {
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            margin-left: 6px;
            vertical-align: middle;
        }
        .dot-done {
            background-color: #10b981;
            box-shadow: 0 0 6px #10b981;
        }
        .dot-fail {
            background-color: #ef4444;
            box-shadow: 0 0 6px #ef4444;
        }
    </style>

    <!-- PWA Setup -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#001a4d">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Al-Ahram">
    <!-- End PWA Setup -->
</head>

<body>
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
    <%- include('partials/sidebar', { activePage: 'reports' }) %>

        <div class="main-content">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold m-0" style="color: var(--brand-gold);"><i class="fa-solid fa-chart-line me-2"></i>
                    التقارير الشاملة والديناميكية</h4>
            </div>

            <!-- فلاتر التقرير -->
            <div class="card-glass">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label text-muted fw-bold">القسم الرئيسي</label>
                        <select id="mainCategory" class="form-select" onchange="updateSubCategory()">
                            <option value="">-- اختر القسم --</option>
                            <option value="direct_client">عميل مباشر</option>
                            <option value="company">شركة</option>
                            <option value="agent">وكيل</option>
                            <option value="executor">المنفذين</option>
                            <option value="api_executor">منفذ API</option>
                        </select>
                    </div>

                    <div class="col-md-3" id="subEntityCol" style="display:none;">
                        <label class="form-label text-muted fw-bold" id="subEntityLabel">الجهة</label>
                        <select id="subEntity" class="form-select" onchange="updateThirdCategory()">
                            <option value="">-- اختر --</option>
                        </select>
                    </div>

                    <div class="col-md-2" id="thirdCategoryCol" style="display:none;">
                        <label class="form-label text-muted fw-bold" id="thirdCategoryLabel">التقسيم الداخلي</label>
                        <select id="thirdCategory" class="form-select">
                            <option value="all">تقارير عامة (الكل)</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label text-muted fw-bold">الفترة الزمنية</label>
                        <select id="dateType" class="form-select" onchange="toggleDateInput()">
                            <option value="day">يوم محدد</option>
                            <option value="month">شهر محدد</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label text-muted fw-bold">&nbsp;</label>
                        <input type="date" id="dateValueDay" class="form-control">
                        <input type="month" id="dateValueMonth" class="form-control" style="display:none;">
                    </div>

                    <div class="col-md-12 mt-3 text-end">
                        <button class="btn btn-warning fw-bold px-4" onclick="fetchReport()"><i
                                class="fa-solid fa-search"></i> عرض التقرير</button>
                        <button id="btnDownloadPdf" class="btn btn-danger fw-bold px-4 ms-2 d-none"
                            onclick="generatePDF()"><i class="fa-solid fa-file-pdf"></i> تحميل تقرير PDF</button>
                    </div>
                </div>
            </div>

            <!-- الإحصائيات -->
            <div class="row g-3 mb-4 d-none" id="statsSection">
                <div class="col-md-3">
                    <div class="stat-card"
                        style="background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(59,130,246,0.02)); border-color: rgba(59,130,246,0.2);">
                        <h5 class="fw-bold mb-2 text-primary" id="statPrevBalance">0.00</h5>
                        <small class="text-primary fw-bold">الرصيد السابق</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card"
                        style="background: linear-gradient(135deg, rgba(239,68,68,0.1), rgba(239,68,68,0.02)); border-color: rgba(239,68,68,0.2);">
                        <h5 class="fw-bold mb-2 text-danger" id="statTotalOps">0.00</h5>
                        <small class="text-danger fw-bold">إجمالي عمليات اليوم</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card"
                        style="background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(16,185,129,0.02)); border-color: rgba(16,185,129,0.2);">
                        <h5 class="fw-bold mb-2 text-success" id="statTotalDeposits">0.00</h5>
                        <small class="text-success fw-bold">إجمالي إيداعات اليوم</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card"
                        style="background: linear-gradient(135deg, rgba(212,175,55,0.1), rgba(212,175,55,0.02)); border-color: rgba(212,175,55,0.2);">
                        <h5 class="fw-bold mb-2 text-warning" id="statEndingBalance">0.00</h5>
                        <small class="text-warning fw-bold">الرصيد الختامي</small>
                    </div>
                </div>
            </div>

            <!-- جدول العمليات -->
            <div class="card-glass d-none" id="tableSection">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-list text-muted me-1"></i> تفاصيل العمليات</h5>
                <div class="table-responsive">
                    <table class="table-custom">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>رقم العملية</th>
                                <th>المبلغ</th>
                                <th>التكلفة</th>
                                <th>الحالة</th>
                                <th>التاريخ</th>
                                <th>المنفذ</th>
                            </tr>
                        </thead>
                        <tbody id="reportTableBody">
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- جدول الإيداعات -->
            <div class="card-glass d-none mt-4" id="depositsSection">
                <h5 class="fw-bold mb-3"><i class="fa-solid fa-money-bill-wave text-success me-1"></i> عمليات الإيداع
                    والتسوية</h5>
                <div class="table-responsive">
                    <table class="table-custom">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>رقم العملية</th>
                                <th>القيمة (LYD)</th>
                                <th>الملاحظة</th>
                                <th>التاريخ</th>
                                <th>الحالة والمسؤول</th>
                            </tr>
                        </thead>
                        <tbody id="depositsTableBody">
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            // حقن البيانات من الخادم
            const dbUsers = <%- JSON.stringify(users) %>;
            const dbCompanies = <%- JSON.stringify(companies) %>;
            const dbAgents = <%- JSON.stringify(agents) %>;
            const dbExecutors = <%- JSON.stringify(executors) %>;
            const dbApiExecutors = <%- JSON.stringify(apiExecutors) %>;

            // تهيئة التواريخ
            document.getElementById('dateValueDay').valueAsDate = new Date();
            const yyyyMM = new Date().toISOString().substring(0, 7);
            document.getElementById('dateValueMonth').value = yyyyMM;

            function toggleSidebar() {
                document.querySelector('.sidebar').classList.toggle('active');
                document.querySelector('.sidebar-overlay').classList.toggle('active');
            }

            function toggleDateInput() {
                const type = document.getElementById('dateType').value;
                if (type === 'day') {
                    document.getElementById('dateValueDay').style.display = 'block';
                    document.getElementById('dateValueMonth').style.display = 'none';
                } else {
                    document.getElementById('dateValueDay').style.display = 'none';
                    document.getElementById('dateValueMonth').style.display = 'block';
                }
            }

            function updateSubCategory() {
                const main = document.getElementById('mainCategory').value;
                const subCol = document.getElementById('subEntityCol');
                const subSel = document.getElementById('subEntity');
                const thirdCol = document.getElementById('thirdCategoryCol');

                subSel.innerHTML = '<option value="">-- اختر --</option>';
                thirdCol.style.display = 'none';

                if (!main) { subCol.style.display = 'none'; return; }
                subCol.style.display = 'block';

                let list = [];
                if (main === 'direct_client') { document.getElementById('subEntityLabel').innerText = 'اسم العميل المباشر'; list = dbUsers; }
                else if (main === 'company') { document.getElementById('subEntityLabel').innerText = 'اسم الشركة'; list = dbCompanies; }
                else if (main === 'agent') { document.getElementById('subEntityLabel').innerText = 'اسم الوكيل'; list = dbAgents; }
                else if (main === 'executor') { document.getElementById('subEntityLabel').innerText = 'مجموعة التنفيذ'; list = dbExecutors; }
                else if (main === 'api_executor') { document.getElementById('subEntityLabel').innerText = 'شركة API'; list = dbApiExecutors; }

                list.forEach(item => {
                    const opt = document.createElement('option');
                    opt.value = item._id;
                    opt.textContent = item.name + (item.phone ? ' (' + item.phone + ')' : '');
                    subSel.appendChild(opt);
                });
            }

            function updateThirdCategory() {
                const main = document.getElementById('mainCategory').value;
                const subId = document.getElementById('subEntity').value;
                const thirdCol = document.getElementById('thirdCategoryCol');
                const thirdSel = document.getElementById('thirdCategory');

                thirdSel.innerHTML = '<option value="all">تقارير عامة (الكل)</option>';

                if (!subId) { thirdCol.style.display = 'none'; return; }

                let hasOptions = false;

                if (main === 'company') {
                    const comp = dbCompanies.find(c => c._id === subId);
                    if (comp && comp.employees && comp.employees.length > 0) {
                        comp.employees.forEach(emp => {
                            if (emp) thirdSel.innerHTML += `<option value="${emp}">موظف: ${emp}</option>`;
                        });
                        hasOptions = true;
                    }
                }
                else if (main === 'agent') {
                    const agent = dbAgents.find(a => a._id === subId);
                    if (agent && agent.subAccounts && agent.subAccounts.length > 0) {
                        agent.subAccounts.forEach(sub => {
                            thirdSel.innerHTML += `<option value="${sub._id}">عميل الوكيل: ${sub.name}</option>`;
                        });
                        hasOptions = true;
                    }
                }
                else if (main === 'executor') {
                    const exec = dbExecutors.find(e => e._id === subId);
                    if (exec && exec.employees && exec.employees.length > 0) {
                        exec.employees.forEach(emp => {
                            if (emp) thirdSel.innerHTML += `<option value="${emp}">منفذ: ${emp}</option>`;
                        });
                        hasOptions = true;
                    }
                }

                thirdCol.style.display = hasOptions ? 'block' : 'none';
            }

            let lastReportData = null;

            async function fetchReport() {
                const mainCategory = document.getElementById('mainCategory').value;
                const subId = document.getElementById('subEntity').value;
                const subType = document.getElementById('thirdCategory').value;
                const dateType = document.getElementById('dateType').value;
                const dateValue = dateType === 'day' ? document.getElementById('dateValueDay').value : document.getElementById('dateValueMonth').value;

                if (!mainCategory || !subId || !dateValue) {
                    return Swal.fire({ icon: 'warning', title: 'تنبيه', text: 'يرجى اختيار القسم والجهة والتاريخ.' });
                }

                const btn = document.querySelector('button.btn-warning');
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> جاري التحميل...';
                btn.disabled = true;

                try {
                    const res = await fetch('/api/reports/filter', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ mainCategory, subId, subType, dateType, dateValue })
                    });
                    const data = await res.json();

                    if (!data.success) throw new Error(data.error);

                    const curr = data.stats.isExecutor ? 'EGP' : 'LYD';

                    // Update Stats
                    document.getElementById('statPrevBalance').innerHTML = `${(data.stats.previousBalance).toFixed(2)} <span class="fs-6">${curr}</span>`;
                    const opsCost = data.stats.isExecutor ? data.stats.totalEGP : data.stats.totalLYD;
                    document.getElementById('statTotalOps').innerHTML = `${(opsCost).toFixed(2)} <span class="fs-6">${curr}</span>`;
                    document.getElementById('statTotalDeposits').innerHTML = `${(data.stats.totalDeposits).toFixed(2)} <span class="fs-6">${curr}</span>`;
                    document.getElementById('statEndingBalance').innerHTML = `${(data.stats.endingBalance).toFixed(2)} <span class="fs-6">${curr}</span>`;

                    lastReportData = data;
                    document.getElementById('statsSection').classList.remove('d-none');
                    document.getElementById('tableSection').classList.remove('d-none');
                    document.getElementById('depositsSection').classList.remove('d-none');
                    document.getElementById('btnDownloadPdf').classList.remove('d-none');

                    // ترتيب العمليات: الناجح أولاً، والملغي أخيراً
                    data.operations.sort((a, b) => {
                        if (a.status === 'completed' && b.status !== 'completed') return -1;
                        if (b.status === 'completed' && a.status !== 'completed') return 1;
                        const aFail = (a.status === 'rejected' || a.status === 'cancelled_by_admin');
                        const bFail = (b.status === 'rejected' || b.status === 'cancelled_by_admin');
                        if (aFail && !bFail) return 1;
                        if (bFail && !aFail) return -1;
                        return new Date(b.createdAt) - new Date(a.createdAt);
                    });

                    // Render Operations Table
                    const tbody = document.getElementById('reportTableBody');
                    tbody.innerHTML = '';
                    if (data.operations.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">لا توجد عمليات</td></tr>';
                    } else {
                        data.operations.forEach((tx, i) => {
                            let stHtml = '';
                            if (tx.status === 'completed') stHtml = '<span class="badge-st st-done"><span class="indicator-dot dot-done"></span>مكتمل</span>';
                            else if (tx.status === 'rejected' || tx.status === 'cancelled_by_admin') stHtml = '<span class="badge-st st-fail"><span class="indicator-dot dot-fail"></span>مرفوض</span>';
                            else stHtml = '<span class="badge-st bg-secondary text-white"><span class="indicator-dot bg-light"></span>' + tx.status + '</span>';

                            let by = tx.operatorName || tx.executorName || tx.employeeName || tx.subAccountName || '---';
                            if (by === 'بوت تنفيذ' && tx.executorGroupName) {
                                by = by + ' - ' + tx.executorGroupName;
                            }

                            const dateObj = new Date(tx.createdAt);
                            const dateStr = dateObj.toLocaleDateString('en-GB');
                            const timeStr = dateObj.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });

                            tbody.innerHTML += `
                            <tr>
                                <td class="text-muted fw-bold">${i + 1}</td>
                                <td dir="ltr" class="fw-bold text-end">#${tx.customId || tx._id.toString().slice(-6)}</td>
                                <td class="fw-bold">${tx.amount} <small class="text-muted">EGP</small></td>
                                <td>
                                    <div class="fw-bold text-warning">${(tx.costLYD || 0).toFixed(2)} <small class="text-muted">LYD</small></div>
                                    <div style="font-size: 0.75rem; color: #94a3b8;">السعر: ${tx.exchangeRate || 0}</div>
                                </td>
                                <td>${stHtml}</td>
                                <td>
                                    <div dir="ltr" style="font-size:0.85em;" class="text-end">${dateStr}</div>
                                    <div dir="ltr" style="font-size:0.75rem; color: #94a3b8;" class="text-end">${timeStr}</div>
                                </td>
                                <td>${by}</td>
                            </tr>
                        `;
                        });
                    }

                    // Render Deposits Table
                    const dtbody = document.getElementById('depositsTableBody');
                    dtbody.innerHTML = '';
                    if (data.deposits.length === 0) {
                        dtbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">لا توجد إيداعات</td></tr>';
                    } else {
                        data.deposits.forEach((tx, i) => {
                            let stHtml = '';
                            if (tx.status === 'deposit') stHtml = '<span class="badge-st bg-success text-white"><span class="indicator-dot bg-light"></span>إيداع</span>';
                            else if (tx.status === 'deduction') stHtml = '<span class="badge-st bg-danger text-white"><span class="indicator-dot bg-light"></span>خصم</span>';
                            else stHtml = '<span class="badge-st bg-secondary text-white"><span class="indicator-dot bg-light"></span>' + tx.status + '</span>';

                            const dateObj = new Date(tx.createdAt);
                            const dateStr = dateObj.toLocaleDateString('en-GB');
                            const timeStr = dateObj.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true });

                            const adminName = tx.employeeName || 'الإدارة';

                            dtbody.innerHTML += `
                            <tr>
                                <td class="text-muted fw-bold">${i + 1}</td>
                                <td dir="ltr" class="fw-bold text-end">#${tx.customId || tx._id.toString().slice(-6)}</td>
                                <td class="fw-bold" style="color: ${tx.status === 'deposit' ? '#10b981' : '#ef4444'};">${tx.amount}</td>
                                <td style="max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${tx.notes || '-'}">${tx.notes || '-'}</td>
                                <td>
                                    <div dir="ltr" style="font-size:0.85em;" class="text-end">${dateStr}</div>
                                    <div dir="ltr" style="font-size:0.75rem; color: #94a3b8;" class="text-end">${timeStr}</div>
                                </td>
                                <td>
                                    <div>${stHtml}</div>
                                    <div style="font-size: 0.75rem; color: #94a3b8; margin-top: 4px;">بواسطة: ${adminName}</div>
                                </td>
                            </tr>
                        `;
                        });
                    }

                } catch (e) {
                    Swal.fire({ icon: 'error', title: 'خطأ', text: e.message || 'فشل جلب التقرير' });
                } finally {
                    btn.innerHTML = '<i class="fa-solid fa-search"></i> عرض التقرير';
                    btn.disabled = false;
                }
            }

            function generatePDF() {
                if (!lastReportData) return;
                const data = lastReportData;
                const ei = data.entityInfo || {};

                let html = `
                <div style="font-family: 'Cairo', sans-serif; direction: rtl; padding: 15px; color: #000; background: #fff;">
                    
                    <!-- Header Section -->
                    <div style="text-align: center; border-bottom: 3px solid #000; padding-bottom: 20px; margin-bottom: 30px; page-break-inside: avoid;">
                        <h1 style="color: #000; margin: 0; font-size: 28px; font-weight: 900;">شركة الأهرام للخدمات المالية</h1>
                        <h2 style="color: #000; margin: 5px 0 0 0; font-size: 18px; font-weight: 800;">تقرير حساب العميل الشامل</h2>
                        <div style="margin-top: 10px; font-size: 12px; color: #000; font-weight: 600;">
                            تاريخ الإصدار: ${new Date().toLocaleDateString('en-GB')} | الوقت: ${new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true })}
                        </div>
                    </div>
                    
                    <!-- Client Card 2030 Style -->
                    <div style="background: #fff; border: 2px solid #000; border-right: 6px solid #000; border-radius: 12px; padding: 20px; margin-bottom: 30px;">
                        <h4 style="margin: 0 0 15px 0; color: #000; font-size: 16px; font-weight: 800; display: flex; align-items: center; border-bottom: 1px solid #ccc; padding-bottom: 10px;">
                            <span style="background: #000; color: #fff; padding: 4px 12px; border-radius: 6px; margin-left: 10px; font-size: 12px;">بيانات الحساب</span>
                        </h4>
                        <table style="width: 100%; font-size: 14px; color: #000; border-spacing: 0 10px; font-weight: 700;">
                            <tr>
                                <td style="width: 50%;">
                                    <div style="color: #333; font-size: 12px; margin-bottom: 2px;">اسم العميل</div>
                                    <strong style="color: #000; font-size: 16px;">${ei.name || '---'}</strong>
                                </td>
                                <td style="width: 50%;">
                                    <div style="color: #333; font-size: 12px; margin-bottom: 2px;">رقم الهاتف</div>
                                    <strong dir="ltr" style="color: #000; font-size: 16px;">${ei.phone || '---'}</strong>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <div style="color: #333; font-size: 12px; margin-bottom: 2px;">اسم المستخدم</div>
                                    <strong style="color: #000; font-size: 16px;">${ei.username || '---'}</strong>
                                </td>
                                <td>
                                    <div style="color: #333; font-size: 12px; margin-bottom: 2px;">تاريخ الانضمام</div>
                                    <strong style="color: #000; font-size: 16px;">${ei.joinDate ? new Date(ei.joinDate).toLocaleDateString('en-GB') : '---'}</strong>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" style="padding-top: 10px; border-top: 1px solid #000;">
                                    <div style="color: #333; font-size: 12px; margin-bottom: 2px;">حالة العميل والتصنيف</div>
                                    <strong style="color: #000; font-size: 16px;">${ei.status || '---'}</strong>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <!-- Financial Summary 2030 Style -->
                    <div style="display: flex; justify-content: space-between; margin-bottom: 30px; gap: 10px; page-break-inside: avoid;">
                        <div style="flex: 1; padding: 15px; background: #fff; border: 2px solid #000; border-radius: 8px; text-align: center;">
                            <div style="color: #000; font-size: 14px; font-weight: 700; margin-bottom: 8px; border-bottom: 1px dashed #000; padding-bottom: 5px;">الرصيد السابق</div>
                            <div style="font-size: 18px; color: #000; font-weight: 900;">${data.stats.previousBalance.toFixed(2)}</div>
                        </div>
                        <div style="flex: 1; padding: 15px; background: #fff; border: 2px solid #000; border-radius: 8px; text-align: center;">
                            <div style="color: #000; font-size: 14px; font-weight: 700; margin-bottom: 8px; border-bottom: 1px dashed #000; padding-bottom: 5px;">إجمالي العمليات</div>
                            <div style="font-size: 18px; color: #000; font-weight: 900;">${data.stats.isExecutor ? data.stats.totalEGP.toFixed(2) : data.stats.totalLYD.toFixed(2)}</div>
                        </div>
                        <div style="flex: 1; padding: 15px; background: #fff; border: 2px solid #000; border-radius: 8px; text-align: center;">
                            <div style="color: #000; font-size: 14px; font-weight: 700; margin-bottom: 8px; border-bottom: 1px dashed #000; padding-bottom: 5px;">إجمالي الإيداعات</div>
                            <div style="font-size: 18px; color: #000; font-weight: 900;">${data.stats.totalDeposits.toFixed(2)}</div>
                        </div>
                        <div style="flex: 1; padding: 15px; background: #000; border: 2px solid #000; border-radius: 8px; text-align: center;">
                            <div style="color: #fff; font-size: 14px; font-weight: 700; margin-bottom: 8px; border-bottom: 1px dashed #fff; padding-bottom: 5px;">الرصيد النهائي</div>
                            <div style="font-size: 20px; color: #fff; font-weight: 900;">${data.stats.endingBalance.toFixed(2)}</div>
                        </div>
                    </div>

                    <!-- Operations Section -->
            `;

                const generateOpsHeader = (isContinuation = false) => `
                    <h4 style="color: #000; font-size: 18px; font-weight: 800; margin-bottom: 15px; padding-bottom: 8px; border-bottom: 2px solid #000; page-break-inside: avoid;">
                        كشف العمليات ${isContinuation ? '<span style="font-size: 14px;">(تكملة)</span>' : ''}
                    </h4>
                    <table style="width: 100%; border-collapse: separate; border-spacing: 0; font-size: 13px; margin-bottom: 30px; text-align: right; border: 2px solid #000; border-radius: 8px; overflow: hidden; page-break-inside: avoid;">
                        <thead>
                            <tr style="background: #000; color: #fff;">
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">#</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">رقم العملية</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">المبلغ</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">سعر الصرف</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">القيمة</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">بواسطة</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">التاريخ والوقت</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
            `;

                if (data.operations.length === 0) {
                    html += generateOpsHeader() + '<tr><td colspan="8" style="border: 1px solid #000; padding: 15px; text-align: center; color: #000; font-weight: bold;">لا توجد عمليات</td></tr></tbody></table>';
                } else {
                    let sortedOps = [...data.operations].sort((a, b) => {
                        const statusA = ['rejected', 'cancelled_by_admin'].includes(a.status) ? 1 : 0;
                        const statusB = ['rejected', 'cancelled_by_admin'].includes(b.status) ? 1 : 0;
                        if (statusA !== statusB) return statusA - statusB;
                        return new Date(b.createdAt) - new Date(a.createdAt);
                    });

                    // Chunking logic: 10 items for the first page (due to summary cards), 20 items for subsequent pages
                    let opsChunks = [];
                    if (sortedOps.length > 10) {
                        opsChunks.push(sortedOps.slice(0, 10));
                        for (let i = 10; i < sortedOps.length; i += 20) {
                            opsChunks.push(sortedOps.slice(i, i + 20));
                        }
                    } else {
                        opsChunks.push(sortedOps);
                    }

                    opsChunks.forEach((chunk, chunkIdx) => {
                        if (chunkIdx > 0) {
                            html += '<div style="page-break-before: always; margin-top: 20px;"></div>';
                        }
                        html += generateOpsHeader(chunkIdx > 0);

                        chunk.forEach((tx, idxInChunk) => {
                            const globalIdx = chunkIdx === 0 ? idxInChunk : 10 + ((chunkIdx - 1) * 20) + idxInChunk;

                            let stTxt = 'معلقة'; let stCol = '#000'; let stBg = '#fff';
                            if (tx.status === 'completed') { stTxt = 'ناجحة'; stCol = '#000'; stBg = '#fff'; }
                            else if (['rejected', 'cancelled_by_admin'].includes(tx.status)) { stTxt = 'ملغية'; stCol = '#fff'; stBg = '#000'; }

                            const dt = new Date(tx.createdAt);
                            let by = tx.operatorName || tx.executorName || tx.employeeName || 'الإدارة';
                            if (by === 'بوت تنفيذ' && tx.executorGroupName) {
                                by = by + ' - ' + tx.executorGroupName;
                            }

                            html += `
                            <tr style="background: ${globalIdx % 2 === 0 ? '#fff' : '#f8f8f8'};">
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; color: #000; font-weight: 700;">${globalIdx + 1}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; font-weight: 800; color: #000;" dir="ltr">${tx.customId || tx._id.toString().slice(-6)}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; font-weight: 900; color: #000;" dir="ltr">${tx.amount}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; color: #000; font-weight: 800;">${tx.exchangeRate || '-'}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; font-weight: 900; color: #000;">${tx.costLYD || 0}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; color: #000; font-weight: 800;">${by}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000;" dir="ltr">
                                    <div style="color: #000; font-weight: 800;">${dt.toLocaleDateString('en-GB')}</div>
                                    <div style="font-size: 11px; color: #000; font-weight: 700;">${dt.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true })}</div>
                                </td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000;">
                                    <span style="background: ${stBg}; color: ${stCol}; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 800; border: 2px solid #000;">${stTxt}</span>
                                </td>
                            </tr>
                        `;
                        });

                        html += `
                            </tbody>
                        </table>
                    `;
                    });
                }

                // Deposits Section
                const generateDepsHeader = (isContinuation = false) => `
                    <h4 style="color: #000; font-size: 18px; font-weight: 800; margin-bottom: 15px; padding-bottom: 8px; border-bottom: 2px solid #000; margin-top: 20px; page-break-inside: avoid;">
                        عمليات الإيداع ${isContinuation ? '<span style="font-size: 14px;">(تكملة)</span>' : ''}
                    </h4>
                    <table style="width: 100%; border-collapse: separate; border-spacing: 0; font-size: 13px; margin-bottom: 30px; text-align: right; border: 2px solid #000; border-radius: 8px; overflow: hidden; page-break-inside: avoid;">
                        <thead>
                            <tr style="background: #000; color: #fff;">
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">#</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">رقم الإيداع</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">القيمة (LYD)</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">الملاحظة</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">بواسطة</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">التاريخ والوقت</th>
                                <th style="padding: 12px 8px; border-bottom: 2px solid #000; font-weight: 800;">الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
            `;

                if (data.deposits.length === 0) {
                    html += generateDepsHeader() + '<tr><td colspan="7" style="padding: 15px; text-align: center; color: #000; font-weight: bold; border-bottom: 1px solid #000;">لا توجد إيداعات</td></tr></tbody></table>';
                } else {
                    // Chunking logic: 20 items per page for deposits
                    let depChunks = [];
                    for (let i = 0; i < data.deposits.length; i += 20) {
                        depChunks.push(data.deposits.slice(i, i + 20));
                    }

                    depChunks.forEach((chunk, chunkIdx) => {
                        if (chunkIdx > 0) {
                            html += '<div style="page-break-before: always; margin-top: 20px;"></div>';
                        }
                        html += generateDepsHeader(chunkIdx > 0);

                        chunk.forEach((tx, idxInChunk) => {
                            const globalIdx = (chunkIdx * 20) + idxInChunk;
                            let stTxt = 'إيداع'; let stCol = '#000'; let stBg = '#fff';
                            if (tx.status === 'deduction') { stTxt = 'خصم'; stCol = '#fff'; stBg = '#000'; }
                            else if (tx.status === 'deposit_pending') { stTxt = 'قيد المراجعة'; stCol = '#000'; stBg = '#fff'; }

                            const dt = new Date(tx.createdAt);
                            const by = tx.employeeName || 'الإدارة';

                            html += `
                            <tr style="background: ${globalIdx % 2 === 0 ? '#fff' : '#f8f8f8'};">
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; color: #000; font-weight: 700;">${globalIdx + 1}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; font-weight: 800; color: #000;" dir="ltr">${tx.customId || tx._id.toString().slice(-6)}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; font-weight: 900; color: #000;">${tx.amount}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; color: #000; font-weight: 800;">${tx.notes || '-'}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000; color: #000; font-weight: 800;">${by}</td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000;" dir="ltr">
                                    <div style="color: #000; font-weight: 800;">${dt.toLocaleDateString('en-GB')}</div>
                                    <div style="font-size: 11px; color: #000; font-weight: 700;">${dt.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: true })}</div>
                                </td>
                                <td style="padding: 10px 8px; border-bottom: 1px solid #000;">
                                    <span style="background: ${stBg}; color: ${stCol}; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 800; border: 2px solid #000;">${stTxt}</span>
                                </td>
                            </tr>
                        `;
                        });

                        html += `
                            </tbody>
                        </table>
                    `;
                    });
                }

                html += `
                </div>
            `;

                const opt = {
                    margin: 10,
                    filename: 'تقرير_حساب_الاهرام_باي.pdf',
                    image: { type: 'jpeg', quality: 1.0 },
                    html2canvas: { scale: 2, useCORS: true, letterRendering: true },
                    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
                    pagebreak: { mode: ['css', 'legacy'] }
                };

                const container = document.createElement('div');
                container.innerHTML = html;
                html2pdf().set(opt).from(container).save();
            }
        </script>
</body>

</html>