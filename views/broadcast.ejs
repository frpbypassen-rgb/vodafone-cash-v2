<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>الإذاعة والمراسلة | الأهرام</title>
    <script>
        const savedTheme = localStorage.getItem('ahram_theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.9);
            --glass-border: rgba(0, 0, 0, 0.08);
            --shadow-3d: 0 15px 35px rgba(0, 0, 0, 0.05);
            --text-main: #1e293b;
            --text-muted: #64748b;
            --input-bg: #f8fafc;
            --brand-primary: #3b82f6;
        }

        [data-theme="dark"] {
            --glass-bg: rgba(30, 41, 59, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
            --shadow-3d: 0 15px 35px rgba(0, 0, 0, 0.4);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --input-bg: rgba(0, 0, 0, 0.2);
            --brand-primary: #fbbf24;
        }

        /* 🚀 3D Card Styling */
        .card-3d-wrapper { perspective: 1200px; margin: 0 auto; }
        .glass-card {
            background: var(--glass-bg); backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px);
            border: 1px solid var(--glass-border); border-radius: 30px; padding: 40px;
            box-shadow: var(--shadow-3d); transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative; overflow: hidden; z-index: 1;
        }
        .glass-card::before {
            content: ''; position: absolute; top: -50%; right: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 60%);
            transform: rotate(45deg); pointer-events: none; z-index: -1;
        }
        .glass-card:hover { transform: translateY(-5px) rotateX(1deg); box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15); }
        [data-theme="dark"] .glass-card:hover { box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6), inset 0 0 0 1px rgba(255,255,255,0.1); }

        /* 🌟 الأيقونة المتوهجة المركزية */
        .broadcast-icon {
            width: 90px; height: 90px; border-radius: 25px;
            display: flex; align-items: center; justify-content: center; font-size: 3rem;
            color: white; box-shadow: 0 15px 25px rgba(0,0,0,0.2); position: relative; margin: 0 auto 30px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        }
        .broadcast-icon::after {
            content: ''; position: absolute; width: 100%; height: 100%; border-radius: inherit;
            background: inherit; filter: blur(15px); z-index: -1; opacity: 0.7; transition: 0.3s;
        }

        /* 📦 حقول الإدخال والرفع */
        .input-section {
            background: var(--input-bg); border-radius: 18px; padding: 20px;
            border: 1px solid var(--glass-border); margin-bottom: 20px; transition: 0.3s;
        }
        .input-section:hover { border-color: rgba(59, 130, 246, 0.3); box-shadow: 0 5px 15px rgba(0,0,0,0.02); }

        .upload-area {
            border: 2px dashed rgba(59, 130, 246, 0.4); border-radius: 18px; padding: 40px 20px;
            text-align: center; background: rgba(59, 130, 246, 0.05); cursor: pointer; transition: 0.3s;
        }
        .upload-area:hover { background: rgba(59, 130, 246, 0.1); border-color: var(--brand-primary); transform: translateY(-2px); }
        [data-theme="dark"] .upload-area { background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.1); }
        [data-theme="dark"] .upload-area:hover { background: rgba(255,255,255,0.05); border-color: var(--brand-gold); }

        .form-control, .form-select {
            background: var(--card-bg); color: var(--text-main); border: 1px solid var(--glass-border);
            border-radius: 14px; padding: 14px; font-weight: bold; font-size: 1.05rem; transition: 0.3s;
        }
        .form-control:focus, .form-select:focus { background: transparent; border-color: var(--brand-primary); box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15); color: var(--text-main); }
        [data-theme="dark"] .form-control, [data-theme="dark"] .form-select { background: rgba(255,255,255,0.02); }
        [data-theme="dark"] .form-control:focus, [data-theme="dark"] .form-select:focus { border-color: #8b5cf6; box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.2); }

        .btn-send-3d {
            background: linear-gradient(45deg, #3b82f6, #2563eb); border: none; color: white;
            border-radius: 16px; padding: 18px; font-weight: 900; font-size: 1.3rem; width: 100%; transition: all 0.3s;
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3); display: flex; align-items: center; justify-content: center; gap: 10px;
        }
        .btn-send-3d:hover { transform: translateY(-3px) scale(1.01); box-shadow: 0 15px 30px rgba(37, 99, 235, 0.4); filter: brightness(1.1); }
        .btn-send-3d:active { transform: translateY(1px); }
        [data-theme="dark"] .btn-send-3d { background: linear-gradient(45deg, #8b5cf6, #6d28d9); box-shadow: 0 10px 20px rgba(139, 92, 246, 0.3); }

        .input-icon-label { display: flex; align-items: center; gap: 8px; font-weight: 800; color: var(--text-muted); margin-bottom: 12px; font-size: 0.95rem; }
        .alert-3d { border-radius: 16px; border: none; font-weight: bold; box-shadow: 0 8px 15px rgba(0,0,0,0.05); padding: 15px 20px; display: flex; align-items: center; gap: 10px; }
    </style>
</head>
<body>

<button class="mobile-nav-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
<div class="sidebar-overlay" onclick="toggleSidebar()"></div>

<%- include('partials/sidebar', { activePage: 'broadcast' }) %>

<div class="main-content">
    <div class="container-fluid">
        <div class="admin-nav mb-4">
            <h3 class="fw-bold m-0 text-dark"><i class="fa-solid fa-satellite-dish text-primary me-2"></i> مركز الإذاعة والمراسلة (Telegram Broadcast)</h3>
        </div>

        <% if (query.success) { %>
            <div class="alert alert-success alert-3d mx-auto" style="max-width: 800px;">
                <i class="fa-solid fa-circle-check fs-4"></i>
                <span>تم إرسال الرسالة مع المرفقات بنجاح للجهات المحددة.</span>
            </div>
        <% } %>
        <% if (query.error) { %>
            <div class="alert alert-danger alert-3d mx-auto" style="max-width: 800px;">
                <i class="fa-solid fa-triangle-exclamation fs-4"></i>
                <span>حدث خطأ أثناء محاولة إرسال الرسائل. تأكد من صحة حالة البوتات.</span>
            </div>
        <% } %>

        <div class="row justify-content-center mt-3 pb-5">
            <div class="col-xl-8 col-lg-10">
                <div class="card-3d-wrapper">
                    <div class="glass-card" style="border-top: 6px solid #3b82f6;">
                        
                        <div class="broadcast-icon">
                            <i class="fa-solid fa-bullhorn"></i>
                        </div>
                        
                        <div class="text-center mb-4">
                            <h4 class="fw-bold" style="color: var(--text-main);">نظام البث المباشر للإشعارات</h4>
                            <p class="text-muted fw-bold small">قم بتحديد الفئة المستهدفة وإرسال إشعارات وصور فورية عبر تيليجرام</p>
                        </div>

                        <form action="/broadcast/send" method="POST" enctype="multipart/form-data" onsubmit="return confirmSend(this)">
                            
                            <div class="input-section" style="border-right: 4px solid #3b82f6;">
                                <div class="input-icon-label text-primary">
                                    <i class="fa-solid fa-users-viewfinder"></i> تحديد الفئة المستهدفة
                                </div>
                                <select name="target" id="targetSelect" class="form-select form-select-lg shadow-sm text-center" required onchange="toggleSpecificFields()">
                                    <option value="all">📢 بث للجميع (أفراد، شركات، موظفين)</option>
                                    <option value="users">👤 جميع العملاء الأفراد فقط</option>
                                    <option value="companies">🏢 جميع الشركات والوكلاء فقط</option>
                                    <option value="employees">⚙️ جميع موظفي التنفيذ فقط</option>
                                    <option value="specific_user">🎯 إرسال لعميل فردي محدد</option>
                                    <option value="specific_company">🎯 إرسال لشركة/وكيل محدد</option>
                                    <option value="specific_executor">🎯 إرسال لطاقم تنفيذ (بوت محدد)</option>
                                </select>
                            </div>

                            <div id="specificUserField" class="input-section" style="display:none; border-right: 4px solid #f59e0b;">
                                <div class="input-icon-label text-warning"><i class="fa-solid fa-user"></i> اختر العميل الفردي</div>
                                <select name="specificUserId" class="form-select shadow-sm text-center">
                                    <% users.forEach(u => { %><option value="<%= u.telegramId %>"><%= u.name %> (<%= u.phone %>)</option><% }) %>
                                </select>
                            </div>

                            <div id="specificCompanyField" class="input-section" style="display:none; border-right: 4px solid #8b5cf6;">
                                <div class="input-icon-label" style="color: #8b5cf6;"><i class="fa-solid fa-building"></i> اختر الشركة/الوكالة</div>
                                <select name="specificCompanyId" class="form-select shadow-sm text-center">
                                    <% companies.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
                                </select>
                            </div>

                            <div id="specificExecutorField" class="input-section" style="display:none; border-right: 4px solid #10b981;">
                                <div class="input-icon-label text-success"><i class="fa-solid fa-robot"></i> اختر بوت/طاقم التنفيذ</div>
                                <select name="specificExecutorId" class="form-select shadow-sm text-center">
                                    <% executors.forEach(e => { %><option value="<%= e._id %>"><%= e.name %></option><% }) %>
                                </select>
                            </div>

                            <div class="input-section">
                                <div class="input-icon-label text-info">
                                    <i class="fa-solid fa-image"></i> إرفاق صورة من الجهاز (اختياري)
                                </div>
                                
                                <div class="upload-area shadow-sm" id="uploadArea" onclick="document.getElementById('imageInput').click()">
                                    <i class="fa-solid fa-cloud-arrow-up fs-1 mb-2 text-info"></i>
                                    <h6 class="fw-bold m-0" style="color: var(--text-main);">اضغط هنا لاختيار صورة من جهازك</h6>
                                    <p class="text-muted small mt-1 mb-0">تدعم الصيغ: JPG, PNG, WEBP</p>
                                    <input type="file" name="imageFile" id="imageInput" class="d-none" accept="image/*" onchange="previewImage(this)">
                                </div>
                                
                                <div id="imagePreviewContainer" class="mt-3 text-center d-none position-relative">
                                    <img id="imagePreview" src="" class="img-fluid rounded-4 shadow-sm" style="max-height: 250px; border: 3px solid var(--brand-primary); object-fit: contain;">
                                    <button type="button" class="btn btn-danger btn-sm position-absolute rounded-circle shadow" style="top: -15px; right: 50%; transform: translateX(50%); width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;" onclick="clearImage()">
                                        <i class="fa-solid fa-times fs-5"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="input-section">
                                <div class="input-icon-label" style="color: var(--text-main);">
                                    <i class="fa-solid fa-pen-nib"></i> محتوى الرسالة (النص)
                                </div>
                                <textarea name="message" class="form-control shadow-sm p-4" rows="6" placeholder="اكتب رسالتك هنا...&#10;ملاحظة: يمكنك استخدام أكواد الـ HTML البسيطة مثل <b>نص عريض</b> لتنسيق الرسالة." required style="resize: vertical;"></textarea>
                            </div>

                            <div class="mt-4">
                                <button type="submit" class="btn-send-3d shadow-lg" id="submitBtn">
                                    <i class="fa-solid fa-paper-plane fa-bounce"></i> إطلاق الإذاعة الآن
                                </button>
                            </div>

                        </form>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function toggleSidebar() { 
        document.querySelector('.sidebar').classList.toggle('active');
        document.querySelector('.sidebar-overlay').classList.toggle('active'); 
    }

    function toggleSpecificFields() {
        const val = document.getElementById('targetSelect').value;
        const userField = document.getElementById('specificUserField');
        const compField = document.getElementById('specificCompanyField');
        const execField = document.getElementById('specificExecutorField');

        [userField, compField, execField].forEach(el => {
            el.style.opacity = '0';
            setTimeout(() => { el.style.display = 'none'; }, 300);
        });

        setTimeout(() => {
            if (val === 'specific_user') {
                userField.style.display = 'block'; setTimeout(() => userField.style.opacity = '1', 10);
            } else if (val === 'specific_company') {
                compField.style.display = 'block'; setTimeout(() => compField.style.opacity = '1', 10);
            } else if (val === 'specific_executor') {
                execField.style.display = 'block'; setTimeout(() => execField.style.opacity = '1', 10);
            }
        }, 300);
    }

    // معاينة الصورة قبل الإرسال
    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('imagePreview').src = e.target.result;
                document.getElementById('imagePreviewContainer').classList.remove('d-none');
                document.getElementById('uploadArea').classList.add('d-none');
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    // إزالة الصورة المختارة
    function clearImage() {
        document.getElementById('imageInput').value = '';
        document.getElementById('imagePreview').src = '';
        document.getElementById('imagePreviewContainer').classList.add('d-none');
        document.getElementById('uploadArea').classList.remove('d-none');
    }

    // تأثير التحميل عند الضغط على زر الإرسال
    function confirmSend(form) {
        if(confirm('هل أنت متأكد من إرسال هذه الرسالة/الصورة للمستخدمين؟')) {
            const btn = document.getElementById('submitBtn');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> جاري رفع الصورة وإرسال الإذاعة...';
            btn.style.pointerEvents = 'none';
            btn.style.opacity = '0.8';
            return true;
        }
        return false;
    }
</script>
</body>
</html>