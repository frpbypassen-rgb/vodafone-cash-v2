# =========================================================
# نموذج متغيرات البيئة — لا تضع هذا الملف في Git!
# انسخ هذا الملف إلى .env وعدّل القيم بحسب بيئتك
# =========================================================

# ── قاعدة البيانات ──────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/vodafone_cash_system

# ── توكنات بوتات تيليجرام ──────────────────────────────
# احصل على التوكن من @BotFather في تيليجرام
CLIENT_BOT_TOKEN=YOUR_CLIENT_BOT_TOKEN_HERE
ADMIN_BOT_TOKEN=YOUR_ADMIN_BOT_TOKEN_HERE

# ── معرف المدير في تيليجرام ─────────────────────────────
# احصل على الـ ID من @userinfobot في تيليجرام
ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_ID_HERE

# كود سري لإضافة مديرين جدد عبر البوت
ADMIN_SECRET_CODE=YOUR_SECRET_CODE_HERE

# ── مفاتيح الحماية ──────────────────────────────────────
# استخدم: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_strong_secret_key_here
JWT_REFRESH_SECRET=generate_a_strong_refresh_key_here
SESSION_SECRET=generate_a_strong_session_key_here

# ── بيانات تسجيل الدخول للوحة التحكم ──────────────────
# مدير رئيسي — غيّر هذه القيم فوراً!
PANEL_USER=YOUR_ADMIN_USERNAME
PANEL_PASS=YOUR_STRONG_PASSWORD

# ── API خارجي (اختياري) ─────────────────────────────────
ZAYN_USERNAME=YOUR_ZAYN_API_USERNAME
ZAYN_PASSWORD=YOUR_ZAYN_API_PASSWORD

# مفتاح API الداخلي بين الخدمات
INTERNAL_API_KEY=generate_a_strong_api_key_here

# ── بيئة التشغيل ────────────────────────────────────────
NODE_ENV=development
PORT=3000
